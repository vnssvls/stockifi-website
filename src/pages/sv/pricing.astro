---

<Layout
  title="Priser — Programvara för varukostnad i restaurang | Stockifi"
  description="Planer för alla verksamheter, från enskilda restauranger till restaurangkedjor. Priset ligger vanligtvis mellan €150 och €400 per månad med en riskfri onboardinggaranti."
>
  <!-- Pricing hero: header + cards share one decorative gradient backdrop that
       bleeds behind both sections (not clipped to either). -->
  <div class="pricing-hero">
    <!-- 1. Page header -->
    <PageHeader
      eyebrow="Priser"
      heading="Välj en plan som passar din verksamhet"
      subhead="Alla planer inkluderar vår riskfria onboardinggaranti. Inga bindningsavtal, avsluta när som helst."
    />

    <!-- 1b. Pricing cards -->
    <PricingCards plans={plans} />
  </div>

  <!-- 2. Logo banner — scrolling marquee (matches the home page) -->
  <LogoBanner label="Används av 500+ restauranger i Europa" logos={userLogos} />

  <!-- 2b. Savings calculator -->
  <SavingsCalculator />
  <!-- 3. Feature section — Feature variant 6 (columns) -->
  <FeatureColumns
    tagline="Varför Stockifi"
    heading="Så betalar planerna sig själva"
    columns={featureCols}
  />

  <!-- 4. FAQ — variant 1 (split) -->
  <FaqSplit
    heading="Frågor om priser?"
    body="Det krögare frågar innan de väljer en plan. Fortfarande osäker? Hör av dig så hjälper vi dig."
    contact={{ label: 'Kontakta oss', href: '/sv/contact' }}
    items={faqs}
  />

  <!-- 5. CTA — variant 2.1 (image-backed button) -->
  <CtaButton
    heading="Redo att investera i din lönsamhet?"
    primary={{ label: 'Kom igång', href: '/sv/book-a-demo' }}
    secondary={{ label: 'Prata med en expert', href: '/sv/contact' }}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Brand gradient glow (from the ads-LP) bleeds behind BOTH the page header and the
     pricing cards as one continuous backdrop — not clipped to either section. */
  .pricing-hero { position: relative; isolation: isolate; }
  .pricing-hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -6%;
    transform: translateX(-50%);
    width: min(1200px, 150%);
    aspect-ratio: 600 / 500;
    background-image: url('/media/gradient-centered.png');
    background-size: contain;
    background-position: center top;
    background-repeat: no-repeat;
    opacity: 0.4;
    z-index: -1;
    pointer-events: none;
  }
  /* Header + cards read as one block: collapse the stacked section paddings between
     them (they each carry full section padding otherwise → an awkward double gap). */
  .pricing-hero :global(.page-header) { padding-bottom: var(--space-32); }
  .pricing-hero :global(.pricing-cards) { padding-top: 0; }
</style>
