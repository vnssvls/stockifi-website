const faqs = [
  { question: "Ansluter Stockifi till mitt bokföringssystem och kassasystem?", answer: "Ja. Stockifi ansluter till 70+ bokförings- och kassasystem och synkroniserar dina fakturor, försäljning och recept automatiskt. Du får en enda källa till sanning utan manuellt arbete." },
  { question: "Kan jag komma igång på 48 timmar?", answer: "Ja. Stockifi tar hand om det tunga arbetet. Vi importerar dina artikellistor och recept, sätter upp integrationerna och förbereder allt inför din första inventering, inom 48 timmar." },
  { question: "Vad kostar Stockifi?", answer: "Priset beror på storleken och komplexiteten i din verksamhet, så vi tittar på det tillsammans i ett kort samtal. Det samtalet bekräftar också om Stockifi passar din verksamhet." },
  { question: "Passar Stockifi min restaurang?", answer: "Ja, om du har etablerade processer. Stockifi passar fristående restauranger, hotellrestauranger med full mat- och dryckesservice samt restaurangkedjor med flera locations. Det passar mindre bra för verksamheter i ett mycket tidigt skede som fortfarande bygger upp sina processer." },
  { question: "Kan mitt team använda Stockifi på vårt språk?", answer: "Ja. Din data förblir på ditt språk och appen är på engelska. Vi kör en kort utbildning så att ditt team är bekvämt från start." },
];
---

<Layout
  title="Programvara för varukostnad för europeiska restauranger | Stockifi"
  description="Förstå din faktiska råvarukostnad. Stockifi kopplar ihop dina fakturor, kassasystem och recept för att visa var din marginal tar vägen, med inställningen gjord åt dig."
>
  <!-- 1. Hero -->
  <Hero
    wide
    tagline="Programvara för råvarukostnad i restaurang"
    heading="Förstå din faktiska råvarukostnad."
    subhead="Dina fakturor, din försäljning och dina recept har redan svaret på din råvarukostnad. Stockifi samlar dem och räknar ut det, så att du ser din marginal och kan agera utifrån den."
    primary={{ label: 'Boka en demo', href: '/sv/book-a-demo' }}
    secondary={{ label: 'Se hur det fungerar', href: '#how-it-works' }}
    images={[
      { src: '/media/photos/hero-manager.png', alt: '' },
      { src: '/media/photos/hero-chef.png',    alt: '' },
      { src: '/media/photos/hero-owner.png',   alt: '' },
    ]}
  >
    <!-- Overlay 0: slide 1 (manager) — food cost card, to build -->
    <div slot="overlays" style="display:contents">
      <div class="hero-overlay">
        <FoodCostAnimation />
      </div>
      <!-- Overlay 1: slide 2 (chef) — supplier price ticker -->
      <div class="hero-overlay">
        <ProcurementAnimation compact />
      </div>
      <!-- Overlay 2: slide 3 (owner) — location health list -->
      <div class="hero-overlay">
        <ManagementAnimation />
      </div>
    </div>
  </Hero>

  <!-- 2. Social proof -->
  <LogoBanner label="Används av 500+ restauranger i Europa" logos={userLogos} />

  <!-- 3. What's inside — FeatureList (product categories) -->
  <div id="how-it-works" class="hp-anchor">
    <FeatureList tagline="Vad ingår" items={whatsInside} />
  </div>

  <!-- 4. Benefits — FeatureSplit -->
  <FeatureSplit
    tagline="Därför är det värt det"
    heading="Råvarukostnadskontroll för restauranger som betalar sig själv"
    body="Det mesta av din marginal läcker i gapen mellan systemen. Stockifi samlar dem i en vy, så att redan 1 % förbättring i råvarukostnad förvandlas till pengar du behåller."
    items={benefits}
    imageSide="right"
  >
    <SavingsAnimation slot="media" />
  </FeatureSplit>

  <!-- 5. By Teams — FeatureTabs -->
  <FeatureTabs
    tagline="För ditt team"
    heading="En uppsättning siffror för varje roll"
    subhead="Från driftschef till kök arbetar alla utifrån samma siffror."
    tabs={byTeams}
  />

  <!-- 6. Customer stories — bento -->
  <CustomerStoryBento
    eyebrow="Kundberättelser"
    heading="Hör det från krögare som du"
    cta={{ label: 'Läs alla berättelser', href: '/sv/customer-stories' }}
    slugs={['byoslo', 'eik-and-friends', 'koie-ramen', 'skigeilo-2']}
  />

  <!-- 7. Onboarding — FeatureSteps -->
  <FeatureSteps
    tagline="Personlig onboarding"
    heading="Kom igång på 48 timmar"
    cta={{ label: 'Boka en demo', href: '/sv/book-a-demo' }}
    steps={onboarding}
  />

  <!-- 8. Integrations — pill cloud (variant 2), wide -->
  <IntegrationPills
    wide
    eyebrow="Integrationer"
    heading="Fungerar med verktygen du redan använder"
    subhead="Eliminera det manuella arbetet och låt Stockifi samla dina kassasystem- och bokföringsdata."
    cta={{ label: 'Visa alla integrationer', href: '/sv/integrations' }}
    items={integrations}
  />

  <!-- 9. Risk / pricing band — CtaBand (stand-in until a dedicated band exists) -->
  <CtaBand
    heading="Utformat för att spara dig tid och pengar"
    subhead="Vill du veta vad det kostar för dig? Priset beror på din storlek och ditt upplägg. Och om vi inte hittar minst 30 000 SEK i dolda förluster under dina första 30 dagar är det gratis."
    primary={{ label: 'Utforska planer', href: '/sv/pricing' }}
