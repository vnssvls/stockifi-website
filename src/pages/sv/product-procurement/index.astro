---
// Swedish: Procurement category LP (/sv/product-procurement).
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Fakturaautomatisering', body: 'Leverantörsfakturor läses rad för rad, automatiskt.', href: '/sv/product-procurement/invoice-automation', icon: icons['receipt-2'], image: '/media/product-invoice-automation.png' },
  { heading: 'Leverantörsprisövervakning', body: 'Varje prisändring fångad den dag den sker.', href: '/sv/product-procurement/supplier-price-tracking', icon: icons['percentage-circle'], image: '/media/product-supplier-price-tracking.png' },
  { heading: 'Centralkök', body: 'Beräkna produktionskostnader och försörj dina egna enheter.', href: '/sv/product-procurement/central-kitchen', icon: icons['building'], image: '/media/product-central-kitchen.png' },
  { heading: 'Anomalidetektion', body: 'Flaggar överkostnader och ovanliga fakturarader för granskning.', href: '/sv/product-procurement/anomaly-detection', icon: icons['fluent-wand'], image: '/media/product-anomaly-detection.png' },
  { heading: 'Beställningsförslag', body: 'Vet vad som ska beställas om innan du tar slut.', href: '/sv/product-procurement/ordering-suggestions', icon: icons['ordering-suggestions'], image: '/media/product-ordering-suggestions.png' },
];
---

<Layout
  title="Fakturahantering och leverantörshantering | Stockifi"
  description="Stockifi läser varje leverantörsfaktura, spårar prisförändringar och flaggar faktureringsfel innan de påverkar dina matkostnader, utan manuell inmatning."
>
  <PageHeader
    eyebrow="Inköp"
    heading="[Placeholder heading]"
    subhead="[Placeholder subhead]"
  />

  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <CtaEmail
    heading="[Placeholder CTA heading]"
    subhead="[Placeholder CTA subhead]"
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
