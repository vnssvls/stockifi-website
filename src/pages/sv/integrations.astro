---
// Integrations page (Figma 67:2342 header + 67:3442 filters + 67:3455 content).
// Page header (heading + subhead) → directory (search/sort/filter +
// card grid) → CTA variant 2 (image-background email capture). Nav + Footer come
// from the layout. DRAFT copy.
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import IntegrationsDirectory from '../../components/integrations/IntegrationsDirectory.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import data from '../../../content/integrations/integrations.en.json';

const live = data.filter((x) => !x.draft);

const CATEGORIES = [
  { value: 'accounting', label: 'Bokföring' },
  { value: 'pos', label: 'Kassasystem' },
  { value: 'other', label: 'Övrigt' },
];

const items = [...live]
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((x) => ({ name: x.name, category: x.category, logo: x.logo }));

---

<Layout
  title="Integrationer — Stockifi"
  description="Stockifi ansluter till 30+ bokföringssystem och 40+ kassasystem så att fakturor, försäljning och receptkostnader alltid är synkroniserade."
>
  <PageHeader
    eyebrow="Integrationer"
    heading="Stockifi fungerar med de system du redan använder"
    subhead="Koppla ditt bokföringssystem och kassasystem så att fakturor, försäljning och receptkostnader hålls synkroniserade, utan manuell export och utan dubbelinmatning."
  />

  <IntegrationsDirectory items={items} categories={CATEGORIES} />

  <CtaEmail
    heading="Se det kopplat till ditt system"
    subhead="Lämna din e-postadress så visar vi vad Stockifi hittar under dina första 30 dagar."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

