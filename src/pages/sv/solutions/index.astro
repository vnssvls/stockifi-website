---
// Solutions hub page (/sv/solutions). One page linking to all individual solution pages
// grouped by type and by team. No /solutions-[segment] sub-pages — this is the single
// landing. Layout per V's wireframe (Jun 14 2026):
// PageHeader (centered) → By Type grid (2-col) → By Team grid (2-col) → CtaEmail → Footer v2
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ImageCardGrid from '../../../components/ImageCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const byType = [
  { heading: 'Fristående restauranger', body: 'Bättre koll på varukostnaden utan kalkylblad.', href: '/sv/solutions/independent-restaurants', image: '/media/solution-independent-restaurants.jpg', icon: icons['fluent-store'] },
  { heading: 'Restaurangkedjor', body: 'Samlad kostnadsbild över alla enheter.', href: '/sv/solutions/restaurant-groups', image: '/media/solution-restaurant-groups.jpg', icon: icons['buildings-2'] },
  { heading: 'Hotell med F&B', body: 'Kontroll över hela mat- och dryckesverksamheten.', href: '/sv/solutions/hotels', image: '/media/solution-hotels.jpg', icon: icons['reserve'] },
  { heading: 'Bar', body: 'Se marginalen på varje drink du serverar.', href: '/sv/solutions/bars', image: '/media/solution-bars.jpg', icon: icons['cocktail'] },
];

const byTeam = [
  { heading: 'Ledning', body: 'Marginalöversikt över hela verksamheten.', href: '/sv/solutions/management', image: '/media/solution-management.jpg', icon: icons['briefcase'] },
  { heading: 'Drift', body: 'Fånga svinn och prisdrift tidigt.', href: '/sv/solutions/operations', image: '/media/solution-operations.jpg', icon: icons['setting-2'] },
  { heading: 'Kök', body: 'Aktuella rättskostnader för skarpare menybeslut.', href: '/sv/solutions/kitchen', image: '/media/solution-kitchen.jpg', icon: icons['chef-hat'] },
  { heading: 'Ekonomi', body: 'Varukostnader du kan lita på vid månadsslut.', href: '/sv/solutions/finance', image: '/media/solution-finance.jpg', icon: icons['fluent-finance'] },
];
---

<Layout
  title="Lösningar | Stockifi"
  description="Stockifi för alla typer av verksamheter och roller. Hitta lösningen som passar hur ditt team arbetar."
>
  <!-- 1. Page header — centered variant -->
  <PageHeader
    eyebrow="Lösningar"
    heading="[Placeholder heading]"
    subhead="[Placeholder subhead]"
  />

  <!-- 2. By Type — 4 segment solution cards -->
  <section class="section solutions-section">
    <div class="container">
      <div class="solutions-group-header">
        <p class="tagline">Efter verksamhetstyp</p>
        <h2 class="solutions-group-heading">[Placeholder heading]</h2>
      </div>
      <div class="solutions-grid">
        <ImageCardGrid items={byType} columns={4} showArrow={true} />
      </div>
    </div>
  </section>

  <!-- 3. By Team — 4 team solution cards -->
  <section class="section solutions-section">
    <div class="container">
      <div class="solutions-group-header">
        <p class="tagline">Efter roll</p>
        <h2 class="solutions-group-heading">[Placeholder heading]</h2>
      </div>
      <div class="solutions-grid">
        <ImageCardGrid items={byTeam} columns={4} showArrow={true} />
      </div>
    </div>
  </section>

  <!-- 4. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="[Placeholder CTA heading]"
    subhead="[Placeholder CTA subhead]"
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  .solutions-section { padding-block: var(--space-48); }
  .solutions-group-header { margin-bottom: var(--space-48); }
  .solutions-group-heading { font-size: var(--text-h2); margin-top: var(--space-12); }

  /* Scoped overrides for this page only */
  .solutions-grid :global(.icg-icon) { color: white; }
  .solutions-grid :global(.icg-arrow) { color: white; }
  .solutions-grid :global(.icg-item--linked:hover) { border-color: white; }
</style>
