---
// Swedish: Solutions item page (/sv/solutions/[slug])
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import PageHeaderHero from '../../../components/page-headers/PageHeaderHero.astro';
import FeatureSplit from '../../../components/features/FeatureSplit.astro';
import BenefitGrid from '../../../components/BenefitGrid.astro';
import FeatureShowcase from '../../../components/features/FeatureShowcase.astro';
import FaqSplit from '../../../components/faq/FaqSplit.astro';
import TestimonialSliderCollage from '../../../components/TestimonialSliderCollage.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import { solutionImages } from '../../../data/solution-section-images';

export async function getStaticPaths() {
  return (await getCollection('solutionsSv'))
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const d = p.data;
const imgs = solutionImages(p.id);
---

<Layout title={d.metaTitle} description={d.metaDescription}>
  <!-- 1. Hero page header -->
  <PageHeaderHero
    eyebrow={d.eyebrow}
    heading={d.heading}
    subhead={d.subhead}
    image={{ src: imgs[0], alt: '' }}
    veil
    cta={{ label: 'Boka en demo', href: '/book-a-demo' }}
  />

  <!-- 2. Feature v2 (Split) — question→answer intro (checklist optional) -->
  {d.problemHeading && (
    <FeatureSplit
      tagline={d.problemTagline}
      heading={d.problemHeading ?? 'Problemet'}
      body={d.problemBody}
      items={d.problem}
      image={{ src: imgs[1], alt: '' }}
      imageSide="left"
    />
  )}

  <!-- 2.1 Grid layout — headerless grid, grouped under Feature v2 -->
  {d.benefits.length > 0 && (
    <section class="section sol-grid">
      <div class="container">
        <BenefitGrid items={d.benefits} columns={4} />
      </div>
    </section>
  )}

  <!-- 3. Feature v7 (Showcase) — how it helps -->
  {d.showcaseSubs.length > 0 && (
    <FeatureShowcase
      tagline={d.showcaseTagline}
      heading={d.showcaseHeading ?? 'Hur det hjälper'}
      body={d.showcaseBody}
      items={d.showcaseSubs}
      primary={{ label: 'Boka en demo', href: '/book-a-demo' }}
      secondary={{ label: 'Se hur det fungerar', href: '/sv/#how-it-works' }}
      image={{ src: imgs[2], alt: '' }}
      imageSide="right"
    />
  )}

  <!-- 4. FAQ — variant 1 (split) -->
  {d.faqs.length > 0 && (
    <FaqSplit
      heading={d.faqHeading}
      body="Vad operatörer frågar innan en demo. Fortfarande osäker? Hör av dig så hjälper vi till."
      contact={{ label: 'Kontakta oss', href: '/contact' }}
      items={d.faqs}
    />
  )}

  <!-- 5. Customer stories — testimonial slider -->
  {d.testimonials.length > 0 && (
    <TestimonialSliderCollage items={d.testimonials} ctaLabel="Läs berättelsen" />
  )}

  <!-- 6. CTA v2 (image-background email capture) -->
  <CtaEmail
    heading={d.ctaHeading}
    subhead={d.ctaSubhead}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Grid (2.1) sits directly under Feature v2 as one group — drop its top padding. */
  .sol-grid { padding-top: 0; }
</style>
