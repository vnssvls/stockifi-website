---
// Swedish: Inventory Management category LP (/sv/product-inventory-management).
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Receptbygge', body: 'Beräkna varje recept utifrån aktuella ingredienspriser.', href: '/sv/product-inventory-management/recipe-building', icon: icons['book'], image: '/media/product-recipe-building.png' },
  { heading: 'Inventering', body: 'Inventera på mobil eller webben, online eller offline.', href: '/sv/product-inventory-management/stock-counting', icon: icons['box'], image: '/media/product-stock-counting.png' },
  { heading: 'Lageröverföringar', body: 'Spåra varor som förflyttas mellan dina platser.', href: '/sv/product-inventory-management/inventory-transfers', icon: icons['convert-3d-cube'], image: '/media/product-inventory-transfers.png' },
  { heading: 'Spårning av svinn', body: 'Logga svinn och se vad det kostar dig.', href: '/sv/product-inventory-management/wastage-tracking', icon: icons['trash'], image: '/media/product-wastage-tracking.png' },
  { heading: 'Försäljning och förbrukning', body: 'Se vad som såldes och hur det rörde sig genom lagret.', href: '/sv/product-inventory-management/sales-and-usage', icon: icons['sales-usage'], image: '/media/cta-bg-2.jpg' },
];
---

<Layout
  title="Programvara för restauranginventering | Stockifi"
  description="Stockifi samlar inventering, avviksövervakning, svinnregistrering och lageröverföringar i ett system så att siffrorna på varje plats stämmer."
>
  <PageHeader
    eyebrow="Lagerhantering"
    heading="Ett lager du faktiskt kan lita på"
    subhead="Recept, inventeringar, överföringar mellan enheter och svinnet däremellan matar alla ett system. När inventeringen stämmer håller allt som byggs på den."
  />

  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <CtaEmail
    heading="Vill du se din verkliga lagerbild?"
    subhead="Boka ett kort samtal så visar vi dig vad Stockifi hittar under dina första 30 dagar."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
