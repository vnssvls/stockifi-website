---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Book a Demo | Stockifi"
  description="Book a 30-minute demo with the Stockifi team. See how Stockifi connects to your POS and accounting software and gives you full visibility over your food costs."
>
  <div class="bd">
    <span class="bd-glow" aria-hidden="true"></span>

    <div class="bd-inner">

      <!-- ── Left: pitch ── -->
      <div class="bd-pitch">
        <p class="bd-eyebrow">Book a demo</p>
        <h1 class="bd-h1">See what Stockifi<br class="bd-break"> can do for you</h1>
        <p class="bd-sub text-muted">Connect with one of our founders for a walkthrough on the platform, to see how it connects to your systems, and to tell you honestly whether it's the right fit.</p>

        <p class="bd-list-heading">Other things we will cover:</p>
        <ul class="bd-list" role="list">
          <li class="bd-item">
            <span class="bd-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span>Your current structure</span>
          </li>
          <li class="bd-item">
            <span class="bd-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span>What issues you're currently facing</span>
          </li>
          <li class="bd-item">
            <span class="bd-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span>Your goals and growth plans</span>
          </li>
        </ul>

        <div class="bd-stats" aria-label="Social proof">
          <div class="bd-stat">
            <strong class="bd-stat-n">500+</strong>
            <span class="bd-stat-l text-muted">users</span>
          </div>
          <div class="bd-stat-div" aria-hidden="true"></div>
          <div class="bd-stat">
            <strong class="bd-stat-n">3%</strong>
            <span class="bd-stat-l text-muted">food cost improvement</span>
          </div>
          <div class="bd-stat-div" aria-hidden="true"></div>
          <div class="bd-stat">
            <strong class="bd-stat-n">30 days</strong>
            <span class="bd-stat-l text-muted">to first results</span>
          </div>
        </div>
      </div>

      <!-- ── Right: form ── -->
      <div class="bd-form-col">
        <div class="bd-card" id="bd-card">

          <form id="bd-form" class="bd-form" novalidate>
            <div class="bd-row2">
              <div class="bd-field">
                <label class="bd-label" for="bd-fname">First name</label>
                <input class="bd-input" id="bd-fname" name="firstname" type="text"
                  placeholder="John" required autocomplete="given-name" />
                <span class="bd-err" id="err-fname" aria-live="polite"></span>
              </div>
              <div class="bd-field">
                <label class="bd-label" for="bd-lname">Last name</label>
                <input class="bd-input" id="bd-lname" name="lastname" type="text"
                  placeholder="Smith" required autocomplete="family-name" />
                <span class="bd-err" id="err-lname" aria-live="polite"></span>
              </div>
            </div>

            <div class="bd-row2">
              <div class="bd-field">
                <label class="bd-label" for="bd-email">Work email</label>
                <input class="bd-input" id="bd-email" name="email" type="email"
                  placeholder="name@email.com" required autocomplete="email" />
                <span class="bd-err" id="err-email" aria-live="polite"></span>
              </div>
              <div class="bd-field">
                <label class="bd-label" for="bd-phone">
                  Phone
                  <span class="bd-opt">(optional)</span>
                </label>
                <input class="bd-input" id="bd-phone" name="phone" type="tel"
                  placeholder="+47 00 00 00 00" autocomplete="tel" />
              </div>
            </div>

            <div class="bd-field">
              <label class="bd-label" for="bd-company">Venue / company name</label>
              <input class="bd-input" id="bd-company" name="company" type="text"
                placeholder="Restaurant AS" required autocomplete="organization" />
              <span class="bd-err" id="err-company" aria-live="polite"></span>
            </div>

            <div class="bd-field">
              <label class="bd-label" for="bd-locations">Number of locations</label>
              <div class="bd-sel-wrap">
                <select class="bd-select" id="bd-locations" name="num_locations" required>
                  <option value="" disabled selected>Select...</option>
                  <option value="1">1 location</option>
                  <option value="2-5">2–5 locations</option>
                  <option value="6-15">6–15 locations</option>
                  <option value="16-50">16–50 locations</option>
                  <option value="50+">50+ locations</option>
                </select>
                <svg class="bd-chev" width="16" height="16" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round" aria-hidden="true">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </div>
              <span class="bd-err" id="err-locations" aria-live="polite"></span>
            </div>

            <button type="submit" class="bd-btn" id="bd-btn">
              <span id="bd-btn-label">Book a demo</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <p class="bd-legal text-muted">
              By submitting, you agree to be contacted by Stockifi in accordance with our
              <a href="/privacy-policy">Privacy Policy</a>.
            </p>
          </form>

          <div id="bd-success" class="bd-success bd-hidden">

            <!-- Illustration band -->
            <div class="bd-art" aria-hidden="true">
              <div class="rla-stage">
                <span class="rla-star s1"></span>
                <span class="rla-star s2"></span>
                <span class="rla-star s3"></span>
                <span class="rla-star s4"></span>
                <span class="rla-star s5"></span>
                <span class="rla-star tiny s6"></span>
                <span class="rla-star tiny s7"></span>
                <span class="rla-star tiny s8"></span>
                <span class="rla-star tiny s9"></span>
                <span class="rla-star s10"></span>
                <span class="rla-star tiny s11"></span>

                <div class="rla-puff a"></div>
                <div class="rla-puff b"></div>
                <div class="rla-puff c"></div>
                <div class="rla-puff d"></div>
                <div class="rla-puff e"></div>
                <div class="rla-puff f"></div>
                <div class="rla-puff g"></div>
                <div class="rla-puff h"></div>

                <span class="rla-spark s1"></span>
                <span class="rla-spark s2"></span>
                <span class="rla-spark s3"></span>
                <span class="rla-spark s4"></span>
                <span class="rla-spark s5"></span>
                <span class="rla-spark s6"></span>
                <span class="rla-spark s7"></span>
                <span class="rla-spark s8"></span>

                <div class="rla-flame">
                  <svg viewBox="0 0 22 30" width="22" height="30" preserveAspectRatio="none">
                    <path d="M11 1 C 3 9, 3 21, 11 29 C 19 21, 19 9, 11 1 Z" fill="#7c4dc2" />
                    <path d="M11 6 C 7 12, 7 20, 11 26 C 15 20, 15 12, 11 6 Z" fill="#ffce4a" />
                  </svg>
                </div>

                <div class="rla-rocket">
                  <svg viewBox="0 0 56 88" width="56" height="88">
                    <path d="M28 4 C 40 16, 44 34, 44 52 L 44 70 L 12 70 L 12 52 C 12 34, 16 16, 28 4 Z"
                      fill="#fff" stroke="#6b3fb8" stroke-width="2.4" stroke-linejoin="round"/>
                    <path d="M28 4 C 22 12, 18 22, 16 30 L 40 30 C 38 22, 34 12, 28 4 Z"
                      fill="#b894e8" stroke="#6b3fb8" stroke-width="2.2" stroke-linejoin="round"/>
                    <circle cx="28" cy="38" r="6.5" fill="#ebdcff" stroke="#6b3fb8" stroke-width="2.2"/>
                    <circle cx="26" cy="36" r="1.8" fill="#ffffff" opacity="0.9"/>
                    <path d="M12 54 L 2 76 L 12 70 Z"
                      fill="#7c4dc2" stroke="#6b3fb8" stroke-width="2.2" stroke-linejoin="round"/>
                    <path d="M44 54 L 54 76 L 44 70 Z"
                      fill="#7c4dc2" stroke="#6b3fb8" stroke-width="2.2" stroke-linejoin="round"/>
                    <line x1="12" y1="60" x2="44" y2="60" stroke="#6b3fb8" stroke-width="1.8"/>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Copy -->
            <div class="bd-success-body">
              <h2 class="bd-success-h">Got it!</h2>
              <p class="bd-success-p">Our team will be in touch shortly.</p>
              <p class="bd-success-alt text-muted">In the meantime, see who else uses Stockifi.</p>
              <a class="bd-success-link" href="/customer-stories">
                Read customer stories
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
/* display: none that can't be overridden by flex/grid declarations */
.bd-hidden { display: none !important; }

/* ── Page shell ── */
.bd {
  position: relative;
  isolation: isolate;
  overflow-x: clip;
  padding: var(--section-y) var(--gutter-wide);
}

.bd-glow {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: -1;
  width: 120vw;
  height: 110%;
  background-image: url('/media/gradient-duo.png');
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
  opacity: 0.35;
  pointer-events: none;
}

.bd-inner {
  width: 100%;
  max-width: var(--container-max);
  margin-inline: auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-48);
  align-items: start;
}

/* ── Left: pitch ── */
.bd-eyebrow {
  font-size: var(--text-body-sm);
  font-weight: var(--fw-semibold);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--primary-light);
  margin-bottom: var(--space-16);
}

.bd-h1 {
  font-size: var(--text-h2);
  line-height: var(--lh-h2);
  margin-bottom: var(--space-24);
}

.bd-break { display: none; }

.bd-sub {
  font-size: var(--text-body-lg);
  line-height: var(--lh-body);
  max-width: 44ch;
  margin-bottom: var(--space-32);
}

.bd-list-heading {
  font-size: var(--text-body-sm);
  font-weight: var(--fw-semibold);
  color: var(--foreground);
  margin-bottom: var(--space-12);
}

.bd-list {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--space-48) 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.bd-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-12);
  font-size: var(--text-body);
  line-height: var(--lh-body);
}

.bd-icon {
  color: var(--primary-light);
  flex-shrink: 0;
  margin-top: 2px;
}

.bd-stats {
  display: flex;
  align-items: center;
  gap: var(--space-24);
  flex-wrap: wrap;
}

.bd-stat {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.bd-stat-n {
  font-size: var(--text-h5);
  font-weight: var(--fw-bold);
  font-family: var(--font-heading);
  color: var(--foreground);
}

.bd-stat-l {
  font-size: var(--text-body-sm);
}

.bd-stat-div {
  width: 1px;
  height: 2.5rem;
  background: var(--border);
  flex-shrink: 0;
}

/* ── Right: form card ── */
.bd-card {
  --card-shadow: 0 8px 32px -4px rgba(0, 0, 0, 0.25);
  --card-border: #2e283e7d;
  border: 1px solid var(--card-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--card-shadow);
  background: var(--muted);
  overflow: hidden;
}

/* ── Form ── */
.bd-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  padding: var(--space-32);
}

.bd-row2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
}

.bd-field {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.bd-label {
  font-size: var(--text-body-sm);
  font-weight: var(--fw-medium);
  color: var(--foreground);
  display: flex;
  align-items: center;
  gap: var(--space-8);
}

.bd-opt {
  font-weight: var(--fw-regular);
  color: var(--muted-foreground);
  font-size: var(--text-caption);
}

.bd-input,
.bd-select {
  width: 100%;
  height: 46px;
  padding: 0 var(--space-16);
  background: var(--background);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--foreground);
  font-size: var(--text-body);
  font-family: var(--font-body);
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
  appearance: none;
  -webkit-appearance: none;
}

.bd-input::placeholder {
  color: var(--muted-foreground);
}

.bd-input:focus,
.bd-select:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(149, 101, 219, 0.18);
}

.bd-field.is-error .bd-input,
.bd-field.is-error .bd-select {
  border-color: var(--destructive);
}

.bd-err {
  font-size: var(--text-caption);
  color: var(--destructive);
  min-height: 1em;
}

/* Custom select */
.bd-sel-wrap {
  position: relative;
}

.bd-sel-wrap .bd-select {
  padding-right: 42px;
  cursor: pointer;
}

.bd-chev {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--muted-foreground);
  pointer-events: none;
}

.bd-select option {
  background: var(--popover);
  color: var(--foreground);
}

/* Submit button */
.bd-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  width: 100%;
  height: 50px;
  padding: 0 var(--space-32);
  background: var(--primary);
  color: var(--primary-foreground);
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--text-body);
  font-weight: var(--fw-semibold);
  font-family: var(--font-body);
  cursor: pointer;
  transition: background 0.18s ease, opacity 0.18s ease;
  margin-top: var(--space-8);
}

.bd-btn:hover {
  background: var(--primary-dark);
}

.bd-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.bd-legal {
  font-size: var(--text-caption);
  line-height: var(--lh-body);
  margin-top: var(--space-4);
}

.bd-legal a {
  color: var(--primary-light);
}

.bd-legal a:hover {
  text-decoration: underline;
}

/* ── Success ── */
.bd-success {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow: hidden;
}

/* Illustration band — transparent so it matches the card/page bg */
.bd-art {
  position: relative;
  height: 200px;
  background: transparent;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── Rocket launch animation (ported from LP SuccessDialog) ── */
.rla-stage {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.rla-rocket {
  position: absolute;
  left: 50%;
  bottom: 22px;
  width: 56px;
  height: 88px;
  margin-left: -28px;
  animation: rla-lift 3.6s cubic-bezier(.55, .05, .6, 1) infinite;
  z-index: 3;
}

@keyframes rla-lift {
  0%        { transform: translate(0, 18px);    opacity: 0; }
  10%       { opacity: 1; }
  25%       { transform: translate(0, 14px); }
  78%       { transform: translate(0, -150px);  opacity: 1; }
  92%, 100% { transform: translate(0, -220px);  opacity: 0; }
}

.rla-flame {
  position: absolute;
  left: 50%;
  bottom: 22px;
  width: 22px;
  height: 30px;
  margin-left: -11px;
  transform-origin: 50% 0%;
  animation:
    rla-flame-flicker 0.14s ease-in-out infinite alternate,
    rla-lift          3.6s cubic-bezier(.55, .05, .6, 1) infinite;
  z-index: 2;
}

@keyframes rla-flame-flicker {
  from { transform: scaleY(1)    scaleX(1); }
  to   { transform: scaleY(1.18) scaleX(0.85); }
}

.rla-puff {
  position: absolute;
  left: 50%;
  bottom: 8px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(149, 101, 219, 0.25);
  transform: translateX(-50%);
  animation: rla-puff 2s ease-out infinite;
  z-index: 1;
}
.rla-puff.a { animation-delay: 0s;     --rla-x:  -2px; }
.rla-puff.b { animation-delay: 0.25s; --rla-x: -32px; }
.rla-puff.c { animation-delay: 0.5s;  --rla-x:  28px; }
.rla-puff.d { animation-delay: 0.75s; --rla-x: -18px; }
.rla-puff.e { animation-delay: 1s;    --rla-x:  16px; }
.rla-puff.f { animation-delay: 1.25s; --rla-x: -42px; }
.rla-puff.g { animation-delay: 1.5s;  --rla-x:  38px; }
.rla-puff.h { animation-delay: 1.75s; --rla-x:  -8px; }

@keyframes rla-puff {
  0%   { transform: translate(calc(-50% + 0px), 0) scale(0.4);                        opacity: 0; }
  12%  { opacity: 0.65; }
  100% { transform: translate(calc(-50% + var(--rla-x, 0px)), 14px) scale(2.6); opacity: 0; }
}

.rla-spark {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #c39df9;
  opacity: 0;
  animation: rla-spark 1.4s ease-out infinite;
  z-index: 2;
}
.rla-spark.s1 { bottom: 26px; left: calc(50% - 28px); animation-delay: 0s;    --rla-tx: -16px; --rla-ty: -10px; }
.rla-spark.s2 { bottom: 26px; left: calc(50% + 24px); animation-delay: 0.2s;  --rla-tx:  18px; --rla-ty: -12px; }
.rla-spark.s3 { bottom: 18px; left: calc(50% - 20px); animation-delay: 0.5s;  --rla-tx: -22px; --rla-ty:   6px; }
.rla-spark.s4 { bottom: 18px; left: calc(50% + 18px); animation-delay: 0.7s;  --rla-tx:  22px; --rla-ty:   6px; }
.rla-spark.s5 { bottom: 32px; left: calc(50% - 10px); animation-delay: 0.35s; --rla-tx:  -8px; --rla-ty: -20px; }
.rla-spark.s6 { bottom: 32px; left: calc(50% + 8px);  animation-delay: 0.55s; --rla-tx:  10px; --rla-ty: -18px; }
.rla-spark.s7 { bottom: 14px; left: calc(50% - 34px); animation-delay: 0.9s;  --rla-tx: -30px; --rla-ty:  12px; }
.rla-spark.s8 { bottom: 14px; left: calc(50% + 30px); animation-delay: 1.1s;  --rla-tx:  28px; --rla-ty:  14px; }

@keyframes rla-spark {
  0%   { opacity: 0;   transform: translate(0, 0) scale(0.6); }
  30%  { opacity: 0.9; }
  100% { opacity: 0;   transform: translate(var(--rla-tx, 0), var(--rla-ty, 0)) scale(0.2); }
}

.rla-star {
  position: absolute;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: #9565db;
  opacity: 0.5;
  animation: rla-twinkle 2.4s ease-in-out infinite;
}
.rla-star.tiny { width: 2px; height: 2px; opacity: 0.35; }
.rla-star.s1  { top: 22px;  left: 14%;  animation-delay: 0s;   }
.rla-star.s2  { top: 48px;  left: 70%;  animation-delay: 0.5s; }
.rla-star.s3  { top: 20px;  left: 52%;  animation-delay: 1s;   }
.rla-star.s4  { top: 78px;  left: 22%;  animation-delay: 1.5s; }
.rla-star.s5  { top: 104px; left: 80%;  animation-delay: 0.8s; }
.rla-star.s6  { top: 60px;  left: 42%;  animation-delay: 1.3s; }
.rla-star.s7  { top: 36px;  left: 90%;  animation-delay: 0.3s; }
.rla-star.s8  { top: 14px;  left: 32%;  animation-delay: 0.7s; }
.rla-star.s9  { top: 90px;  left: 58%;  animation-delay: 1.8s; }
.rla-star.s10 { top: 50px;  left: 6%;   animation-delay: 1.1s; }
.rla-star.s11 { top: 130px; left: 44%;  animation-delay: 0.4s; }

@keyframes rla-twinkle {
  0%, 100% { opacity: 0.15; transform: scale(0.7); }
  50%      { opacity: 0.9;  transform: scale(1.3); }
}

@media (prefers-reduced-motion: reduce) {
  .rla-rocket, .rla-flame, .rla-puff, .rla-spark, .rla-star { animation: none; }
  .rla-rocket { transform: translate(0, -40px); opacity: 1; }
}

/* Copy below the illustration */
.bd-success-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-12);
  padding: var(--space-32) var(--space-32) 2.5rem;
  background: var(--muted);
  animation: success-rise 0.4s ease-out 0.3s both;
}

@keyframes success-rise {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.bd-success-h {
  font-family: var(--font-heading);
  font-size: var(--text-h3);
  font-weight: var(--fw-bold);
  line-height: var(--lh-h3);
  color: var(--foreground);
}

.bd-success-p {
  font-family: var(--font-body);
  font-size: var(--text-body);
  line-height: var(--lh-body);
  color: var(--foreground);
}

.bd-success-alt {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--lh-body);
  color: var(--muted-foreground);
}

.bd-success-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-8);
  margin-top: var(--space-8);
  padding: var(--space-12) var(--space-24);
  background: transparent;
  border: 1.5px solid var(--accent);
  border-radius: var(--radius-md);
  color: var(--foreground);
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--fw-semibold);
  text-decoration: none;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.bd-success-link svg { transition: transform 0.18s ease; }

.bd-success-link:hover {
  border-color: var(--primary-light);
  background: rgba(149, 101, 219, 0.1);
  text-decoration: none;
}

.bd-success-link:hover svg { transform: translateX(2px); }

/* ── Responsive ── */
@media (min-width: 1024px) {
  .bd-inner {
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-96);
    align-items: start;
  }

  .bd-pitch {
    position: sticky;
    top: calc(var(--nav-h) + var(--space-32));
  }

  .bd-break {
    display: block;
  }
}

@media (max-width: 480px) {
  .bd-row2 {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
// TODO: replace with your HubSpot portal ID and form GUID
const PORTAL_ID = 'YOUR_PORTAL_ID';
const FORM_GUID = 'YOUR_FORM_GUID';

const form = document.getElementById('bd-form');
const successPanel = document.getElementById('bd-success');
const submitBtn = document.getElementById('bd-btn');
const submitLabel = document.getElementById('bd-btn-label');

const REQUIRED = [
  { id: 'bd-fname',     errId: 'err-fname',     msg: 'First name is required.' },
  { id: 'bd-lname',     errId: 'err-lname',     msg: 'Last name is required.' },
  { id: 'bd-email',     errId: 'err-email',     msg: 'A valid work email is required.' },
  { id: 'bd-company',   errId: 'err-company',   msg: 'Restaurant name is required.' },
  { id: 'bd-locations', errId: 'err-locations', msg: 'Please select a number of locations.' },
];

function validate() {
  let valid = true;
  REQUIRED.forEach(({ id, errId, msg }) => {
    const el = document.getElementById(id);
    const err = document.getElementById(errId);
    const wrapper = el?.closest('.bd-field');
    if (!el || !err || !wrapper) return;

    const empty = !el.value.trim();
    const badEmail = id === 'bd-email' && !empty && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value);

    if (empty || badEmail) {
      wrapper.classList.add('is-error');
      err.textContent = badEmail ? 'Enter a valid email address.' : msg;
      valid = false;
    } else {
      wrapper.classList.remove('is-error');
      err.textContent = '';
    }
  });
  return valid;
}

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!validate()) return;

  submitBtn.disabled = true;
  submitLabel.textContent = 'Booking...';

  const data = new FormData(form);
  const fields = Array.from(data.entries())
    .filter(([, v]) => String(v).trim())
    .map(([name, value]) => ({ name, value: String(value) }));

  try {
    if (PORTAL_ID !== 'YOUR_PORTAL_ID') {
      const res = await fetch(
        `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_GUID}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            fields,
            context: { pageUri: window.location.href, pageName: document.title },
          }),
        }
      );
      if (!res.ok) throw new Error('HubSpot submission failed');
    }

    showSuccess();
  } catch {
    submitBtn.disabled = false;
    submitLabel.textContent = 'Book a demo';
  }
});

function showSuccess() {
  form.classList.add('bd-hidden');
  successPanel.classList.remove('bd-hidden');
}

// Preview shortcut: /book-a-demo?preview=success — shows success state without submitting
try {
  const params = new URLSearchParams(window.location.search);
  if (params.get('preview') === 'success') {
    showSuccess();
    params.delete('preview');
    const qs = params.toString();
    window.history.replaceState({}, '', window.location.pathname + (qs ? '?' + qs : ''));
  }
} catch (_) {}

// Clear error state on input
form?.querySelectorAll('.bd-input, .bd-select').forEach((el) => {
  el.addEventListener('input', () => {
    el.closest('.bd-field')?.classList.remove('is-error');
  });
});
</script>
