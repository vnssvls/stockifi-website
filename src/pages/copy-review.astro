---
// COPY REVIEW ROUTE — not part of the site. Lives only on the dc-474-website-copy
// branch so V can review the home draft rendered through the REAL components
// (run `astro dev`, open /copy-review). Never merged to main; only the approved
// copy gets ported into the real index.astro at the end. Mirrors index.astro's
// component usage with the new home arc + draft copy.
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LogoBanner from '../components/LogoBanner.astro';
import FeatureList from '../components/features/FeatureList.astro';
import FeatureSplit from '../components/features/FeatureSplit.astro';
import FeatureTabs from '../components/features/FeatureTabs.astro';
import CustomerStoryBento from '../components/CustomerStoryBento.astro';
import FeatureSteps from '../components/features/FeatureSteps.astro';
import IntegrationPills from '../components/integrations/IntegrationPills.astro';
import FaqSplit from '../components/faq/FaqSplit.astro';
import CtaBand from '../components/CtaBand.astro';
import integrations from '../data/integrations-home.json';
import userLogos from '../data/user-logos.json';

// 3. Product categories — FeatureList. New taxonomy (V + Simon, 2026-06-04):
// Procurement / Inventory Management / Business Intelligence. Integrations is now
// its OWN top-level nav item, no longer in the Product mega menu. Sub-features
// folded into each body as real sentences (FeatureList items are heading + body only).
// CTA build-dep: each category gets a button to its landing page. FeatureList items
// are <button> tabs, so a per-item CTA link must sit OUTSIDE the tab (component change,
// other session). Labels/hrefs captured in each item's `cta`; lead-in is the last
// body sentence; the button itself is not rendered yet. Category hrefs are PROVISIONAL.
const categories = [
  { heading: 'Procurement', body: 'Stockifi reads your supplier invoices automatically, tracks every price change, and flags anomalies like overcharges, with your central kitchen costed in the same place. See how it keeps your supplier costs in check.', cta: { label: 'Explore Procurement', href: '/product/procurement' } },
  { heading: 'Inventory Management', body: 'You count stock and log any transfers and wastage in the app, and Stockifi compares it to the recipes we set up with you to show what you really used. See how your counts become numbers you can act on.', cta: { label: 'Explore Inventory Management', href: '/product/inventory-management' } },
  { heading: 'Business Intelligence', body: 'Stockifi turns all of it into performance dashboards, variance analysis, and profitability insights, with an API to push the data wherever you need it. See what your numbers can tell you.', cta: { label: 'Explore Business Intelligence', href: '/product/business-intelligence' } },
];

// 4. Benefits / value prop — FeatureSplit
const benefitItems = [
  'Catch supplier price rises the day they hit an invoice',
  'See what you actually used against what you should have, per dish',
  'Know the live margin of every recipe as your costs move',
  'Most operators see a 2 to 3% improvement in food cost after onboarding',
];

// 5. By team — FeatureTabs
const teamTabs = [
  { label: 'Management', heading: "The whole operation's margin at a glance", body: "Owners and GMs get cost visibility across every location, so you know where margin is won or lost without chasing a single report. See it from an owner's seat.", primary: { label: 'Stockifi for Management', href: '/solutions/management' } },
  { label: 'Operations', heading: 'Run tighter service without the extra admin', body: 'Spot waste, over-portioning, and price drift early, so the day-to-day stays under control even as you add locations. See it on the floor.', primary: { label: 'Stockifi for Operations', href: '/solutions/operations' } },
  { label: 'Kitchen', heading: 'Recipes that cost themselves', body: 'Chefs see the live cost and margin of every dish, so menu calls reflect what ingredients cost today. See it in the kitchen.', primary: { label: 'Stockifi for Kitchen', href: '/solutions/kitchen' } },
  { label: 'Finance', heading: 'COGS you can actually trust', body: 'Finance gets actual against theoretical cost from real invoice and POS data, so month-end stops being a guessing game. See it on the books.', primary: { label: 'Stockifi for Finance', href: '/solutions/finance' } },
];

// 7. Onboarding — FeatureSteps
const onboarding = [
  { heading: 'Connect your systems', body: 'We connect your accounting and POS, and your invoices and sales start flowing into Stockifi automatically.' },
  { heading: 'We set up your recipes', body: 'We build your recipe baseline with you, so every cost is right from day one.' },
  { heading: 'Your account is ready', body: 'Most operations are live within two days of connecting their systems.' },
  { heading: 'Start seeing the gaps', body: 'From your first counts, you see real food cost, variance, and price changes.' },
];

const faqs = [
  { question: 'How does Stockifi connect to my systems?', answer: 'It reads your accounting software for supplier invoices and your POS for sales. We support 30+ accounting and 40+ POS integrations; the full list is on the integrations page.' },
  { question: 'How long does it take to set up?', answer: 'Most operations are running quickly once recipes and integrations are connected. We set the recipe baseline with you so the numbers are right from day one.' },
  { question: 'What does it cost?', answer: 'Pricing depends on the size and complexity of your setup, typically between €150 and €400 per month. We look at it together on a short call.' },
  { question: 'Is my restaurant a good fit?', answer: 'Stockifi suits established restaurants and groups that have recipes and an accounting or POS system. Very early-stage operations usually are not the right fit yet.' },
  { question: 'Can my team use it in our language?', answer: 'Your data stays in your language and the app modules are in English. We run a short training so the team is comfortable from the start.' },
];
---

<Layout
  title="European Restaurant Food Cost Software | Stockifi"
  description="Know your real food cost. Stockifi connects your invoices, POS, and recipes to show where your margin goes, with the setup done for you."
>
  <!-- 1. Hero -->
  <Hero
    wide
    tagline="Restaurant food cost software"
    heading="Know your real food cost."
    subhead="Your invoices, sales, and recipes already hold the answer to your food cost. Stockifi pulls them together and does the math, so you see your margin and act on it."
    primary={{ label: 'Book a demo', href: '/book-a-demo' }}
    secondary={{ label: 'See how it works', href: '#how-it-works' }}
  />

  <!-- 2. Social proof -->
  <LogoBanner label="Trusted by 500+ restaurants across Europe" logos={userLogos} />

  <!-- 3. Product categories (FeatureList) -->
  <div id="how-it-works" class="hp-anchor">
    <FeatureList tagline="What's inside" items={categories} />
  </div>

  <!-- 4. Benefits / value prop (FeatureSplit) -->
  <FeatureSplit
    tagline="Why it's worth it"
    heading="Restaurant food cost control that pays for itself"
    body="Most of your margin leaks in the gaps between systems. Stockifi pulls them into one view, so even a 1% improvement in food cost turns into money you keep."
    items={benefitItems}
    imageSide="right"
  />

  <!-- 5. By team (FeatureTabs) -->
  <FeatureTabs
    tagline="For your team"
    heading="One set of numbers for every role"
    subhead="From the GM to the kitchen, everyone works from the same numbers."
    tabs={teamTabs}
  />

  <!-- 6. Customer stories -->
  <CustomerStoryBento
    eyebrow="Customer stories"
    heading="Hear it from operators like you"
    subhead="See how hospitality businesses use Stockifi to win back margin they couldn't see before."
    cta={{ label: 'Read all stories', href: '/customer-stories' }}
    slugs={['byoslo', 'eik-and-friends', 'koie-ramen', 'skigeilo-2']}
  />

  <!-- 7. Onboarding (FeatureSteps) -->
  <FeatureSteps
    tagline="Personalized onboarding"
    heading="Get up and running in 48 hours"
    cta={{ label: 'Book a demo', href: '/book-a-demo' }}
    steps={onboarding}
  />

  <!-- 8. Integrations. CTA build-dep: IntegrationPills has no cta prop — add one to
       render a "View all integrations" button → /integrations. -->
  <IntegrationPills
    wide
    eyebrow="Integrations"
    heading="Works with the tools you already run"
    subhead="Stockifi reads your accounting software and POS automatically, with 70+ integrations ready to connect."
    items={integrations}
  />

  <!-- 9. Risk-reversal / pricing lead-in (CtaBand stand-in). Per V: guarantee moved
       into the body, heading now leads to pricing. -->
  <CtaBand
    heading="See what Stockifi would cost for your setup."
    subhead="Pricing depends on your size and setup, and onboarding is risk-free: if we don't find at least €3,000 in hidden losses in your first 30 days, you pay nothing."
    primary={{ label: 'See pricing', href: '/pricing' }}
  />

  <!-- 10. FAQ -->
  <FaqSplit
    eyebrow="FAQs"
    heading="Questions operators ask"
    body="The things operators check before a demo. Still unsure? Reach out and we'll help."
    contact={{ label: 'Contact us', href: '/contact' }}
    items={faqs}
  />

  <!-- 11. Final CTA -->
  <CtaBand
    heading="See where your margin is leaking"
    subhead="Book a short call and we'll walk through it using your own numbers."
    primary={{ label: 'Book a demo', href: '/book-a-demo' }}
  />
</Layout>

<style>
  .hp-anchor { scroll-margin-top: var(--space-96); }

  /* Hero background experiment — page-scoped to /copy-review only (does NOT touch the
     shared Hero component or any other page). Aurora glow per V's gradient stack.
     Hardcoded rgba is fine here since this file is review-only and never ships; if it
     graduates to the real Hero, swap to tokens for stylelint. */
  :global(.hero) {
    background:
      radial-gradient(58% 66% at 62% 50%, rgba(158, 180, 250, 0.54), transparent 62%),
      radial-gradient(54% 62% at 40% 50%, rgba(186, 140, 238, 0.42), transparent 64%),
      radial-gradient(48% 56% at 30% 72%, rgba(248, 176, 214, 0.28), transparent 62%);
  }
</style>
