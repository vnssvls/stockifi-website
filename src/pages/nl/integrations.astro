---
// Integrations page — Dutch (NL) locale. Translated from src/pages/integrations.astro.
// Page header (heading + subhead + logo strip) → directory (search/sort/filter +
// card grid) → CTA variant 2 (image-background email capture). Nav + Footer come
// from the layout.
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import IntegrationsDirectory from '../../components/integrations/IntegrationsDirectory.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import data from '../../../content/integrations/integrations.en.json';

const live = data.filter((x) => !x.draft);

const CATEGORIES = [
  { value: 'accounting', label: 'Boekhouding' },
  { value: 'pos', label: 'Kassasysteem' },
  { value: 'other', label: 'Overig' },
];

const items = [...live]
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((x) => ({ name: x.name, category: x.category, logo: x.logo }));

// Recognizable subset for the header strip (rendered as uniform white silhouettes).
const stripNames = ['Square', 'Lightspeed', 'Xero', 'Quickbooks', 'Visma', 'Fortnox', 'Mews', 'Wolt', 'Tripletex', 'Trivec'];
const strip = stripNames
  .map((n) => live.find((x) => x.name === n))
  .filter((x): x is (typeof live)[number] => Boolean(x));
---

<Layout
  title="Integraties — Stockifi"
  description="Stockifi koppelt aan meer dan 30 boekhoudpakketten en 40 kassasystemen, zodat facturen, verkopen en receptkosten altijd gesynchroniseerd zijn."
>
  <PageHeader
    eyebrow="Integraties"
    heading="Stockifi werkt met de tools die je al gebruikt"
    subhead="Koppel je boekhoudsoftware en kassasysteem zodat facturen, verkopen en receptkosten gesynchroniseerd blijven — geen handmatige exports, geen dubbele invoer."
  >
    <div class="int-strip">
      {strip.map((s) => <img class="int-strip-logo" src={s.logo} alt={s.name} width="120" height="40" loading="lazy" />)}
    </div>
  </PageHeader>

  <IntegrationsDirectory items={items} categories={CATEGORIES} />

  <CtaEmail
    heading="Bekijk het gekoppeld aan jouw systemen"
    subhead="Laat je e-mailadres achter en we laten je zien wat Stockifi in je eerste 30 dagen boven water haalt."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  .int-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-32);
  }
  /* Uniform white silhouettes so the mixed brand logos read on the dark header */
  .int-strip-logo {
    height: 26px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.55;
  }
</style>
