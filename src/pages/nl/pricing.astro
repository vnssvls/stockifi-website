---

<Layout
  title="Prijzen — Software voor foodcostbeheer | Stockifi"
  description="Abonnementen voor elke operatie, van zelfstandige restaurants tot restaurantgroepen met meerdere locaties. Met een risicovrije onboardinggarantie."
>
  <!-- Pricing hero: header + cards share one decorative gradient backdrop that
       bleeds behind both sections (not clipped to either). -->
  <div class="pricing-hero">
    <!-- 1. Page header -->
    <PageHeader
      eyebrow="Prijzen"
      heading="Kies een abonnement dat bij je past"
      subhead="Elk abonnement wordt geleverd met onze risicovrije onboardinggarantie. Geen langlopende contracten, op elk moment opzegbaar."
    />

    <!-- 1b. Pricing cards -->
    <PricingCards plans={plans} />
  </div>

  <!-- 2. Logo banner — scrolling marquee (matches the home page) -->
  <LogoBanner label="Vertrouwd door 500+ restaurants in heel Europa" logos={userLogos} />

  <!-- 3. Feature section — Feature variant 6 (columns) -->
  <FeatureColumns
    tagline="Waarom Stockifi"
    heading="Waar de abonnementen zichzelf terugverdienen"
    columns={featureCols}
  />

  <!-- 4. FAQ — variant 1 (split) -->
  <FaqSplit
    heading="Vragen over de prijzen?"
    body="Wat operators vragen voordat ze een abonnement kiezen. Toch niet zeker? Neem contact op en we helpen je verder."
    contact={{ label: 'Neem contact op', href: '/nl/contact' }}
    items={faqs}
  />

  <!-- 5. CTA — variant 2.1 (image-backed button) -->
  <CtaButton
    heading="Klaar om te investeren in je winstgevendheid?"
    primary={{ label: 'Aan de slag', href: '/nl/book-a-demo' }}
    secondary={{ label: 'Praat met een expert', href: '/nl/contact' }}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Brand gradient glow (from the ads-LP) bleeds behind BOTH the page header and the
     pricing cards as one continuous backdrop — not clipped to either section. */
  .pricing-hero { position: relative; isolation: isolate; }
  .pricing-hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -6%;
    transform: translateX(-50%);
    width: min(1200px, 150%);
    aspect-ratio: 600 / 500;
    background-image: url('/media/gradient-centered.png');
    background-size: contain;
    background-position: center top;
    background-repeat: no-repeat;
    opacity: 0.4;
    z-index: -1;
    pointer-events: none;
  }
  /* Header + cards read as one block: collapse the stacked section paddings between
     them (they each carry full section padding otherwise → an awkward double gap). */
  .pricing-hero :global(.page-header) { padding-bottom: var(--space-32); }
  .pricing-hero :global(.pricing-cards) { padding-top: 0; }
</style>
