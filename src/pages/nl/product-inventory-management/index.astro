---
// Dutch: Inventory Management category LP (/nl/product-inventory-management).
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Receptenbeheer', body: 'Bereken elk recept op basis van actuele ingrediëntprijzen.', href: '/nl/product-inventory-management/recipe-building', icon: icons['book'], image: '/media/product-recipe-building.png' },
  { heading: 'Voorraadtelling', body: 'Tel voorraad op mobiel of web, online of offline.', href: '/nl/product-inventory-management/stock-counting', icon: icons['box'], image: '/media/product-stock-counting.png' },
  { heading: 'Voorraadoverdrachten', body: 'Volg goederen die tussen je locaties worden verplaatst.', href: '/nl/product-inventory-management/inventory-transfers', icon: icons['convert-3d-cube'], image: '/media/product-inventory-transfers.png' },
  { heading: 'Verspillingregistratie', body: 'Registreer verspilling en zie wat het je kost.', href: '/nl/product-inventory-management/wastage-tracking', icon: icons['trash'], image: '/media/product-wastage-tracking.png' },
  { heading: 'Verkoop en verbruik', body: 'Zie wat er is verkocht en hoe het door de voorraad is gegaan.', href: '/nl/product-inventory-management/sales-and-usage', icon: icons['sales-usage'], image: '/media/cta-bg-2.jpg' },
];
---

<Layout
  title="Software voor restaurantvoorraadbeheer | Stockifi"
  description="Stockifi brengt voorraadtelling, afwijkingsmonitoring, verspillingregistratie en voorraadoverdrachten samen in één systeem, zodat de cijfers op elke locatie kloppen."
>
  <PageHeader
    eyebrow="Voorraadbeheer"
    heading="Een voorraad waar je echt op kunt vertrouwen"
    subhead="Recepten, voorraadtellingen, overdrachten tussen vestigingen en het verlies daartussen voeden allemaal één systeem. Als de telling klopt, houdt alles wat erop gebouwd is stand."
  />

  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <CtaEmail
    heading="Wil je je echte voorraadbeeld zien?"
    subhead="Plan een kort gesprek en we laten je zien wat Stockifi in je eerste 30 dagen blootlegt."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
