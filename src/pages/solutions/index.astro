---
// Solutions hub page (/solutions). One page linking to all individual solution pages
// grouped by type and by team. No /solutions-[segment] sub-pages — this is the single
// landing. Layout per V's wireframe (Jun 14 2026):
// PageHeader (centered) → By Type grid (2-col) → By Team grid (2-col) → CtaEmail → Footer v2
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import ImageCardGrid from '../../components/ImageCardGrid.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import navIcons from '../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const byType = [
  { heading: 'Independent restaurants', body: 'Tighter food cost without the spreadsheets.', href: '/solutions/independent-restaurants', image: '/media/solution-independent-restaurants.jpg', icon: icons['fluent-store'] },
  { heading: 'Restaurant groups', body: 'Consolidated cost visibility across sites.', href: '/solutions/restaurant-groups', image: '/media/solution-restaurant-groups.jpg', icon: icons['buildings-2'] },
  { heading: 'Hotels with F&B', body: 'Control across full food and beverage.', href: '/solutions/hotels', image: '/media/solution-hotels.jpg', icon: icons['reserve'] },
  { heading: 'Bars', body: 'Know the margin on every drink you pour.', href: '/solutions/bars', image: '/media/solution-bars.jpg', icon: icons['cocktail'] },
];

const byTeam = [
  { heading: 'Management', body: 'Margin visibility across the whole operation.', href: '/solutions/management', image: '/media/solution-management.jpg', icon: icons['briefcase'] },
  { heading: 'Operations', body: 'Spot waste and price drift early.', href: '/solutions/operations', image: '/media/solution-operations.jpg', icon: icons['setting-2'] },
  { heading: 'Kitchen', body: 'Live dish costs for sharper menu calls.', href: '/solutions/kitchen', image: '/media/solution-kitchen.jpg', icon: icons['chef-hat'] },
  { heading: 'Finance', body: 'COGS you can trust at month-end.', href: '/solutions/finance', image: '/media/solution-finance.jpg', icon: icons['fluent-finance'] },
];
---

<Layout
  title="Restaurant Management Solutions | Stockifi"
  description="Stockifi works across independent restaurants, groups, hotels, and every role in between. See which solution fits how your operation actually runs."
>
  <!-- 1. Page header — centered variant -->
  <PageHeader
    eyebrow="Solutions"
    heading="Protect the margins that fund your growth"
    subhead="A single restaurant and a fifteen-site group face very different problems. Find the view built for yours, by the kind of business you are or the seat you sit in."
  />

  <!-- 2. By Type — 4 segment solution cards -->
  <section class="section solutions-section">
    <div class="container">
      <div class="solutions-group-header">
        <p class="tagline">By type</p>
        <h2 class="solutions-group-heading">Whatever kind of operation you run</h2>
      </div>
      <div class="solutions-grid">
        <ImageCardGrid items={byType} columns={4} showArrow={true} />
      </div>
    </div>
  </section>

  <!-- 3. By Team — 4 team solution cards -->
  <section class="section solutions-section">
    <div class="container">
      <div class="solutions-group-header">
        <p class="tagline">By team</p>
        <h2 class="solutions-group-heading">Whatever role you play</h2>
      </div>
      <div class="solutions-grid">
        <ImageCardGrid items={byTeam} columns={4} showArrow={true} />
      </div>
    </div>
  </section>

  <!-- 4. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="Want to see which one fits your operation?"
    subhead="Book a short call and we'll point you to the right fit and show you what Stockifi surfaces in your first 30 days."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  .solutions-section { padding-block: var(--space-48); }
  .solutions-group-header { margin-bottom: var(--space-48); }
  .solutions-group-heading { font-size: var(--text-h2); margin-top: var(--space-12); }

  /* Scoped overrides for this page only */
  .solutions-grid :global(.icg-icon) { color: white; }
  .solutions-grid :global(.icg-arrow) { color: white; }
  .solutions-grid :global(.icg-item--linked:hover) { border-color: white; }
</style>
