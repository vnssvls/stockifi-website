---
// Solutions item page template (Figma 80:*). Arrangement per V:
// PageHeaderHero → Feature v2 (Split) → Grid layout (BenefitGrid) → Feature v7
// (Showcase) → FAQ v2 (Grid) → [customer story gallery slot] → CTA v2 (CtaEmail).
// Built as the concrete "independent-restaurants" instance; the other solution
// items follow the same template. DRAFT copy.
import Layout from '../../layouts/Layout.astro';
import PageHeaderHero from '../../components/page-headers/PageHeaderHero.astro';
import FeatureSplit from '../../components/features/FeatureSplit.astro';
import BenefitGrid from '../../components/BenefitGrid.astro';
import FeatureShowcase from '../../components/features/FeatureShowcase.astro';
import FaqSplit from '../../components/faq/FaqSplit.astro';
import TestimonialSlider from '../../components/TestimonialSlider.astro';
import CtaEmail from '../../components/CtaEmail.astro';

const problemItems = [
  'Supplier prices creep up unnoticed between deliveries',
  'Portions drift from the recipe over a busy service',
  'Waste and spoilage never make it into a number',
  'What you bought never reconciles with what you sold',
];

const benefits = [
  { heading: 'Live recipe costs', body: 'Every recipe re-costs itself as supplier prices move, so your margins are always current.' },
  { heading: 'Invoices, read for you', body: 'Stockifi reads supplier invoices line by line. No retyping, no missed price changes.' },
  { heading: 'Variance you can act on', body: 'See theoretical against actual consumption and find where the margin is going.' },
  { heading: 'Set up with you', body: 'We build your recipe baseline together so the numbers are right from day one.' },
];

const showcaseSubs = [
  { heading: 'Actual vs theoretical', body: 'Compare what should have been used against what sold, per item.' },
  { heading: 'Price-rise alerts', body: 'Catch supplier increases the moment they hit an invoice.' },
];

const faqs = [
  { question: 'Is Stockifi worth it for a single restaurant?', answer: 'Yes, if you have recipes and use accounting or a POS. A 1% improvement in food cost is usually worth far more than the subscription.' },
  { question: 'How long does setup take?', answer: 'Most independents are running quickly once recipes and integrations are connected. We set the recipe baseline with you.' },
  { question: 'What does it cost?', answer: 'Pricing depends on your setup, typically between €150 and €400 per month. We look at it together on a short call.' },
  { question: 'Does it work with my systems?', answer: 'We support 30+ accounting and 40+ POS integrations. Check the full list on the integrations page.' },
];

// DRAFT placeholder testimonials — replace with real sourced customer stories.
const testimonials = [
  { quote: '"Stockifi showed us a 4% gap between what we bought and what we actually sold in the first month. We closed most of it by the next stock count."', name: 'Owner', position: 'Owner', company: 'Independent restaurant', storyHref: '/customer-stories' },
  { quote: '"Recipe costs update themselves now. We catch a supplier price rise the day it lands on an invoice, not weeks later at month-end."', name: 'Head Chef', position: 'Kitchen', company: 'Neighbourhood bistro', storyHref: '/customer-stories' },
];
---

<Layout
  title="Food Cost Software for Independent Restaurants | Stockifi"
  description="Run a tighter kitchen without the spreadsheets. Stockifi connects your invoices, POS, and recipes so independent restaurants track actual food cost."
>
  <!-- 1. Hero page header -->
  <PageHeaderHero
    eyebrow="Independent restaurants"
    heading="Run a tighter kitchen without the spreadsheets"
    subhead="Stockifi connects your invoices, POS, and recipes so you see where margin leaks, then close the gap, without adding hours of admin."
    cta={{ label: 'Book a demo', href: '/book-a-demo' }}
  />

  <!-- 2. Feature v2 (Split) — the problem -->
  <FeatureSplit
    tagline="The problem"
    heading="Margin leaks hide in plain sight"
    body="In a single kitchen the small losses add up quietly, and by the time the month closes the money is already gone."
    items={problemItems}
    imageSide="left"
  />

  <!-- 2.1 Grid layout — headerless grid, grouped under Feature v2 (its own heading
       carries the context); dropped inside a section here. -->
  <section class="section sol-grid">
    <div class="container">
      <BenefitGrid items={benefits} columns={4} />
    </div>
  </section>

  <!-- 3. Feature v7 (Showcase) — how it helps -->
  <FeatureShowcase
    tagline="How it helps"
    heading="From guesswork to numbers you trust"
    body="Stockifi turns the invoices and sales you already produce into a clear picture of where your food cost actually goes."
    items={showcaseSubs}
    primary={{ label: 'Book a demo', href: '/book-a-demo' }}
    secondary={{ label: 'See how it works', href: '/#how-it-works' }}
    imageSide="right"
  />

  <!-- 4. FAQ — variant 1 (split) -->
  <FaqSplit
    heading="Questions independents ask"
    body="What independents ask before a demo. Still unsure? Reach out and we'll help."
    contact={{ label: 'Contact us', href: '/contact' }}
    items={faqs}
  />

  <!-- 5. Customer stories — testimonial slider -->
  <TestimonialSlider items={testimonials} ctaLabel="Read story" />

  <!-- 6. CTA v2 (image-background email capture) -->
  <CtaEmail
    heading="See where your margin is leaking"
    subhead="Drop your email and we'll show you what Stockifi surfaces in your first 30 days."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Grid (2.1) sits directly under Feature v2 as one group — drop its top padding so
     it isn't a full section gap away. */
  .sol-grid { padding-top: 0; }
</style>
