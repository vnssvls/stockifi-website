---
// Solutions item page template (Figma 80:*). One page per entry in the `solutions`
// content collection. Arrangement per V:
// PageHeaderHero → Feature v2 (Split) → Grid layout (BenefitGrid) → Feature v7
// (Showcase) → FAQ v2 (Grid) → [customer story gallery slot] → CTA v2 (CtaEmail).
// Optional sections render only when their data is present in frontmatter.
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeaderHero from '../../components/page-headers/PageHeaderHero.astro';
import FeatureSplit from '../../components/features/FeatureSplit.astro';
import BenefitGrid from '../../components/BenefitGrid.astro';
import FeatureShowcase from '../../components/features/FeatureShowcase.astro';
import FaqSplit from '../../components/faq/FaqSplit.astro';
import TestimonialSlider from '../../components/TestimonialSlider.astro';
import CtaEmail from '../../components/CtaEmail.astro';

export async function getStaticPaths() {
  return (await getCollection('solutions'))
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const d = p.data;
---

<Layout title={d.metaTitle} description={d.metaDescription}>
  <!-- 1. Hero page header -->
  <PageHeaderHero
    eyebrow={d.eyebrow}
    heading={d.heading}
    subhead={d.subhead}
    cta={{ label: 'Book a demo', href: '/book-a-demo' }}
  />

  <!-- 2. Feature v2 (Split) — the problem -->
  {d.problem.length > 0 && (
    <FeatureSplit
      tagline={d.problemTagline}
      heading={d.problemHeading ?? 'The problem'}
      body={d.problemBody}
      items={d.problem}
      imageSide="left"
    />
  )}

  <!-- 2.1 Grid layout — headerless grid, grouped under Feature v2 -->
  {d.benefits.length > 0 && (
    <section class="section sol-grid">
      <div class="container">
        <BenefitGrid items={d.benefits} columns={4} />
      </div>
    </section>
  )}

  <!-- 3. Feature v7 (Showcase) — how it helps -->
  {d.showcaseSubs.length > 0 && (
    <FeatureShowcase
      tagline={d.showcaseTagline}
      heading={d.showcaseHeading ?? 'How it helps'}
      body={d.showcaseBody}
      items={d.showcaseSubs}
      primary={{ label: 'Book a demo', href: '/book-a-demo' }}
      secondary={{ label: 'See how it works', href: '/#how-it-works' }}
      imageSide="right"
    />
  )}

  <!-- 4. FAQ — variant 1 (split) -->
  {d.faqs.length > 0 && (
    <FaqSplit
      heading={d.faqHeading}
      body="What operators ask before a demo. Still unsure? Reach out and we'll help."
      contact={{ label: 'Contact us', href: '/contact' }}
      items={d.faqs}
    />
  )}

  <!-- 5. Customer stories — testimonial slider -->
  {d.testimonials.length > 0 && (
    <TestimonialSlider items={d.testimonials} ctaLabel="Read story" />
  )}

  <!-- 6. CTA v2 (image-background email capture) -->
  <CtaEmail
    heading={d.ctaHeading}
    subhead={d.ctaSubhead}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Grid (2.1) sits directly under Feature v2 as one group — drop its top padding so
     it isn't a full section gap away. */
  .sol-grid { padding-top: 0; }
</style>
