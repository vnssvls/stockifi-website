---
// Danish blog article (/da/blog/[slug]): split header (text left, image right, 80px gutter) →
// light-mode body with a sticky, scroll-spy table of contents on the left → CTA v2.
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import CtaEmail from '../../../components/CtaEmail.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blogDa')).filter((p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const d = post.data;
const dateLabel = d.publishDate
  ? d.publishDate.toLocaleDateString('da-DK', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Layout
  title={`${d.metaTitle ?? d.title} | Stockifi`}
  description={d.metaDescription ?? d.excerpt}
  image={d.heroImage}
>
  <!-- Split header -->
  <header class="bi-header">
    <div class="bi-hwide">
      <div class="bi-hgrid">
        <div class="bi-htext">
          <a class="bi-back" href="/da/blog">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Alle artikler
          </a>
          <div class="bi-tags">
            <span class="bi-cat">{d.category}</span>
            {d.readTime && <span class="bi-read text-muted">{d.readTime}</span>}
          </div>
          <h1 class="bi-title">{d.title}</h1>
          {dateLabel && <p class="bi-pub text-muted">Publiceret {dateLabel}</p>}
        </div>
        <div class="bi-hmedia">
          {d.heroImage ? (
            <img src={d.heroImage} alt={d.heroImageAlt} loading="eager" />
          ) : (
            <span class="bi-hmedia-ph" aria-hidden="true"></span>
          )}
        </div>
      </div>
    </div>
  </header>

  <!-- Light-mode reading section: TOC + prose. -->
  <article class="bi-article section" data-theme="light">
    <div class="bi-layout">
      {toc.length > 0 && (
        <aside class="bi-toc">
          <p class="bi-toc-label">I denne artikel</p>
          <nav>
            <ol class="bi-toc-list">
              {toc.map((h, i) => (
                <li class:list={['bi-toc-item', h.depth === 3 && 'is-sub']}>
                  <a href={`#${h.slug}`} data-toc={h.slug}>
                    <span class="bi-toc-num">{String(i + 1).padStart(2, '0')}</span>
                    <span class="bi-toc-text">{h.text}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}
      <div class="bi-body prose">
        <Content />
      </div>
    </div>
  </article>

  <CtaEmail
    heading="Se hvor din margin forsvinder"
    subhead="Indtast din e-mail, og vi viser dig hvad Stockifi afslører i de første 30 dage."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Split header — modest top padding (was a tall hero). */
  .bi-header { padding-block: var(--space-48) var(--space-64); }
  .bi-hwide { width: 100%; max-width: none; margin-inline: auto; padding-inline: var(--gutter-wide); }
  .bi-hgrid { display: grid; grid-template-columns: 1fr; gap: var(--space-32); align-items: center; }
  .bi-htext { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-16); }
  .bi-back { display: inline-flex; align-items: center; gap: var(--space-8); color: var(--muted-foreground); font-size: var(--text-body-sm); }
  .bi-back:hover { color: var(--foreground); text-decoration: none; }
  .bi-tags { display: flex; align-items: center; gap: var(--space-12); }
  .bi-cat { padding: var(--space-4) var(--space-12); border-radius: var(--radius-full); background: var(--muted); color: var(--foreground); font-size: var(--text-caption); font-weight: var(--fw-medium); }
  .bi-read { font-size: var(--text-body-sm); }
  .bi-title { font-size: var(--text-h2); line-height: var(--lh-h2); text-wrap: pretty; }
  .bi-pub { font-size: var(--text-body-sm); }
  .bi-hmedia img,
  .bi-hmedia-ph { display: block; width: 100%; aspect-ratio: 16 / 10; object-fit: cover; border-radius: var(--radius-lg); }
  .bi-hmedia-ph { background: var(--muted); }

  /* Light reading section. */
  .bi-article { background-color: var(--background); color: var(--foreground); overflow-x: clip; }
  .bi-layout { display: grid; grid-template-columns: 1fr; gap: var(--space-48); width: 100%; padding-inline: var(--gutter-wide); }

  /* Friendly numbered TOC in a soft card: NN | title, with the active item accented. */
  .bi-toc { display: none; }
  .bi-toc-label { font-size: var(--text-body); font-weight: var(--fw-semibold); color: var(--foreground); margin-bottom: var(--space-16); }
  .bi-toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-16); }
  .bi-toc a { display: grid; grid-template-columns: auto 1fr; gap: var(--space-12); align-items: start; }
  .bi-toc a:hover { text-decoration: none; }
  .bi-toc-num { font-variant-numeric: tabular-nums; font-size: var(--text-body-sm); font-weight: var(--fw-medium); color: var(--muted-foreground); }
  .bi-toc-text {
    padding-left: var(--space-12);
    border-left: 1px solid var(--border);
    color: var(--muted-foreground);
    font-size: var(--text-body-sm);
    line-height: var(--lh-body-sm);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .bi-toc a:hover .bi-toc-text { color: var(--foreground); }
  .bi-toc-item.is-sub .bi-toc-num { opacity: 0; }
  .bi-toc-item.is-sub .bi-toc-text { margin-left: var(--space-12); }
  /* Active section (intentional primary accent — marks where you are). */
  .bi-toc a.is-active .bi-toc-num { color: var(--primary); }
  .bi-toc a.is-active .bi-toc-text { color: var(--foreground); font-weight: var(--fw-semibold); border-left-color: var(--primary); }

  .bi-body :global(p),
  .bi-body :global(li) { font-size: var(--text-prose); }
  .bi-body :global(p),
  .bi-body :global(ul),
  .bi-body :global(ol) { margin-bottom: var(--space-24); line-height: var(--lh-body); }
  .bi-body :global(h2),
  .bi-body :global(h3),
  .bi-body :global(h4) { font-family: var(--font-body); text-wrap: pretty; scroll-margin-top: calc(var(--nav-h) + var(--space-16)); }
  .bi-body :global(h2) { margin-top: var(--space-48); margin-bottom: var(--space-16); font-size: var(--text-h4); }
  .bi-body :global(h3) { margin-top: var(--space-32); margin-bottom: var(--space-12); font-size: var(--text-h5); }
  .bi-body :global(h4) { margin-top: var(--space-24); margin-bottom: var(--space-8); font-size: var(--text-h6); }
  .bi-body :global(ul) { list-style: disc; }
  .bi-body :global(ol) { list-style: decimal; }
  .bi-body :global(ul),
  .bi-body :global(ol) { padding-left: var(--space-32); }
  .bi-body :global(li) { margin-bottom: var(--space-12); }
  .bi-body :global(li)::marker { color: var(--muted-foreground); }
  .bi-body :global(ol) :global(li)::marker { color: var(--foreground); font-weight: var(--fw-semibold); }
  .bi-body :global(li) :global(p) { margin-bottom: 0; }
  .bi-body :global(li) :global(ul),
  .bi-body :global(li) :global(ol) { margin-top: var(--space-12); margin-bottom: 0; }
  .bi-body :global(li) :global(ul) { list-style: circle; }
  .bi-body :global(a) { color: var(--primary); text-decoration: underline; }
  .bi-body :global(strong) { color: var(--foreground); font-weight: var(--fw-semibold); }
  .bi-body :global(img) { width: 100%; height: auto; margin-block: var(--space-32); border-radius: var(--radius-md); }
  .bi-body :global(blockquote) {
    margin-block: var(--space-32);
    padding-left: var(--space-24);
    border-left: 3px solid var(--primary);
    color: var(--muted-foreground);
    font-size: var(--text-body-lg);
  }

  @media (min-width: 1024px) {
    .bi-hwide { padding-inline: 80px; }
    .bi-hgrid { grid-template-columns: 1fr 1fr; gap: var(--space-64); }
    .bi-layout { padding-inline: 80px; grid-template-columns: 240px minmax(0, var(--prose-max)); gap: var(--space-64); }
    .bi-toc {
      display: block;
      position: sticky;
      top: calc(var(--nav-h) + var(--space-24));
      align-self: start;
      padding: var(--space-24);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      background: var(--card);
    }
  }
</style>

<script>
  // Scroll-spy: highlight the TOC entry for the heading nearest the top.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc]'));
  const headings = Array.from(document.querySelectorAll<HTMLElement>('.bi-body h2[id], .bi-body h3[id]'));
  if (links.length && headings.length) {
    const byId = new Map(links.map((l) => [l.dataset.toc, l]));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          links.forEach((l) => l.classList.remove('is-active'));
          byId.get((e.target as HTMLElement).id)?.classList.add('is-active');
        });
      },
      { rootMargin: '-20% 0px -70% 0px' },
    );
    headings.forEach((h) => io.observe(h));
  }
</script>
