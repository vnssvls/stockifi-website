---
// Danish: Inventory Management category LP (/da/product-inventory-management).
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Opskriftsbygning', body: 'Beregn hvert recept ud fra aktuelle ingredienspriser.', href: '/da/product-inventory-management/recipe-building', icon: icons['book'], image: '/media/product-recipe-building.png' },
  { heading: 'Varetælling', body: 'Tæl varer på mobil eller web, med eller uden net.', href: '/da/product-inventory-management/stock-counting', icon: icons['box'], image: '/media/product-stock-counting.png' },
  { heading: 'Lageroverførsler', body: 'Spor varer, der flyttes mellem dine lokationer.', href: '/da/product-inventory-management/inventory-transfers', icon: icons['convert-3d-cube'], image: '/media/product-inventory-transfers.png' },
  { heading: 'Spildregistrering', body: 'Registrer spild og se, hvad det koster dig.', href: '/da/product-inventory-management/wastage-tracking', icon: icons['trash'], image: '/media/product-wastage-tracking.png' },
  { heading: 'Salg og forbrug', body: 'Se, hvad der blev solgt, og hvordan det bevægede sig gennem lageret.', href: '/da/product-inventory-management/sales-and-usage', icon: icons['sales-usage'], image: '/media/cta-bg-2.jpg' },
];
---

<Layout
  title="Software til restaurantlagerstyring | Stockifi"
  description="Stockifi samler lagertælling, afvigelsesovervågning, spildregistrering og lageroverførsler i ét system, så tallene på hvert sted er korrekte."
>
  <PageHeader
    eyebrow="Lagerstyring"
    heading="[Placeholder heading]"
    subhead="[Placeholder subhead]"
  />

  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <CtaEmail
    heading="[Placeholder CTA heading]"
    subhead="[Placeholder CTA subhead]"
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
