---

<Layout
  title="Priser — Software til vareforbrug i restauranter | Stockifi"
  description="Planer til alle typer drift, fra enkeltrestauranter til restaurantkæder med flere lokationer. Prisen ligger typisk mellem €150 og €400 pr. måned med en risikofri onboarding-garanti."
>
  <!-- Pricing hero: header + cards share one decorative gradient backdrop that
       bleeds behind both sections (not clipped to either). -->
  <div class="pricing-hero">
    <!-- 1. Page header -->
    <PageHeader
      eyebrow="Priser"
      heading="Vælg en plan der passer til din forretning"
      subhead="Alle planer inkluderer vores risikofri onboarding-garanti. Ingen bindingsperiode, opsig når som helst."
    />

    <!-- 1b. Pricing cards -->
    <PricingCards plans={plans} />
  </div>

  <!-- 2. Logo banner — scrolling marquee -->
  <LogoBanner label="Brugt af 500+ restauranter i hele Europa" logos={userLogos} />

  <!-- 2b. Savings calculator — reserved slot -->
  <SectionPlaceholder
    label="Besparelsesberegner"
    note="Interaktivt estimat over, hvad Stockifi kan spare din forretning. Kommer snart."
  />

  <!-- 3. Feature section — Feature variant 6 (columns) -->
  <FeatureColumns
    tagline="Hvorfor Stockifi"
    heading="Her tjener planerne sig selv hjem"
    columns={featureCols}
  />

  <!-- 4. FAQ — variant 1 (split) -->
  <FaqSplit
    heading="Spørgsmål om priser?"
    body="Det, restauratører spørger om, inden de vælger en plan. Er du stadig i tvivl? Skriv til os, så hjælper vi."
    contact={{ label: 'Kontakt os', href: '/da/contact' }}
    items={faqs}
  />

  <!-- 5. CTA — variant 2.1 (image-backed button) -->
  <CtaButton
    heading="Klar til at investere i din rentabilitet?"
    primary={{ label: 'Kom i gang', href: '/da/book-a-demo' }}
    secondary={{ label: 'Tal med en ekspert', href: '/da/contact' }}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Brand gradient glow (from the ads-LP) bleeds behind BOTH the page header and the
     pricing cards as one continuous backdrop — not clipped to either section. */
  .pricing-hero { position: relative; isolation: isolate; }
  .pricing-hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -6%;
    transform: translateX(-50%);
    width: min(1200px, 150%);
    aspect-ratio: 600 / 500;
    background-image: url('/media/gradient-centered.png');
    background-size: contain;
    background-position: center top;
    background-repeat: no-repeat;
    opacity: 0.4;
    z-index: -1;
    pointer-events: none;
  }
  /* Header + cards read as one block: collapse the stacked section paddings between
     them (they each carry full section padding otherwise → an awkward double gap). */
  .pricing-hero :global(.page-header) { padding-bottom: var(--space-32); }
  .pricing-hero :global(.pricing-cards) { padding-top: 0; }
</style>
