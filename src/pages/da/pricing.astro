const faqs = [
  {
    question: 'Hvilke planer tilbyder Stockifi?',
    answer: 'Stockifi har tre planer: Automated, Full Control og Custom. Højere niveauer tilføjer beregning af opskriftsomkostninger, rapporter over afvigelse og spild, kassesystemintegrationer og opsætning til flere lokationer.',
