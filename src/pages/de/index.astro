---

<Layout
  title="Wareneinsatz-Software für Restaurants | Stockifi"
  description="Verbessern Sie den Betrieb und die Gewinnmargen Ihres F&B-Betriebs mit Stockifis automatisierten Tools und intelligenten Integrationen für Restaurants, Bars und Hotels."
>
  <!-- 1. Hero -->
  <Hero
    wide
    tagline="Wareneinsatz-Software für Restaurants"
    heading="Kennen Sie Ihren tatsächlichen Wareneinsatz."
    subhead="Ihre Rechnungen, Umsatzdaten und Rezepte enthalten bereits die Antwort auf Ihre Wareneinsatzfrage. Stockifi führt sie zusammen und übernimmt die Berechnung, damit Sie Ihre Marge sehen und handeln können."
    primary={{ label: 'Demo buchen', href: '/de/book-a-demo' }}
    secondary={{ label: 'So funktioniert es', href: '#how-it-works' }}
    images={[
      { src: '/media/photos/hero-manager.png', alt: '' },
      { src: '/media/photos/hero-chef.png',    alt: '' },
      { src: '/media/photos/hero-owner.png',   alt: '' },
    ]}
  >
    <!-- Overlay 0: slide 1 (manager) — food cost card, to build -->
    <div slot="overlays" style="display:contents">
      <div class="hero-overlay">
        <FoodCostAnimation />
      </div>
      <!-- Overlay 1: slide 2 (chef) — supplier price ticker -->
      <div class="hero-overlay">
        <ProcurementAnimation compact />
      </div>
      <!-- Overlay 2: slide 3 (owner) — location health list -->
      <div class="hero-overlay">
        <ManagementAnimation />
      </div>
    </div>
  </Hero>

  <!-- 2. Social proof -->
  <LogoBanner label="Vertrauen von über 500 Restaurants in ganz Europa" logos={userLogos} />

  <!-- 3. What's inside — FeatureList (product categories) -->
  <div id="how-it-works" class="hp-anchor">
    <FeatureList tagline="Was enthalten ist" items={whatsInside} />
  </div>

  <!-- 4. Benefits — FeatureSplit -->
  <FeatureSplit
    tagline="Warum es sich lohnt"
    heading="Wareneinsatzkontrolle für Restaurants, die sich selbst bezahlt macht"
    body="Der größte Teil Ihrer Marge entweicht in den Lücken zwischen den Systemen. Stockifi fasst sie in einer Ansicht zusammen, sodass bereits eine Verbesserung der Wareneinsatzquote um 1 % zu echten Einsparungen führt."
    items={benefits}
    imageSide="right"
  >
    <SavingsAnimation slot="media" />
  </FeatureSplit>

  <!-- 5. By Teams — FeatureTabs -->
  <FeatureTabs
    tagline="Für Ihr Team"
    heading="Eine Datenbasis für jeden Bereich"
    subhead="Von der Geschäftsführung bis zur Küche arbeiten alle mit denselben Zahlen."
    tabs={byTeams}
  />

  <!-- 6. Customer stories — bento -->
  <CustomerStoryBento
    eyebrow="Kundenstimmen"
    heading="Was Betreiber wie Sie sagen"
    cta={{ label: 'Alle Geschichten lesen', href: '/de/customer-stories' }}
    slugs={['byoslo', 'eik-and-friends', 'koie-ramen', 'skigeilo-2']}
  />

  <!-- 7. Onboarding — FeatureSteps -->
  <FeatureSteps
    tagline="Persönliches Onboarding"
    heading="In 48 Stunden startklar"
    cta={{ label: 'Demo buchen', href: '/de/book-a-demo' }}
    steps={onboarding}
  />

  <!-- 8. Integrations — pill cloud (variant 2), wide -->
  <IntegrationPills
    wide
    eyebrow="Integrationen"
    heading="Funktioniert mit den Tools, die Sie bereits nutzen"
    subhead="Eliminieren Sie manuelle Arbeit und lassen Sie Stockifi Ihre Kassen- und Buchhaltungsdaten zusammenführen."
    cta={{ label: 'Alle Integrationen ansehen', href: '/de/integrations' }}
    items={integrations}
  />

  <!-- 9. Risk / pricing band — CtaBand -->
  <CtaBand
    heading="Entwickelt, um Ihnen Zeit und Geld zu sparen"
    subhead="Was kostet es für Ihren Betrieb? Der Preis hängt von Ihrer Größe und Ihrem Setup ab. Und wenn Stockifi in den ersten 30 Tagen keine versteckten Verluste von mindestens 3.000 € aufdeckt, zahlen Sie nichts."
    primary={{ label: 'Pläne ansehen', href: '/de/pricing' }}
    secondary={{ label: 'Mit einem Experten sprechen', href: '/de/book-a-demo' }}
  />

  <!-- 10. FAQ — variant 1 (split) -->
  <FaqSplit
    eyebrow="FAQs"
    heading="Fragen, die Sie haben könnten"
    body="Die Punkte, die Betreiber vor einer Demo klären. Noch unsicher? Schreiben Sie uns, wir helfen gerne weiter."
    contact={{ label: 'Kontakt aufnehmen', href: '/de/contact' }}
    items={faqs}
  />

  <!-- 11. Final CTA — variant 2.1 (button-only, photo-backed) -->
  <CtaButton
