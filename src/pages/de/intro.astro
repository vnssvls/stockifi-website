---
import LayoutLP from '../../layouts/LayoutLP.astro';
import PriceIndexTable from '../../components/PriceIndexTable.astro';
import LogoBanner from '../../components/LogoBanner.astro';
import CustomerStoryBento from '../../components/CustomerStoryBento.astro';
import FeatureSteps from '../../components/features/FeatureSteps.astro';
import BenefitGrid from '../../components/BenefitGrid.astro';

import priceIndex from '../../data/price-index.json';
import userLogos from '../../data/user-logos.json';

const PORTAL_ID  = '48915892';
const FORM_GUID  = 'fbcec545-2f2a-418e-a661-20c138914435';

const howItWorksItems = [
  {
    heading: "Rezeptverwaltung",
    body: "Sieh, welche Gerichte diese Woche Marge verloren haben",
    icon: '<lottie-player src="/animations/Recipe-2.1.json" background="transparent" speed="1" style="width:120px;height:120px;" loop autoplay></lottie-player>',
  },
  {
    heading: "Kassenintegration",
    body: "Vergleiche wöchentlich tatsächliche und theoretische Kosten",
    icon: '<lottie-player src="/animations/Sales-v2.json" background="transparent" speed="1" style="width:120px;height:120px;" loop autoplay></lottie-player>',
  },
  {
    heading: "Rechnungsverarbeitung",
    body: "Erkenne versteckte Preiserhöhungen auf jeder Lieferantenrechnung",
    icon: '<lottie-player src="/animations/Purchases-2.json" background="transparent" speed="1" style="width:120px;height:120px;" loop autoplay></lottie-player>',
  },
  {
    heading: "Inventur",
    body: "Bringe die Inventur auf unter 1 Stunde",
    icon: '<lottie-player src="/animations/Stock-Count.json" background="transparent" speed="1" style="width:120px;height:120px;" loop autoplay></lottie-player>',
  },
];

