  {
    heading: "Margen im Blick behalten",
    body: "Live-Kostenübersicht für jeden Standort erhalten",
    icon: '<path fill="currentColor" d="M248,152a8,8,0,0,1-8,8H224v16a8,8,0,0,1-16,0V160H192a8,8,0,0,1,0-16h16V128a8,8,0,0,1,16,0v16h16A8,8,0,0,1,248,152ZM56,72H72V88a8,8,0,0,0,16,0V72h16a8,8,0,0,0,0-16H88V40a8,8,0,0,0-16,0V56H56a8,8,0,0,0,0,16ZM184,192h-8v-8a8,8,0,0,0-16,0v8h-8a8,8,0,0,0,0,16h8v8a8,8,0,0,0,16,0v-8h8a8,8,0,0,0,0-16ZM219.31,80,80,219.31a16,16,0,0,1-22.62,0L36.68,198.63a16,16,0,0,1,0-22.63L176,36.69a16,16,0,0,1,22.63,0l20.68,20.68A16,16,0,0,1,219.31,80ZM208,68.69,187.31,48l-32,32L176,100.69Z"/>',
    iconViewBox: '0 0 256 256',
  },
];
---

<LayoutLP
  title="So funktioniert Stockifi — Kostenkontrolle für Restaurants"
  description="Sieh, welche Lieferantenpreise still deine Margen auffressen. Buche eine Demo und erhalte einen personalisierten Überblick über deine Lebensmittelkosten."
>
  <section class="intro-hero">
    <div class="container ih-grid">
      <div class="ih-copy">
        <p class="ih-eyebrow">Stockifi Supplier Price Index · {priceIndex.month}</p>
        <h1>Die {priceIndex.items.length} verstecktesten Preisanstiege dieses Monats</h1>
        <p class="ih-subhead text-muted">
          Direkt aus 800+ Lieferantenrechnungen. Monatlich aktualisiert.
        </p>

        <form class="ih-form" id="intro-form" novalidate>
          <div class="ih-field-wrap">
            <input
              type="email"
              id="intro-email"
              name="email"
              placeholder="deine@email.de"
              autocomplete="email"
              required
              class="ih-input"
            />
            <button type="submit" class="ih-btn" id="intro-btn">
              <span id="intro-btn-label">Meinen Bericht holen &rarr;</span>
              <span id="intro-btn-spinner" hidden aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              </span>
            </button>
          </div>
          <p class="ih-error" id="intro-error" hidden>Bitte gib eine gültige E-Mail-Adresse ein.</p>
          <p class="ih-already">
            Erkennst du einen Lieferanten? <a href="https://calendly.com/simon-stockifi/profit-potential">Demo buchen</a>
          </p>
        </form>
      </div>

      <div class="ih-table">
        <PriceIndexTable month={priceIndex.month} items={priceIndex.items} />
      </div>
    </div>
  </section>

  <LogoBanner label="Vertrauen von 500+ Restaurants in Europa" logos={userLogos} />

  <section class="section">
    <div class="container">
      <div class="hiw-head">
        <p class="tagline">So funktioniert es</p>
        <h2>Lass Stockifi die Arbeit für dich erledigen</h2>
      </div>
      <BenefitGrid items={howItWorksItems} columns={4} />
    </div>
  </section>

  <CustomerStoryBento
    eyebrow="Kundenberichte"
    heading="Erfahre es von Betrieben wie deinem"
    cta={{ label: "Alle Berichte ansehen", href: "/de/customer-stories" }}
    slugs={["eik-and-friends", "skigeilo-2", "torika-gruppen", "koie-ramen"]}
  />

  <FeatureSteps
    tagline="Persönliches Onboarding"
    heading="In 48 Stunden startklar"
    subhead="Du musst nicht alles selbst herausfinden. Wir machen die schwere Arbeit und sorgen dafür, dass du von Anfang an erfolgreich bist."
    cta={{ label: "So funktioniert es →", href: "#intro-form" }}
    steps={setupSteps}
  />

  <section class="section simon-cta">
    <div class="container sc-inner">
      <img
        src="/media/team/headshot-simon.png"
        alt="Simon Burman, Mitgründer und COO bei Stockifi"
        class="sc-avatar"
        width="120"
        height="120"
        loading="lazy"
      />
      <h2 class="sc-heading">Noch am Überlegen?</h2>
      <p class="sc-subhead text-muted">Lass uns kurz sprechen und schauen, ob es zu deinem Betrieb passt</p>
      <p class="sc-name">Simon Burman <span class="sc-dot" aria-hidden="true">·</span> Mitgründer &amp; COO</p>
      <a href="https://calendly.com/simon-stockifi/profit-potential" class="sc-btn">
        Jetzt mit Simon sprechen &rarr;
      </a>
    </div>
  </section>
</LayoutLP>

<style>
  .ih-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-32); align-items: center; padding-top: var(--space-64); padding-bottom: var(--space-48); }
  @media (min-width: 1024px) { .ih-grid { grid-template-columns: 1fr 1fr; gap: 60px; } }
  .ih-eyebrow { font-size: var(--text-body-sm); font-weight: var(--fw-medium); letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground); }
  .ih-copy { display: flex; flex-direction: column; gap: var(--space-24); }
  .ih-copy h1 { font-size: var(--text-h2); line-height: var(--lh-h2); max-width: 18ch; }
  .ih-subhead { font-size: var(--text-body-lg); line-height: 1.7; max-width: 52ch; }
  .ih-form { display: flex; flex-direction: column; gap: var(--space-12); max-width: 480px; }
  .ih-field-wrap { display: flex; gap: var(--space-8); }
  .ih-input { flex: 1; height: 48px; padding: 0 var(--space-16); background: var(--input); border: 1px solid var(--border); border-radius: 8px; color: var(--foreground); font-size: var(--text-body); outline: none; transition: border-color 0.15s; }
  .ih-input:focus { border-color: var(--primary); }
  .ih-input::placeholder { color: var(--muted-foreground); }
  .ih-btn { display: inline-flex; align-items: center; justify-content: center; gap: var(--space-8); height: 48px; padding: 0 var(--space-24); background: var(--primary); color: var(--primary-foreground); border: none; border-radius: 8px; font-size: var(--text-body); font-weight: var(--fw-semibold); cursor: pointer; white-space: nowrap; transition: background 0.15s; }
  .ih-btn:hover { background: var(--primary-dark); }
  .ih-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .ih-error { font-size: var(--text-body-sm); color: var(--destructive); }
  .ih-already { font-size: var(--text-body-sm); color: var(--muted-foreground); }
  .ih-already a { color: var(--primary-light); font-weight: var(--fw-medium); }
  .ih-table { display: flex; justify-content: center; }
  @media (max-width: 640px) { .ih-field-wrap { flex-direction: column; } .ih-btn { width: 100%; } }
  .hiw-head { text-align: center; margin-bottom: var(--space-64); }
  .hiw-head h2 { font-size: var(--text-h3); margin-top: var(--space-8); }
  .simon-cta { background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .sc-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-16); }
  .sc-avatar { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin-bottom: var(--space-8); }
  .sc-heading { font-size: var(--text-h2); line-height: var(--lh-h2); }
  .sc-subhead { font-size: var(--text-body-lg); max-width: 40ch; }
  .sc-name { font-size: var(--text-body-sm); font-weight: var(--fw-semibold); letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground); margin-top: var(--space-4); }
  .sc-dot { margin-inline: 0.4em; opacity: 0.5; }
  .sc-btn { display: inline-flex; align-items: center; gap: var(--space-8); height: 52px; padding: 0 var(--space-32); background: var(--primary); color: var(--primary-foreground); border-radius: 999px; font-size: var(--text-body); font-weight: var(--fw-semibold); text-decoration: none; margin-top: var(--space-8); transition: background 0.15s; }
  .sc-btn:hover { background: var(--primary-dark); }
</style>

<script define:vars={{ PORTAL_ID, FORM_GUID }}>
  const form = document.getElementById('intro-form');
  const emailInput = document.getElementById('intro-email');
  const btnLabel = document.getElementById('intro-btn-label');
  const btnSpinner = document.getElementById('intro-btn-spinner');
  const errorEl = document.getElementById('intro-error');
  const btn = document.getElementById('intro-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true;
    const email = emailInput.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.hidden = false;
      emailInput.focus();
      return;
    }
    btn.disabled = true;
    btnLabel.hidden = true;
    btnSpinner.hidden = false;
    try {
      if (FORM_GUID) {
        await fetch(
          `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_GUID}`,
          { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ fields: [{ name: 'email', value: email }], context: { pageUri: window.location.href, pageName: document.title } }) }
        );
      }
    } catch (_) {}
    window.location.href = `/intro/confirm?email=${encodeURIComponent(email)}`;
  });
</script>
