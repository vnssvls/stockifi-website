  },
  {
    heading: "Einrichtung erledigt",
    body: "Rezepte, Rechnungen und Inventar von Stockifi importiert",
    icon: '<path d="M21 20.25H11C10.59 20.25 10.25 19.91 10.25 19.5C10.25 19.09 10.59 18.75 11 18.75H21C21.41 18.75 21.75 19.09 21.75 19.5C21.75 19.91 21.41 20.25 21 20.25Z" fill="currentColor"/><path d="M21 13.25H11C10.59 13.25 10.25 12.91 10.25 12.5C10.25 12.09 10.59 11.75 11 11.75H21C21.41 11.75 21.75 12.09 21.75 12.5C21.75 12.91 21.41 13.25 21 13.25Z" fill="currentColor"/><path d="M21 6.25H11C10.59 6.25 10.25 5.91 10.25 5.5C10.25 5.09 10.59 4.75 11 4.75H21C21.41 4.75 21.75 5.09 21.75 5.5C21.75 5.91 21.41 6.25 21 6.25Z" fill="currentColor"/><path d="M4.00043 7.24994C3.81043 7.24994 3.62043 7.17994 3.47043 7.02994L2.47043 6.02994C2.18043 5.73994 2.18043 5.25994 2.47043 4.96994C2.76043 4.67994 3.24043 4.67994 3.53043 4.96994L4.00043 5.43994L6.47043 2.96994C6.76043 2.67994 7.24043 2.67994 7.53043 2.96994C7.82043 3.25994 7.82043 3.73994 7.53043 4.02994L4.53043 7.02994C4.38043 7.17994 4.19043 7.24994 4.00043 7.24994Z" fill="currentColor"/><path d="M4.00043 14.2499C3.81043 14.2499 3.62043 14.1799 3.47043 14.0299L2.47043 13.0299C2.18043 12.7399 2.18043 12.2599 2.47043 11.9699C2.76043 11.6799 3.24043 11.6799 3.53043 11.9699L4.00043 12.4399L6.47043 9.96994C6.76043 9.67994 7.24043 9.67994 7.53043 9.96994C7.82043 10.2599 7.82043 10.7399 7.53043 11.0299L4.53043 14.0299C4.38043 14.1799 4.19043 14.2499 4.00043 14.2499Z" fill="currentColor"/><path d="M4.00043 21.2499C3.81043 21.2499 3.62043 21.1799 3.47043 21.0299L2.47043 20.0299C2.18043 19.7399 2.18043 19.2599 2.47043 18.9699C2.76043 18.6799 3.24043 18.6799 3.53043 18.9699L4.00043 19.4399L6.47043 16.9699C6.76043 16.6799 7.24043 16.6799 7.53043 16.9699C7.82043 17.2599 7.82043 17.7399 7.53043 18.0299L4.53043 21.0299C4.38043 21.1799 4.19043 21.2499 4.00043 21.2499Z" fill="currentColor"/>',
