---
// Inventory Management category LP (/de/product-inventory-management).
// Section map: PageHeader → product card grid (4 items, 4-col) → CtaEmail → Footer v2
// When Data Quality page ships, add 5th item and columns will auto-switch to 3-col.
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Rezeptaufbau', body: 'Kalkulieren Sie jedes Rezept auf Basis aktueller Zutatenpreise.', href: '/de/product-inventory-management/recipe-building', icon: icons['book'], image: '/media/product-recipe-building.png' },
  { heading: 'Inventur', body: 'Erfassen Sie Ihren Lagerbestand per App oder Browser, online oder offline.', href: '/de/product-inventory-management/stock-counting', icon: icons['box'], image: '/media/photos/stock-counting-tablet.png' },
  { heading: 'Lagertransfers', body: 'Verfolgen Sie Warenbewegungen zwischen Ihren Standorten.', href: '/de/product-inventory-management/inventory-transfers', icon: icons['convert-3d-cube'], image: '/media/product-inventory-transfers.png' },
  { heading: 'Schwunderfassung', body: 'Dokumentieren Sie Schwund und sehen Sie, was er Sie kostet.', href: '/de/product-inventory-management/wastage-tracking', icon: icons['trash'], image: '/media/product-wastage-tracking.png' },
  { heading: 'Umsatz und Verbrauch', body: 'Sehen Sie, was verkauft wurde und wie es den Lagerbestand beeinflusst hat.', href: '/de/product-inventory-management/sales-and-usage', icon: icons['sales-usage'], image: '/media/cta-bg-2.jpg' },
];
---

<Layout
  title="Restaurant-Inventarverwaltungssoftware | Stockifi"
  description="Stockifi vereint Inventuren, Abweichungsverfolgung, Schwunderfassung und Lagerumbuchungen in einem System, damit die Zahlen jedes Standorts stimmen."
>
  <!-- 1. Page header — centered -->
  <PageHeader
    eyebrow="Lagerverwaltung"
    heading="Ein Lagerbestand, dem Sie wirklich vertrauen können"
    subhead="Rezepte, Inventuren, Umbuchungen zwischen Standorten und der Schwund dazwischen speisen alle ein System. Wenn die Inventur stimmt, hält alles, was darauf aufbaut."
  />

  <!-- 2. Product card grid -->
  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <!-- 3. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="Möchten Sie Ihr echtes Bestandsbild sehen?"
    subhead="Buchen Sie einen kurzen Anruf und wir zeigen Ihnen, was Stockifi in Ihren ersten 30 Tagen aufdeckt."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
