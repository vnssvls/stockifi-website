---
// DE: Inventory Management category — individual product pages (/de/product-inventory-management/[slug]).
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import PageHeaderImage from '../../../components/page-headers/PageHeaderImage.astro';
import FeatureSteps from '../../../components/features/FeatureSteps.astro';
import FeatureShowcase from '../../../components/features/FeatureShowcase.astro';
import ProductHowItWorks from '../../../components/features/ProductHowItWorks.astro';
import IntegrationGrid from '../../../components/integrations/IntegrationGrid.astro';
import ImageCardGrid from '../../../components/ImageCardGrid.astro';
import FaqSplit from '../../../components/faq/FaqSplit.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import integrations from '../../../data/integrations-home.json';
import navIcons from '../../../data/nav-icons.json';
import { productHowItWorksIcons } from '../../../data/product-howitworks-icons';
import { getCategoryCards } from '../../../data/product-category-cards';

export async function getStaticPaths() {
  return (await getCollection('productsDe'))
    .filter((p) => !p.data.draft && p.data.category === 'inventory-management')
    .map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const d = p.data;
const icons = navIcons as Record<string, string>;
const howItWorksItems = d.howItWorks ? d.howItWorks.points.map((pt, i) => ({ ...pt, icon: icons[(productHowItWorksIcons[p.id] ?? [])[i]] })) : [];
const benefitCards = getCategoryCards('inventory-management', Astro.currentLocale ?? 'en').map((c) => ({
  heading: c.heading,
  body: c.body,
  icon: icons[c.iconKey],
  image: c.image,
}));
---

<Layout title={d.metaTitle} description={d.metaDescription}>
  <PageHeaderImage
    eyebrow={d.eyebrow}
    heading={d.heading}
    subhead={d.subhead}
    cta={{ label: 'Demo buchen', href: '/de/book-a-demo' }}
    ctaVariant="secondary"
    image={d.heroImage}
  />

  {d.howItWorks ? (
      <ProductHowItWorks p={p} />
  ) : d.steps.length > 0 ? (
    <FeatureSteps
      tagline={d.stepsTagline}
      heading={d.stepsHeading ?? d.heading}
      cta={{ label: 'So funktioniert es', href: '/de/#how-it-works' }}
      steps={d.steps}
    />
  ) : null}

  {d.showIntegrations && (
    <IntegrationGrid
      heading={d.integrationsHeading}
      defaultSubject={d.integrationsSubject}
      cta={{ label: 'Alle Integrationen ansehen', href: '/de/integrations' }}
      items={integrations}
    />
  )}

  {d.benefits.length > 0 && (
    <section class="section">
      <div class="container-page">
        <ImageCardGrid items={benefitCards} columns={4} />
      </div>
    </section>
  )}

  {d.faqs.length > 0 && (
    <FaqSplit
      heading={d.faqHeading}
      body="Was Betreiber vor einer Demo fragen. Noch unsicher? Schreiben Sie uns."
      contact={{ label: 'Kontakt', href: '/de/contact' }}
      items={d.faqs}
    />
  )}

  <CtaEmail
    heading={d.ctaHeading}
    subhead={d.ctaSubhead}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
