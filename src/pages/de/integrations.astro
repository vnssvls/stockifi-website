---
// Integrations page (Figma 67:2342 header + 67:3442 filters + 67:3455 content).
// Page header (heading + subhead) → directory (search/sort/filter +
// card grid) → CTA variant 2 (image-background email capture). Nav + Footer come
// from the layout. DRAFT copy.
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import IntegrationsDirectory from '../../components/integrations/IntegrationsDirectory.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import data from '../../../content/integrations/integrations.en.json';

const live = data.filter((x) => !x.draft);

const CATEGORIES = [
  { value: 'accounting', label: 'Buchhaltung' },
  { value: 'pos', label: 'Kassensystem' },
  { value: 'other', label: 'Sonstiges' },
];

const items = [...live]
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((x) => ({ name: x.name, category: x.category, logo: x.logo }));

---

<Layout
  title="70+ POS- und Buchhaltungsintegrationen | Stockifi"
  description="Stockifi integriert mit 70+ Tools, um Umsätze und Rechnungen mit Ihren Inventuren zu synchronisieren und Ihnen wertvolle Empfehlungen zur Erreichung Ihrer F&B-Ziele zu geben."
>
  <PageHeader
    eyebrow="Integrationen"
    heading="Stockifi arbeitet mit den Systemen, die Sie bereits nutzen"
    subhead="Verbinden Sie Ihre Buchhaltungs- und Kassensysteme, damit Rechnungen, Umsätze und Rezeptkosten synchron bleiben — ohne manuelle Exporte, ohne doppelte Dateneingabe."
  />

  <IntegrationsDirectory items={items} categories={CATEGORIES} />

  <CtaEmail
    heading="Sehen Sie es mit Ihrem System verbunden"
    subhead="Hinterlassen Sie Ihre E-Mail-Adresse und wir zeigen Ihnen, was Stockifi in Ihren ersten 30 Tagen aufdeckt."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

