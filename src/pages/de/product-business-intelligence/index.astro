---
// Business Intelligence category LP (/de/product-business-intelligence).
// Section map: PageHeader → product card grid (4 items, 4-col) → CtaEmail → Footer v2
// When Sales & Usage page ships, add 5th item and columns will auto-switch to 3-col.
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Performance-Dashboards', body: 'Wareneinsatz und Marge für alle Standorte im Überblick.', href: '/de/product-business-intelligence/performance-dashboards', icon: icons['element-4'], image: '/media/solution-management.jpg' },
  { heading: 'Abweichungsanalyse', body: 'Soll-Verbrauch aus Rezepten gegenüber dem tatsächlichen Verkauf.', href: '/de/product-business-intelligence/variance-analysis', icon: icons['presention-chart'], image: '/media/solution-operations.jpg' },
  { heading: 'Rentabilitätsanalyse', body: 'Die aktuelle Marge jedes Menüartikels auf einen Blick.', href: '/de/product-business-intelligence/profitability', icon: icons['trend-up'], image: '/media/solution-finance.jpg' },
  { heading: 'API', body: 'Übertragen Sie Ihre Daten dorthin, wo Sie sie benötigen.', href: '/de/product-business-intelligence/api', icon: icons['code'], image: '/media/solution-restaurant-groups.jpg' },
  { heading: 'Datenqualität', body: 'Hält Ihre Daten kontinuierlich auf höchster Qualität.', href: '/de/product-business-intelligence/data-quality', icon: icons['data-quality'], image: '/media/solution-hotels.jpg' },
];
---

<Layout
  title="Analyse & Business Intelligence für Restaurants | Stockifi"
  description="Dashboards auf Basis Ihrer tatsächlichen Rechnungs- und Kassendaten. Sehen Sie Wareneinsatz, Marge und Abweichungen nach Gericht, Standort und Zeitraum und treffen Sie Entscheidungen auf Basis genauer Zahlen."
>
  <!-- 1. Page header — centered -->
  <PageHeader
    eyebrow="Business Intelligence"
    heading="[Placeholder heading]"
    subhead="[Placeholder subhead]"
  />

  <!-- 2. Product card grid -->
  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <!-- 3. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="[Placeholder CTA heading]"
    subhead="[Placeholder CTA subhead]"
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
