---
// Style guide index. Foundations (tokens, atoms) live here; multi-variant page
// sections each get their own page with a variant switcher (see /styleguide/features).
// Site is dark-only; the toggle is a preview affordance for both token sets.
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import LocaleSwitcher from '../components/LocaleSwitcher.astro';
import Hero from '../components/Hero.astro';
import SgThemeToggle from '../components/SgThemeToggle.astro';

const sections = [
  { label: 'Features', meta: '5 variants', href: '/styleguide/features' },
  { label: 'FAQ', meta: 'soon', href: null },
  { label: 'CTA', meta: 'soon', href: null },
  { label: 'Pricing', meta: 'soon', href: null },
];

const swatches = [
  'background', 'foreground', 'card', 'popover', 'primary', 'primary-foreground',
  'secondary', 'secondary-foreground', 'muted', 'muted-foreground', 'accent',
  'border', 'ring', 'destructive', 'success', 'warning',
];
const typeRoles = [
  { tag: 'h1', label: 'Heading 1' },
  { tag: 'h2', label: 'Heading 2' },
  { tag: 'h3', label: 'Heading 3' },
  { tag: 'h4', label: 'Heading 4' },
  { tag: 'h5', label: 'Heading 5' },
  { tag: 'h6', label: 'Heading 6' },
];
---

<Layout title="Style guide — Stockifi">
  <div class="sg">
    <div class="container">
      <header class="sg-head">
        <p class="tagline">Design system</p>
        <h1>Style guide</h1>
        <p class="text-muted">Foundations and atoms below. Multi-variant page sections open on their own pages.</p>
      </header>

      <!-- Sections directory -->
      <section class="sg-block" aria-labelledby="sg-sections">
        <h2 id="sg-sections">Sections</h2>
        <p class="text-muted sg-note">Page-level sections with multiple layouts. Each opens its own page with a variant switcher.</p>
        <div class="sg-cards">
          {sections.map((s) => (
            s.href
              ? <a class="sg-card" href={s.href}><span class="sg-card-title">{s.label}</span><span class="sg-card-meta">{s.meta}</span></a>
              : <span class="sg-card is-soon"><span class="sg-card-title">{s.label}</span><span class="sg-card-meta">{s.meta}</span></span>
          ))}
        </div>
      </section>
    </div>

    <!-- Hero (full width) -->
    <div class="container">
      <div class="sg-block-head" id="sg-hero">
        <h2>Hero</h2>
        <p class="text-muted sg-note">Split layout, stacks below 1024px. Full width, matches the home page. Visual is a placeholder until the real asset lands.</p>
      </div>
    </div>
    <Hero
      tagline="For European hospitality operators"
      heading="See exactly where your food cost is leaking."
      subhead="Stockifi connects your invoices, POS, and recipes so you track actual food cost instead of guessing at it."
      primary={{ label: 'Book a demo', href: '#' }}
      secondary={{ label: 'See how it works', href: '#' }}
    />

    <div class="container">
      <!-- Buttons -->
      <section class="sg-block" aria-labelledby="sg-buttons">
        <h2 id="sg-buttons">Buttons</h2>
        <p class="text-muted sg-note">Hover to see states. Primary flips to foreground/background; secondary keeps white text and tints its border to primary.</p>
        <div class="sg-row">
          <Button variant="primary" href="/contact">Get Started</Button>
          <Button variant="secondary" href="#">Login</Button>
          <Button variant="primary">Submit</Button>
          <Button variant="secondary">Cancel</Button>
        </div>
        <div class="sg-row sg-row-narrow">
          <Button variant="primary" block>Full-width primary</Button>
          <Button variant="secondary" block>Full-width secondary</Button>
        </div>
      </section>

      <!-- Locale switcher -->
      <section class="sg-block" aria-labelledby="sg-locale">
        <h2 id="sg-locale">Locale switcher</h2>
        <p class="text-muted sg-note">Click to open. 6 locked locales, vendored circle-flags (English = UK flag). Also lives in the nav between the last link and the buttons.</p>
        <div class="sg-row"><LocaleSwitcher current="en" /></div>
      </section>

      <!-- Nav + Footer -->
      <section class="sg-block" aria-labelledby="sg-shell">
        <h2 id="sg-shell">Global shell</h2>
        <p class="text-muted sg-note">Nav (sticky, with mega menus + drawer below 1024px) and Footer are live on this page, top and bottom. Resize to test the mobile drawer.</p>
      </section>

      <!-- Form inputs -->
      <section class="sg-block" aria-labelledby="sg-inputs">
        <h2 id="sg-inputs">Inputs</h2>
        <p class="text-muted sg-note">Tab in to see the focus ring.</p>
        <div class="sg-fields">
          <label>Text<input type="text" placeholder="restaurant@example.com" /></label>
          <label>Select
            <select><option>Independent restaurant</option><option>Restaurant group</option><option>Hotel with F&amp;B</option></select>
          </label>
          <label>Message<textarea rows="3" placeholder="Tell us about your setup"></textarea></label>
        </div>
      </section>

      <!-- Typography -->
      <section class="sg-block" aria-labelledby="sg-type">
        <h2 id="sg-type">Typography</h2>
        {typeRoles.map((t) => {
          const Tag = t.tag as any;
          return <div class="sg-type-row"><span class="sg-type-label text-muted">{t.label}</span><Tag>The quick brown fox</Tag></div>;
        })}
        <div class="sg-type-row"><span class="sg-type-label text-muted">Body</span><p>Stockifi connects what was bought, sold, and should have been used so operators can see where margin goes.</p></div>
        <div class="sg-type-row"><span class="sg-type-label text-muted">Tagline</span><p class="tagline">Built for hospitality</p></div>
      </section>

      <!-- Colors -->
      <section class="sg-block" aria-labelledby="sg-colors">
        <h2 id="sg-colors">Color tokens</h2>
        <div class="sg-swatches">
          {swatches.map((name) => (
            <div class="sg-swatch">
              <span class="sg-chip" style={`background: var(--${name})`}></span>
              <code>--{name}</code>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>

  <SgThemeToggle />
</Layout>

<style>
  .sg-head { padding-top: var(--section-y); padding-bottom: var(--space-32); }
  .sg-block-head { padding-top: var(--space-32); padding-bottom: var(--space-16); }
  .sg-block { padding-block: var(--space-48); border-top: 1px solid var(--border); }
  .sg-block > h2 { margin-bottom: var(--space-8); }
  .sg-note { margin-bottom: var(--space-24); max-width: 60ch; }

  .sg-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--space-16); }
  .sg-card {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-12);
    padding: var(--space-16) var(--space-24);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  a.sg-card:hover { border-color: var(--primary); text-decoration: none; }
  .sg-card-title { font-family: var(--font-heading); font-weight: var(--fw-semibold); color: var(--foreground); }
  .sg-card-meta { font-size: var(--text-caption); color: var(--muted-foreground); }
  .sg-card.is-soon { opacity: 0.55; }

  .sg-row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-16); }
  .sg-row-narrow { flex-direction: column; align-items: stretch; max-width: 320px; margin-top: var(--space-24); }

  .sg-fields { display: grid; gap: var(--space-24); max-width: 420px; }
  .sg-fields label { display: flex; flex-direction: column; gap: var(--space-8); font-size: var(--text-body-sm); color: var(--muted-foreground); }
  .sg-fields input,
  .sg-fields select,
  .sg-fields textarea {
    padding: var(--space-12) var(--space-16);
    background: var(--card);
    color: var(--foreground);
    border: 1px solid var(--input);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-body);
  }

  .sg-type-row { display: grid; grid-template-columns: 120px 1fr; gap: var(--space-24); align-items: baseline; padding-block: var(--space-12); }
  .sg-type-label { font-size: var(--text-caption); }

  .sg-swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--space-16); }
  .sg-swatch { display: flex; align-items: center; gap: var(--space-12); }
  .sg-chip { width: 40px; height: 40px; flex: none; border-radius: var(--radius-md); border: 1px solid var(--border); }
  .sg-swatch code { font-size: var(--text-caption); color: var(--muted-foreground); }
</style>
