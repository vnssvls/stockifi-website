---
// Business Intelligence category LP (/product-business-intelligence).
// Section map: PageHeader → product card grid (4 items, 4-col) → CtaEmail → Footer v2
// When Sales & Usage page ships, add 5th item and columns will auto-switch to 3-col.
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../components/ProductCardGrid.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import navIcons from '../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Performance dashboards', body: 'Food cost and margin across every location.', href: '/product-business-intelligence/performance-dashboards', icon: icons['element-4'], image: '/media/bi-performance-dashboards.jpg' },
  { heading: 'Variance analysis', body: 'Theoretical usage against what actually sold.', href: '/product-business-intelligence/variance-analysis', icon: icons['presention-chart'], image: '/media/bi-variance-analysis.jpg' },
  { heading: 'Profitability insights', body: 'See the live margin of every menu item.', href: '/product-business-intelligence/profitability', icon: icons['trend-up'], image: '/media/bi-profitability-insights.jpg' },
  { heading: 'API', body: 'Push your data wherever you need it.', href: '/product-business-intelligence/api', icon: icons['code'], image: '/media/bi-api.jpg' },
  { heading: 'Data quality', body: 'Continuously keeping your data at the highest quality.', href: '/product-business-intelligence/data-quality', icon: icons['data-quality'], image: '/media/bi-data-quality.jpg' },
];
---

<Layout
  title="Restaurant Analytics & Business Intelligence | Stockifi"
  description="Dashboards built on your actual invoice and POS data. See COGS, margin, and variance by dish, location, and period, and make decisions on accurate numbers."
>
  <!-- 1. Page header — centered -->
  <PageHeader
    eyebrow="Business Intelligence"
    heading="Make decisions backed by real data"
    subhead="Every dashboard is built on your real invoice and POS data, not estimates. See COGS, margin, and variance by dish, location, and period, then act on what they tell you."
  />

  <!-- 2. Product card grid -->
  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <!-- 3. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="Ready to act on numbers you can trust?"
    subhead="Book a short call and we'll show you what Stockifi surfaces in your first 30 days."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
