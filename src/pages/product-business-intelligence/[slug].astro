---
// Business Intelligence category — individual product pages.
// Routes: /product-business-intelligence/performance-dashboards, /variance-analysis,
//         /profitability, /api
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeaderImage from '../../components/page-headers/PageHeaderImage.astro';
import FeatureSteps from '../../components/features/FeatureSteps.astro';
import FeatureShowcase from '../../components/features/FeatureShowcase.astro';
import IntegrationGrid from '../../components/integrations/IntegrationGrid.astro';
import ImageCardGrid from '../../components/ImageCardGrid.astro';
import FaqSplit from '../../components/faq/FaqSplit.astro';
import CtaBand from '../../components/CtaBand.astro';
import integrations from '../../data/integrations-home.json';
import navIcons from '../../data/nav-icons.json';
import { productHowItWorksIcons } from '../../data/product-howitworks-icons';
import { businessIntelligenceCards } from '../../data/product-category-cards';

export async function getStaticPaths() {
  return (await getCollection('products'))
    .filter((p) => !p.data.draft && p.data.category === 'business-intelligence')
    .map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const d = p.data;
const icons = navIcons as Record<string, string>;
const howItWorksItems = d.howItWorks ? d.howItWorks.points.map((pt, i) => ({ ...pt, icon: icons[(productHowItWorksIcons[p.id] ?? [])[i]] })) : [];
const benefitCards = businessIntelligenceCards.map((c, i) => ({
  heading: c.heading,
  body: c.body,
  icon: icons[c.iconKey],
  image: c.image,
}));
---

<Layout title={d.metaTitle} description={d.metaDescription}>
  <PageHeaderImage
    eyebrow={d.eyebrow}
    heading={d.heading}
    subhead={d.subhead}
    cta={{ label: 'Book a demo', href: '/book-a-demo' }}
    ctaVariant="secondary"
    image={d.heroImage}
  />

  {d.howItWorks ? (
    <FeatureShowcase
      tagline={d.howItWorks.tagline}
      heading={d.howItWorks.heading}
      body={d.howItWorks.body}
      items={howItWorksItems}
      image={d.howItWorks.image ? { src: d.howItWorks.image, alt: d.howItWorks.imageAlt } : undefined}
      imageSide={d.howItWorks.imageSide}
      mediaRatio="16 / 10"
    />
  ) : d.steps.length > 0 ? (
    <FeatureSteps
      tagline={d.stepsTagline}
      heading={d.stepsHeading ?? d.heading}
      cta={{ label: 'See how it works', href: '/#how-it-works' }}
      steps={d.steps}
    />
  ) : null}

  {d.showIntegrations && (
    <IntegrationGrid
      heading={d.integrationsHeading}
      defaultSubject={d.integrationsSubject}
      cta={{ label: 'View all integrations', href: '/integrations' }}
      items={integrations}
    />
  )}

  {d.benefits.length > 0 && (
    <section class="section">
      <div class="container">
        <ImageCardGrid items={benefitCards} columns={4} />
      </div>
    </section>
  )}

  {d.faqs.length > 0 && (
    <FaqSplit
      heading={d.faqHeading}
      body="What operators ask before a demo. Still unsure? Reach out and we'll help."
      contact={{ label: 'Contact us', href: '/contact' }}
      items={d.faqs}
    />
  )}

  <CtaBand
    heading={d.ctaHeading}
    subhead={d.ctaSubhead}
    primary={{ label: 'Book a demo', href: '/book-a-demo' }}
    secondary={{ label: 'View pricing', href: '/pricing' }}
  />
</Layout>
