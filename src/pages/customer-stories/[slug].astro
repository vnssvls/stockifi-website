---
// Customer story item page (Figma 100:2699 header + 100:3055 body): hero header →
// breadcrumb + share → prose body → image gallery → pull quote → share → CTA v2 → footer.
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CustomerStoryHeader from '../../components/CustomerStoryHeader.astro';
import CtaEmail from '../../components/CtaEmail.astro';

export async function getStaticPaths() {
  const stories = (await getCollection('customerStories')).filter((s) => !s.data.draft);
  return stories.map((story) => ({ params: { slug: story.id }, props: { story } }));
}

const { story } = Astro.props;
const { Content } = await render(story);
const d = story.data;

const words = (story.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readTime = `${Math.max(1, Math.round(words / 200))} min read`;

const shareUrl = new URL(Astro.url.pathname.replace(/(.)\/$/, '$1'), Astro.site).href;
const enc = encodeURIComponent(shareUrl);
const shares = [
  { label: 'Share on LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc}`, path: 'M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3 0-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21h-4z' },
  { label: 'Share on X', href: `https://twitter.com/intent/tweet?url=${enc}`, path: 'M18.9 2H22l-7.6 8.7L23 22h-6.8l-5-6.6L5.5 22H2.4l8.2-9.3L2 2h6.9l4.5 6 5.5-6zm-1.2 18h1.7L7.5 3.8H5.7z' },
  { label: 'Share on Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc}`, path: 'M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6c-.8-.1-1.6-.15-2.4-.15-2.4 0-4.05 1.46-4.05 4.16V9.9H7.5V13h2.75v8z' },
];
---

<Layout
  title={`${d.metaTitle ?? d.articleTitle} | Stockifi`}
  description={d.metaDescription ?? d.oneLiner ?? d.featuredQuote}
  image={d.thumbnail}
>
  <CustomerStoryHeader
    title={d.articleTitle}
    image={d.thumbnail ?? d.singleImage}
    logo={d.logoTransparent ?? d.logoPrimary}
    avatar={d.userPhoto}
    quote={d.featuredQuote}
    name={d.user}
    designation={d.designation}
    readTime={readTime}
  />

  <article class="cs-article section">
    <div class="container">
      <div class="cs-bar">
        <nav class="cs-crumb" aria-label="Breadcrumb">
          <a href="/customer-stories">Customer Stories</a>
          {d.businessType && <span aria-hidden="true">›</span>}
          {d.businessType && <span class="cs-crumb-cur">{d.businessType}</span>}
        </nav>
        <div class="cs-share">
          {shares.map((s) => (
            <a class="cs-share-link" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="cs-body prose">
        <Content />
      </div>

      {d.imageGrid.length > 0 && (
        <div class="cs-gallery" data-count={d.imageGrid.length}>
          {d.imageGrid.map((src) => <img src={src} alt={`${d.companyName} photo`} loading="lazy" decoding="async" />)}
        </div>
      )}

      {d.fullTestimonial && d.fullTestimonial !== d.featuredQuote && (
        <blockquote class="cs-pull">{d.fullTestimonial}</blockquote>
      )}

      <footer class="cs-foot">
        <p class="cs-foot-label">Share this story</p>
        <div class="cs-share">
          {shares.map((s) => (
            <a class="cs-share-link" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </footer>
    </div>
  </article>

  <CtaEmail
    heading="See where your margin is leaking"
    subhead="Drop your email and we'll show you what Stockifi surfaces in your first 30 days."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Header, bar, body and gallery share the readable prose column. */
  .cs-bar,
  .cs-body,
  .cs-gallery,
  .cs-pull,
  .cs-foot { max-width: var(--prose-max); margin-inline: auto; }

  .cs-bar { display: flex; align-items: center; justify-content: space-between; gap: var(--space-16); padding-bottom: var(--space-24); border-bottom: 1px solid var(--border); }
  .cs-crumb { display: flex; align-items: center; gap: var(--space-8); font-size: var(--text-body-sm); color: var(--muted-foreground); }
  .cs-crumb a { color: var(--muted-foreground); }
  .cs-crumb a:hover { color: var(--foreground); text-decoration: none; }
  .cs-crumb-cur { color: var(--foreground); }

  .cs-share { display: flex; align-items: center; gap: var(--space-8); }
  .cs-share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    color: var(--muted-foreground);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .cs-share-link:hover { color: var(--foreground); border-color: var(--muted-foreground); }

  .cs-body { margin-top: var(--space-48); }
  .cs-body :global(p),
  .cs-body :global(ul),
  .cs-body :global(ol) { margin-bottom: var(--space-24); line-height: var(--lh-body); }
  .cs-body :global(h2) { margin-top: var(--space-48); margin-bottom: var(--space-16); font-size: var(--text-h3); }
  .cs-body :global(h3) { margin-top: var(--space-32); margin-bottom: var(--space-12); font-size: var(--text-h5); }
  .cs-body :global(ul),
  .cs-body :global(ol) { padding-left: var(--space-24); }
  .cs-body :global(li) { margin-bottom: var(--space-8); }
  .cs-body :global(strong) { color: var(--foreground); font-weight: var(--fw-semibold); }
  .cs-body :global(img) { width: 100%; height: auto; margin-block: var(--space-32); border-radius: var(--radius-md); }
  .cs-body :global(blockquote) {
    margin-block: var(--space-32);
    padding-left: var(--space-24);
    border-left: 3px solid var(--primary);
    color: var(--muted-foreground);
    font-size: var(--text-body-lg);
  }

  /* Image gallery (frontmatter imageGrid). */
  .cs-gallery { display: grid; grid-template-columns: 1fr; gap: var(--space-16); margin-top: var(--space-48); }
  .cs-gallery img { width: 100%; aspect-ratio: 3 / 4; object-fit: cover; border-radius: var(--radius-md); }

  /* Pull quote (full testimonial). */
  .cs-pull {
    margin-top: var(--space-48);
    padding-left: var(--space-32);
    border-left: 3px solid var(--primary);
    font-family: var(--font-heading);
    font-size: var(--text-h5);
    line-height: var(--lh-h5);
    color: var(--foreground);
  }

  .cs-foot { margin-top: var(--space-48); padding-top: var(--space-32); border-top: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; gap: var(--space-16); }
  .cs-foot-label { font-weight: var(--fw-semibold); }

  @media (min-width: 768px) {
    .cs-gallery[data-count='3'] { grid-template-columns: repeat(3, 1fr); }
    .cs-gallery[data-count='2'] { grid-template-columns: repeat(2, 1fr); }
  }
</style>
