---
// Customer story item page (Figma 100:2699 header + 100:3055 body): full-height hero
// header → light-mode body (breadcrumb + share → prose with a wide 3-image grid in the
// middle → end featured image → share) → CTA v2 → footer.
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CustomerStoryHeader from '../../components/CustomerStoryHeader.astro';
import CtaEmail from '../../components/CtaEmail.astro';

export async function getStaticPaths() {
  const stories = (await getCollection('customerStories')).filter((s) => !s.data.draft);
  return stories.map((story) => ({ params: { slug: story.id }, props: { story } }));
}

const { story } = Astro.props;
const { Content } = await render(story);
const d = story.data;

// End featured image: the first available image that isn't the header thumbnail.
const endImage = [d.singleImage, ...[...d.imageGrid].reverse()].find((img) => img && img !== d.thumbnail) ?? null;

const shareUrl = new URL(Astro.url.pathname.replace(/(.)\/$/, '$1'), Astro.site).href;
const enc = encodeURIComponent(shareUrl);
const shares = [
  { label: 'Share on LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc}`, path: 'M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3 0-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21h-4z' },
  { label: 'Share on X', href: `https://twitter.com/intent/tweet?url=${enc}`, path: 'M18.9 2H22l-7.6 8.7L23 22h-6.8l-5-6.6L5.5 22H2.4l8.2-9.3L2 2h6.9l4.5 6 5.5-6zm-1.2 18h1.7L7.5 3.8H5.7z' },
  { label: 'Share on Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${enc}`, path: 'M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6c-.8-.1-1.6-.15-2.4-.15-2.4 0-4.05 1.46-4.05 4.16V9.9H7.5V13h2.75v8z' },
];
---

<Layout
  title={`${d.metaTitle ?? d.articleTitle} | Stockifi`}
  description={d.metaDescription ?? d.oneLiner ?? d.featuredQuote}
  image={d.thumbnail}
>
  <CustomerStoryHeader
    title={d.articleTitle}
    image={d.thumbnail ?? d.singleImage}
    logo={d.logoTransparent ?? d.logoPrimary}
    avatar={d.userPhoto}
    quote={d.featuredQuote}
    name={d.user}
    designation={d.designation}
  />

  <!-- Light-mode reading section (easier for long-form than the dark page). -->
  <article class="cs-article section" data-theme="light" data-cs-article>
    <div class="container">
      <div class="cs-bar">
        <nav class="cs-crumb" aria-label="Breadcrumb">
          <a href="/customer-stories">Customer Stories</a>
          {d.businessType && <span aria-hidden="true">›</span>}
          {d.businessType && <span class="cs-crumb-cur">{d.businessType}</span>}
        </nav>
        <div class="cs-share">
          {shares.map((s) => (
            <a class="cs-share-link" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="cs-body prose" data-cs-body>
        <Content />
        {d.imageGrid.length > 0 && (
          <div class="cs-gallery" data-count={d.imageGrid.length} data-cs-gallery>
            {d.imageGrid.map((src) => <img src={src} alt={`${d.companyName} photo`} loading="lazy" decoding="async" />)}
          </div>
        )}
      </div>

      {endImage && <img class="cs-end" src={endImage} alt={`${d.companyName}`} loading="lazy" decoding="async" />}

      <footer class="cs-foot">
        <p class="cs-foot-label">Share this story</p>
        <div class="cs-share">
          {shares.map((s) => (
            <a class="cs-share-link" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </footer>
    </div>
  </article>

  <CtaEmail
    heading="See where your margin is leaking"
    subhead="Drop your email and we'll show you what Stockifi surfaces in your first 30 days."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Light reading section. data-theme flips the tokens; paint the light background. */
  .cs-article { background-color: var(--background); overflow-x: clip; }

  .cs-bar,
  .cs-body,
  .cs-end,
  .cs-foot { max-width: var(--prose-max); margin-inline: auto; }

  .cs-bar { display: flex; align-items: center; justify-content: space-between; gap: var(--space-16); padding-bottom: var(--space-24); border-bottom: 1px solid var(--border); }
  .cs-crumb { display: flex; align-items: center; gap: var(--space-8); font-size: var(--text-body-sm); color: var(--muted-foreground); }
  .cs-crumb a { color: var(--muted-foreground); }
  .cs-crumb a:hover { color: var(--foreground); text-decoration: none; }
  .cs-crumb-cur { color: var(--foreground); }

  .cs-share { display: flex; align-items: center; gap: var(--space-8); }
  .cs-share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    color: var(--muted-foreground);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .cs-share-link:hover { color: var(--foreground); border-color: var(--muted-foreground); }

  .cs-body { margin-top: var(--space-48); }
  .cs-body :global(p),
  .cs-body :global(li) { font-size: var(--text-prose); }
  .cs-body :global(p),
  .cs-body :global(ul),
  .cs-body :global(ol) { margin-bottom: var(--space-24); line-height: var(--lh-body); }
  .cs-body :global(h2),
  .cs-body :global(h3),
  .cs-body :global(h4) { font-family: var(--font-body); text-wrap: pretty; }
  .cs-body :global(h2) { margin-top: var(--space-48); margin-bottom: var(--space-16); font-size: var(--text-h4); }
  .cs-body :global(h3) { margin-top: var(--space-32); margin-bottom: var(--space-12); font-size: var(--text-h5); }
  .cs-body :global(h4) { margin-top: var(--space-24); margin-bottom: var(--space-8); font-size: var(--text-h6); }
  /* Lists: explicit markers + rhythm (see blog [slug] for the loose-list note). */
  .cs-body :global(ul) { list-style: disc; }
  .cs-body :global(ol) { list-style: decimal; }
  .cs-body :global(ul),
  .cs-body :global(ol) { padding-left: var(--space-32); }
  .cs-body :global(li) { margin-bottom: var(--space-12); }
  .cs-body :global(li)::marker { color: var(--muted-foreground); }
  .cs-body :global(ol) :global(li)::marker { color: var(--foreground); font-weight: var(--fw-semibold); }
  .cs-body :global(li) :global(p) { margin-bottom: 0; }
  .cs-body :global(li) :global(ul),
  .cs-body :global(li) :global(ol) { margin-top: var(--space-12); margin-bottom: 0; }
  .cs-body :global(li) :global(ul) { list-style: circle; }
  .cs-body :global(strong) { color: var(--foreground); font-weight: var(--fw-semibold); }
  .cs-body :global(img) { width: 100%; height: auto; margin-block: var(--space-32); border-radius: var(--radius-md); }
  .cs-body :global(blockquote) {
    margin-block: var(--space-32);
    padding-left: var(--space-24);
    border-left: 3px solid var(--primary);
    color: var(--muted-foreground);
    font-size: var(--text-body-lg);
  }

  /* Wide image grid — breaks out of the prose column to near-full-width (80px gutter).
     Mobile: a swipeable, scroll-snapping slider. */
  .cs-gallery {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    margin-block: var(--space-48);
    padding-inline: var(--gutter-wide);
    display: flex;
    gap: var(--space-16);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .cs-gallery::-webkit-scrollbar { display: none; }
  .cs-gallery img { flex: 0 0 82%; scroll-snap-align: center; aspect-ratio: 3 / 4; object-fit: cover; border-radius: var(--radius-md); }

  .cs-end { display: block; width: 100%; margin-top: var(--space-48); aspect-ratio: 3 / 2; object-fit: cover; border-radius: var(--radius-lg); }

  .cs-foot { margin-top: var(--space-48); padding-top: var(--space-32); border-top: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; gap: var(--space-16); }
  .cs-foot-label { font-weight: var(--fw-semibold); }

  @media (min-width: 768px) {
    .cs-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      padding-inline: 80px;
      overflow: visible;
    }
    .cs-gallery[data-count='2'] { grid-template-columns: repeat(2, 1fr); }
    .cs-gallery[data-count='1'] { grid-template-columns: 1fr; }
    .cs-gallery img { flex: none; width: 100%; }
  }
</style>

<script>
  // Move the image grid into the middle of the prose (after the middle paragraph).
  document.querySelectorAll<HTMLElement>('[data-cs-article]').forEach((article) => {
    const body = article.querySelector<HTMLElement>('[data-cs-body]');
    const gallery = article.querySelector<HTMLElement>('[data-cs-gallery]');
    if (!body || !gallery) return;
    const paras = Array.from(body.querySelectorAll<HTMLElement>(':scope > p'))
      .filter((p) => (p.textContent ?? '').replace(/‍/g, '').trim().length > 0);
    if (paras.length < 2) return;
    const mid = paras[Math.floor(paras.length / 2)];
    body.insertBefore(gallery, mid);
  });
</script>
