---
// Business Intelligence category LP (/no/product-business-intelligence).
// Section map: PageHeader → product card grid (4 items, 4-col) → CtaEmail → Footer v2
// When Sales & Usage page ships, add 5th item and columns will auto-switch to 3-col.
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Resultatdashbord', body: 'Varekostnad og margin på tvers av alle lokasjoner.', href: '/no/product-business-intelligence/performance-dashboards', icon: icons['element-4'], image: '/media/solution-management.jpg' },
  { heading: 'Avviksanalyse', body: 'Teoretisk forbruk sammenlignet med hva som faktisk ble solgt.', href: '/no/product-business-intelligence/variance-analysis', icon: icons['presention-chart'], image: '/media/solution-operations.jpg' },
  { heading: 'Lønnsomhetsoversikt', body: 'Se den live-marginene på hvert menyelement.', href: '/no/product-business-intelligence/profitability', icon: icons['trend-up'], image: '/media/solution-finance.jpg' },
  { heading: 'API', body: 'Send dataene dine dit du trenger dem.', href: '/no/product-business-intelligence/api', icon: icons['code'], image: '/media/solution-restaurant-groups.jpg' },
  { heading: 'Datakvalitet', body: 'Holder dataene dine på høyeste kvalitet, kontinuerlig.', href: '/no/product-business-intelligence/data-quality', icon: icons['data-quality'], image: '/media/solution-hotels.jpg' },
];
---

<Layout
  title="Analyse og forretningsintelligens for restaurant | Stockifi"
  description="Dashboards bygget på faktiske faktura- og kassedata. Se varekostnad, margin og avvik per rett, sted og periode, og ta beslutninger basert på nøyaktige tall."
>
  <!-- 1. Page header — centered -->
  <PageHeader
    eyebrow="Business Intelligence"
    heading="Ta beslutninger forankret i ekte data"
    subhead="Hvert dashbord bygger på dine ekte faktura- og kassedata, ikke estimater. Se varekost, margin og avvik per rett, sted og periode, og handle på det de forteller deg."
  />

  <!-- 2. Product card grid -->
  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <!-- 3. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="Klar til å handle på tall du kan stole på?"
    subhead="Book en kort samtale, så viser vi deg hva Stockifi avdekker i løpet av de første 30 dagene."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
