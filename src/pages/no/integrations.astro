---
// Integrations page (Figma 67:2342 header + 67:3442 filters + 67:3455 content).
// Page header (heading + subhead) → directory (search/sort/filter +
// card grid) → CTA variant 2 (image-background email capture). Nav + Footer come
// from the layout. DRAFT copy.
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import IntegrationsDirectory from '../../components/integrations/IntegrationsDirectory.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import data from '../../../content/integrations/integrations.en.json';

const live = data.filter((x) => !x.draft);

const CATEGORIES = [
  { value: 'accounting', label: 'Regnskap' },
  { value: 'pos', label: 'Kassesystem' },
  { value: 'other', label: 'Annet' },
];

const items = [...live]
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((x) => ({ name: x.name, category: x.category, logo: x.logo }));

---

<Layout
  title="70+ POS- og regnskapsintegrasjoner | Stockifi"
  description="Stockifi integrerer med 70+ verktøy for å synkronisere salg og fakturaer med varetellingene dine og gi deg verdifulle anbefalinger for å nå F&B-målene dine."
>
  <PageHeader
    eyebrow="Integrasjoner"
    heading="Stockifi fungerer med systemene du allerede bruker"
    subhead="Koble til regnskaps- og kassesystemet ditt så fakturaer, salg og oppskriftskostnader holder seg synkronisert, uten manuelle eksporter eller dobbel registrering."
  />

  <IntegrationsDirectory items={items} categories={CATEGORIES} />

  <CtaEmail
    heading="Se det koblet til ditt system"
    subhead="Legg igjen e-postadressen din, så viser vi deg hva Stockifi avdekker i løpet av de første 30 dagene."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

