---
// Procurement category LP (/no/product-procurement).
// Section map: PageHeader → product card grid (4 items, 4-col) → CtaEmail → Footer v2
// When Ordering page ships, add 5th item and columns will auto-switch to 3-col.
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../../components/ProductCardGrid.astro';
import CtaEmail from '../../../components/CtaEmail.astro';
import navIcons from '../../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Fakturaautomatisering', body: 'Leverandørfakturaer leses linje for linje, automatisk.', href: '/no/product-procurement/invoice-automation', icon: icons['receipt-2'], image: '/media/product-invoice-automation.png' },
  { heading: 'Prisovervåking fra leverandør', body: 'Alle prisendringer fanges opp samme dag de skjer.', href: '/no/product-procurement/supplier-price-tracking', icon: icons['percentage-circle'], image: '/media/product-supplier-price-tracking.png' },
  { heading: 'Sentralkjøkken', body: 'Kalkler produksjonskostnader og forsyner dine egne utsalgssteder.', href: '/no/product-procurement/central-kitchen', icon: icons['building'], image: '/media/product-central-kitchen.png' },
  { heading: 'Avviksdeteksjon', body: 'Markerer overprising og uvanlige fakturalinjer for gjennomgang.', href: '/no/product-procurement/anomaly-detection', icon: icons['fluent-wand'], image: '/media/product-anomaly-detection.png' },
  { heading: 'Bestillingsforslag', body: 'Vet hva du bør bestille på nytt før du går tom.', href: '/no/product-procurement/ordering-suggestions', icon: icons['ordering-suggestions'], image: '/media/product-ordering-suggestions.png' },
];
---

<Layout
  title="Fakturabehandling og leverandørstyring | Stockifi"
  description="Stockifi leser hver leverandørfaktura, sporer prisendringer og varsler om faktureringsfeil før de påvirker matkostnaden din, uten manuell inntasting."
>
  <!-- 1. Page header — centered -->
  <PageHeader
    eyebrow="Innkjøp"
    heading="Alt du kjøper, under ett blikk"
    subhead="Hvert kjøkken lever av det det kjøper inn. Stockifi hjelper deg å bestille riktige mengder, forsyne dine egne utsalgssteder og vite nøyaktig hva hver leverandør tar betalt."
  />

  <!-- 2. Product card grid -->
  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <!-- 3. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="Klar til å få kontroll på innkjøpet?"
    subhead="Book en kort samtale, så viser vi deg hva Stockifi avdekker i løpet av de første 30 dagene."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
