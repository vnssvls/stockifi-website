---

<Layout
  title="Matkostnadssoftware for europeiske restauranter | Stockifi"
  description="Kjenn din reelle matkostnad. Stockifi kobler fakturaene, kassesystemet og oppskriftene dine for å vise hvor marginen din forsvinner, med oppsett gjort for deg."
>
  <!-- 1. Hero -->
  <Hero
    wide
    tagline="Matkostnadssoftware for restauranter"
    heading="Kjenn din reelle matkostnad."
    subhead="Fakturaene, salget og oppskriftene dine holder allerede svaret på matkostnaden din. Stockifi trekker dem sammen og gjør regnestykket, slik at du ser marginen din og kan handle på den."
    primary={{ label: 'Book en demo', href: '/no/book-a-demo' }}
    secondary={{ label: 'Se hvordan det fungerer', href: '#how-it-works' }}
    images={[
      { src: '/media/photos/hero-manager.png', alt: '' },
      { src: '/media/photos/hero-chef.png',    alt: '' },
      { src: '/media/photos/hero-owner.png',   alt: '' },
    ]}
  >
    <!-- Overlay 0: slide 1 (manager) — food cost card, to build -->
    <div slot="overlays" style="display:contents">
      <div class="hero-overlay">
        <FoodCostAnimation />
      </div>
      <!-- Overlay 1: slide 2 (chef) — supplier price ticker -->
      <div class="hero-overlay">
        <ProcurementAnimation compact />
      </div>
      <!-- Overlay 2: slide 3 (owner) — location health list -->
      <div class="hero-overlay">
        <ManagementAnimation />
      </div>
    </div>
  </Hero>

  <!-- 2. Social proof -->
  <LogoBanner label="Brukt av 500+ restauranter i Europa" logos={userLogos} />

  <!-- 3. What's inside — FeatureList (product categories) -->
  <div id="how-it-works" class="hp-anchor">
    <FeatureList tagline="Hva er inni" items={whatsInside} />
  </div>

  <!-- 4. Benefits — FeatureSplit -->
  <FeatureSplit
    tagline="Derfor er det verdt det"
    heading="Matkostnadskontroll for restauranter som betaler seg selv"
    body="Det meste av marginen din lekker i gapene mellom systemene. Stockifi trekker dem inn i én visning, slik at selv 1 % forbedring i matkostnad blir penger du beholder."
    items={benefits}
    imageSide="right"
  >
    <SavingsAnimation slot="media" />
  </FeatureSplit>

  <!-- 5. By Teams — FeatureTabs -->
  <FeatureTabs
    tagline="For teamet ditt"
    heading="Ett sett med tall for alle roller"
    subhead="Fra daglig leder til kjøkken jobber alle ut fra de samme tallene."
    tabs={byTeams}
  />

  <!-- 6. Customer stories — bento -->
  <CustomerStoryBento
    eyebrow="Kundecaser"
    heading="Hør det fra operatører som deg"
    cta={{ label: 'Les alle caser', href: '/no/customer-stories' }}
    slugs={['byoslo', 'eik-and-friends', 'koie-ramen', 'skigeilo-2']}
  />

  <!-- 7. Onboarding — FeatureSteps -->
  <FeatureSteps
    tagline="Personlig onboarding"
    heading="Kom i gang på 48 timer"
    cta={{ label: 'Book en demo', href: '/no/book-a-demo' }}
    steps={onboarding}
  />

  <!-- 8. Integrations — pill cloud (variant 2), wide -->
  <IntegrationPills
    wide
    eyebrow="Integrasjoner"
    heading="Fungerer med verktøyene du allerede bruker"
    subhead="Eliminer det manuelle arbeidet og la Stockifi samle POS- og regnskapsdataene dine."
    cta={{ label: 'Se alle integrasjoner', href: '/no/integrations' }}
    items={integrations}
  />

  <!-- 9. Risk / pricing band — CtaBand (stand-in until a dedicated band exists) -->
  <CtaBand
    heading="Designet for å spare deg tid og penger"
    subhead="Vil du vite hva det koster for deg? Prisen avhenger av størrelsen og oppsettet ditt. Og hvis vi ikke finner minst 30 000 NOK i skjulte tap i løpet av de første 30 dagene, er det gratis."
    primary={{ label: 'Utforsk planer', href: '/no/pricing' }}
    secondary={{ label: 'Snakk med en ekspert', href: '/no/book-a-demo' }}
  />

  <!-- 10. FAQ — variant 1 (split) -->
  <FaqSplit
    eyebrow="Ofte stilte spørsmål"
    heading="Spørsmål du kanskje har"
    body="Det operatørene sjekker før en demo. Fortsatt usikker? Ta kontakt og vi hjelper deg."
    contact={{ label: 'Kontakt oss', href: '/no/contact' }}
    items={faqs}
  />

  <!-- 11. Final CTA — variant 2.1 (button-only, photo-backed) -->
  <CtaButton
    heading="Klar til å investere i lønnsomheten din?"
    subhead="Book et kort møte og vi går gjennom dine egne tall med deg."
    primary={{ label: 'Book en demo', href: '/no/book-a-demo' }}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Offset anchored scroll so the floating nav doesn't cover the section top */
  .hp-anchor { scroll-margin-top: var(--space-96); }
</style>
