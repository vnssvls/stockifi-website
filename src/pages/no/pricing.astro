---

<Layout
  title="Stockifi-priser | Programvare for varekostnad i restaurant"
  description="Finn riktig Stockifi-plan for din restaurant. Prisen avhenger av oppsettet ditt, og alle planer kommer med 30 dagers risikofri garanti. Book en demo nå."
>
  <!-- Pricing hero: header + cards share one decorative gradient backdrop that
       bleeds behind both sections (not clipped to either). -->
  <div class="pricing-hero">
    <!-- 1. Page header -->
    <PageHeader
      eyebrow="Priser"
      heading="Velg en plan som passer din drift"
      subhead="Alle planer inkluderer vår risikofrie oppstartsgaranti. Ingen bindingstid, avbryt når som helst."
    />

    <!-- 1b. Pricing cards -->
    <PricingCards plans={plans} />
  </div>

  <!-- 2. Logo banner — scrolling marquee (matches the home page) -->
  <LogoBanner label="Brukt av 500+ restauranter i Europa" logos={userLogos} />

  <!-- 2b. Savings calculator — reserved slot, real section lands later -->
  <SectionPlaceholder
    label="Besparelseskalkulator"
    note="Interaktivt estimat over hva Stockifi kan spare driften din. Kommer snart."
  />

  <!-- 3. Feature section — Feature variant 6 (columns) -->
  <FeatureColumns
    tagline="Hvorfor Stockifi"
    heading="Slik betaler planene seg selv"
    columns={featureCols}
  />

  <!-- 4. FAQ — variant 1 (split) -->
  <FaqSplit
    heading="Spørsmål om priser?"
    body="Det operatører spør om før de velger en plan. Fortsatt usikker? Ta kontakt, så hjelper vi deg."
    contact={{ label: 'Kontakt oss', href: '/no/contact' }}
    items={faqs}
  />

  <!-- 5. CTA — variant 2.1 (image-backed button) -->
  <CtaButton
    heading="Klar til å investere i lønnsomheten din?"
    primary={{ label: 'Kom i gang', href: '/no/book-a-demo' }}
    secondary={{ label: 'Snakk med en ekspert', href: '/no/contact' }}
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>

<style>
  /* Brand gradient glow (from the ads-LP) bleeds behind BOTH the page header and the
     pricing cards as one continuous backdrop — not clipped to either section. */
  .pricing-hero { position: relative; isolation: isolate; }
  .pricing-hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -6%;
    transform: translateX(-50%);
    width: min(1200px, 150%);
    aspect-ratio: 600 / 500;
    background-image: url('/media/gradient-centered.png');
    background-size: contain;
    background-position: center top;
    background-repeat: no-repeat;
    opacity: 0.4;
    z-index: -1;
    pointer-events: none;
  }
  /* Header + cards read as one block: collapse the stacked section paddings between
     them (they each carry full section padding otherwise → an awkward double gap). */
  .pricing-hero :global(.page-header) { padding-bottom: var(--space-32); }
  .pricing-hero :global(.pricing-cards) { padding-top: 0; }
</style>
