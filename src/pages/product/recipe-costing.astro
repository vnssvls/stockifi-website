---
// Product item page template (Figma 82:*). Arrangement per V:
// Page Header (image variant) → Feature v3 (Steps) → Integrations block →
// Grid row v2 (ImageCardGrid) → FAQ v1 (FaqSplit) → CTA v1 (CtaBand).
// Built as the concrete "recipe-costing" instance; other product items follow the
// same template. No /product landing (404 by design). DRAFT copy + placeholder images.
import Layout from '../../layouts/Layout.astro';
import PageHeaderImage from '../../components/page-headers/PageHeaderImage.astro';
import FeatureSteps from '../../components/features/FeatureSteps.astro';
import IntegrationGrid from '../../components/integrations/IntegrationGrid.astro';
import ImageCardGrid from '../../components/ImageCardGrid.astro';
import FaqSplit from '../../components/faq/FaqSplit.astro';
import CtaBand from '../../components/CtaBand.astro';
import integrations from '../../data/integrations-home.json';

const steps = [
  { heading: 'Build the recipe baseline', body: 'Import your recipes and ingredient costs once. This becomes the reference every calculation runs from.' },
  { heading: 'Read every invoice', body: 'Stockifi pulls supplier invoices line by line from your accounting, so each ingredient carries its real, current price.' },
  { heading: 'Re-cost automatically', body: 'When a supplier price moves, every recipe that uses that ingredient updates the same day. No manual edits.' },
  { heading: 'See margin per dish', body: 'Know the live cost and margin of every recipe, and which ones drift when prices climb.' },
];

const benefits = [
  { heading: 'Always-current costs', body: 'Recipe costs reflect the latest invoice prices, not a spreadsheet someone last touched in spring.' },
  { heading: 'Price-rise alerts', body: 'Catch a supplier increase the day it lands, while you can still adjust a price or a portion.' },
  { heading: 'Margin per recipe', body: 'See which dishes carry the margin and which quietly lose it as costs move.' },
  { heading: 'No manual re-costing', body: 'The work that used to mean updating dozens of recipes by hand happens on its own.' },
];
const benefitCards = benefits.map((b, i) => ({ ...b, image: `/media/cta-bg-${i + 1}.jpg` }));

const faqs = [
  { question: 'How do recipe costs stay current?', answer: 'Stockifi reads your supplier invoices line by line and updates the cost of every affected recipe automatically, usually the same day the invoice arrives.' },
  { question: 'Do I have to enter prices by hand?', answer: 'No. Once recipes and your accounting integration are connected, ingredient prices flow in from invoices. The manual re-costing goes away.' },
  { question: 'What if a recipe uses a sub-recipe or prebatch?', answer: 'Nested recipes are supported, so a prebatch re-costs once and rolls up into every dish that uses it.' },
  { question: 'Which accounting systems does it work with?', answer: 'We support 30+ accounting integrations. The full list is on the integrations page, and custom integrations are available on the Custom plan.' },
];
---

<Layout
  title="Recipe Costing Software for Restaurants | Stockifi"
  description="Live recipe costing that updates from your supplier invoices. See the real cost and margin of every dish as prices move, without manual re-costing."
>
  <!-- 1. Page header — image variant -->
  <PageHeaderImage
    eyebrow="Recipe costing"
    heading="Recipe costs that move with your prices"
    subhead="Stockifi keeps the cost of every dish current by reading your supplier invoices, so you always know your real margin."
    cta={{ label: 'Book a demo', href: '/book-a-demo' }}
    image="/media/cta-bg-2.jpg"
  />

  <!-- 2. Feature v3 (Steps) — how recipe costing works -->
  <FeatureSteps
    tagline="How it works"
    heading="From recipe to live cost in four steps"
    cta={{ label: 'See how it works', href: '/#how-it-works' }}
    steps={steps}
  />

  <!-- 3. Integrations block -->
  <IntegrationGrid
    heading="Reads prices from"
    defaultSubject="your accounting software"
    cta={{ label: 'View all integrations', href: '/integrations' }}
    items={integrations}
  />

  <!-- 4. Grid row v2 (image-backed cards) — what you get -->
  <section class="section">
    <div class="container">
      <ImageCardGrid items={benefitCards} columns={4} />
    </div>
  </section>

  <!-- 5. FAQ v1 (split) -->
  <FaqSplit
    heading="Questions about recipe costing"
    body="What operators ask before a demo. Still unsure? Reach out and we'll help."
    contact={{ label: 'Contact us', href: '/contact' }}
    items={faqs}
  />

  <!-- 6. CTA v1 (band) -->
  <CtaBand
    heading="See your real recipe costs"
    subhead="Book a short call and we'll show you what Stockifi surfaces in your first 30 days."
    primary={{ label: 'Book a demo', href: '/book-a-demo' }}
    secondary={{ label: 'View pricing', href: '/pricing' }}
  />
</Layout>
