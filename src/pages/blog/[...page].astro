---
// Blog index (/blog) — centered page header + a 3-up card grid, numbered pagination at
// 6 per page via Astro's paginate() (/blog, /blog/2, ...). Wide layout, 80px gutter.
import type { GetStaticPaths, Page, PaginateFunction } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import CtaBand from '../../components/CtaBand.astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }: { paginate: PaginateFunction }) => {
  const posts = (await getCollection('blog'))
    .filter((p) => !p.data.draft)
    .sort((a, b) => (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0));
  return paginate(posts, { pageSize: 6 });
};

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };
const pageUrl = (n: number) => (n === 1 ? '/blog' : `/blog/${n}`);
const pages = Array.from({ length: page.lastPage }, (_, i) => i + 1);
const fmtDate = (d?: Date) => (d ? d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '');
---

<Layout
  title="Blog — Food Cost & Restaurant Margins | Stockifi"
  description="Practical reads on recipe costing, supplier prices, invoice processing, and the numbers behind a healthier restaurant margin."
>
  <PageHeader
    eyebrow="Blog"
    heading="Food cost, in plain language"
    subhead="Practical reads on recipe costing, supplier prices, and the numbers behind a healthier margin."
  />

  <section class="section bl-grid-section">
    <div class="bl-wide">
      <div class="bl-grid">
        {page.data.map((p) => (
          <a class="bl-card" href={`/blog/${p.id}`}>
            <div class="bl-media">
              {p.data.heroImage ? (
                <img src={p.data.heroImage} alt={p.data.heroImageAlt} loading="lazy" decoding="async" />
              ) : (
                <span class="bl-media-ph" aria-hidden="true"></span>
              )}
            </div>
            <div class="bl-meta">
              <span class="bl-pill">{p.data.category}</span>
              <span class="bl-time text-muted">{[fmtDate(p.data.publishDate), p.data.readTime].filter(Boolean).join(' · ')}</span>
            </div>
            <h3 class="bl-title">{p.data.title}</h3>
            <p class="bl-excerpt text-muted">{p.data.excerpt}</p>
            <span class="bl-cta">Read more
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </span>
          </a>
        ))}
      </div>

      {page.lastPage > 1 && (
        <nav class="bl-pages" aria-label="Pagination">
          {page.url.prev ? <a class="bl-nav" href={page.url.prev}>← Prev</a> : <span class="bl-nav is-off">← Prev</span>}
          <span class="bl-nums">
            {pages.map((n) => (
              n === page.currentPage
                ? <span class="bl-num is-active" aria-current="page">{n}</span>
                : <a class="bl-num" href={pageUrl(n)}>{n}</a>
            ))}
          </span>
          {page.url.next ? <a class="bl-nav" href={page.url.next}>Next →</a> : <span class="bl-nav is-off">Next →</span>}
        </nav>
      )}
    </div>
  </section>

  <CtaBand
    heading="See where your margin is leaking"
    subhead="Book a short call and we'll show you what Stockifi surfaces in your first 30 days."
    primary={{ label: 'Book a demo', href: '/book-a-demo' }}
    secondary={{ label: 'See how it works', href: '/#how-it-works' }}
  />
</Layout>

<style>
  .bl-wide { width: 100%; max-width: none; margin-inline: auto; padding-inline: var(--gutter-wide); }
  /* Pull up so the header→grid gap is one spacing, not two stacked. */
  .bl-grid-section { padding-top: 0; margin-top: calc(-1 * var(--space-64)); }

  .bl-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-64) var(--space-48); }

  .bl-card { display: flex; flex-direction: column; }
  .bl-card:hover { text-decoration: none; }
  .bl-media { border-radius: var(--radius-lg); overflow: hidden; margin-bottom: var(--space-16); }
  .bl-media img,
  .bl-media-ph { display: block; width: 100%; aspect-ratio: 3 / 2; object-fit: cover; }
  .bl-media-ph { background: var(--muted); }

  .bl-meta { display: flex; align-items: center; gap: var(--space-12); margin-bottom: var(--space-12); }
  .bl-pill { padding: var(--space-4) var(--space-12); border-radius: var(--radius-full); background: var(--muted); color: var(--foreground); font-size: var(--text-caption); font-weight: var(--fw-medium); }
  .bl-time { font-size: var(--text-caption); }

  /* Title in body font (Inter), no purple hover. */
  .bl-title { font-family: var(--font-body); font-size: var(--text-h5); text-wrap: pretty; }
  .bl-excerpt { margin-top: var(--space-8); font-size: var(--text-body-sm); line-height: var(--lh-body); }
  /* "Read more" white, regular weight. */
  .bl-cta { display: inline-flex; align-items: center; gap: var(--space-8); margin-top: var(--space-16); color: var(--foreground); font-weight: var(--fw-regular); font-size: var(--text-body-sm); }
  .bl-card:hover .bl-cta { gap: var(--space-12); }

  .bl-pages { display: flex; align-items: center; justify-content: center; gap: var(--space-16); margin-top: var(--space-64); }
  .bl-nums { display: flex; align-items: center; gap: var(--space-8); }
  .bl-nav { color: var(--muted-foreground); font-size: var(--text-body-sm); font-weight: var(--fw-medium); }
  .bl-nav:hover { color: var(--foreground); text-decoration: none; }
  .bl-nav.is-off { opacity: 0.4; pointer-events: none; }
  .bl-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding-inline: var(--space-8);
    border-radius: var(--radius-md);
    color: var(--muted-foreground);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
  }
  .bl-num:hover { color: var(--foreground); text-decoration: none; }
  .bl-num.is-active { background: var(--foreground); color: var(--background); }

  @media (min-width: 640px) { .bl-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) {
    .bl-wide { padding-inline: 80px; }
    .bl-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
