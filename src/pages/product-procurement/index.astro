---
// Procurement category LP (/product-procurement).
// Section map: PageHeader → product card grid (4 items, 4-col) → CtaEmail → Footer v2
// When Ordering page ships, add 5th item and columns will auto-switch to 3-col.
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/page-headers/PageHeader.astro';
import ProductCardGrid from '../../components/ProductCardGrid.astro';
import CtaEmail from '../../components/CtaEmail.astro';
import navIcons from '../../data/nav-icons.json';

const icons = navIcons as Record<string, string>;

const items = [
  { heading: 'Invoice automation', body: 'Supplier invoices read line by line, automatically.', href: '/product-procurement/invoice-automation', icon: icons['receipt-2'], image: '/media/product-invoice-automation.png' },
  { heading: 'Supplier price tracking', body: 'Every price change caught the day it lands.', href: '/product-procurement/supplier-price-tracking', icon: icons['percentage-circle'], image: '/media/product-supplier-price-tracking.png' },
  { heading: 'Central kitchen', body: 'Cost production and supply your own outlets.', href: '/product-procurement/central-kitchen', icon: icons['building'], image: '/media/product-central-kitchen.png' },
  { heading: 'Anomaly detection', body: 'Flags overcharges and odd line items for review.', href: '/product-procurement/anomaly-detection', icon: icons['fluent-wand'], image: '/media/product-anomaly-detection.png' },
  { heading: 'Ordering suggestions', body: 'Know what to reorder based on usage.', href: '/product-procurement/ordering-suggestions', icon: icons['ordering-suggestions'], image: '/media/product-ordering-suggestions.png' },
];
---

<Layout
  title="Invoice Processing & Supplier Management | Stockifi"
  description="Stockifi reads every supplier invoice, tracks price changes, and flags billing errors before they reach your food cost, without any manual entry."
>
  <!-- 1. Page header — centered -->
  <PageHeader
    eyebrow="Procurement"
    heading="Everything you buy, under one eye"
    subhead="Every kitchen runs on what it buys. Stockifi helps you order the right amounts, supply your own outlets, and know exactly what every supplier charges you."
  />

  <!-- 2. Product card grid -->
  <section class="section">
    <div class="container">
      <ProductCardGrid items={items} />
    </div>
  </section>

  <!-- 3. CTA — variant 2 centered email capture -->
  <CtaEmail
    heading="Ready to get your buying under control?"
    subhead="Book a short call and we'll show you what Stockifi surfaces in your first 30 days."
    bgImages={['/media/cta-bg-1.jpg', '/media/cta-bg-2.jpg', '/media/cta-bg-3.jpg', '/media/cta-bg-4.jpg']}
  />
</Layout>
