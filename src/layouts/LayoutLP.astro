---
// Stripped landing-page layout — used by /intro and /intro/confirm.
// No full nav, no footer. Logo left + single CTA right.
import Layout from './Layout.astro';
import Logo from '../components/Logo.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
import PaletteToggle from '../components/PaletteToggle.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  canonicalUrl?: string;
}
const {
  title,
  description,
  noindex = true,
  canonicalUrl,
} = Astro.props;

const DEMO_HREF = 'https://calendly.com/simon-stockifi/profit-potential';
---

<Layout {title} {description} {noindex} bare>
  <div class="lp-shell">
    <header class="lp-nav">
      <Logo height={28} />
      <Button variant="primary" href={DEMO_HREF}>Book a Demo</Button>
    </header>

    <main>
      <slot />
    </main>

    <Footer showCta={false} />
  </div>
  <PaletteToggle />
  <script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
</Layout>

<style>
  .lp-shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .lp-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-16) var(--space-32);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--background);
  }

  main {
    flex: 1;
  }

  @media (max-width: 640px) {
    .lp-nav {
      padding: var(--space-12) var(--space-24);
    }
  }
</style>
