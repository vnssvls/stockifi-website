---
// Light-mode floating stats card — overlays on a photo section.
// Used in Benefits (FeatureSplit) and By Teams (FeatureTabs).
// Props are intentionally open so each section can pass its own rows.

interface Row {
  label: string;
  value: string;
}

interface Props {
  cardLabel?: string;
  total: string;
  rows: Row[];
  class?: string;
}

const { cardLabel = 'Total savings this month', total, rows, class: className } = Astro.props;
---

<div class:list={['sc-card', className]}>
  <p class="sc-label">{cardLabel}</p>
  <p class="sc-total">{total}</p>
  <div class="sc-rows">
    {rows.map((r) => (
      <div class="sc-row">
        <span class="sc-check" aria-hidden="true">
          <svg viewBox="0 0 12 12" fill="none">
            <path d="M2 6.2 4.8 9 10 3.2" stroke="#34d399" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="sc-row-name">{r.label}</span>
        <span class="sc-row-value">{r.value}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .sc-card {
    width: 240px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 14px;
    padding: 16px 18px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18), 0 1px 4px rgba(0, 0, 0, 0.08);
  }
  .sc-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.38);
    margin-bottom: 6px;
  }
  .sc-total {
    font-size: 20px;
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: #111111;
    line-height: 1;
    margin-bottom: 14px;
  }
  .sc-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }
  .sc-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sc-check {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: grid;
    place-items: center;
  }
  .sc-check svg { width: 12px; height: 12px; display: block; }
  .sc-row-name {
    flex: 1;
    font-size: 11.5px;
    font-weight: 400;
    color: rgba(0, 0, 0, 0.48);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sc-row-value {
    font-size: 11.5px;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: rgba(0, 0, 0, 0.72);
    white-space: nowrap;
  }
</style>
