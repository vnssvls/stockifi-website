---
// Supplier Price Index table — hero widget for /intro.
// Data lives in src/data/price-index.json — update month + items monthly.
interface Item {
  name: string;
  category: string;
  change: number;
}
interface Props {
  month: string;
  items: Item[];
}
const { month, items } = Astro.props;
---

<div class="pit-card">
  <div class="pit-header">
    <p class="pit-title">Top {items.length} sneakiest price hikes</p>
    <p class="pit-month">Last 30 days</p>
  </div>

  <ol class="pit-list">
    {items.map((item, i) => (
      <li class="pit-row">
        <span class="pit-rank">{i + 1}</span>
        <span class="pit-change">
          <svg class="pit-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 19V5M5 12l7-7 7 7"/>
          </svg>
          {item.change}%
        </span>
        <span class="pit-name">{item.name}</span>
        <span class="pit-category">{item.category}</span>
      </li>
    ))}
  </ol>

  <p class="pit-source">Pulled from 800+ suppliers · Updated monthly</p>
</div>

<style>
  .pit-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: var(--space-32);
    width: 100%;
    max-width: 100%;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.15),
      0 12px 32px rgba(0, 0, 0, 0.2);
  }

  /* Header */
  .pit-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-16);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-4);
  }

  .pit-title {
    font-size: var(--text-body-sm);
    font-weight: var(--fw-semibold);
    color: var(--foreground);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pit-month {
    font-size: var(--text-caption);
    color: var(--muted-foreground);
    white-space: nowrap;
    padding-top: 2px;
    opacity: 0.7;
  }

  /* Rows */
  .pit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .pit-row {
    display: grid;
    grid-template-columns: 16px auto 1fr auto;
    align-items: center;
    gap: var(--space-16);
    padding: var(--space-12) 0;
    border-bottom: 1px solid var(--border);
  }

  .pit-row:last-child {
    border-bottom: none;
  }

  .pit-rank {
    font-size: var(--text-body-sm);
    color: var(--muted-foreground);
    text-align: center;
    opacity: 0.6;
  }

  .pit-change {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-body);
    font-weight: var(--fw-semibold);
    color: var(--destructive);
  }

  .pit-arrow {
    flex-shrink: 0;
    stroke: currentColor;
  }

  .pit-name {
    font-size: var(--text-body);
    font-weight: var(--fw-medium);
    color: var(--foreground);
  }

  .pit-category {
    font-size: var(--text-caption);
    font-weight: var(--fw-medium);
    color: var(--muted-foreground);
    background: var(--accent);
    border-radius: 20px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  .pit-source {
    margin-top: var(--space-16);
    font-size: var(--text-caption);
    color: var(--muted-foreground);
    opacity: 0.5;
  }
</style>
