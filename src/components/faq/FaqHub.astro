---
// FAQ hub (Daylight/Graza-style): a plain category filter list on the left + a content
// area on the right that shows ONLY the selected category's FAQs. No parent accordion —
// just the FAQ items are accordions (so nothing "peeks"). The header search filters FAQs
// across every category. Categories come from the `categories` prop, so a page can pass a
// subset (e.g. a solutions-only slice) and the same component renders it.
interface Item { question: string; answer: string; link?: { label: string; href: string }; }
interface Category { id: string; name: string; items: Item[]; }
interface Props { categories: Category[]; }
const { categories } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const lp = (p: string) => (locale === 'en' ? p : `/${locale}${p}`);

const STRINGS = {
  en: { title: 'Frequently asked questions', notePre: "Don't see the answer you're looking for? ", noteLink: 'Get in touch', empty: 'No FAQs match your search.' },
  no: { title: 'Ofte stilte spørsmål',        notePre: 'Finner du ikke svaret du leter etter? ', noteLink: 'Ta kontakt',      empty: 'Ingen spørsmål matcher søket ditt.' },
  da: { title: 'Ofte stillede spørgsmål',     notePre: 'Kan du ikke finde svaret, du leder efter? ', noteLink: 'Kontakt os', empty: 'Ingen spørgsmål matcher din søgning.' },
  sv: { title: 'Vanliga frågor',              notePre: 'Hittar du inte svaret du letar efter? ', noteLink: 'Kontakta oss',   empty: 'Inga frågor matchar din sökning.' },
  nl: { title: 'Veelgestelde vragen',         notePre: 'Vind je niet het antwoord dat je zoekt? ', noteLink: 'Neem contact op', empty: 'Geen vragen komen overeen met je zoekopdracht.' },
  de: { title: 'Häufig gestellte Fragen',     notePre: 'Sie finden nicht die gesuchte Antwort? ', noteLink: 'Kontaktieren Sie uns', empty: 'Keine Fragen entsprechen Ihrer Suche.' },
};
const t = STRINGS[locale as keyof typeof STRINGS] ?? STRINGS.en;
---

<section class="faq-hub section" data-faq-hub>
  <div class="container fh-grid">
    <!-- Left: filter list + contact note -->
    <aside class="fh-aside">
      <nav class="fh-filters" aria-label="FAQ categories">
        {categories.map((c, i) => (
          <button class:list={['fh-filter', i === 0 && 'is-active']} type="button" data-cat={c.id} aria-pressed={i === 0 ? 'true' : 'false'}>{c.name}</button>
        ))}
      </nav>
      <p class="fh-note">{t.notePre}<a href={lp('/contact')}>{t.noteLink}</a>.</p>
    </aside>

    <!-- Right: title + per-category FAQ panels (only the selected one shows) -->
    <div class="fh-content">
      {categories.map((c, i) => (
        <div class="fh-panel" data-cat={c.id} hidden={i !== 0}>
          <h2 class="fh-panel-cat">{c.name}</h2>
          <div class="fh-faqs">
            {c.items.map((it) => (
              <div class="fh-faq" data-faq data-text={`${it.question} ${it.answer}`.toLowerCase()}>
                <h3 class="fh-faq-h">
                  <button class="fh-faq-q" type="button" aria-expanded="false" data-faq-toggle>
                    <span>{it.question}</span>
                    <svg class="fh-faq-chev" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </button>
                </h3>
                <div class="fh-faq-a"><div class="fh-faq-a-inner"><p>{it.answer}{it.link && (<> <a class="fh-faq-link" href={lp(it.link.href)}>{it.link.label}</a></>)}</p></div></div>
              </div>
            ))}
          </div>
        </div>
      ))}
      <p class="fh-empty" data-faq-empty hidden>{t.empty}</p>
    </div>
  </div>
</section>

<style>
  /* Pull up so the layout sits closer to the page header. */
  .faq-hub { padding-top: 0; margin-top: calc(-1 * var(--space-64)); }

  .fh-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); }

  /* ── Category filter ────────────────────────────────────────────── */
  /* Mobile/tablet: a tidy grid of chips so every category reads as tappable
     (not just the active one) and rows stay aligned. Desktop (below) turns this
     into the plain vertical sidebar list. */
  .fh-filters { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); }
  .fh-filter {
    padding: var(--space-12) var(--space-16);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--foreground) 4%, transparent);
    color: var(--muted-foreground);
    font-family: var(--font-body);
    font-size: var(--text-body);
    text-align: center;
    cursor: pointer;
    transition: color 0.18s ease, background-color 0.18s ease, border-color 0.18s ease;
  }
  .fh-filter:hover { color: var(--foreground); }
  .fh-filter.is-active {
    background-color: color-mix(in srgb, var(--foreground) 10%, transparent);
    border-color: color-mix(in srgb, var(--foreground) 22%, transparent);
    color: var(--foreground);
    font-weight: var(--fw-medium);
  }

  .fh-note { margin-top: var(--space-24); color: var(--muted-foreground); font-size: var(--text-body-sm); line-height: var(--lh-body); }
  .fh-note a { color: var(--foreground); text-decoration: underline; }
  .fh-note a:hover { color: var(--primary-light); }

  /* ── Right content ──────────────────────────────────────────────── */
  .fh-panel[hidden] { display: none; }
  /* Category name doubles as the section heading (also groups results during search). */
  .fh-panel-cat { margin-bottom: var(--space-32); font-size: var(--text-h3); font-weight: var(--fw-semibold); color: var(--foreground); }
  .fh-panel + .fh-panel .fh-panel-cat { margin-top: var(--space-48); }

  /* FAQ accordions. */
  .fh-faq { border-top: 1px solid var(--border); }
  .fh-faqs > .fh-faq:first-child { border-top: none; }
  .fh-faq[hidden] { display: none; }
  .fh-faq-h { margin: 0; }
  .fh-faq-q {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    padding: var(--space-16) 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--fw-medium);
    color: var(--foreground);
  }
  .fh-faq-chev { flex: none; color: var(--muted-foreground); transition: transform 0.25s ease; }
  .fh-faq.is-open .fh-faq-chev { transform: rotate(180deg); }
  .fh-faq-a { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.25s ease; }
  .fh-faq.is-open .fh-faq-a { grid-template-rows: 1fr; }
  .fh-faq-a-inner { overflow: hidden; min-height: 0; }
  .fh-faq-a p { padding-bottom: var(--space-16); color: var(--muted-foreground); line-height: var(--lh-body); }
  .fh-faq-link { color: var(--foreground); text-decoration: underline; text-underline-offset: 2px; white-space: nowrap; }
  .fh-faq-link:hover { color: var(--primary-light); }

  .fh-empty { padding: var(--space-32) 0; color: var(--muted-foreground); }

  @media (prefers-reduced-motion: reduce) {
    .fh-faq-a { transition: none; }
  }

  @media (min-width: 1024px) {
    .fh-grid { grid-template-columns: 280px 1fr; gap: var(--space-96); align-items: start; }
    /* Plain vertical list in the sticky sidebar (no chip borders); FAQs scroll. */
    .fh-filters { display: flex; flex-direction: column; flex-wrap: nowrap; gap: var(--space-4); }
    .fh-filter { width: 100%; text-align: left; background: transparent; border: none; }
    .fh-filter.is-active { background-color: color-mix(in srgb, var(--foreground) 7%, transparent); color: var(--foreground); }
    .fh-aside { position: sticky; top: calc(var(--nav-h) + var(--space-24)); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-faq-hub]').forEach((hub) => {
    const filters = Array.from(hub.querySelectorAll<HTMLButtonElement>('.fh-filter'));
    const panels = Array.from(hub.querySelectorAll<HTMLElement>('.fh-panel'));
    const empty = hub.querySelector<HTMLElement>('[data-faq-empty]');
    const search = document.querySelector<HTMLInputElement>('[data-faq-search]');
    let currentCat = filters[0]?.dataset.cat ?? '';

    // Show one category's panel; reset any search filtering on the FAQ items.
    const showCategory = (id: string) => {
      panels.forEach((p) => {
        p.hidden = p.dataset.cat !== id;
        p.querySelectorAll<HTMLElement>('.fh-faq').forEach((f) => { f.hidden = false; });
      });
      filters.forEach((f) => {
        const on = f.dataset.cat === id;
        f.classList.toggle('is-active', on);
        f.setAttribute('aria-pressed', String(on));
      });
      if (empty) empty.hidden = true;
    };

    filters.forEach((f) => {
      f.addEventListener('click', () => { currentCat = f.dataset.cat ?? ''; showCategory(currentCat); });
    });

    // FAQ accordions — independent.
    hub.querySelectorAll<HTMLElement>('.fh-faq').forEach((faq) => {
      faq.querySelector<HTMLButtonElement>('[data-faq-toggle]')?.addEventListener('click', () => {
        const open = faq.classList.toggle('is-open');
        faq.querySelector('[data-faq-toggle]')?.setAttribute('aria-expanded', String(open));
      });
    });

    // Header search — filters FAQs across every category and shows the matches grouped by
    // category (each panel keeps its category label). Clearing returns to the selected one.
    search?.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      if (!q) { showCategory(currentCat); return; }
      let any = false;
      panels.forEach((p) => {
        let hit = false;
        p.querySelectorAll<HTMLElement>('.fh-faq').forEach((faq) => {
          const match = (faq.dataset.text || '').includes(q);
          faq.hidden = !match;
          if (match) hit = true;
        });
        p.hidden = !hit;
        if (hit) any = true;
      });
      filters.forEach((f) => { f.classList.remove('is-active'); f.setAttribute('aria-pressed', 'false'); });
      if (empty) empty.hidden = any;
    });
  });
</script>
