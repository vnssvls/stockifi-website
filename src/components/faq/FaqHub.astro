---
// FAQ hub (Figma 132:734): a category filter strip + a "double accordion". Each category
// is a collapsible block — its name sits in a narrow left column, its FAQ list in a wider
// right column — and each FAQ inside is its own accordion. The strip and the category
// heads share one open state: "View all" = every category collapsed; clicking a category
// opens just that one (its FAQs still collapsed). An optional search (a [data-faq-search]
// input anywhere on the page, e.g. in the page header) filters FAQs across all categories.
interface Item { question: string; answer: string; }
interface Category { id: string; name: string; items: Item[]; }
interface Props { categories: Category[]; }
const { categories } = Astro.props;
---

<section class="faq-hub section" data-faq-hub>
  <div class="fh-wide">
    <!-- Category filter strip -->
    <div class="fh-strip" role="tablist" aria-label="FAQ categories">
      <button class="fh-tab is-active" type="button" role="tab" aria-selected="true" data-cat="all">View all</button>
      {categories.map((c) => (
        <button class="fh-tab" type="button" role="tab" aria-selected="false" data-cat={c.id}>{c.name}</button>
      ))}
    </div>

    <!-- Double accordion -->
    <div class="fh-list">
      {categories.map((c) => (
        <div class="fh-cat" data-cat={c.id} id={`faq-${c.id}`}>
          <h2 class="fh-cat-head-wrap">
            <button class="fh-cat-head" type="button" aria-expanded="false" data-cat-toggle>
              <span class="fh-cat-name">{c.name}</span>
              <svg class="fh-cat-chev" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </button>
          </h2>
          <div class="fh-cat-panel">
            <div class="fh-cat-panel-inner">
              <div class="fh-faqs">
                {c.items.map((it) => (
                  <div class="fh-faq" data-faq data-text={`${it.question} ${it.answer}`.toLowerCase()}>
                    <h3 class="fh-faq-h">
                      <button class="fh-faq-q" type="button" aria-expanded="false" data-faq-toggle>
                        <span>{it.question}</span>
                        <svg class="fh-faq-chev" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                      </button>
                    </h3>
                    <div class="fh-faq-a"><div class="fh-faq-a-inner"><p>{it.answer}</p></div></div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
      <p class="fh-empty" data-faq-empty hidden>No FAQs match your search.</p>
    </div>
  </div>
</section>

<style>
  /* Standard container gutter (not the wide 80px). Pull up so the strip sits closer to
     the page header. */
  .faq-hub { padding-top: 0; margin-top: calc(-1 * var(--space-64)); }
  .fh-wide { width: 100%; max-width: var(--container-max); margin-inline: auto; padding-inline: var(--gutter); }

  /* ── Category strip — bare, centred tabs (no bar / no full-width container) ──────── */
  .fh-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-8);
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
  }
  .fh-tab {
    padding: var(--space-8) var(--space-16);
    border: none;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--muted-foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition: color 0.18s ease, background-color 0.18s ease;
  }
  .fh-tab:hover { color: var(--foreground); }
  .fh-tab.is-active { background-color: color-mix(in srgb, var(--foreground) 8%, transparent); color: var(--foreground); }

  /* ── Double accordion ───────────────────────────────────────────── */
  .fh-list { margin-top: var(--space-64); }
  .fh-cat { border-top: 1px solid var(--border); scroll-margin-top: calc(var(--nav-h) + var(--space-16)); }
  .fh-list .fh-cat:last-of-type { border-bottom: 1px solid var(--border); }
  .fh-cat[hidden] { display: none; }

  .fh-cat-head-wrap { margin: 0; }
  .fh-cat-head {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    padding: var(--space-32) 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .fh-cat-name { font-family: var(--font-heading); font-size: var(--text-h4); font-weight: var(--fw-semibold); color: var(--foreground); }
  .fh-cat-chev { flex: none; color: var(--muted-foreground); transition: transform 0.3s ease; }
  .fh-cat.is-open .fh-cat-chev { transform: rotate(180deg); }

  /* Collapsible panel (grid-rows 0fr→1fr). min-height:0 is required because the panel is a
     grid item (in the 2-col category grid) and would otherwise keep its content height. */
  .fh-cat-panel { display: grid; grid-template-rows: 0fr; min-height: 0; transition: grid-template-rows 0.35s ease; }
  .fh-cat.is-open .fh-cat-panel { grid-template-rows: 1fr; }
  .fh-cat-panel-inner { overflow: hidden; min-height: 0; }

  /* Inner FAQ accordions. */
  .fh-faq { border-top: 1px solid var(--border); }
  .fh-faqs > .fh-faq:first-child { border-top: none; }
  .fh-faq[hidden] { display: none; }
  .fh-faq-h { margin: 0; }
  .fh-faq-q {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    padding: var(--space-16) 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--fw-medium);
    color: var(--foreground);
  }
  .fh-faq-chev { flex: none; color: var(--muted-foreground); transition: transform 0.25s ease; }
  .fh-faq.is-open .fh-faq-chev { transform: rotate(180deg); }
  .fh-faq-a { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.25s ease; }
  .fh-faq.is-open .fh-faq-a { grid-template-rows: 1fr; }
  .fh-faq-a-inner { overflow: hidden; min-height: 0; }
  .fh-faq-a p { padding-bottom: var(--space-16); color: var(--muted-foreground); line-height: var(--lh-body); }

  .fh-empty { padding: var(--space-32) 0; color: var(--muted-foreground); }

  @media (prefers-reduced-motion: reduce) {
    .fh-cat-panel,
    .fh-faq-a { transition: none; }
  }

  @media (min-width: 1024px) {
    /* Category name in a left column with breathing room, FAQ list in a wider right col. */
    .fh-cat { display: grid; grid-template-columns: 340px 1fr; gap: var(--space-48); align-items: start; }
    .fh-cat-panel-inner { padding-bottom: var(--space-32); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-faq-hub]').forEach((hub) => {
    const tabs = Array.from(hub.querySelectorAll<HTMLButtonElement>('.fh-tab'));
    const cats = Array.from(hub.querySelectorAll<HTMLElement>('.fh-cat'));
    const empty = hub.querySelector<HTMLElement>('[data-faq-empty]');
    const search = document.querySelector<HTMLInputElement>('[data-faq-search]');

    const setTab = (id: string) => {
      tabs.forEach((t) => {
        const on = t.dataset.cat === id;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', String(on));
      });
    };
    const setCatOpen = (cat: HTMLElement, open: boolean) => {
      cat.classList.toggle('is-open', open);
      cat.querySelector('[data-cat-toggle]')?.setAttribute('aria-expanded', String(open));
    };
    // Filter the list: "all" shows every category collapsed; a category id shows ONLY
    // that category (others hidden), expanded.
    const setFilter = (id: string) => {
      cats.forEach((c) => {
        const sel = c.dataset.cat === id;
        c.hidden = id !== 'all' && !sel;
        setCatOpen(c, id !== 'all' && sel);
      });
      setTab(id);
    };

    // Strip tabs filter the list.
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => setFilter(tab.dataset.cat || 'all'));
    });

    // Category heads toggle their own block open/closed (independent of the filter).
    cats.forEach((cat) => {
      cat.querySelector<HTMLButtonElement>('[data-cat-toggle]')?.addEventListener('click', () => {
        setCatOpen(cat, !cat.classList.contains('is-open'));
      });
    });

    // Inner FAQ accordions — independent.
    hub.querySelectorAll<HTMLElement>('.fh-faq').forEach((faq) => {
      faq.querySelector<HTMLButtonElement>('[data-faq-toggle]')?.addEventListener('click', () => {
        const open = faq.classList.toggle('is-open');
        faq.querySelector('[data-faq-toggle]')?.setAttribute('aria-expanded', String(open));
      });
    });

    // Search — filter FAQs across categories; open categories that have matches.
    const resetSearch = () => {
      cats.forEach((c) => {
        c.hidden = false;
        c.querySelectorAll<HTMLElement>('.fh-faq').forEach((f) => { f.hidden = false; });
      });
      if (empty) empty.hidden = true;
      setFilter('all');
    };
    search?.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      if (!q) { resetSearch(); return; }
      let any = false;
      cats.forEach((cat) => {
        let hit = false;
        cat.querySelectorAll<HTMLElement>('.fh-faq').forEach((faq) => {
          const match = (faq.dataset.text || '').includes(q);
          faq.hidden = !match;
          if (match) hit = true;
        });
        cat.hidden = !hit;
        setCatOpen(cat, hit);
        if (hit) any = true;
      });
      setTab('all');
      if (empty) empty.hidden = any;
    });
  });
</script>
