---
// Blog library — Section 1. Centered header, a category filter row, and a
// responsive grid of vertical BlogCards. Filtering is client-side: each card
// carries data-category (from BlogCard) and non-matching cards get [hidden].
import BlogCard from './BlogCard.astro';

interface Post {
  title: string;
  excerpt?: string;
  category?: string;
  date?: Date;
  readTime?: string;
  image?: string;
  imageAlt?: string;
  href?: string;
}
interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  categories?: string[];
  posts: Post[];
}
const { eyebrow, heading, subhead, categories = [], posts } = Astro.props;
---

<section class="blog-grid section" data-blog-grid>
  <div class="container">
    <header class="bg-head">
      {eyebrow && <p class="tagline">{eyebrow}</p>}
      <h2>{heading}</h2>
      {subhead && <p class="bg-subhead text-muted">{subhead}</p>}
    </header>

    {categories.length > 0 && (
      <div class="bg-filters" role="group" aria-label="Filter posts by category">
        <button class="bg-filter" type="button" data-filter="*" aria-pressed="true">View all</button>
        {categories.map((c) => (
          <button class="bg-filter" type="button" data-filter={c} aria-pressed="false">{c}</button>
        ))}
      </div>
    )}

    <div class="bg-cards">
      {posts.map((p) => <BlogCard {...p} orientation="vertical" />)}
    </div>
  </div>
</section>

<style>
  .bg-head { text-align: center; max-width: 48rem; margin-inline: auto; }
  .bg-head h2 { margin-top: var(--space-12); }
  .bg-subhead { margin-top: var(--space-16); font-size: var(--text-body-lg); }

  .bg-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-8);
    margin-top: var(--space-48);
  }
  .bg-filter {
    padding: var(--space-8) var(--space-16);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-full);
    color: var(--muted-foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .bg-filter:hover { color: var(--foreground); }
  .bg-filter[aria-pressed='true'] { color: var(--foreground); border-color: var(--border); }

  .bg-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-48) var(--space-32);
    margin-top: var(--space-48);
  }

  @media (max-width: 1023px) {
    .bg-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .bg-cards { grid-template-columns: 1fr; gap: var(--space-32); }
  }
</style>

<script>
  document.querySelectorAll('[data-blog-grid]').forEach((root) => {
    const filters = Array.from(root.querySelectorAll<HTMLButtonElement>('.bg-filter'));
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.bc'));
    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        filters.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        cards.forEach((c) => {
          c.hidden = !(f === '*' || c.getAttribute('data-category') === f);
        });
      });
    });
  });
</script>
