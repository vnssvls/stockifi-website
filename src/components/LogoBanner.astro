---
// Logo banner — social-proof logo row, rendered as uniform white silhouettes so the
// mixed brand marks read on the dark shell.
//   variant="scroll" (default) — auto-scrolling marquee, pauses on hover.
//   variant="static"          — one centered, wrapping row, no motion.
// Fed integration logos for now — swap to client logos when we have those assets.
// `screen` flag: the logo is a white mark on a solid (black) background — use
// mix-blend-mode: screen to drop the background instead of the brightness/invert filter.
interface Logo { name: string; logo: string; screen?: boolean }
interface Props {
  label?: string;
  logos: Logo[];
  variant?: 'scroll' | 'static';
}
const { label, logos, variant = 'scroll' } = Astro.props;
// Marquee needs the list duplicated for a seamless -50% loop; static shows it once.
const items = variant === 'scroll' ? [...logos, ...logos] : logos;
---

<section class:list={['logo-banner section-sm', `lb--${variant}`]}>
  <div class="container">
    {label && <p class="lb-label text-muted">{label}</p>}
    <div class="lb-viewport">
      <div class="lb-track">
        {items.map((l) => (
          <img class:list={['lb-logo', l.screen && 'lb-logo--screen']} src={l.logo} alt={l.name} width="120" height="36" loading="lazy" />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .lb-label {
    text-align: center;
    margin-bottom: var(--space-32);
    font-size: var(--text-body-sm);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .lb-logo {
    flex: none;
    height: 36px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }
  /* White-on-black marks: screen drops the black background (the silhouette filter would
     turn the whole opaque rectangle white). */
  .lb-logo--screen { filter: none; mix-blend-mode: screen; }

  /* ── Scroll variant ── */
  .lb--scroll .lb-viewport {
    overflow: hidden;
    /* Solid backdrop so the screen-blended marks have the page colour to blend against —
       the mask below isolates this box, which otherwise left their black bg showing. */
    background: var(--background);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .lb--scroll .lb-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: lb-scroll 45s linear infinite;
  }
  /* Trailing margin (not flex gap) so the two copies are identical width and translateX
     -50% wraps seamlessly — a seam gap would make the loop jump. */
  .lb--scroll .lb-logo { margin-right: var(--space-64); }
  .lb--scroll .lb-viewport:hover .lb-track { animation-play-state: paused; }

  /* ── Static variant ── */
  .lb--static .lb-track {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-32) var(--space-64);
  }

  @keyframes lb-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lb--scroll .lb-track { animation: none; flex-wrap: wrap; justify-content: center; width: auto; }
  }
</style>
