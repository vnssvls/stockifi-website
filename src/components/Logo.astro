---
// Stockifi horizontal lockup (submark + wordmark). Static SVG, brand colors fixed;
// the white variant reads on the dark shell. For light mode, swap /logo.svg for the
// dark variant already saved at /logo-dark.svg.
const RATIO = 941 / 174; // intrinsic aspect of logo.svg (horizontal lockup)

interface Props {
  href?: string;
  height?: number;
  class?: string;
}
const { href = '/', height = 30, class: className } = Astro.props;
---

<a class:list={['logo', className]} href={href} aria-label="Stockifi home" style={`--logo-h:${height}px`}>
  <img src="/logo.svg" alt="Stockifi" width={Math.round(height * RATIO)} height={height} />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    flex: none;
  }
  .logo img {
    display: block;
    height: var(--logo-h, 30px);
    width: auto;
  }
</style>
