}

.rla-puff {
  position: absolute;
  left: 50%;
  bottom: 8px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(149, 101, 219, 0.25);
  transform: translateX(-50%);
  animation: rla-puff 2s ease-out infinite;
