<script define:vars={{ jsT: { errFirstName: s.errFirstName, errLastName: s.errLastName, errEmail: s.errEmail, errPhone: s.errPhone, errCompany: s.errCompany, errLocations: s.errLocations, errInvalidEmail: s.errInvalidEmail, errSubmit: s.errSubmit, submit: s.submit, submitting: s.submitting } }}>
const PORTAL_ID = '48915892';
const FORM_GUID = '32c272c3-584c-4db1-883f-1cf00fa44a1c';

const form = document.getElementById('bd-form');
const successPanel = document.getElementById('bd-success');
const submitBtn = document.getElementById('bd-btn');
const submitLabel = document.getElementById('bd-btn-label');
const submitArrow = document.getElementById('bd-btn-arrow');
const submitSpinner = document.getElementById('bd-btn-spinner');

const REQUIRED = [
  { id: 'bd-fname',     errId: 'err-fname',     msg: jsT.errFirstName },
  { id: 'bd-lname',     errId: 'err-lname',     msg: jsT.errLastName },
  { id: 'bd-email',     errId: 'err-email',     msg: jsT.errEmail },
  { id: 'bd-phone',     errId: 'err-phone',     msg: jsT.errPhone },
  { id: 'bd-company',   errId: 'err-company',   msg: jsT.errCompany },
  { id: 'bd-locations', errId: 'err-locations', msg: jsT.errLocations },
];

function validate() {
  let valid = true;
  REQUIRED.forEach(({ id, errId, msg }) => {
    const el = document.getElementById(id);
    const err = document.getElementById(errId);
    const wrapper = el?.closest('.bd-field');
    if (!el || !err || !wrapper) return;

    const empty = !el.value.trim();
    const badEmail = id === 'bd-email' && !empty && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value);

    if (empty || badEmail) {
      wrapper.classList.add('is-error');
      err.textContent = badEmail ? jsT.errInvalidEmail : msg;
      valid = false;
    } else {
      wrapper.classList.remove('is-error');
      err.textContent = '';
    }
  });
  return valid;
}

const formError = document.getElementById('bd-form-error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!validate()) return;

  formError?.classList.add('bd-hidden');
  submitBtn.disabled = true;
  submitLabel.textContent = jsT.submitting;
  submitArrow?.classList.add('bd-hidden');
  submitSpinner?.classList.remove('bd-hidden');

  const data = new FormData(form);
  const fields = Array.from(data.entries())
    .filter(([, v]) => String(v).trim())
    .map(([name, value]) => ({ name, value: String(value) }));

  const hutk = document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith('hubspotutk='))?.split('=')[1];

  try {
    const res = await fetch(
      `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_GUID}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fields,
          context: {
            pageUri: window.location.href,
            pageName: document.title,
            ...(hutk && { hutk }),
          },
        }),
      }
    );
    if (!res.ok) throw new Error('HubSpot submission failed');

    showSuccess();
  } catch {
    submitBtn.disabled = false;
    submitLabel.textContent = jsT.submit;
    submitArrow?.classList.remove('bd-hidden');
    submitSpinner?.classList.add('bd-hidden');
    if (formError) {
      formError.textContent = jsT.errSubmit;
      formError.classList.remove('bd-hidden');
    }
  }
});

function showSuccess() {
  form.classList.add('bd-hidden');
  successPanel.classList.remove('bd-hidden');
}

try {
  const params = new URLSearchParams(window.location.search);
  if (params.get('preview') === 'success') {
    showSuccess();
    params.delete('preview');
    const qs = params.toString();
    window.history.replaceState({}, '', window.location.pathname + (qs ? '?' + qs : ''));
  }
} catch (_) {}

form?.querySelectorAll('.bd-input, .bd-select').forEach((el) => {
  el.addEventListener('input', () => {
    el.closest('.bd-field')?.classList.remove('is-error');
  });
});
</script>
