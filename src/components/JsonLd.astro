---
// Renders one or more JSON-LD objects as a <script type="application/ld+json">.
// `set:html` keeps the JSON unescaped (so quotes stay quotes); we additionally
// escape `<` to < so answer/title content can never break out of the script.
// Use sitewide in Layout for the global graph, or per page via `slot="head"`.
interface Props {
  schema: object | object[];
}
const { schema } = Astro.props;
const list = Array.isArray(schema) ? schema : [schema];
const json = JSON.stringify(list.length === 1 ? list[0] : list).replace(/</g, '\\u003c');
---
<script type="application/ld+json" is:inline set:html={json} />
