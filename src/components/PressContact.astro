---
// Press & Media — closing band: media-inquiries contact + brand-kit download.
// Centered, bordered block (same translucent-card treatment as the contact page).
// Strings come in localized from the page; email + brandKitHref are constants.
import Button from './Button.astro';

interface Props {
  heading: string;
  body: string;
  email: string;
  contactLabel: string;
  brandKitLabel: string;
  brandKitHref: string;
}
const { heading, body, email, contactLabel, brandKitLabel, brandKitHref } = Astro.props;
---

<section class="section press-contact">
  <div class="container">
    <div class="pc-card">
      <h2 class="pc-heading">{heading}</h2>
      <p class="pc-body text-muted">{body}</p>
      <div class="pc-actions">
        <Button variant="primary" href={`mailto:${email}`}>
          {contactLabel}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></svg>
        </Button>
        <Button variant="secondary" href={brandKitHref}>
          {brandKitLabel}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12" /><path d="m7 10 5 5 5-5" /><path d="M5 21h14" /></svg>
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .pc-card {
    --pc-border: #2e283e7d;
    max-width: 56rem;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-16);
    padding: var(--space-64) var(--space-32);
    border: 1px solid var(--pc-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.2);
  }
  .pc-heading { font-size: var(--text-h3); }
  .pc-body { font-size: var(--text-body-lg); max-width: 52ch; }
  .pc-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
    margin-top: var(--space-8);
  }
</style>
