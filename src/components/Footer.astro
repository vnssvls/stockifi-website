---
// Site footer (Figma 67:365 full / 67:565 links-only). Themed dark, wired to the IA.
// showCta=true (default): CTA heading + text + a single secondary button on the left,
//   link columns on the right.
// showCta=false (variant 2): no CTA block — just the link columns, full width.
// A large half-clipped "Stockifi" wordmark (real SVG) sits decoratively at the bottom.
// "Follow us" column holds the social icons. DRAFT copy + placeholder social URLs.
import Button from './Button.astro';
import wordmark from '../assets/wordmark.svg?raw';

interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;

const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Recipe Costing', href: '/product/recipe-costing' },
      { label: 'Supplier Price Tracking', href: '/product/supplier-price-tracking' },
      { label: 'POS & Consumption', href: '/product/pos-integration' },
      { label: 'Inventory & Variance', href: '/product/inventory-variance' },
      { label: 'Integrations', href: '/integrations' },
    ],
  },
  {
    title: 'Solutions',
    links: [
      { label: 'Independent restaurants', href: '/solutions/independent-restaurants' },
      { label: 'Restaurant groups', href: '/solutions/restaurant-groups' },
      { label: 'Hotels with F&B', href: '/solutions/hotels' },
      { label: 'Bars', href: '/solutions/bars' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'Customer Stories', href: '/customer-stories' },
      { label: 'Savings Calculator', href: '/savings-calculator' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'Pricing', href: '/pricing' },
      { label: 'Press & Media', href: '/press' },
      { label: 'Contact', href: '/contact' },
    ],
  },
];

// TODO: confirm real social URLs with V (placeholders for now).
const socials = [
  { name: 'LinkedIn', href: '#', viewBox: '0 0 24 24', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'YouTube', href: '#', viewBox: '0 0 24 24', path: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' },
];

const year = new Date().getFullYear();
---

<footer class:list={['site-footer', !showCta && 'site-footer--links-only']}>
  <div class="footer-top">
    {showCta && (
      <div class="footer-cta">
        <h2 class="footer-heading">Take control of your food cost.</h2>
        <p class="footer-text text-muted">See where margin leaks across recipes, suppliers, and sales. Book a demo and we will map it with you.</p>
        <div class="footer-buttons">
          <Button variant="secondary" href="/contact">Book a demo</Button>
        </div>
      </div>
    )}

    <nav class="footer-cols" aria-label="Footer">
      {columns.map((col) => (
        <div class="footer-col">
          <p class="footer-col-title">{col.title}</p>
          <ul>
            {col.links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>
      ))}

      <div class="footer-col">
        <p class="footer-col-title">Follow us</p>
        <ul class="footer-social">
          {socials.map((s) => (
            <li>
              <a href={s.href} aria-label={s.name}>
                <svg width="20" height="20" viewBox={s.viewBox} fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <p class="text-muted">© {year} Stockifi. All rights reserved.</p>
    <ul class="footer-legal">
      <li><a href="/privacy-policy">Privacy Policy</a></li>
      <li><a href="/terms-conditions">Terms &amp; Conditions</a></li>
    </ul>
  </div>

  <!-- Decorative oversized wordmark (real SVG), full-bleed and half-clipped by the
       footer's bottom edge. Inlined so the fill can read the --border token. -->
  <div class="footer-wordmark" aria-hidden="true" set:html={wordmark}></div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    isolation: isolate; /* own stacking context so the wordmark sits above bg, below content */
    background: var(--muted);
    border-top: 1px solid var(--border);
    padding-block: var(--space-64) var(--space-128);
  }

  /* The footer ignores the global container/gutter — it runs full width with a small
     20px edge inset on its content. The wordmark below bleeds fully to the edges. */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-48);
    padding-inline: 20px;
  }

  .footer-heading { font-size: var(--text-h4); max-width: 16ch; }
  .footer-text { margin-top: var(--space-16); max-width: 44ch; font-size: var(--text-body-sm); }
  .footer-buttons { display: flex; flex-wrap: wrap; gap: var(--space-12); margin-top: var(--space-24); }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-32) var(--space-24);
  }
  .footer-col-title {
    margin-bottom: var(--space-16);
    font-family: var(--font-heading);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-semibold);
    color: var(--foreground);
  }
  .footer-col ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: var(--space-12); }
  .footer-col a { color: var(--muted-foreground); font-size: var(--text-body-sm); }
  .footer-col a:hover { color: var(--foreground); text-decoration: none; }

  /* Social icons inside the "Follow us" column */
  .footer-social { flex-direction: row !important; gap: var(--space-16) !important; }
  .footer-social a { display: inline-flex; color: var(--muted-foreground); }
  .footer-social a:hover { color: var(--foreground); }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    margin-top: var(--space-48);
    padding-top: var(--space-24);
    padding-inline: 20px;
    border-top: 1px solid var(--border);
    font-size: var(--text-body-sm);
  }
  .footer-legal { display: flex; gap: var(--space-24); margin: 0; padding: 0; list-style: none; }
  .footer-legal a { color: var(--muted-foreground); font-size: var(--text-body-sm); }
  .footer-legal a:hover { color: var(--foreground); text-decoration: none; }

  /* Oversized brand wordmark (real SVG) anchored to the bottom and pushed down so only
     its top portion shows; the footer's overflow:hidden clips the rest. Sits behind
     content via z-index:-1 within the footer's own stacking context, faded back. */
  .footer-wordmark {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -1;
    transform: translateY(28%);
    color: var(--border); /* subtle, matches the input/border tone (#2A2A35) */
    pointer-events: none;
    user-select: none;
  }
  .footer-wordmark :global(svg) { display: block; width: 100%; height: auto; }

  @media (min-width: 1024px) {
    .footer-top { grid-template-columns: 1fr 1.6fr; gap: var(--space-96); align-items: start; }
    /* Variant 2 (no CTA): links span the full width */
    .site-footer--links-only .footer-top { grid-template-columns: 1fr; }
  }
</style>
