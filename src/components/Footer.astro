---
// Site footer. Two variants:
// showCta=true  (variant 1, Figma 67:365): CTA heading + text + a secondary button on the
//   left, link columns on the right, social icons in a "Follow us" column.
// showCta=false (variant 2, Figma 160:753 "Footer 15"): logo + contact + social icons in a
//   left brand column, link columns on the right; a legal row, a divider, then the large
//   half-clipped "Stockifi" wordmark "peeking" at the bottom. No CTA block (more room for
//   the columns). This is the deployed footer.
import Button from './Button.astro';
import Logo from './Logo.astro';
import wordmark from '../assets/wordmark.svg?raw';
import { getNavStrings } from '../data/nav-i18n';

interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;

// Locale-aware: labels from the shared nav strings, internal links prefixed.
const locale = Astro.currentLocale ?? 'en';
const lp = (p: string) => (locale === 'en' ? p : `/${locale}${p}`);
const t = getNavStrings(locale);

// Curated (not exhaustive): the top pages per area. The full Product/Solutions sets
// live in the nav mega menus — the footer carries a representative slice + Integrations.
const columns = [
  {
    title: t.product,
    links: [
      { label: t.procurementGroup, href: lp('/product-procurement') },
      { label: t.inventoryGroup, href: lp('/product-inventory-management') },
      { label: t.biGroup, href: lp('/product-business-intelligence') },
      { label: t.integrations, href: lp('/integrations') },
    ],
  },
  {
    title: t.solutions,
    links: [
      { label: t.independentRestaurants, href: lp('/solutions/independent-restaurants') },
      { label: t.restaurantGroups, href: lp('/solutions/restaurant-groups') },
      { label: t.hotelsWithFnB, href: lp('/solutions/hotels') },
      { label: t.bars, href: lp('/solutions/bars') },
    ],
  },
  {
    title: t.resources,
    links: [
      { label: t.blog, href: lp('/blog') },
      { label: t.customerStories, href: lp('/customer-stories') },
      { label: t.faq, href: lp('/faq') },
      // Post-launch: Press & Media, Savings Calculator
    ],
  },
  {
    title: t.company,
    links: [
      { label: t.pricing, href: lp('/pricing') },
      { label: t.contact, href: lp('/contact') },
      { label: t.login, href: 'https://web.stockifi.io/#/login' },
    ],
  },
];

const socials = [
  { name: 'LinkedIn', href: 'https://linkedin.com/company/stockifi-io', viewBox: '0 0 24 24', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'YouTube', href: 'https://youtube.com/@stockifi-io', viewBox: '0 0 24 24', path: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' },
];

const year = new Date().getFullYear();
---

<footer class:list={['site-footer', !showCta && 'site-footer--links-only']}>
  <div class="footer-top">
    {showCta ? (
      <div class="footer-cta">
        <h2 class="footer-heading">{t.footerCtaHeading}</h2>
        <p class="footer-text text-muted">{t.footerCtaText}</p>
        <div class="footer-buttons">
          <Button variant="secondary" href={lp('/contact')}>{t.bookDemo}</Button>
        </div>
      </div>
    ) : (
      <div class="footer-brand">
        <Logo height={32} />
        <div class="footer-contact">
          <p class="footer-contact-title">{t.footerContact}</p>
          <a href="tel:+4721051403">+47 21 05 14 03</a>
          <a href="mailto:support@stockifi.io">support@stockifi.io</a>
        </div>
        <ul class="footer-social">
          {socials.map((s) => (
            <li>
              <a href={s.href} aria-label={s.name} target="_blank" rel="noopener noreferrer">
                <svg width="22" height="22" viewBox={s.viewBox} fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <nav class="footer-cols" aria-label="Footer">
      {columns.map((col) => (
        <div class="footer-col">
          <p class="footer-col-title">{col.title}</p>
          <ul>
            {col.links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>
      ))}

      {showCta && (
        <div class="footer-col">
          <p class="footer-col-title">{t.footerFollow}</p>
          <ul class="footer-social">
            {socials.map((s) => (
              <li>
                <a href={s.href} aria-label={s.name} target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox={s.viewBox} fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </nav>
  </div>

  <div class="footer-bottom">
    <p class="text-muted">© {year} Stockifi. {t.footerRights}</p>
    <ul class="footer-legal">
      <li><a href={lp('/privacy-policy')}>{t.privacyPolicy}</a></li>
      <li><a href={lp('/terms-conditions')}>{t.termsConditions}</a></li>
    </ul>
  </div>

  <!-- Variant 2: a divider sits between the legal row and the peeking wordmark. -->
  {!showCta && <div class="footer-rule" aria-hidden="true"></div>}

  <!-- Decorative oversized wordmark (real SVG), full-bleed and half-clipped ("peeking")
       by the footer's bottom edge. Inlined so the fill can read the --border token. -->
  <div class="footer-wordmark" aria-hidden="true" set:html={wordmark}></div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    background: var(--muted);
    border-top: 1px solid var(--border);
    /* No bottom padding: the wordmark is the last element and sits flush at the bottom. */
    padding-block: var(--space-64) 0;
  }

  /* The footer ignores the global container/gutter — it runs full width with a small
     20px edge inset on its content. The wordmark below bleeds fully to the edges. */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-48);
    padding-inline: 20px;
  }

  /* Variant 1 — CTA block */
  .footer-heading { font-size: var(--text-h4); max-width: 16ch; }
  .footer-text { margin-top: var(--space-16); max-width: 44ch; font-size: var(--text-body-sm); }
  .footer-buttons { display: flex; flex-wrap: wrap; gap: var(--space-12); margin-top: var(--space-24); }

  /* Variant 2 — brand column (logo + contact + socials) */
  .footer-brand { display: flex; flex-direction: column; gap: var(--space-32); align-items: flex-start; }
  .footer-contact { display: flex; flex-direction: column; gap: var(--space-4); font-size: var(--text-body-sm); }
  .footer-contact-title { font-weight: var(--fw-semibold); color: var(--foreground); }
  .footer-contact a { color: var(--muted-foreground); text-decoration: underline; }
  .footer-contact a:hover { color: var(--foreground); }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-32) var(--space-24);
  }
  .footer-col-title {
    margin-bottom: var(--space-16);
    font-family: var(--font-heading);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-semibold);
    color: var(--foreground);
  }
  .footer-col ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: var(--space-12); }
  .footer-col a { color: var(--muted-foreground); font-size: var(--text-body-sm); }
  .footer-col a:hover { color: var(--foreground); text-decoration: none; }

  /* Social icon rows (left brand column in v2, "Follow us" column in v1) */
  .footer-social { display: flex; flex-direction: row; gap: var(--space-16); margin: 0; padding: 0; list-style: none; }
  .footer-social a { display: inline-flex; color: var(--muted-foreground); }
  .footer-social a:hover { color: var(--foreground); }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    margin-top: var(--space-48);
    padding-top: var(--space-24);
    padding-inline: 20px;
    border-top: 1px solid var(--border);
    font-size: var(--text-body-sm);
  }
  .footer-legal { display: flex; gap: var(--space-24); margin: 0; padding: 0; list-style: none; }
  .footer-legal a { color: var(--muted-foreground); font-size: var(--text-body-sm); text-decoration: underline; }
  .footer-legal a:hover { color: var(--foreground); }

  /* Variant 2: no top border on the legal row (the divider sits BELOW it instead). */
  .site-footer--links-only .footer-bottom { border-top: none; padding-top: 0; margin-top: var(--space-64); }
  .footer-rule { height: 1px; margin-top: var(--space-32); margin-inline: 20px; background: var(--border); }

  /* Oversized brand wordmark (real SVG), full-bleed, in NORMAL FLOW below the divider so
     the two never overlap. The wrapper's aspect-ratio is shorter than the mark's natural
     712/146, so overflow:hidden clips the bottom of the letters and only the top "peeks"
     at the footer's bottom edge — deterministic at any viewport width. */
  .footer-wordmark {
    width: 100%;
    margin-top: var(--space-48);
    aspect-ratio: 712 / 104;
    overflow: hidden;
    color: var(--border); /* subtle, matches the input/border tone */
    pointer-events: none;
    user-select: none;
  }
  .footer-wordmark :global(svg) { display: block; width: 100%; height: auto; }

  @media (min-width: 1024px) {
    /* Variant 1 (CTA): copy left, links right */
    .footer-top { grid-template-columns: 1fr 1.6fr; gap: var(--space-96); align-items: start; }
    /* Variant 2 (Footer 15): brand column left, link columns right */
    .site-footer--links-only .footer-top { grid-template-columns: minmax(0, 360px) 1fr; gap: var(--space-64); }
  }
</style>
