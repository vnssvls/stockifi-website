---
// Product category card grid — icon + heading + body, bordered, linkable.
// 5 items → 3-col Parker layout (bottom 2 stretch to ~50% via flex-grow); 4 → 4-col.
// Card: icon top-left, title+desc+arrow at bottom (space-between).
// Hover: radial gradient spotlight follows cursor via --mouse-x / --mouse-y CSS vars.
interface Item { heading: string; body: string; icon?: string; href?: string; image?: string; }
interface Props { items: Item[]; columns?: 3 | 4; }
const { items, columns } = Astro.props;
const cols = columns ?? (items.length >= 5 ? 3 : 4);
---

<div class:list={['product-card-grid', `pcg-cols-${cols}`]}>
  {items.map((it) => (
    <article class:list={['pcg-item', it.href && 'pcg-item--linked', it.image && 'pcg-item--photo']}>
      {it.href && <a class="pcg-cover-link" href={it.href} aria-label={it.heading}></a>}
      {it.image && (
        <div class="pcg-bg" aria-hidden="true">
          <img src={it.image} alt="" loading="lazy" />
        </div>
      )}
      <div class="pcg-inner">
        <span class="pcg-icon" aria-hidden="true">
          {it.icon ? <Fragment set:html={it.icon} /> : (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          )}
        </span>
        <div class="pcg-bottom">
          <div class="pcg-text">
            <h3 class="pcg-title">{it.heading}</h3>
            <p class="pcg-body">{it.body}</p>
          </div>
          {it.href && (
            <span class="pcg-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          )}
        </div>
      </div>
    </article>
  ))}
</div>

<style>
  /* ── Grid ──────────────────────────────────────────────────────────────────── */
  .product-card-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-24);
  }

  /* ── Card shell ────────────────────────────────────────────────────────────── */
  .pcg-item {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 0 0 100%;
    min-height: 18rem;
    border: 1px solid var(--muted);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, black 20%, var(--card));
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3), 0 1px 3px rgba(0, 0, 0, 0.15);
    transition: border-color 0.3s ease, box-shadow 0.22s ease;
  }

  /* Spotlight — radial gradient centered at cursor position via --mouse-x / --mouse-y.
     Defaults off-screen so it never shows until first mousemove. */
  .pcg-item--linked::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      280px circle at var(--mouse-x, -1000px) var(--mouse-y, -1000px),
      rgba(149, 101, 219, 0.2),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    border-radius: inherit;
  }

  .pcg-item--linked:hover {
    border-color: rgba(149, 101, 219, 0.3);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.22), 0 1px 4px rgba(0, 0, 0, 0.12);
  }

  .pcg-item--linked:hover::after {
    opacity: 1;
  }

  .pcg-item--linked:hover .pcg-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  /* Reduced-motion fallback: skip gradient tracking, just show border */
  @media (prefers-reduced-motion: reduce) {
    .pcg-item--linked::after { display: none; }
    .pcg-item--linked:hover  { border-color: rgba(149, 101, 219, 0.45); }
    .pcg-item--linked:hover .pcg-arrow { opacity: 1; }
  }

  /* ── Parker 3+2 flex-grow layout ────────────────────────────────────────────── */
  @media (min-width: 640px)  { .pcg-item { flex: 0 0 calc(50% - 12px); } }

  @media (min-width: 1024px) {
    .product-card-grid.pcg-cols-3 .pcg-item { flex: 1 1 calc(33.333% - 16px); }
    .product-card-grid.pcg-cols-4 .pcg-item { flex: 0 0 calc(25% - 18px); }
  }

  /* ── Cover link ─────────────────────────────────────────────────────────────── */
  .pcg-item--linked { cursor: pointer; }
  .pcg-cover-link   { position: absolute; inset: 0; border-radius: inherit; z-index: 2; }

  /* ── Content wrapper — above spotlight (z-index: 1) ─────────────────────────── */
  .pcg-inner {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-64);
    padding: var(--space-32);
  }

  /* ── Icon ───────────────────────────────────────────────────────────────────── */
  .pcg-icon { display: inline-flex; color: white; }
  .pcg-icon :global(svg) { width: 28px; height: 28px; }

  /* ── Bottom group ───────────────────────────────────────────────────────────── */
  .pcg-bottom { display: flex; flex-direction: column; gap: var(--space-16); }
  .pcg-text   { display: flex; flex-direction: column; gap: var(--space-8); }
  .pcg-title  { font-size: var(--text-h5); }
  .pcg-body   { font-size: var(--text-body-sm); line-height: var(--lh-body); opacity: 0.65; }

  /* ── Arrow ───────────────────────────────────────────────────────────────────── */
  .pcg-arrow {
    display: inline-flex;
    opacity: 0;
    color: white;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  /* ── Photo variant ──────────────────────────────────────────────────────────── */
  .pcg-item--photo { background: transparent; border-color: rgba(255,255,255,0.1); }

  .pcg-bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
  }
  .pcg-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  /* Dark gradient scrim — heavier at bottom so heading text is always readable */
  .pcg-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.82) 0%,
      rgba(0, 0, 0, 0.48) 45%,
      rgba(0, 0, 0, 0.18) 100%
    );
  }
</style>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>('.pcg-item--linked').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mouse-x', `${(e as MouseEvent).clientX - rect.left}px`);
        card.style.setProperty('--mouse-y', `${(e as MouseEvent).clientY - rect.top}px`);
      });

      card.addEventListener('mouseleave', () => {
        card.style.setProperty('--mouse-x', '-1000px');
        card.style.setProperty('--mouse-y', '-1000px');
      });
    });
  }
</script>
