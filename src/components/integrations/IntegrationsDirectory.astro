---
// Integrations directory (Figma filters 67:3442 + content 67:3455). Toolbar with a
// search box + sort dropdown, a category filter row, and a responsive grid of
// integration cards (logo on a light tile + name + category tag). All filtering,
// search, and sorting is client-side. The Relume "bookmark" affordance is dropped —
// these are reference cards, not savable items.
interface Item { name: string; category: string; logo: string }
interface Category { value: string; label: string }
interface Props {
  items: Item[];
  categories: Category[];
}
const { items, categories } = Astro.props;
const catLabel = Object.fromEntries(categories.map((c) => [c.value, c.label]));
---

<section class="int-dir section" data-int-dir>
  <div class="container">
    <div class="id-toolbar">
      <label class="id-search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" /><path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
        <input type="search" placeholder="Search integrations" aria-label="Search integrations" data-search />
      </label>

      <div class="id-sort" data-sort-dd>
        <button type="button" class="id-sort-trigger" aria-haspopup="listbox" aria-expanded="false">
          Sort
          <svg class="id-sort-caret" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
        <div class="id-sort-panel" role="listbox" aria-label="Sort">
          <p class="id-sort-title">Sort</p>
          <button type="button" class="id-sort-opt is-active" role="option" aria-selected="true" data-value="az">A-Z</button>
          <button type="button" class="id-sort-opt" role="option" aria-selected="false" data-value="za">Z-A</button>
        </div>
      </div>
    </div>

    <div class="id-filters" role="group" aria-label="Filter by category">
      <button class="id-filter" type="button" data-filter="*" aria-pressed="true">View all</button>
      {categories.map((c) => (
        <button class="id-filter" type="button" data-filter={c.value} aria-pressed="false">{c.label}</button>
      ))}
    </div>

    <div class="id-grid" data-grid>
      {items.map((it) => (
        <article class="ic" data-category={it.category} data-name={it.name.toLowerCase()}>
          <div class="ic-logo"><img src={it.logo} alt={it.name} loading="lazy" /></div>
          <div class="ic-body">
            <span class="ic-name">{it.name}</span>
            <span class="ic-cat">{catLabel[it.category] ?? it.category}</span>
          </div>
        </article>
      ))}
    </div>

    <p class="id-empty" data-empty hidden>No integrations match your search.</p>
  </div>
</section>

<style>
  .id-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-12);
  }
  .id-search {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    flex: 1 1 280px;
    max-width: 420px;
    padding: var(--space-12) var(--space-16);
    background: var(--card);
    border: 1px solid var(--input);
    border-radius: var(--radius-md);
    color: var(--muted-foreground);
  }
  .id-search input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    color: var(--foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
  }
  .id-search input:focus { outline: none; }
  .id-search input::placeholder { color: var(--muted-foreground); }

  /* Custom sort dropdown: the trigger fills with primary when open and merges
     seamlessly into the panel below (rounded top, square join), matching the
     attached style (brand purple in place of the reference orange). */
  .id-sort { position: relative; }
  .id-sort-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-12) var(--space-16);
    background: var(--card);
    color: var(--foreground);
    border: 1px solid var(--input);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition: background-color 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .id-sort-caret { transition: transform 0.18s ease; }
  .id-sort.is-open .id-sort-trigger {
    background: var(--primary);
    color: var(--primary-foreground);
    border-color: var(--primary);
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
  .id-sort.is-open .id-sort-caret { transform: rotate(180deg); }

  .id-sort-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 20;
    display: none;
    background: var(--popover);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .id-sort.is-open .id-sort-panel { display: block; }
  .id-sort-title {
    padding: var(--space-12) var(--space-16) var(--space-8);
    color: var(--primary);
    font-family: var(--font-heading);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-semibold);
  }
  .id-sort-opt {
    display: block;
    width: 100%;
    text-align: left;
    padding: var(--space-12) var(--space-16);
    background: transparent;
    border: none;
    border-top: 1px solid var(--border);
    color: var(--popover-foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    cursor: pointer;
  }
  .id-sort-opt:hover { background: var(--accent); }
  .id-sort-opt.is-active { color: var(--primary-light); font-weight: var(--fw-semibold); }

  .id-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-8);
    margin-top: var(--space-24);
  }
  .id-filter {
    padding: var(--space-8) var(--space-16);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-full);
    color: var(--muted-foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .id-filter:hover { color: var(--foreground); }
  .id-filter[aria-pressed='true'] { color: var(--foreground); border-color: var(--border); }

  .id-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-24);
    margin-top: var(--space-48);
  }

  .ic {
    display: flex;
    flex-direction: column;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.18s ease;
  }
  .ic:hover { border-color: var(--muted-foreground); }
  .ic[hidden] { display: none; }

  /* Logos are brand marks built for light backgrounds, so the logo area is a light
     tile (off-white) to keep all 69 legible on the dark page. */
  .ic-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3 / 2;
    padding: var(--space-16);
    background: var(--primary-foreground); /* pure white, matches logos' baked-in backgrounds */
  }
  .ic-logo img { width: 100%; height: 100%; object-fit: contain; }

  .ic-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-8);
    padding: var(--space-16);
  }
  .ic-name { font-family: var(--font-heading); font-weight: var(--fw-semibold); color: var(--foreground); font-size: var(--text-body); }
  .ic-cat {
    padding: var(--space-4) var(--space-8);
    background: var(--secondary);
    color: var(--secondary-foreground);
    border-radius: var(--radius-sm);
    font-size: var(--text-caption);
    font-weight: var(--fw-medium);
  }

  .id-empty { margin-top: var(--space-48); text-align: center; color: var(--muted-foreground); }

  @media (min-width: 640px) {
    .id-toolbar { justify-content: space-between; }
    .id-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .id-grid { grid-template-columns: repeat(5, 1fr); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-int-dir]').forEach((root) => {
    const grid = root.querySelector<HTMLElement>('[data-grid]');
    const search = root.querySelector<HTMLInputElement>('[data-search]');
    const empty = root.querySelector<HTMLElement>('[data-empty]');
    const filters = Array.from(root.querySelectorAll<HTMLButtonElement>('.id-filter'));
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.ic'));
    let activeCat = '*';

    const apply = () => {
      const q = (search?.value ?? '').trim().toLowerCase();
      let visible = 0;
      cards.forEach((c) => {
        const okCat = activeCat === '*' || c.dataset.category === activeCat;
        const okQ = !q || (c.dataset.name ?? '').includes(q);
        const show = okCat && okQ;
        c.hidden = !show;
        if (show) visible += 1;
      });
      if (empty) empty.hidden = visible !== 0;
    };

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCat = btn.dataset.filter ?? '*';
        filters.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        apply();
      });
    });
    search?.addEventListener('input', apply);

    // ── Custom sort dropdown ─────────────────────────────────────────────
    const dd = root.querySelector<HTMLElement>('[data-sort-dd]');
    const trigger = dd?.querySelector<HTMLButtonElement>('.id-sort-trigger');
    const opts = Array.from(dd?.querySelectorAll<HTMLButtonElement>('.id-sort-opt') ?? []);
    let sortVal = 'az';

    const sort = () => {
      const dir = sortVal === 'za' ? -1 : 1;
      [...cards]
        .sort((a, b) => (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '') * dir)
        .forEach((c) => grid.appendChild(c));
    };
    const setOpen = (open: boolean) => {
      dd?.classList.toggle('is-open', open);
      trigger?.setAttribute('aria-expanded', String(open));
    };

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!dd?.classList.contains('is-open'));
    });
    opts.forEach((opt) => {
      opt.addEventListener('click', () => {
        sortVal = opt.dataset.value ?? 'az';
        opts.forEach((o) => {
          const active = o === opt;
          o.classList.toggle('is-active', active);
          o.setAttribute('aria-selected', String(active));
        });
        sort();
        setOpen(false);
      });
    });
    document.addEventListener('click', (e) => {
      if (dd && !dd.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  });
</script>
