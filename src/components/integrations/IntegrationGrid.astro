---
// Integrations section. Left: two-line header (line 2 swaps to the hovered
// integration's name, defaulting to defaultSubject) + ghost CTA. Right: staggered
// rows of logo tiles — grayscale at rest, full colour on hover/focus.
import Button from '../Button.astro';

interface Item { name: string; logo: string; round?: boolean; pad?: boolean }
interface Props {
  heading: string;
  defaultSubject: string;
  cta?: { label: string; href: string };
  items: Item[];
  cols?: number;
}
const { heading, defaultSubject, cta, items, cols = 11 } = Astro.props;
const linkHref = cta?.href ?? '/integrations';

// Chunk flat list into rows for the staggered layout — capped at 3 rows.
const rows: Item[][] = [];
for (let i = 0; i < items.length && rows.length < 3; i += cols) {
  rows.push(items.slice(i, i + cols));
}
---

<section class="integrations section" data-integrations>
  <div class="container-page ig-grid">
    <div class="ig-copy">
      <h2 class="ig-heading">
        <span class="ig-line">{heading}</span>
        <span class="ig-subject" data-default={defaultSubject}>{defaultSubject}</span>
      </h2>
      {cta && (
        <div class="ig-cta">
          <Button variant="ghost" href={cta.href}>
            {cta.label}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </Button>
        </div>
      )}
    </div>

    <div class="ig-icons">
      {rows.map((row, ri) => (
        <div class:list={['ig-row', ri % 2 === 1 && 'ig-row--offset']}>
          {row.map((it) => (
            <a class="ig-icon" href={linkHref} data-name={it.name} aria-label={`Stockifi integrates with ${it.name}`}>
              <img class:list={[it.round && 'is-round', it.pad && 'is-pad']} src={it.logo} alt={it.name} width="40" height="40" loading="lazy" />
            </a>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ig-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-32);
    align-items: center;
  }

  .ig-heading { font-size: var(--text-h2); }
  .ig-line { display: block; color: var(--foreground); }
  .ig-subject { display: block; color: var(--primary); }
  .ig-cta { margin-top: var(--space-32); }

  /* The section clips its own overflow so the right-edge bleed never spawns a
     horizontal scrollbar (100vw can include the scrollbar gutter). */
  .integrations { overflow-x: clip; }

  /* Staggered rows — bleed past the container's right gutter to the viewport edge,
     then fade out with a gradient mask.
     --ig-tile and --ig-gap are defined here so .ig-row--offset can reference them. */
  .ig-icons {
    --ig-tile: 64px;
    --ig-gap: 16px;
    display: flex;
    flex-direction: column;
    gap: var(--ig-gap);
    /* Cancel the container's right padding + (on wide screens) its centering margin */
    margin-right: calc(-1 * (var(--gutter) + max(0px, (100vw - var(--container-max)) / 2)));
    overflow: hidden;
    mask-image: linear-gradient(to right, black 50%, transparent 92%);
    -webkit-mask-image: linear-gradient(to right, black 50%, transparent 92%);
  }

  .ig-row {
    display: flex;
    gap: var(--ig-gap);
    flex-shrink: 0;
  }

  /* Brick offset: even rows shift right by half a tile + half a gap */
  .ig-row--offset {
    padding-left: calc(var(--ig-tile) / 2 + var(--ig-gap) / 2);
  }

  /* Glass tile built in CSS so it stays crisp and theme-aware. The tint is derived
     from --foreground over the page background: a faint light wash in dark mode,
     a faint dark wash in light mode. Logos are transparent marks, inset and centered. */
  .ig-icon {
    flex: 0 0 var(--ig-tile);
    width: var(--ig-tile);
    height: var(--ig-tile);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    /* iOS-style glass: flat even translucency + a brighter top edge for the specular
       highlight. (No gradient wash — that reads as frost. No backdrop-filter either —
       it caused a hover artifact that bled the glass onto neighbouring tiles.) */
    background: color-mix(in srgb, var(--foreground) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--foreground) 10%, transparent);
    border-top-color: color-mix(in srgb, var(--foreground) 20%, transparent);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .ig-icon:hover,
  .ig-icon:focus-visible {
    background: color-mix(in srgb, var(--foreground) 10%, transparent);
    border-color: color-mix(in srgb, var(--foreground) 18%, transparent);
    border-top-color: color-mix(in srgb, var(--foreground) 30%, transparent);
  }

  .ig-icon img {
    width: 68%;
    height: 68%;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.65;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .ig-icon:hover img,
  .ig-icon:focus-visible img { filter: grayscale(0); opacity: 1; }
  /* Marks supplied full-bleed (less internal whitespace than the earlier set) — shrink so
     their inner padding matches the rest. */
  .ig-icon img.is-pad { width: 54%; height: 54%; }
  /* Brand badges supplied without transparency: clip to a circle to drop the
     square background (same handling as the pill variant). */
  .ig-icon img.is-round { object-fit: cover; border-radius: var(--radius-full); }

  /* Two-column hero only kicks in once the viewport is wide enough to seat the
     heading beside the icons. Below this, the copy stacks full-width and never
     wraps awkwardly. The container is capped at --container-max, so above 1280
     the copy column width is fixed and the heading always fits on two lines. */
  /* From the full-width breakpoint up, the page runs to a 100px gutter, so the icons
     bleed to the viewport's right edge by cancelling exactly that gutter (the old
     1280-based calc over-pulled and clipped the tiles off-screen). */
  @media (min-width: 1024px) {
    .ig-icons { margin-right: -100px; }
  }

  @media (min-width: 1280px) {
    .ig-grid {
      /* Cap the copy column so the short heading doesn't leave a dead gap before the
         icons at full width; the icons column takes all remaining space. */
      grid-template-columns: minmax(420px, 600px) 1fr;
      gap: var(--space-64);
      align-items: center;
    }
    /* Each line stays unbroken → heading is always exactly two lines */
    .ig-line,
    .ig-subject { white-space: nowrap; }
    .ig-icons {
      --ig-tile: 72px;
      --ig-gap: 18px;
      /* More room now, so keep tiles solid further across before the fade. */
      mask-image: linear-gradient(to right, black 60%, transparent 98%);
      -webkit-mask-image: linear-gradient(to right, black 60%, transparent 98%);
    }
  }
</style>

<script>
  document.querySelectorAll('[data-integrations]').forEach((root) => {
    const subject = root.querySelector<HTMLElement>('.ig-subject');
    const wrap = root.querySelector('.ig-icons');
    if (!subject || !wrap) return;
    const def = subject.dataset.default ?? subject.textContent ?? '';

    root.querySelectorAll<HTMLElement>('.ig-icon').forEach((icon) => {
      const name = icon.dataset.name ?? def;
      const set = () => { subject.textContent = name; };
      icon.addEventListener('mouseenter', set);
      icon.addEventListener('focus', set);
    });

    const reset = () => { subject.textContent = def; };
    wrap.addEventListener('mouseleave', reset);
    wrap.addEventListener('focusout', (e) => {
      if (!wrap.contains((e as FocusEvent).relatedTarget as Node | null)) reset();
    });
  });
</script>
