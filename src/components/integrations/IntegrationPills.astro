---
// Integrations variant 2 — logo-pill cloud (Figma 92:1152, Supy reference).
// Left: a centered, staggered cloud of pills (brand icon + uppercase name); right:
// heading + body. Pills are built in CODE (not Figma image exports) so they stay
// light, crisp, and recolourable — only the brand icon is an asset (the existing
// icon-only submarks in /media/integrations-logos/, mostly SVG).
// Logos shuffled at build time. A controller (script below) flips 2-3 random pills at
// a time (vertical rotateX, swap-at-edge) to cycle the full list through the visible
// slots — IntersectionObserver-gated, paused offscreen / on hidden tab, reduced-motion safe.
interface Item { name: string; logo: string; round?: boolean; pad?: boolean }
interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  items: Item[];
  /** Optionally cap how many pills render (default: all, shuffled). */
  count?: number;
  /** Reversed layout: copy on the left, cloud on the right (bleeds off the right edge). */
  reverse?: boolean;
  /** Wide layout: full-width — cloud bleeds off the left edge, copy + 80px gutter right. */
  wide?: boolean;
}
const { eyebrow, heading, subhead, items, count, reverse = false, wide = false } = Astro.props;

// Randomize at build time (placeholder until the cycling flip animation lands).
const shuffled = [...items].sort(() => Math.random() - 0.5);
// Lay out as 4 rows, round-robin so each row gets a varied mix. The visible count is
// capped (the planned flip animation will cycle the rest of the list through these slots).
const ROW_COUNT = 4;
const visible = shuffled.slice(0, count ?? ROW_COUNT * 6);
const rows = Array.from({ length: ROW_COUNT }, (_, r) => visible.filter((_, i) => i % ROW_COUNT === r));
---

<section class:list={['integration-pills section', reverse && 'ip-reverse']} data-ip-pills>
  <div class:list={['ip-grid', wide ? 'ip-wide' : 'container']}>
    <div class="ip-copy">
      {eyebrow && <p class="tagline">{eyebrow}</p>}
      <h2 class="ip-heading">{heading}</h2>
      {subhead && <p class="ip-subhead text-muted">{subhead}</p>}
    </div>

    <div class="ip-cloud">
      {rows.map((row) => (
        <div class="ip-row">
          {row.map((it) => (
            <span class="ip-pill" data-pill data-name={it.name}>
              <img class:list={['ip-pill-icon', it.round && 'ip-pill-icon--round']} src={it.logo} alt="" width="28" height="28" loading="lazy" decoding="async" />
              <span class="ip-pill-name">{it.name}</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>
  <script type="application/json" data-ip-all set:html={JSON.stringify(items)}></script>
</section>

<style>
  /* Soft duo gradient glow behind the pills (also gives the glass blur something to
     sample so it reads as real glass). Sits behind the content via isolation + z-index. */
  /* overflow-x: clip keeps the cloud's edge bleed (esp. the reversed right bleed) from
     spawning a horizontal scrollbar. */
  .integration-pills { position: relative; isolation: isolate; overflow-x: clip; }
  .integration-pills::before {
    content: '';
    position: absolute;
    /* Bleed past the top/bottom edges into the neighbouring sections (overflow-x:clip on
       the section keeps the horizontal edge from scrolling; vertical stays visible). */
    inset: -360px 0;
    z-index: -1;
    background-image: url('/media/gradient-duo.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.4;
    pointer-events: none;
  }

  .ip-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); }

  /* Wide variant (home): full width — cloud bleeds off the left edge, copy + 80px gutter
     on the right (desktop). Cloud --ip-bleed is overridden to match this wrapper's left
     padding so the pills still reach the viewport edge. */
  .ip-wide { width: 100%; max-width: none; margin-inline: auto; padding-inline: var(--gutter-wide); }
  .ip-wide .ip-cloud { --ip-bleed: var(--gutter-wide); }

  /* Four rows that bleed off the LEFT viewport edge ("coming from the edge"). The box
     keeps its right edge at the column boundary and extends left to the screen edge:
     cancel the container's left gutter + (on wide screens) its centering margin. */
  .ip-cloud {
    --ip-bleed: calc(var(--gutter) + max(0px, (100vw - var(--container-max)) / 2));
    /* Overshoot past the left edge so the leftmost pills bleed off-screen — the flush
       alignment + the width re-flow while pills flip then happen in the faded zone. */
    --ip-overshoot: 40px;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    width: calc(100% + var(--ip-bleed) + var(--ip-overshoot));
    margin-left: calc(-1 * (var(--ip-bleed) + var(--ip-overshoot)));
    overflow: hidden;
    /* Fade BOTH edges: pills bleed softly out of the left and taper on the right. */
    mask-image: linear-gradient(to right, transparent 40px, #000 104px, #000 86%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 40px, #000 104px, #000 86%, transparent 100%);
  }
  .ip-row { display: flex; gap: var(--space-12); flex-shrink: 0; }

  .ip-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-16) var(--space-8) var(--space-8);
    border: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
    /* Brighter top edge = the specular sheen that reads as glass. */
    border-top-color: color-mix(in srgb, var(--foreground) 26%, transparent);
    border-radius: var(--radius-full);
    /* Sleek iOS glass: flat translucency + a specular top edge, sitting over the
       gradient glow behind (which shows through the translucent fill). No
       backdrop-filter — it caused a hover artifact that bled glass onto neighbours. */
    background-color: color-mix(in srgb, var(--foreground) 8%, transparent);
    /* Flip + width morph (the controller drives transform/width inline). */
    transform-origin: center;
    transition: transform 0.26s ease, width 0.26s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .ip-pill { transition: none; }
  }
  .ip-pill-icon { width: 28px; height: 28px; flex: none; object-fit: contain; }
  /* Brand badges supplied without transparency (JPEG / flat PNG): clip to a circle
     so the square background is removed, leaving the circular mark clean. */
  .ip-pill-icon--round { object-fit: cover; border-radius: var(--radius-full); }
  .ip-pill-name {
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--foreground);
    white-space: nowrap;
  }

  .ip-heading { max-width: 24ch; }
  .ip-subhead { margin-top: var(--space-16); max-width: 44ch; font-size: var(--text-body-lg); }

  @media (min-width: 1024px) {
    .ip-grid { grid-template-columns: 1fr 1fr; align-items: center; gap: var(--space-32); }
    /* Cloud on the left, copy on the right (DOM order is copy-first for mobile). */
    .ip-cloud { order: 1; }
    .ip-copy { order: 2; }
    /* Reversed: copy left, cloud right. */
    .ip-reverse .ip-cloud { order: 2; }
    .ip-reverse .ip-copy { order: 1; }
    /* Wide: no left gutter (cloud reaches the edge), 80px gutter on the right. */
    .ip-wide { padding-left: 0; padding-right: 80px; }
    .ip-wide .ip-cloud { --ip-bleed: 0px; }
  }

  /* Reversed: mirror the bleed to the RIGHT edge (default bleeds left). Pills align to the
     right so they pack off the right edge and taper toward the centre. */
  .ip-reverse .ip-cloud {
    margin-left: 0;
    margin-right: calc(-1 * (var(--ip-bleed) + var(--ip-overshoot)));
    mask-image: linear-gradient(to left, transparent 40px, #000 104px, #000 86%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, transparent 40px, #000 104px, #000 86%, transparent 100%);
  }
  .ip-reverse .ip-row { justify-content: flex-end; }
</style>

<script>
  type Item = { name: string; logo: string; round?: boolean };
  const DUR = 260; // keep in sync with the .ip-pill transition

  document.querySelectorAll<HTMLElement>('[data-ip-pills]').forEach((section) => {
    const dataEl = section.querySelector('[data-ip-all]');
    const pills = Array.from(section.querySelectorAll<HTMLElement>('[data-pill]'));
    if (!dataEl || pills.length === 0) return;

    let all: Item[] = [];
    try { all = JSON.parse(dataEl.textContent || '[]'); } catch { return; }
    if (all.length <= pills.length) return; // no spare logos to cycle in

    // Names currently on screen (reserved on pick to avoid two pills showing the same).
    const shown = new Set(pills.map((p) => p.dataset.name || ''));
    const pickNext = (): Item | null => {
      const pool = all.filter((it) => !shown.has(it.name));
      return pool.length ? pool[Math.floor(Math.random() * pool.length)] : null;
    };

    const flip = (pill: HTMLElement) => {
      const next = pickNext();
      if (!next) return;
      // Reserve immediately so a simultaneous flip can't pick the same logo.
      shown.delete(pill.dataset.name || '');
      shown.add(next.name);
      pill.dataset.name = next.name;

      // Rotate to edge-on, then swap content while it's invisible (width reflows unseen).
      pill.style.transform = 'perspective(600px) rotateX(90deg)';
      window.setTimeout(() => {
        const oldW = pill.offsetWidth;
        const img = pill.querySelector('img');
        const label = pill.querySelector('.ip-pill-name');
        if (img) { img.src = next.logo; img.classList.toggle('ip-pill-icon--round', !!next.round); }
        if (label) label.textContent = next.name;

        pill.style.width = 'auto';
        const newW = pill.getBoundingClientRect().width;
        pill.style.width = `${oldW}px`;
        pill.style.transition = 'none';
        pill.style.transform = 'perspective(600px) rotateX(-90deg)';
        void pill.offsetWidth; // reflow so the jump to -90deg isn't animated
        pill.style.transition = '';
        pill.style.transform = 'perspective(600px) rotateX(0deg)';
        pill.style.width = `${newW}px`; // morph width to the new content over the flip
      }, DUR);
    };

    const inFlight = new Set<HTMLElement>();
    const tick = () => {
      const batch = 2 + Math.floor(Math.random() * 2); // 2 or 3 at a time
      const candidates = pills.filter((p) => !inFlight.has(p));
      for (let i = 0; i < batch && candidates.length; i++) {
        const pill = candidates.splice(Math.floor(Math.random() * candidates.length), 1)[0];
        inFlight.add(pill);
        window.setTimeout(() => {
          flip(pill);
          window.setTimeout(() => inFlight.delete(pill), DUR * 2 + 200);
        }, Math.random() * 400); // stagger so they don't move in unison
      }
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let timer: number | null = null;
    let inView = false;
    const sync = () => {
      const run = inView && !document.hidden;
      if (run && timer === null) timer = window.setInterval(tick, 2400);
      else if (!run && timer !== null) { clearInterval(timer); timer = null; }
    };
    new IntersectionObserver((entries) => {
      entries.forEach((e) => { inView = e.isIntersecting; });
      sync();
    }, { threshold: 0.2 }).observe(section);
    document.addEventListener('visibilitychange', sync);
  });
</script>
