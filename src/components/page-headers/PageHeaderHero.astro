---
// Page header — Hero variant (Figma 80:1184). Split layout: tagline + heading + body
// + a single CTA on one side, a large media on the other. For inner-page heroes
// (solutions/product item pages). The centered variant lives in PageHeader.astro.
import Button from '../Button.astro';
import MediaPlaceholder from '../features/MediaPlaceholder.astro';

interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  cta?: { label: string; href: string };
  image?: { src: string; alt: string };
  imageSide?: 'left' | 'right';
  /** Fade the image into the page background with a veil, matching the home hero. */
  veil?: boolean;
}
const { eyebrow, heading, subhead, cta, image, imageSide = 'right', veil = false } = Astro.props;
---

<section class:list={['page-header-hero section', `phh--${imageSide}`, veil && 'phh--veil']}>
  <div class="container phh-grid">
    <div class="phh-copy">
      {eyebrow && <p class="tagline">{eyebrow}</p>}
      <h1 class="phh-heading">{heading}</h1>
      {subhead && <p class="phh-sub text-muted">{subhead}</p>}
      {cta && (
        <div class="phh-cta">
          <Button variant="primary" href={cta.href}>{cta.label}</Button>
        </div>
      )}
    </div>
    <div class="phh-media">
      {image ? <img src={image.src} alt={image.alt} /> : <MediaPlaceholder ratio="1 / 1" />}
    </div>
  </div>
</section>

<style>
  .phh-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); align-items: center; }
  .phh-heading { font-size: var(--text-h1); }
  .tagline + .phh-heading { margin-top: var(--space-12); }
  .phh-sub { margin-top: var(--space-16); max-width: 48ch; font-size: var(--text-body-lg); }
  .phh-cta { margin-top: var(--space-32); }
  .phh-media img { width: 100%; border-radius: var(--radius-lg); }

  /* Veil variant — fade the image into the page background, matching the home hero.
     Mobile: full-bleed image under a left-to-right dark gradient veil. */
  .phh--veil .phh-media { position: relative; overflow: hidden; margin-inline: calc(-1 * var(--gutter)); }
  .phh--veil .phh-media img { aspect-ratio: 16 / 9; object-fit: cover; border-radius: 0; }
  .phh--veil .phh-media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--background) 90%, transparent) 0%,
      color-mix(in srgb, var(--background) 72%, transparent) 28%,
      color-mix(in srgb, var(--background) 35%, transparent) 52%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .phh-grid { grid-template-columns: 1fr 1fr; gap: var(--space-96); }
    .phh--left .phh-copy { order: 2; }
    .phh--left .phh-media { order: 1; }

    /* Desktop: drop the overlay veil, fade the image pixels into the bg via a mask. */
    .phh--veil .phh-media { margin-inline: 0; }
    .phh--veil .phh-media img { border-radius: var(--radius-lg); }
    .phh--veil .phh-media::before { display: none; }
    .phh--veil.phh--right .phh-media img {
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 50%);
      mask-image: linear-gradient(to right, transparent 0%, black 50%);
    }
    .phh--veil.phh--left .phh-media img {
      -webkit-mask-image: linear-gradient(to left, transparent 0%, black 50%);
      mask-image: linear-gradient(to left, transparent 0%, black 50%);
    }
  }
</style>
