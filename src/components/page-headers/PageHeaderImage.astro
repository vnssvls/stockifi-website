---
// Page header v3 — "image" variant (Figma 82:1095, Relume header-65), reworked to a
// rounded "hero card" per the Supy reference (supy.io/solutions/restaurant-types/cafes):
// the photo + dark scrim sit inside a rounded, near-full-width card (inset via the
// reduced gutter), with the tagline + heading + body + CTA centered inside it.
import Button from '../Button.astro';

interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  cta?: { label: string; href: string };
  /** Button style for the hero CTA (product pages use secondary). */
  ctaVariant?: 'primary' | 'secondary' | 'ghost';
  /** Background image (site-relative path). */
  image: string;
}
const { eyebrow, heading, subhead, cta, ctaVariant = 'primary', image } = Astro.props;
---

<section class="page-header-image">
  <div class="container-wide">
    <div class="phi-card" style={`--phi-bg: url('${image}')`}>
      <div class="phi-content">
        {eyebrow && <p class="tagline phi-eyebrow">{eyebrow}</p>}
        <h1 class="phi-heading">{heading}</h1>
        {subhead && <p class="phi-subhead">{subhead}</p>}
      </div>
      {cta && (
        <div class="phi-actions">
          <Button variant={ctaVariant} href={cta.href}>
            {cta.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </Button>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Pull the card up behind the floating nav (same trick as CustomerStoryHeader), but
     stop ~20-30px short of the top so the rounded corners don't jam the edge. The nav is
     sticky/transparent and floats over the card's scrim'd top. */
  .page-header-image {
    margin-top: calc(-1 * var(--nav-h));
    padding-top: calc(var(--nav-h) - var(--space-64));
    padding-bottom: var(--space-32);
  }

  /* The hero card: rounded, near-full-width (inside .container-wide), tall, with the
     photo + dark scrim as its background. background-image dodges the strict-value
     guard (same pattern as CtaEmail). */
  .phi-card {
    --phi-bg: none;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-32);
    min-height: 30rem;
    padding: var(--space-96) var(--gutter);
    text-align: center;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  /* Blurred photo layer. Expanded past the edges (negative inset) so the blur
     feather is clipped by the card instead of showing a soft transparent border. */
  .phi-card::before {
    content: '';
    position: absolute;
    inset: -24px;
    background-image: var(--phi-bg);
    background-size: cover;
    background-position: center;
    filter: blur(2px);
    z-index: 0;
  }
  /* Dark scrim, kept sharp above the blurred photo. Gradient (darker toward the
     bottom) for contrast behind the centered copy. */
  .phi-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
      color-mix(in srgb, var(--background) 80%, transparent),
      color-mix(in srgb, var(--background) 90%, transparent)
    );
    z-index: 1;
  }

  .phi-content,
  .phi-actions { position: relative; z-index: 2; }
  .phi-content { display: flex; flex-direction: column; align-items: center; gap: var(--space-16); max-width: 768px; }
  .phi-eyebrow { margin-bottom: 0; }
  .phi-heading { font-size: var(--text-h1); line-height: var(--lh-h1); }
  .phi-subhead {
    max-width: 56ch;
    font-size: var(--text-body);
    color: color-mix(in srgb, var(--foreground) 85%, transparent);
  }

  /* Brighter border for secondary buttons sitting on the dark photo scrim */
  .phi-actions :global(.btn-secondary) {
    border-color: rgba(255, 255, 255, 0.45);
  }
  .phi-actions :global(.btn-secondary:hover) {
    border-color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 767px) {
    .phi-card { min-height: 22rem; padding-block: var(--space-64); border-radius: var(--radius-lg); }
    .phi-subhead { font-size: var(--text-body-sm); }
  }
</style>
