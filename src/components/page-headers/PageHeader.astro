---
// Generic inner-page header (Figma 67:2342): centered eyebrow + heading + subhead,
// with an optional default slot below (e.g. a logo strip). Reusable across pages.
interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
}
const { eyebrow, heading, subhead } = Astro.props;
const hasExtra = Astro.slots.has('default');
---

<section class="page-header section">
  <div class="container ph-inner">
    {eyebrow && <p class="tagline">{eyebrow}</p>}
    <h1 class="ph-heading">{heading}</h1>
    {subhead && <p class="ph-subhead text-muted">{subhead}</p>}
    {hasExtra && <div class="ph-extra"><slot /></div>}
  </div>
</section>

<style>
  .ph-inner { text-align: center; max-width: 76rem; margin-inline: auto; }
  .ph-heading { font-size: var(--text-h1); }
  .tagline + .ph-heading { margin-top: var(--space-12); }
  .ph-subhead { margin-top: var(--space-16); margin-inline: auto; max-width: 62ch; font-size: var(--text-body-lg); }
  .ph-extra { margin-top: var(--space-48); }
</style>
