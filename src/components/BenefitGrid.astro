---
// Grid layout (Figma 80:1418): a grid of benefit/solution items (icon + heading +
// body). Headerless and section-less by design — it's a building block dropped
// INSIDE a section; the parent provides the section, container, and any heading.
// 4-up on desktop, stacks down. Icon defaults to a generic box; pass per-item
// `icon` (inline SVG string) to override.
interface Item { heading: string; body: string; icon?: string }
interface Props {
  items: Item[];
  columns?: 3 | 4;
}
const { items, columns = 4 } = Astro.props;
---

<div class:list={['benefit-grid', `bgr-cols-${columns}`]}>
  {items.map((it) => (
    <article class="bgr-item">
      <span class="bgr-icon" aria-hidden="true">
        {it.icon ? <Fragment set:html={it.icon} /> : (
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" /><path d="m3.3 7 8.7 5 8.7-5" /><path d="M12 22V12" /></svg>
        )}
      </span>
      <h3 class="bgr-title">{it.heading}</h3>
      <p class="bgr-body text-muted">{it.body}</p>
    </article>
  ))}
</div>

<style>
  .benefit-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48) var(--space-32); }
  .bgr-item { display: flex; flex-direction: column; align-items: center; gap: var(--space-12); text-align: center; }
  .bgr-icon { display: inline-flex; color: var(--primary); }
  .bgr-title { font-size: var(--text-h6); }
  .bgr-body { max-width: 32ch; font-size: var(--text-body-sm); line-height: var(--lh-body); }

  @media (min-width: 640px) { .benefit-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) {
    .benefit-grid.bgr-cols-3 { grid-template-columns: repeat(3, 1fr); }
    .benefit-grid.bgr-cols-4 { grid-template-columns: repeat(4, 1fr); }
  }
</style>
