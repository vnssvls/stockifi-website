---
// Primary navigation. Built from the locked IA (docs/audit/07-information-architecture.md)
// onto the three wireframe patterns: Product/Solutions = mega menus, Resources/Company
// = simple dropdowns, Pricing = plain link. Locale switcher sits between the last link
// and the buttons. Collapses to a drawer below lg (1024px) per the project breakpoints.
import Logo from './Logo.astro';
import Button from './Button.astro';
import LocaleSwitcher from './LocaleSwitcher.astro';
import navIcons from '../data/nav-icons.json';

// Mega menus = grouped columns. Grouping is a nav/UX choice, NOT the page/URL structure.
// Each item carries an icon (key into nav-icons.json, Iconsax linear, currentColor) + a
// short description. Icons + descriptions are a first pass — easy to swap. See memory:
// project_website_product_taxonomy.
const productGroups = [
  { title: 'Procurement', href: '/product-procurement', items: [
    { label: 'Invoice automation', href: '/product-procurement/invoice-automation', icon: 'receipt-2', desc: 'Supplier invoices read line by line, automatically.' },
    { label: 'Supplier price tracking', href: '/product-procurement/supplier-price-tracking', icon: 'percentage-circle', desc: 'Every price change caught the day it lands.' },
    { label: 'Central kitchen', href: '/product-procurement/central-kitchen', icon: 'building', desc: 'Cost production and supply your own outlets.' },
    { label: 'Anomaly detection', href: '/product-procurement/anomaly-detection', icon: 'fluent-wand', desc: 'Flags overcharges and odd line items for review.' },
    { label: 'Ordering suggestions', href: '/product-procurement/ordering-suggestions', icon: 'ordering-suggestions', desc: 'Know what to reorder before you run short.' },
  ] },
  { title: 'Inventory Management', href: '/product-inventory-management', items: [
    { label: 'Recipe building', href: '/product-inventory-management/recipe-building', icon: 'book', desc: 'Cost every recipe from live ingredient prices.' },
    { label: 'Stock counting', href: '/product-inventory-management/stock-counting', icon: 'box', desc: 'Count stock on mobile or web, online or off.' },
    { label: 'Inventory transfers', href: '/product-inventory-management/inventory-transfers', icon: 'convert-3d-cube', desc: 'Track stock moved between your locations.' },
    { label: 'Wastage tracking', href: '/product-inventory-management/wastage-tracking', icon: 'trash', desc: 'Log waste and see what it costs you.' },
    { label: 'Data quality', href: '/product-inventory-management/data-quality', icon: 'data-quality', desc: 'Clean, validated data behind every report.' },
  ] },
  { title: 'Business Intelligence', href: '/product-business-intelligence', items: [
    { label: 'Performance Dashboards', href: '/product-business-intelligence/performance-dashboards', icon: 'element-4', desc: 'Food cost and margin across every location.' },
    { label: 'Variance analysis', href: '/product-business-intelligence/variance-analysis', icon: 'presention-chart', desc: 'Theoretical usage against what actually sold.' },
    { label: 'Profitability insights', href: '/product-business-intelligence/profitability', icon: 'trend-up', desc: 'See the live margin of every menu item.' },
    { label: 'API', href: '/product-business-intelligence/api', icon: 'code', desc: 'Push your data wherever you need it.' },
    { label: 'Sales and usage', href: '/product-business-intelligence/sales-and-usage', icon: 'sales-usage', desc: 'See what sold and how it moved through stock.' },
  ] },
];
const solutionsGroups = [
  { title: 'By Type', items: [
    { label: 'Independent restaurants', href: '/solutions/independent-restaurants', icon: 'fluent-store', desc: 'Tighter food cost without the spreadsheets.' },
    { label: 'Restaurant groups', href: '/solutions/restaurant-groups', icon: 'buildings-2', desc: 'Consolidated cost visibility across sites.' },
    { label: 'Hotels with F&B', href: '/solutions/hotels', icon: 'reserve', desc: 'Control across full food and beverage.' },
    { label: 'Bars', href: '/solutions/bars', icon: 'cocktail', desc: 'Know the margin on every drink you pour.' },
  ] },
  { title: 'By team', items: [
    { label: 'Management', href: '/solutions/management', icon: 'briefcase', desc: 'Margin visibility across the whole operation.' },
    { label: 'Operations', href: '/solutions/operations', icon: 'setting-2', desc: 'Spot waste and price drift early.' },
    { label: 'Kitchen', href: '/solutions/kitchen', icon: 'chef-hat', desc: 'Live dish costs for sharper menu calls.' },
    { label: 'Finance', href: '/solutions/finance', icon: 'fluent-finance', desc: 'COGS you can trust at month-end.' },
  ] },
];
const resourcesItems = [
  { label: 'Blog', href: '/blog' },
  { label: 'Customer Stories', href: '/customer-stories' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Press & Media', href: '/press' },
  { label: 'Savings Calculator', href: '/savings-calculator' },
  { label: 'Comparisons', href: null, soon: true },
];
const LOGIN_URL = 'https://web.stockifi.io/#/login';
---

<header class="site-header">
  <div class="nav-bar">
    <Logo height={28} />

    <nav class="nav-desktop" aria-label="Primary">
      <ul class="nav-list">
        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-product">
            Product
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel mega mega-3col" id="panel-product">
            {productGroups.map((g) => (
              <div class="mega-group">
                <p class="mega-group-title">{g.title}</p>
                <ul>
                  {g.items.map((i) => (
                    <li>
                      <a class="mega-item" href={i.href}>
                        <span class="mega-ico" aria-hidden="true" set:html={navIcons[i.icon]}></span>
                        <span class="mega-item-body">
                          <span class="mega-item-title">{i.label}</span>
                          <span class="mega-item-desc">{i.desc}</span>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </li>

        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-solutions">
            Solutions
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel mega mega-2col" id="panel-solutions">
            {solutionsGroups.map((g) => (
              <div class="mega-group">
                <p class="mega-group-title">{g.title}</p>
                <ul>
                  {g.items.map((i) => (
                    <li>
                      <a class="mega-item" href={i.href}>
                        <span class="mega-ico" aria-hidden="true" set:html={navIcons[i.icon]}></span>
                        <span class="mega-item-body">
                          <span class="mega-item-title">{i.label}</span>
                          <span class="mega-item-desc">{i.desc}</span>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </li>

        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-resources">
            Resources
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel" id="panel-resources">
            <ul class="dropdown-list">
              {resourcesItems.map((i) => (
                <li>
                  {i.soon
                    ? <span class="dropdown-link is-soon">{i.label}<span class="badge">Soon</span></span>
                    : <a class="dropdown-link" href={i.href}>{i.label}</a>}
                </li>
              ))}
            </ul>
          </div>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/integrations">Integrations</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/pricing">Pricing</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/contact">Contact</a>
        </li>
      </ul>
    </nav>

    <div class="nav-actions">
      <LocaleSwitcher current="en" />
      <Button variant="secondary" href={LOGIN_URL}>Login</Button>
      <Button variant="primary" href="/book-a-demo">Get Started</Button>
    </div>

    <button type="button" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg class="burger-icon icon-open" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
      <svg class="burger-icon icon-close" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="m-close-bar">
      <button type="button" class="m-close" aria-label="Close menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
      </button>
    </div>
    <div class="mobile-scroll">
    <div class="container mobile-inner">
      <nav aria-label="Mobile">
        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-product">
            Product
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-product" hidden>
            {productGroups.map((g) => (
              <Fragment>
                <p class="m-sub-title">{g.title}</p>
                {g.items.map((i) => (
                  <a class="m-link" href={i.href}>
                    <span class="m-link-ico" aria-hidden="true" set:html={navIcons[i.icon]}></span>
                    {i.label}
                  </a>
                ))}
              </Fragment>
            ))}
          </div>
        </div>

        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-solutions">
            Solutions
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-solutions" hidden>
            {solutionsGroups.map((g) => (
              <Fragment>
                <p class="m-sub-title">{g.title}</p>
                {g.items.map((i) => (
                  <a class="m-link" href={i.href}>
                    <span class="m-link-ico" aria-hidden="true" set:html={navIcons[i.icon]}></span>
                    {i.label}
                  </a>
                ))}
              </Fragment>
            ))}
          </div>
        </div>

        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-resources">
            Resources
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-resources" hidden>
            {resourcesItems.map((i) => (
              i.soon
                ? <span class="m-link is-soon">{i.label}<span class="badge">Soon</span></span>
                : <a class="m-link" href={i.href}>{i.label}</a>
            ))}
          </div>
        </div>

        <a class="m-acc-link" href="/integrations">Integrations</a>
        <a class="m-acc-link" href="/pricing">Pricing</a>
        <a class="m-acc-link" href="/contact">Contact</a>
      </nav>

      <div class="mobile-locale"><LocaleSwitcher current="en" mobile={true} /></div>
    </div>
    </div>
  <div class="mobile-actions">
    <Button variant="secondary" href={LOGIN_URL} block>Login</Button>
    <Button variant="primary" href="/book-a-demo" block>Get Started</Button>
  </div>
  </div>
  <div class="mobile-backdrop" id="mobile-backdrop" aria-hidden="true"></div>
</header>

<style>
  /* Transparent sticky shell. The padding-top is the floating gap and it lives
     INSIDE the sticky box, so the pill sits the same distance from the top at rest
     and once pinned. The inline padding is the gap from the screen edges. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: var(--space-16) var(--gutter);
  }
  /* The pill itself — capped width, fully rounded, translucent with a backdrop
     blur so page content frosts behind it as you scroll. */
  .nav-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-24);
    max-width: var(--container-max);
    margin-inline: auto;
    padding: var(--space-12) var(--space-24);
  }
  /* The pill's glass lives on a pseudo-element, NOT the .nav-bar box itself. If .nav-bar
     carried backdrop-filter it would be a "backdrop root", and the dropdown panels nested
     inside it would have nothing for their own backdrop-filter to sample (they rendered
     flat while the pill blurred). With the blur on ::before, .nav-bar is a plain ancestor,
     so the panels blur the page correctly. z-index:-1 sits it behind the pill content;
     the sticky header's stacking context keeps it above the page. */
  .nav-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--background) 80%, transparent);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
  }

  /* ── Desktop nav (hidden until lg) ─────────────────────────────────── */
  .nav-desktop { display: none; }
  .nav-actions { display: none; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .nav-item { position: relative; }

  .nav-link,
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-12);
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    line-height: 1;
    cursor: pointer;
  }
  .nav-link:hover,
  .nav-trigger:hover { color: var(--primary); text-decoration: none; }
  .caret { transition: transform 0.18s ease; }
  .nav-item.is-open .caret { transform: rotate(180deg); }
  .nav-item.is-open .nav-trigger { color: var(--primary); }

  .nav-panel {
    position: absolute;
    top: calc(100% + var(--space-8));
    left: 0;
    z-index: 60;
    padding: var(--space-12);
    /* Frosted floating glass, same character as the pill (now that the panel's
       backdrop-filter actually samples the page — see .nav-bar::before). 86% fill + a
       strong blur frosts the content behind into an unreadable soft wash without going
       fully solid. */
    background: color-mix(in srgb, var(--popover) 86%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }
  .nav-item.is-open .nav-panel {
    opacity: 1;
    visibility: visible;
    transform: none;
    pointer-events: auto;
  }

  /* Transparent bridge over the gap so the pointer can travel from trigger to
     panel without leaving the item — keeps the mega menu open and clickable. */
  .nav-panel::before {
    content: '';
    position: absolute;
    top: calc(-1 * var(--space-8));
    left: 0;
    right: 0;
    height: var(--space-8);
  }

  .dropdown-list {
    min-width: 216px;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .dropdown-link {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-12);
    border-radius: var(--radius-sm);
    color: var(--popover-foreground);
    font-size: var(--text-body-sm);
    white-space: nowrap;
  }
  .dropdown-link:hover { background: var(--accent); text-decoration: none; }
  .is-soon { color: var(--muted-foreground); cursor: default; }
  .badge {
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    background: var(--secondary);
    color: var(--secondary-foreground);
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
  }

  /* Dark, icon-tile mega menu (drawn from the Duna/Cohere/ToDesktop dark references —
     deliberately not Supy's light bare-label grid). Each item = a rounded icon tile that
     lifts to purple on hover, a title, and a one-line description. */
  .mega { padding: var(--space-16); }
  .mega-2col {
    display: grid;
    grid-template-columns: repeat(2, minmax(248px, 1fr));
    gap: var(--space-16) var(--space-24);
    min-width: 560px;
  }
  .mega-3col {
    display: grid;
    grid-template-columns: repeat(3, minmax(248px, 1fr));
    gap: var(--space-16) var(--space-24);
    min-width: 820px;
  }
  .mega-group ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: var(--space-4); }
  .mega-group-title {
    margin: 0 0 var(--space-12);
    padding: 0 var(--space-12) var(--space-8);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .mega-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-12);
    padding: var(--space-8) var(--space-12);
    border-radius: var(--radius-md);
  }
  .mega-item:hover { background: var(--accent); text-decoration: none; }
  .mega-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--foreground) 6%, transparent);
    color: var(--foreground);
    transition: background-color 0.18s ease, color 0.18s ease;
  }
  .mega-ico :global(svg) { display: block; width: 20px; height: 20px; }
  /* Icon + tile stay as-is on hover (white icon); only the row background tints. */
  .mega-item-body { display: flex; flex-direction: column; gap: var(--space-4); min-width: 0; }
  .mega-item-title { color: var(--popover-foreground); font-weight: var(--fw-semibold); font-size: var(--text-body-sm); line-height: 1.3; }
  .mega-item-desc { color: var(--muted-foreground); font-size: var(--text-caption); line-height: var(--lh-body-sm); }

  /* ── Hamburger ─────────────────────────────────────────────────────── */
  .nav-burger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-8);
    background: transparent;
    border: none;
    color: var(--foreground);
    cursor: pointer;
  }
  .burger-icon { display: block; }
  .nav-burger .icon-close { display: none; }

  /* ── Mobile drawer (right-side panel, slides in from right, over the pill) */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    width: min(85vw, 380px);
    height: 100dvh;
    z-index: 60;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: color-mix(in srgb, var(--background) 85%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-left: 1px solid var(--border);
    box-shadow: -8px 0 40px color-mix(in srgb, #000 60%, transparent);
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.3s;
  }
  .mobile-menu.is-open {
    transform: translateX(0);
    visibility: visible;
  }
  /* Dimmed backdrop on the left strip — tap it to close */
  .mobile-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: min(85vw, 380px);
    bottom: 0;
    z-index: 48;
    background: color-mix(in srgb, #000 55%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  :global(body.nav-open) { overflow: hidden; }

  .m-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: color-mix(in srgb, var(--foreground) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
    border-radius: var(--radius-full);
    color: var(--muted-foreground);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.18s ease, color 0.18s ease;
  }
  .m-close:hover { background: color-mix(in srgb, var(--foreground) 10%, transparent); color: var(--foreground); }

  .m-acc { border-bottom: 1px solid var(--border); }
  .m-acc-trigger {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-16);
    padding-inline: 0;
    background: transparent;
    border: none;
    color: var(--foreground);
    font-family: var(--font-heading);
    font-size: var(--text-h6);
    font-weight: var(--fw-semibold);
    cursor: pointer;
  }
  .m-acc-trigger[aria-expanded='true'] .caret { transform: rotate(180deg); }
  .m-acc-panel { display: flex; flex-direction: column; gap: var(--space-4); padding-bottom: var(--space-16); }
  .m-acc-panel[hidden] { display: none; }
  .m-acc-link {
    display: block;
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--border);
    color: var(--foreground);
    font-family: var(--font-heading);
    font-size: var(--text-h6);
    font-weight: var(--fw-semibold);
  }
  .m-acc-link:hover { text-decoration: none; color: var(--primary); }
  .m-link {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-8);
    padding-left: var(--space-16);
    color: var(--foreground);
    font-size: var(--text-body-sm);
  }
  .m-link:hover { text-decoration: none; }
  .m-link-ico { display: inline-flex; flex: none; color: var(--foreground); }
  .m-link-ico :global(svg) { display: block; width: 20px; height: 20px; }
  .m-sub-title {
    margin-top: var(--space-12);
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }
  .mobile-scroll { flex: 1; overflow-y: auto; overflow-x: hidden; }
  /* Close bar sits above the scroll area — always visible at top of drawer */
  .m-close-bar {
    flex-shrink: 0;
    display: flex;
    justify-content: flex-end;
    padding: var(--space-24) var(--space-24) var(--space-16);
    border-bottom: 1px solid var(--border);
  }
  .mobile-locale { padding-top: var(--space-8); }
  /* Actions bar pinned at the bottom — never scrolls away */
  .mobile-actions {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding: var(--space-16) var(--gutter) calc(var(--space-24) + env(safe-area-inset-bottom, 0px));
    border-top: 1px solid var(--border);
  }
  .mobile-actions :global(.btn) { padding-block: var(--space-8); }

  @media (min-width: 1024px) {
    .nav-desktop { display: flex; flex: 1; justify-content: flex-end; margin-right: var(--space-16); }
    .nav-actions { display: flex; align-items: center; gap: var(--space-12); }
    .nav-burger,
    .mobile-menu,
    .mobile-backdrop { display: none; }
  }
</style>

<script>
  // ── Desktop dropdowns: hover + click + keyboard, one open at a time ──
  const desktopItems = Array.from(document.querySelectorAll<HTMLElement>('.nav-desktop .has-panel'));

  const closeItem = (item: HTMLElement) => {
    item.classList.remove('is-open');
    item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
  };
  const openItem = (item: HTMLElement) => {
    desktopItems.forEach((other) => { if (other !== item) closeItem(other); });
    item.classList.add('is-open');
    item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'true');
  };

  desktopItems.forEach((item) => {
    const trigger = item.querySelector('.nav-trigger');
    item.addEventListener('mouseenter', () => openItem(item));
    item.addEventListener('mouseleave', () => {
      if (!item.contains(document.activeElement)) closeItem(item);
    });
    trigger?.addEventListener('click', () => {
      item.classList.contains('is-open') ? closeItem(item) : openItem(item);
    });
    trigger?.addEventListener('focus', () => openItem(item));
    item.addEventListener('focusout', (e) => {
      if (!item.contains(e.relatedTarget as Node | null)) closeItem(item);
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { desktopItems.forEach(closeItem); setMenu(false); }
  });

  // ── Mobile drawer ───────────────────────────────────────────────────
  const burger = document.querySelector('.nav-burger');
  const mobileMenu = document.getElementById('mobile-menu');

  const backdrop = document.getElementById('mobile-backdrop');

  const setMenu = (open: boolean) => {
    if (!burger || !mobileMenu) return;
    mobileMenu.classList.toggle('is-open', open);
    mobileMenu.setAttribute('aria-hidden', String(!open));
    backdrop?.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.classList.toggle('nav-open', open);
  };

  burger?.addEventListener('click', () => setMenu(!mobileMenu?.classList.contains('is-open')));
  backdrop?.addEventListener('click', () => setMenu(false));
  document.querySelector<HTMLButtonElement>('.m-close')?.addEventListener('click', () => setMenu(false));

  document.querySelectorAll<HTMLButtonElement>('.m-acc-trigger').forEach((t) => {
    t.addEventListener('click', () => {
      const id = t.getAttribute('aria-controls');
      const panel = id ? document.getElementById(id) : null;
      const open = t.getAttribute('aria-expanded') === 'true';
      t.setAttribute('aria-expanded', String(!open));
      if (panel) panel.hidden = open;
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenu(false);
  });
</script>
