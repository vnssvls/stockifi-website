---
// Primary navigation. Built from the locked IA (audit/07-information-architecture.md)
// onto the three wireframe patterns: Product/Solutions = mega menus, Resources/Company
// = simple dropdowns, Pricing = plain link. Locale switcher sits between the last link
// and the buttons. Collapses to a drawer below lg (1024px) per the project breakpoints.
import Logo from './Logo.astro';
import Button from './Button.astro';
import LocaleSwitcher from './LocaleSwitcher.astro';

// Draft mega-menu microcopy — for V review.
const productItems = [
  { label: 'Recipe Costing', href: '/product/recipe-costing', desc: 'Live recipe costs that move with your supplier prices.' },
  { label: 'Supplier Price Tracking', href: '/product/supplier-price-tracking', desc: 'Catch price rises line by line, read from your invoices.' },
  { label: 'POS & Consumption', href: '/product/pos-integration', desc: 'Theoretical against actual usage, straight from sales.' },
  { label: 'Inventory & Variance', href: '/product/inventory-variance', desc: 'Stock counts and variance analysis in one place.' },
  { label: 'Integrations', href: '/integrations', desc: 'Connects to 30+ accounting and 40+ POS systems.' },
];
const solutionsSegment = [
  { label: 'Independent restaurants', href: '/solutions/independent-restaurants' },
  { label: 'Restaurant groups', href: '/solutions/restaurant-groups' },
  { label: 'Hotels with F&B', href: '/solutions/hotels' },
  { label: 'Bars', href: '/solutions/bars' },
];
const solutionsRole = [
  { label: 'Owners & GMs', href: '/solutions/owners' },
  { label: 'Finance', href: '/solutions/finance' },
  { label: 'Head Chefs', href: '/solutions/chefs' },
  { label: 'Operations', href: '/solutions/operations' },
];
const resourcesItems = [
  { label: 'Blog', href: '/blog' },
  { label: 'Customer Stories', href: '/customer-stories' },
  { label: 'Savings Calculator', href: '/savings-calculator' },
  { label: 'Comparisons', href: null, soon: true },
];
const companyItems = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const LOGIN_URL = 'https://web.stockifi.io/#/login';
---

<header class="site-header">
  <div class="container nav-bar">
    <Logo height={30} />

    <nav class="nav-desktop" aria-label="Primary">
      <ul class="nav-list">
        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-product">
            Product
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel mega" id="panel-product">
            <ul class="mega-grid">
              {productItems.map((i) => (
                <li>
                  <a class="mega-link" href={i.href}>
                    <span class="mega-title">{i.label}</span>
                    <span class="mega-desc">{i.desc}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>

        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-solutions">
            Solutions
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel mega mega-2col" id="panel-solutions">
            <div class="mega-group">
              <p class="mega-group-title">By segment</p>
              <ul>
                {solutionsSegment.map((i) => (<li><a href={i.href}>{i.label}</a></li>))}
              </ul>
            </div>
            <div class="mega-group">
              <p class="mega-group-title">By role</p>
              <ul>
                {solutionsRole.map((i) => (<li><a href={i.href}>{i.label}</a></li>))}
              </ul>
            </div>
          </div>
        </li>

        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-resources">
            Resources
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel" id="panel-resources">
            <ul class="dropdown-list">
              {resourcesItems.map((i) => (
                <li>
                  {i.soon
                    ? <span class="dropdown-link is-soon">{i.label}<span class="badge">Soon</span></span>
                    : <a class="dropdown-link" href={i.href}>{i.label}</a>}
                </li>
              ))}
            </ul>
          </div>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/pricing">Pricing</a>
        </li>

        <li class="nav-item has-panel">
          <button type="button" class="nav-trigger" aria-haspopup="true" aria-expanded="false" aria-controls="panel-company">
            Company
            <svg class="caret" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="nav-panel" id="panel-company">
            <ul class="dropdown-list">
              {companyItems.map((i) => (<li><a class="dropdown-link" href={i.href}>{i.label}</a></li>))}
            </ul>
          </div>
        </li>
      </ul>
    </nav>

    <div class="nav-actions">
      <LocaleSwitcher current="en" />
      <Button variant="secondary" href={LOGIN_URL}>Login</Button>
      <Button variant="primary" href="/contact">Book a demo</Button>
    </div>

    <button type="button" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg class="burger-icon icon-open" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
      <svg class="burger-icon icon-close" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <div class="container mobile-inner">
      <nav aria-label="Mobile">
        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-product">
            Product
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-product" hidden>
            {productItems.map((i) => (<a class="m-link" href={i.href}>{i.label}</a>))}
          </div>
        </div>

        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-solutions">
            Solutions
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-solutions" hidden>
            <p class="m-sub-title">By segment</p>
            {solutionsSegment.map((i) => (<a class="m-link" href={i.href}>{i.label}</a>))}
            <p class="m-sub-title">By role</p>
            {solutionsRole.map((i) => (<a class="m-link" href={i.href}>{i.label}</a>))}
          </div>
        </div>

        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-resources">
            Resources
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-resources" hidden>
            {resourcesItems.map((i) => (
              i.soon
                ? <span class="m-link is-soon">{i.label}<span class="badge">Soon</span></span>
                : <a class="m-link" href={i.href}>{i.label}</a>
            ))}
          </div>
        </div>

        <a class="m-acc-link" href="/pricing">Pricing</a>

        <div class="m-acc">
          <button type="button" class="m-acc-trigger" aria-expanded="false" aria-controls="m-company">
            Company
            <svg class="caret" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <div class="m-acc-panel" id="m-company" hidden>
            {companyItems.map((i) => (<a class="m-link" href={i.href}>{i.label}</a>))}
          </div>
        </div>
      </nav>

      <div class="mobile-locale"><LocaleSwitcher current="en" /></div>

      <div class="mobile-actions">
        <Button variant="secondary" href={LOGIN_URL} block>Login</Button>
        <Button variant="primary" href="/contact" block>Book a demo</Button>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--background);
    border-bottom: 1px solid var(--border);
  }
  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-24);
    padding-block: var(--space-16);
  }

  /* ── Desktop nav (hidden until lg) ─────────────────────────────────── */
  .nav-desktop { display: none; }
  .nav-actions { display: none; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .nav-item { position: relative; }

  .nav-link,
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-12);
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--foreground);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-medium);
    line-height: 1;
    cursor: pointer;
  }
  .nav-link:hover,
  .nav-trigger:hover { color: var(--primary); text-decoration: none; }
  .caret { transition: transform 0.18s ease; }
  .nav-item.is-open .caret { transform: rotate(180deg); }
  .nav-item.is-open .nav-trigger { color: var(--primary); }

  .nav-panel {
    position: absolute;
    top: calc(100% + var(--space-8));
    left: 0;
    z-index: 60;
    padding: var(--space-12);
    background: var(--popover);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }
  .nav-item.is-open .nav-panel {
    opacity: 1;
    visibility: visible;
    transform: none;
    pointer-events: auto;
  }

  .dropdown-list {
    min-width: 216px;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .dropdown-link {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-12);
    border-radius: var(--radius-sm);
    color: var(--popover-foreground);
    font-size: var(--text-body-sm);
    white-space: nowrap;
  }
  .dropdown-link:hover { background: var(--accent); text-decoration: none; }
  .is-soon { color: var(--muted-foreground); cursor: default; }
  .badge {
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-full);
    background: var(--secondary);
    color: var(--secondary-foreground);
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
  }

  .mega { min-width: 540px; }
  .mega-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4) var(--space-16);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .mega-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-12);
    border-radius: var(--radius-md);
  }
  .mega-link:hover { background: var(--accent); text-decoration: none; }
  .mega-title { color: var(--popover-foreground); font-weight: var(--fw-semibold); font-size: var(--text-body-sm); }
  .mega-desc { color: var(--muted-foreground); font-size: var(--text-caption); line-height: var(--lh-body-sm); }

  .mega-2col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-32);
    min-width: 460px;
  }
  .mega-group ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: var(--space-4); }
  .mega-group-title {
    margin-bottom: var(--space-8);
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }
  .mega-group a {
    display: block;
    padding: var(--space-8) var(--space-12);
    border-radius: var(--radius-sm);
    color: var(--popover-foreground);
    font-size: var(--text-body-sm);
  }
  .mega-group a:hover { background: var(--accent); text-decoration: none; }

  /* ── Hamburger ─────────────────────────────────────────────────────── */
  .nav-burger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-8);
    background: transparent;
    border: none;
    color: var(--foreground);
    cursor: pointer;
  }
  .burger-icon { display: block; }
  .nav-burger .icon-close { display: none; }
  .nav-burger[aria-expanded='true'] .icon-open { display: none; }
  .nav-burger[aria-expanded='true'] .icon-close { display: block; }

  /* ── Mobile menu ───────────────────────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: var(--background);
    overflow-y: auto;
    padding-block: calc(var(--space-64) + var(--space-8)) var(--space-32);
  }
  .mobile-menu[hidden] { display: none; }
  :global(body.nav-open) { overflow: hidden; }

  .m-acc { border-bottom: 1px solid var(--border); }
  .m-acc-trigger {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-16);
    background: transparent;
    border: none;
    color: var(--foreground);
    font-family: var(--font-heading);
    font-size: var(--text-h6);
    font-weight: var(--fw-semibold);
    cursor: pointer;
  }
  .m-acc-trigger[aria-expanded='true'] .caret { transform: rotate(180deg); }
  .m-acc-panel { display: flex; flex-direction: column; gap: var(--space-4); padding-bottom: var(--space-16); }
  .m-acc-panel[hidden] { display: none; }
  .m-acc-link {
    display: block;
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--border);
    color: var(--foreground);
    font-family: var(--font-heading);
    font-size: var(--text-h6);
    font-weight: var(--fw-semibold);
  }
  .m-acc-link:hover { text-decoration: none; color: var(--primary); }
  .m-link {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-8);
    color: var(--muted-foreground);
    font-size: var(--text-body-lg);
  }
  .m-link:hover { color: var(--foreground); text-decoration: none; }
  .m-sub-title {
    margin-top: var(--space-12);
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }
  .mobile-locale { margin-top: var(--space-24); }
  .mobile-actions { display: flex; flex-direction: column; gap: var(--space-12); margin-top: var(--space-24); }

  @media (min-width: 1024px) {
    .nav-desktop { display: flex; flex: 1; justify-content: flex-end; margin-right: var(--space-16); }
    .nav-actions { display: flex; align-items: center; gap: var(--space-12); }
    .nav-burger,
    .mobile-menu { display: none; }
  }
</style>

<script>
  // ── Desktop dropdowns: hover + click + keyboard, one open at a time ──
  const desktopItems = Array.from(document.querySelectorAll<HTMLElement>('.nav-desktop .has-panel'));

  const closeItem = (item: HTMLElement) => {
    item.classList.remove('is-open');
    item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
  };
  const openItem = (item: HTMLElement) => {
    desktopItems.forEach((other) => { if (other !== item) closeItem(other); });
    item.classList.add('is-open');
    item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'true');
  };

  desktopItems.forEach((item) => {
    const trigger = item.querySelector('.nav-trigger');
    item.addEventListener('mouseenter', () => openItem(item));
    item.addEventListener('mouseleave', () => {
      if (!item.contains(document.activeElement)) closeItem(item);
    });
    trigger?.addEventListener('click', () => {
      item.classList.contains('is-open') ? closeItem(item) : openItem(item);
    });
    trigger?.addEventListener('focus', () => openItem(item));
    item.addEventListener('focusout', (e) => {
      if (!item.contains(e.relatedTarget as Node | null)) closeItem(item);
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') desktopItems.forEach(closeItem);
  });

  // ── Mobile drawer ───────────────────────────────────────────────────
  const burger = document.querySelector('.nav-burger');
  const mobileMenu = document.getElementById('mobile-menu');

  const setMenu = (open: boolean) => {
    if (!burger || !mobileMenu) return;
    mobileMenu.hidden = !open;
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.classList.toggle('nav-open', open);
  };

  burger?.addEventListener('click', () => setMenu(mobileMenu?.hidden ?? true));

  document.querySelectorAll<HTMLButtonElement>('.m-acc-trigger').forEach((t) => {
    t.addEventListener('click', () => {
      const id = t.getAttribute('aria-controls');
      const panel = id ? document.getElementById(id) : null;
      const open = t.getAttribute('aria-expanded') === 'true';
      t.setAttribute('aria-expanded', String(!open));
      if (panel) panel.hidden = open;
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenu(false);
  });
</script>
