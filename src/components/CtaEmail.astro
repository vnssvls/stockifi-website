---
// CTA variant 2 (Figma CTA/28, node 10:2189 desktop / 10:2200 mobile): centered
// heading + subhead + inline email-capture form + terms line, on a FULL-BLEED
// image background (edge to edge) with a dark scrim for contrast. The form hands
// off to the lead-capture flow (default /intro); swap `action` per use. Stacks on
// mobile. With no bgImage it falls back to a plain section on the page background.
import Button from './Button.astro';

interface Props {
  heading: string;
  subhead?: string;
  placeholder?: string;
  buttonLabel?: string;
  action?: string;
  termsHref?: string;
  bgImage?: string;
  /** Pass 2+ to cycle a random one per page load. */
  bgImages?: string[];
}
const {
  heading,
  subhead,
  placeholder = 'Enter your email',
  buttonLabel = 'Get started',
  action = '/intro',
  termsHref = '/terms-conditions',
  bgImage,
  bgImages,
} = Astro.props;

const TERMS: Record<string, {
  pre: string; mid: string; link: string; post: string; success: string;
  successH: string; successP: string; successAlt: string; successCta: string; successCtaHref: string;
}> = {
  en: {
    pre: 'By clicking', mid: "you're confirming that you agree with our", link: 'Terms and Conditions', post: '.',
    success: "Got it! Someone will be in touch shortly.",
    successH: "Got it!", successP: "Someone will be in touch shortly.",
    successAlt: "In the meantime, read about how other businesses improved their operations with Stockifi.",
    successCta: "Read customer stories", successCtaHref: "/customer-stories",
  },
  de: {
    pre: 'Mit Klick auf', mid: 'bestätigen Sie, dass Sie unseren', link: 'Allgemeinen Geschäftsbedingungen', post: ' zustimmen.',
    success: 'Alles klar! Jemand meldet sich in Kürze.',
    successH: "Alles klar!", successP: "Jemand aus unserem Team meldet sich in Kürze.",
    successAlt: "Lesen Sie in der Zwischenzeit, wie andere Betriebe ihre Abläufe mit Stockifi verbessert haben.",
    successCta: "Kundenberichte lesen", successCtaHref: "/de/customer-stories",
  },
  no: {
    pre: 'Ved å klikke på', mid: 'bekrefter du at du godtar våre', link: 'Vilkår og betingelser', post: '.',
    success: 'Mottatt! Noen tar kontakt snart.',
    successH: "Mottatt!", successP: "Noen tar kontakt med deg snart.",
    successAlt: "Les i mellomtiden hvordan andre virksomheter har forbedret driften sin med Stockifi.",
    successCta: "Les kundehistorier", successCtaHref: "/no/customer-stories",
  },
  sv: {
    pre: 'Genom att klicka på', mid: 'bekräftar du att du godkänner våra', link: 'Villkor', post: '.',
    success: 'Klart! Någon hör av sig inom kort.',
    successH: "Klart!", successP: "Någon hör av sig till dig inom kort.",
    successAlt: "Läs under tiden hur andra verksamheter har förbättrat sin verksamhet med Stockifi.",
    successCta: "Läs kundberättelser", successCtaHref: "/sv/customer-stories",
  },
  nl: {
    pre: 'Door op', mid: 'te klikken, bevestigt u dat u akkoord gaat met onze', link: 'Algemene voorwaarden', post: '.',
    success: 'Gelukt! Iemand neemt binnenkort contact op.',
    successH: "Gelukt!", successP: "Iemand neemt binnenkort contact met je op.",
    successAlt: "Lees ondertussen hoe andere bedrijven hun bedrijfsvoering hebben verbeterd met Stockifi.",
    successCta: "Lees klantverhalen", successCtaHref: "/nl/customer-stories",
  },
  da: {
    pre: 'Ved at klikke på', mid: 'bekræfter du, at du accepterer vores', link: 'Vilkår og betingelser', post: '.',
    success: 'Modtaget! Nogen kontakter dig snart.',
    successH: "Modtaget!", successP: "Nogen kontakter dig snart.",
    successAlt: "Læs i mellemtiden, hvordan andre virksomheder har forbedret deres drift med Stockifi.",
    successCta: "Læs kundehistorier", successCtaHref: "/da/customer-stories",
  },
};
const locale = Astro.currentLocale ?? 'en';
const t = TERMS[locale] ?? TERMS.en;

const imgs = bgImages?.length ? bgImages : bgImage ? [bgImage] : [];
const hasBg = imgs.length > 0;
// A single image is set server-side; for 2+ the client script picks one at random,
// kept out of SSR so only the chosen image downloads (no wasted second load).
const single = imgs.length === 1 ? imgs[0] : '';
---

<section
  class:list={['cta-email section', hasBg && 'cta-email--bg']}
  style={single ? `--ce-bg: url('${single}')` : undefined}
  data-cta-bgs={imgs.length > 1 ? JSON.stringify(imgs) : undefined}
>
  <div class="container ce-inner">
    <h2 class="ce-heading">{heading}</h2>

    <div class="ce-form-wrap">
      <form class="ce-form" data-ce-form action={action} method="get">
        <input
          class="ce-input"
          type="email"
          name="email"
          required
          placeholder={placeholder}
          aria-label="Email address"
        />
        <Button variant="primary" type="submit">{buttonLabel}</Button>
      </form>
      <p class="ce-success ce-hidden" data-ce-success data-msg={t.success}></p>
    </div>

    <p class="ce-terms text-muted" data-ce-terms>
      {t.pre} {buttonLabel} {t.mid} <a href={termsHref}>{t.link}</a>{t.post}
    </p>
  </div>

  <dialog class="ce-dialog" data-ce-dialog>
  <div class="ce-dialog-inner">
    <button class="ce-dialog-close" data-ce-dialog-close aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="ce-dialog-check" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="14" r="13" stroke="var(--primary)" stroke-width="1.5"/>
        <path d="M8.5 14l4 4 7-8" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <p class="ce-dialog-h">{t.successH}</p>
    <p class="ce-dialog-p">{t.successP}</p>
    <p class="ce-dialog-alt">{t.successAlt}</p>
    <a class="ce-dialog-cta" href={t.successCtaHref}>{t.successCta} →</a>
  </div>
  </dialog>
</section>

<style>
  /* Full-bleed image background. `background-image` (not the linted `background`
     shorthand) layers a dark scrim over the photo so the white heading + form stay
     legible on any image. */
  .cta-email--bg {
    --ce-bg: none; /* scrim-only until the client script sets the chosen image */
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--background) 82%, transparent),
        color-mix(in srgb, var(--background) 82%, transparent)
      ),
      var(--ce-bg);
    background-size: cover;
    background-position: center;
  }

  .ce-inner { text-align: center; }
  .ce-heading { max-width: 26ch; margin-inline: auto; }
  .ce-subhead { margin-top: var(--space-16); margin-inline: auto; max-width: 56ch; font-size: var(--text-body-lg); }

  .ce-form {
    display: flex;
    gap: var(--space-12);
    max-width: 38rem;
    margin: var(--space-32) auto 0;
  }
  .ce-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-12) var(--space-16);
    background: var(--card);
    color: var(--foreground);
    border: 1px solid var(--input);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-body);
  }
  .ce-input::placeholder { color: var(--muted-foreground); }

  /* White-fill submit button — the CTA sits on a dark photo, so white reads stronger
     than the purple primary. Ripple (built for the purple base) is hidden. */
  .ce-form :global(.btn-primary) {
    background: var(--foreground);
    color: var(--background);
  }
  .ce-form :global(.btn-primary:hover) {
    background: color-mix(in srgb, var(--foreground) 88%, transparent);
  }
  .ce-form :global(.btn-primary .btn-ripple) { display: none; }

  .ce-hidden { display: none; }
  .ce-success {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: var(--space-32);
    font-size: var(--text-body-lg);
    font-weight: var(--fw-medium);
    color: var(--foreground);
  }

  .ce-terms { margin-top: var(--space-16); font-size: var(--text-caption); }
  .ce-terms a { color: var(--muted-foreground); text-decoration: underline; }
  .ce-terms a:hover { color: var(--foreground); }

  /* On an image background: brighten the secondary text and make the input a
     transparent white-outlined field (matches the wireframe). */
  .cta-email--bg .ce-subhead,
  .cta-email--bg .ce-terms { color: color-mix(in srgb, var(--foreground) 82%, transparent); }
  .cta-email--bg .ce-terms a { color: var(--foreground); }
  .cta-email--bg .ce-input {
    background: transparent;
    border-color: color-mix(in srgb, var(--foreground) 55%, transparent);
    color: var(--foreground);
  }
  .cta-email--bg .ce-input::placeholder { color: color-mix(in srgb, var(--foreground) 70%, transparent); }

  @media (max-width: 639px) {
    .ce-form { flex-direction: column; }
  }

  /* Dialog — display goes on the inner div, not .ce-dialog, to keep dialog:not([open]) working */
  .ce-dialog {
    /* The global `* { margin: 0 }` reset overrides the UA `margin: auto` that
       centers a modal dialog, dropping it top-left. Re-center it explicitly. */
    position: fixed;
    inset: 0;
    margin: auto;
    height: fit-content;
    max-height: calc(100dvh - 2rem);
    border: none;
    border-radius: var(--radius-lg);
    background: var(--card);
    padding: 0;
    max-width: 360px;
    width: calc(100% - 2rem);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }
  .ce-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
  }
  .ce-dialog[open] .ce-dialog-inner {
    animation: ce-dialog-in 0.22s ease-out both;
  }
  @keyframes ce-dialog-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .ce-dialog-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-12);
    padding: var(--space-32) var(--space-32) 2.5rem;
    position: relative;
  }
  .ce-dialog-close {
    position: absolute;
    top: var(--space-16);
    right: var(--space-16);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted-foreground);
    padding: var(--space-4);
    line-height: 0;
    border-radius: var(--radius-sm);
    transition: color 0.15s;
  }
  .ce-dialog-close:hover { color: var(--foreground); }
  .ce-dialog-check { margin-bottom: var(--space-4); }
  .ce-dialog-h {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: var(--fw-bold);
    line-height: var(--lh-h3);
    color: var(--foreground);
  }
  .ce-dialog-p {
    font-size: var(--text-body);
    line-height: var(--lh-body);
    color: var(--foreground);
  }
  .ce-dialog-alt {
    font-size: var(--text-body-sm);
    line-height: var(--lh-body);
    color: var(--muted-foreground);
  }
  .ce-dialog-cta {
    font-size: var(--text-body-sm);
    color: var(--primary);
    text-decoration: none;
    margin-top: var(--space-4);
  }
  .ce-dialog-cta:hover { text-decoration: underline; }
</style>

<script>
  // Pick a random background from the list on each load (re-rolls the SSR choice).
  document.querySelectorAll<HTMLElement>('[data-cta-bgs]').forEach((el) => {
    let imgs: string[] = [];
    try { imgs = JSON.parse(el.dataset.ctaBgs ?? '[]'); } catch { /* ignore */ }
    if (imgs.length < 2) return;
    const pick = imgs[Math.floor(Math.random() * imgs.length)];
    el.style.setProperty('--ce-bg', `url('${pick}')`);
  });

  const PORTAL_ID = '48915892';
  const FORM_GUID = 'a9687b88-dcf6-4d77-9288-abc68e2bb521';

  document.querySelectorAll<HTMLFormElement>('[data-ce-form]').forEach((form) => {
    const section = form.closest('section');
    const dialog = section?.querySelector<HTMLDialogElement>('[data-ce-dialog]');
    const wrap = form.closest('.ce-form-wrap');
    const successEl = wrap?.querySelector<HTMLElement>('[data-ce-success]');

    // Close on backdrop click
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    dialog?.querySelector('[data-ce-dialog-close]')?.addEventListener('click', () => {
      dialog?.close();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const input = form.querySelector<HTMLInputElement>('[name="email"]');
      const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
      if (!input || !btn) return;

      const email = input.value.trim();
      if (!email) return;

      btn.disabled = true;

      const hutk = document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith('hubspotutk='))
        ?.split('=')[1];

      const payload: Record<string, unknown> = {
        fields: [{ name: 'email', value: email }],
        context: {
          pageUri: window.location.href,
          pageName: document.title,
          ...(hutk && { hutk }),
        },
      };

      try {
        const res = await fetch(
          `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_GUID}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          }
        );

        if (!res.ok) throw new Error(`${res.status}`);

        // Clear the page state behind the dialog: hide the form, subhead and terms,
        // then show the inline confirmation so the band reads clean once dismissed.
        form.classList.add('ce-hidden');
        section?.querySelector('.ce-terms')?.classList.add('ce-hidden');
        if (successEl) {
          successEl.textContent = successEl.dataset.msg ?? '';
          successEl.classList.remove('ce-hidden');
        }
        dialog?.showModal();
      } catch {
        btn.disabled = false;
      }
    });
  });
</script>
