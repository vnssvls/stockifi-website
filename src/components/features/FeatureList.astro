---
// Feature Layout 1 — stacked heading/paragraph list beside one tall image.
import MediaPlaceholder from './MediaPlaceholder.astro';

interface Item { heading: string; body: string; }
interface Props {
  tagline?: string;
  items: Item[];
  image?: { src: string; alt: string };
}
const { tagline, items, image } = Astro.props;
---

<section class="feature-list section">
  <div class="container fl-grid">
    <div class="fl-copy">
      {tagline && <p class="tagline">{tagline}</p>}
      <div class="fl-items">
        {items.map((it) => (
          <div class="fl-item">
            <h3>{it.heading}</h3>
            <p class="text-muted">{it.body}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="fl-media">
      {image ? <img src={image.src} alt={image.alt} /> : <MediaPlaceholder ratio="3 / 4" />}
    </div>
  </div>
</section>

<style>
  .fl-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); align-items: start; }
  .fl-items { display: flex; flex-direction: column; gap: var(--space-32); }
  .tagline + .fl-items { margin-top: var(--space-24); }
  .fl-item { border-left: 2px solid var(--border); padding-left: var(--space-24); }
  .fl-item h3 { font-size: var(--text-h5); margin-bottom: var(--space-8); }
  .fl-media img { width: 100%; aspect-ratio: 3 / 4; object-fit: cover; border-radius: var(--radius-lg); }

  @media (min-width: 1024px) {
    .fl-grid { grid-template-columns: 1fr 1fr; gap: var(--space-96); }
    .fl-media { position: sticky; top: var(--space-96); }
  }
</style>
