---
// Feature Layout 1 — interactive vertical list beside a swapping image.
// Each item is a tab: the active one keeps the left accent border at full opacity,
// inactive items dim, and the media on the right swaps to the active item's image.
// The active item's body reveals (accordion) and can carry an optional CTA link.
import MediaPlaceholder from './MediaPlaceholder.astro';
import ProcurementAnimation from '../animations/ProcurementAnimation.astro';

interface Item { heading: string; body: string; icon?: string; cta?: { label: string; href: string }; image?: { src: string; alt: string }; animation?: string; }
interface Props {
  tagline?: string;
  items: Item[];
}
const { tagline, items } = Astro.props;
---

<section class="feature-list section" data-feature-list>
  <div class="container fl-grid">
    <div class="fl-copy">
      {tagline && <p class="tagline">{tagline}</p>}
      <div class:list={['fl-items', tagline && 'fl-items--spaced']} role="tablist" aria-orientation="vertical">
        {items.map((it, i) => (
          <div class:list={['fl-item', i === 0 && 'is-active']} data-index={i} data-has-icon={!!it.icon}>
            <button class="fl-item-trigger" type="button" role="tab" data-index={i} aria-selected={i === 0 ? 'true' : 'false'}>
              <span class="fl-item-left">
                {it.icon && (
                  <span class="fl-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={it.icon} />
                  </span>
                )}
                <span class="fl-item-h">{it.heading}</span>
              </span>
              <svg class="fl-item-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="fl-item-b"><div class="fl-item-b-inner">
              <p class="fl-item-body">{it.body}</p>
              {it.cta && (
                <a class="fl-item-cta" href={it.cta.href}>
                  {it.cta.label}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </a>
              )}
            </div></div>
          </div>
        ))}
      </div>
    </div>

    <div class="fl-media">
      {items.map((it, i) => (
        <div class="fl-panel" role="tabpanel" data-index={i} hidden={i !== 0}>
          {it.animation === 'procurement' ? <ProcurementAnimation /> : it.image ? <img src={it.image.src} alt={it.image.alt} /> : <MediaPlaceholder ratio="16 / 10" label={it.heading} />}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .fl-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); align-items: start; }
  .fl-items { display: flex; flex-direction: column; }
  .fl-items--spaced { margin-top: var(--space-16); }

  /* Separator-row accordion: divider only between items, not above the first or
     below the last. */
  .fl-item { padding: var(--space-24) 0; }
  .fl-item + .fl-item {
    border-top: 1px solid color-mix(in srgb, var(--foreground) 10%, transparent);
  }

  /* Trigger is full-width flex row: left group (icon + heading), chevron right. */
  .fl-item-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    width: 100%;
    text-align: left;
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 0;
  }
  .fl-item-trigger:focus-visible { outline: none; }

  .fl-item-left {
    display: flex;
    align-items: center;
    gap: var(--space-16);
  }

  /* Icon container — small rounded square, Causal-style. */
  .fl-item-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--foreground) 10%, transparent);
    background: color-mix(in srgb, var(--foreground) 6%, transparent);
    color: color-mix(in srgb, var(--foreground) 35%, transparent);
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .fl-item:not(.is-active):hover .fl-item-icon {
    color: color-mix(in srgb, var(--foreground) 65%, transparent);
    border-color: color-mix(in srgb, var(--foreground) 18%, transparent);
  }
  .fl-item.is-active .fl-item-icon {
    color: var(--foreground);
    border-color: color-mix(in srgb, var(--foreground) 22%, transparent);
    background: color-mix(in srgb, var(--foreground) 10%, transparent);
  }

  .fl-item-h {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--fw-regular);
    color: var(--muted-foreground);
    transition: color 0.2s ease, font-weight 0.2s ease;
  }
  .fl-item:not(.is-active):hover .fl-item-h { color: var(--foreground); }
  .fl-item.is-active .fl-item-h { color: var(--foreground); font-weight: var(--fw-semibold); }

  /* Chevron rotates 180° when open — gives a clear expand/collapse signal. */
  .fl-item-chevron {
    flex-shrink: 0;
    color: color-mix(in srgb, var(--foreground) 25%, transparent);
    transition: transform 0.3s ease, color 0.2s ease;
  }
  .fl-item:not(.is-active):hover .fl-item-chevron { color: color-mix(in srgb, var(--foreground) 50%, transparent); }
  .fl-item.is-active .fl-item-chevron { transform: rotate(180deg); color: var(--primary); }

  /* When icons are present, indent the body to align under the heading (past the icon). */
  .fl-item[data-has-icon="true"] .fl-item-b-inner {
    padding-left: calc(36px + var(--space-16));
  }

  /* Body reveals like an accordion (grid-rows 0fr→1fr is content-height-aware). */
  .fl-item-b { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.3s ease; }
  .fl-item.is-active .fl-item-b { grid-template-rows: 1fr; }
  .fl-item-b-inner { overflow: hidden; min-height: 0; padding-top: var(--space-12); }
  .fl-item-body { font-size: var(--text-body); color: var(--muted-foreground); line-height: var(--lh-body); }
  .fl-item-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    margin-top: var(--space-16);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-semibold);
    color: var(--foreground);
    transition: gap 0.18s ease, color 0.18s ease;
  }
  .fl-item-cta:hover { gap: var(--space-12); color: var(--primary-light); text-decoration: none; }
  @media (prefers-reduced-motion: reduce) {
    .fl-item-b, .fl-item-chevron { transition: none; }
  }

  .fl-panel[hidden] { display: none; }
  .fl-panel img { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; border-radius: var(--radius-lg); }

  @media (min-width: 1024px) {
    .fl-grid { grid-template-columns: 1fr 1fr; gap: var(--space-96); }
    .fl-media { position: sticky; top: var(--space-96); }
    .fl-items--spaced { margin-top: var(--space-32); }
  }
</style>

<script>
  let n = 0;
  document.querySelectorAll('[data-feature-list]').forEach((root) => {
    const base = `flist-${n++}`;
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.fl-item-trigger'));
    const items = Array.from(root.querySelectorAll<HTMLElement>('.fl-item'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.fl-panel'));

    tabs.forEach((tab, i) => {
      tab.id = `${base}-tab-${i}`;
      panels[i].id = `${base}-panel-${i}`;
      tab.setAttribute('aria-controls', panels[i].id);
      panels[i].setAttribute('aria-labelledby', tab.id);
      tab.setAttribute('tabindex', i === 0 ? '0' : '-1');

      tab.addEventListener('click', () => {
        tabs.forEach((t, j) => {
          const on = j === i;
          t.setAttribute('aria-selected', String(on));
          t.setAttribute('tabindex', on ? '0' : '-1');
          items[j]?.classList.toggle('is-active', on);
          panels[j].hidden = !on;
        });
        tab.focus();
      });

      tab.addEventListener('keydown', (e) => {
        const keys = ['ArrowDown', 'ArrowUp', 'Home', 'End'];
        if (!keys.includes(e.key)) return;
        e.preventDefault();
        let next = i;
        if (e.key === 'ArrowDown') next = (i + 1) % tabs.length;
        else if (e.key === 'ArrowUp') next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else next = tabs.length - 1;
        tabs[next].click();
      });
    });
  });
</script>
