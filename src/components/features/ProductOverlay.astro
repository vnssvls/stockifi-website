---
// Resolves the light-mode UI card laid on top of a product showcase image, by
// product slug. Add a page's overlay component here once and every locale's
// template renders it (templates only pass the slug). Pages without an overlay
// render nothing here and show the background photo alone.
import ProcurementAnimation from '../animations/ProcurementAnimation.astro';
import CentralKitchenFlow from '../animations/CentralKitchenFlow.astro';
import InvoiceScan from '../animations/InvoiceScan.astro';
import AnomalyDetect from '../animations/AnomalyDetect.astro';
import OrderSuggestions from '../animations/OrderSuggestions.astro';
import RecipeCost from '../animations/RecipeCost.astro';
import StockCount from '../animations/StockCount.astro';
import InventoryTransfer from '../animations/InventoryTransfer.astro';
import { productMedia } from '../../data/product-media';

interface Props { slug: string; }
const { slug } = Astro.props;
const overlay = productMedia[slug]?.overlay ?? null;
---
{overlay === 'ProcurementAnimation' && <ProcurementAnimation />}
{overlay === 'CentralKitchenFlow' && <CentralKitchenFlow />}
{overlay === 'InvoiceScan' && <InvoiceScan />}
{overlay === 'AnomalyDetect' && <AnomalyDetect />}
{overlay === 'OrderSuggestions' && <OrderSuggestions />}
{overlay === 'RecipeCost' && <RecipeCost />}
{overlay === 'StockCount' && <StockCount />}
{overlay === 'InventoryTransfer' && <InventoryTransfer />}
