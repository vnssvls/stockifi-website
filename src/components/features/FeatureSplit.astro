---
// Feature Layout 2 — image one side, heading + paragraph + icon checklist the other.
// Supports a `media` slot to replace the image with an animation component.
import MediaPlaceholder from './MediaPlaceholder.astro';

interface Props {
  tagline?: string;
  heading: string;
  body?: string;
  items?: string[];
  image?: { src: string; alt: string };
  imageSide?: 'left' | 'right';
}
const { tagline, heading, body, items = [], image, imageSide = 'left' } = Astro.props;
const hasMediaSlot = Astro.slots.has('media');
---

<section class="feature-split section">
  <div class:list={['container', 'fs-grid', imageSide === 'right' && 'fs-image-right']}>
    <div class:list={['fs-media', hasMediaSlot && 'fs-media--anim']}>
      {hasMediaSlot
        ? <slot name="media" />
        : image
          ? <img src={image.src} alt={image.alt} />
          : <MediaPlaceholder ratio="1 / 1" />
      }
      {!hasMediaSlot && (
        <div class="fs-overlay-anchor">
          <slot name="media-overlay" />
        </div>
      )}
    </div>
    <div class="fs-copy">
      {tagline && <p class="tagline">{tagline}</p>}
      <h2>{heading}</h2>
      {body && <p class="fs-body text-muted">{body}</p>}
      {items.length > 0 && (
        <ul class="fs-list">
          {items.map((label) => (
            <li>
              <svg class="fs-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m5 13 4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>
              <span>{label}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>

<style>
  .feature-split {
    background-image:
      radial-gradient(50% 65% at 12% 48%, rgba(158, 180, 250, 0.05), transparent 62%),
      radial-gradient(45% 55% at 4% 28%, rgba(186, 140, 238, 0.04), transparent 64%),
      radial-gradient(48% 52% at 16% 72%, rgba(248, 176, 214, 0.04), transparent 62%),
      radial-gradient(50% 65% at 88% 48%, rgba(158, 180, 250, 0.05), transparent 62%),
      radial-gradient(45% 55% at 96% 28%, rgba(186, 140, 238, 0.04), transparent 64%),
      radial-gradient(48% 52% at 84% 72%, rgba(248, 176, 214, 0.04), transparent 62%);
  }
  .fs-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); align-items: center; }
  /* Mobile: copy first, image below, full-width bleed */
  .fs-media { position: relative; order: 2; margin-inline: calc(-1 * var(--gutter)); }
  .fs-copy { order: 1; }
  .fs-media img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border-radius: 0; }
  /* Mobile veil — matches hero ::before gradient exactly */
  .fs-media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--background) 90%, transparent) 0%,
      color-mix(in srgb, var(--background) 72%, transparent) 28%,
      color-mix(in srgb, var(--background) 35%, transparent) 52%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
  }
  .fs-overlay-anchor { position: absolute; bottom: -24px; left: 20px; z-index: 2; }
  .fs-copy h2 { margin-bottom: var(--space-16); }
  .tagline + h2 { margin-top: var(--space-16); }
  .fs-body { font-size: var(--text-body-lg); margin-bottom: var(--space-24); }
  .fs-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-16); }
  .fs-list li { display: flex; align-items: center; gap: var(--space-12); font-size: var(--text-body); }
  .fs-icon { color: var(--primary); flex: none; }

  /* Animation variant — no gradient veil, no aspect-ratio crop */
  .fs-media--anim::before { display: none; }
  .fs-media--anim img { aspect-ratio: unset; }

  /* Scale card down on narrow phones only */
  @media (max-width: 599px) {
    .fs-overlay-anchor { zoom: 0.72; }
  }

  @media (min-width: 1024px) {
    .fs-grid { grid-template-columns: 1fr 1fr; gap: var(--space-96); max-width: none; padding-inline: 100px; }
    /* Reset mobile overrides */
    .fs-media { order: 0; margin-inline: 0; }
    .fs-copy { order: 0; }
    .fs-media img { border-radius: var(--radius-lg); }
    .fs-media::before { display: none; }
    .fs-image-right .fs-media { order: 2; }

    .fs-image-right .fs-media img {
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 50%);
      mask-image: linear-gradient(to right, transparent 0%, black 50%);
    }
  }
</style>
