---
// Feature Layout 5 — "Feature 5 new" (Figma 80:1230, Relume layout-507), restyled with
// a borderless, pill tab switcher ("Spring Slide"): a rounded track with a sliding
// indicator pill that springs between tabs, and a cross-fading split pane (copy left +
// media right). Wide (full-width, 60px desktop gutter). Accessible tabs.
import Button from '../Button.astro';
import MediaPlaceholder from './MediaPlaceholder.astro';
import TabCard from '../ui/TabCard.astro';

interface TabCardData {
  title?: string;
  avg?: { label: string; value: string };
  rows?: { label: string; value: string; value2?: string; status?: 'green' | 'amber' | 'red'; barPct?: number }[];
  visual?: any;
  insight?: string;
  insightType?: 'amber' | 'green';
  action?: string;
  invertValues?: boolean;
  side?: 'left' | 'right';
}
interface Tab {
  label: string;
  tagline?: string;
  heading: string;
  body: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
  image?: { src: string; alt: string };
  card?: TabCardData;
}
interface Props {
  tagline?: string;
  heading: string;
  subhead?: string;
  tabs: Tab[];
}
const { tagline, heading, subhead, tabs } = Astro.props;
---

<section class="feature-tabs section" data-feature-tabs>
  <div class="ft-wide">
    <div class="ft-head">
      {tagline && <p class="tagline">{tagline}</p>}
      <h2>{heading}</h2>
      {subhead && <p class="ft-sub text-muted">{subhead}</p>}
    </div>

    <div class="ft-tabs" role="tablist" aria-label="Features">
      <span class="ft-indicator" aria-hidden="true"></span>
      {tabs.map((t, i) => (
        <button class="ft-tab" type="button" role="tab" data-index={i} aria-selected={i === 0 ? 'true' : 'false'}>{t.label}</button>
      ))}
    </div>

    <div class="ft-panels">
      {tabs.map((t, i) => (
        <div class:list={['ft-panel', i === 0 && 'is-active']} role="tabpanel" data-index={i}>
          <div class="ft-copy">
            {t.tagline && <p class="tagline">{t.tagline}</p>}
            <h3 class="ft-h">{t.heading}</h3>
            <p class="ft-body text-muted">{t.body}</p>
            {(t.primary || t.secondary) && (
              <div class="ft-actions">
                {t.primary && (
                  <Button variant="secondary" href={t.primary.href}>
                    {t.primary.label}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </Button>
                )}
                {t.secondary && (
                  <Button variant="ghost" href={t.secondary.href}>
                    {t.secondary.label}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </Button>
                )}
              </div>
            )}
          </div>
          <div class="ft-media">
            {t.image ? <img src={t.image.src} alt={t.image.alt} /> : <MediaPlaceholder ratio="1 / 1" />}
            {t.card && (
              <div class:list={['ft-card-anchor', t.card.side === 'right' && 'ft-card-anchor--right']}>
                <TabCard
                  title={t.card.title}
                  avg={t.card.avg}
                  rows={t.card.rows}
                  visual={t.card.visual}
                  insight={t.card.insight}
                  insightType={t.card.insightType}
                  action={t.card.action}
                  invertValues={t.card.invertValues}
                />
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Wide: full width with a 60px gutter on desktop (V), 20px on mobile. */
  .ft-wide { width: 100%; max-width: none; margin-inline: auto; padding-inline: var(--gutter-wide); }

  .ft-head { max-width: 768px; margin: 0 auto var(--space-48); text-align: center; }
  .tagline + h2 { margin-top: var(--space-16); }
  .ft-sub { margin-top: var(--space-16); font-size: var(--text-body-lg); }

  /* Mobile: no track — the pills simply wrap and stay clickable; the active pill fills
     directly (the sliding indicator is desktop-only). */
  .ft-tabs {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-8);
    margin: 0 auto var(--space-48);
  }

  /* The sliding pill (desktop only). JS sets its width/height/transform to the active
     tab's box; the spring easing (slight overshoot) gives the flowing slide. */
  .ft-indicator {
    display: none;
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    border-radius: var(--radius-full);
    /* Secondary-button look: subtle tint inside + a white border (not primary). */
    background-color: color-mix(in srgb, var(--foreground) 8%, transparent);
    border: 1px solid var(--foreground);
    z-index: 0;
    pointer-events: none;
    transition:
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      width 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ft-tab {
    position: relative;
    z-index: 1;
    flex: none;
    padding: var(--space-12) var(--space-24);
    border: 1px solid transparent;
    background: transparent;
    border-radius: var(--radius-full);
    color: var(--muted-foreground);
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: var(--fw-semibold);
    white-space: nowrap;
    cursor: pointer;
    transition: color 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }
  .ft-tab:hover { color: var(--foreground); }
  /* Mobile active pill: subtle tint + white border (desktop hands this to the indicator). */
  .ft-tab[aria-selected='true'] {
    color: var(--foreground);
    background-color: color-mix(in srgb, var(--foreground) 8%, transparent);
    border-color: var(--foreground);
  }

  /* Panes stacked in one cell so they cross-fade without a layout jump. */
  .ft-panels { display: grid; }
  .ft-panel {
    grid-area: 1 / 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-32);
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transform: translateX(16px);
    transition: opacity 0.35s ease, transform 0.35s ease, visibility 0.35s;
  }
  .ft-panel.is-active { opacity: 1; visibility: visible; transform: none; }

  .ft-copy { display: flex; flex-direction: column; gap: var(--space-16); }
  .ft-h { font-size: var(--text-h3); }
  .ft-body { line-height: var(--lh-body); }
  .ft-actions { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-24); margin-top: var(--space-8); }
  .ft-media { position: relative; }
  .ft-media img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: var(--radius-lg); }

  .ft-card-anchor {
    position: absolute;
    bottom: 20px;
    left: 20px;
    z-index: 2;
  }
  .ft-card-anchor--right {
    left: auto;
    right: 20px;
  }
  @media (max-width: 599px) {
    .ft-card-anchor { zoom: 0.72; }
  }

  /* Tablet+: floating pill track (nav-style) — translucent page-bg fill (not grey),
     border, shadow, blur. Single row; the sliding indicator provides the active pill. */
  @media (min-width: 768px) {
    .ft-tabs {
      flex-wrap: nowrap;
      width: fit-content;
      max-width: 100%;
      gap: 0;
      padding: var(--space-8);
      border-radius: var(--radius-full);
      background-color: color-mix(in srgb, var(--background) 80%, transparent);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-md);
      backdrop-filter: blur(12px) saturate(140%);
      -webkit-backdrop-filter: blur(12px) saturate(140%);
      overflow-x: auto;
      scrollbar-width: none;
    }
    .ft-tabs::-webkit-scrollbar { display: none; }
    .ft-indicator { display: block; }
    /* Indicator (not the tab) carries the active fill + border on desktop. */
    .ft-tab[aria-selected='true'] { background-color: transparent; border-color: transparent; }
  }

  @media (min-width: 1024px) {
    .ft-wide { padding-inline: 100px; }
    .ft-panel { grid-template-columns: 1fr 1fr; gap: var(--space-64); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ft-indicator,
    .ft-panel { transition: none; }
  }
</style>

<script>
  let n = 0;
  document.querySelectorAll<HTMLElement>('[data-feature-tabs]').forEach((root) => {
    const base = `ftabs-${n++}`;
    const indicator = root.querySelector<HTMLElement>('.ft-indicator');
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.ft-tab'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.ft-panel'));
    if (tabs.length === 0) return;
    let current = 0;

    // Position the indicator pill over tab i. `animate=false` snaps it (init/resize).
    const place = (i: number, animate: boolean) => {
      const tab = tabs[i];
      if (!indicator || !tab) return;
      if (!animate) indicator.style.transition = 'none';
      indicator.style.width = `${tab.offsetWidth}px`;
      indicator.style.height = `${tab.offsetHeight}px`;
      indicator.style.transform = `translate(${tab.offsetLeft}px, ${tab.offsetTop}px)`;
      if (!animate) { void indicator.offsetWidth; indicator.style.transition = ''; }
    };

    const select = (i: number) => {
      current = i;
      tabs.forEach((t, j) => {
        const on = j === i;
        t.setAttribute('aria-selected', String(on));
        t.setAttribute('tabindex', on ? '0' : '-1');
      });
      panels.forEach((p, j) => p.classList.toggle('is-active', j === i));
      place(i, true);
      // Only auto-scroll when the track actually overflows horizontally (desktop, many
      // tabs); on mobile the pills wrap, so nothing should scroll the page.
      const list = tabs[i].parentElement;
      if (list && list.scrollWidth > list.clientWidth + 1) {
        tabs[i].scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
      }
    };

    tabs.forEach((tab, i) => {
      tab.id = `${base}-tab-${i}`;
      panels[i].id = `${base}-panel-${i}`;
      tab.setAttribute('aria-controls', panels[i].id);
      panels[i].setAttribute('aria-labelledby', tab.id);
      tab.setAttribute('tabindex', i === 0 ? '0' : '-1');

      tab.addEventListener('click', () => { select(i); tab.focus(); });
      tab.addEventListener('keydown', (e) => {
        const keys = ['ArrowRight', 'ArrowLeft', 'Home', 'End'];
        if (!keys.includes(e.key)) return;
        e.preventDefault();
        let next = i;
        if (e.key === 'ArrowRight') next = (i + 1) % tabs.length;
        else if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else next = tabs.length - 1;
        select(next);
        tabs[next].focus();
      });
    });

    // Initial snap, then re-snap once fonts settle and on resize (widths change).
    place(0, false);
    if (document.fonts?.ready) document.fonts.ready.then(() => place(current, false));
    let rt: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(rt);
      rt = window.setTimeout(() => place(current, false), 120);
    });
    // Re-snap when the track gains a size — covers starting hidden (e.g. an inactive
    // styleguide variant), where offsetWidth was 0 on the initial place().
    if ('ResizeObserver' in window && indicator?.parentElement) {
      new ResizeObserver(() => place(current, false)).observe(indicator.parentElement);
    }
  });
</script>
