---
// Product-page "How it works" section. Wraps FeatureShowcase with the treatment
// locked on — full-width gutter matching the FAQ (`wide`) and the media column
// bleeding to the page edge (`mediaBleed`) — and composes a two-layer media slot:
// a full-bleed background photo with an optional light-mode UI card on top (the
// homepage team-showcase model). Documented in /styleguide/features.
import FeatureShowcase from './FeatureShowcase.astro';

interface Props {
  tagline?: string;
  heading: string;
  body?: string;
  items?: { heading: string; body: string; icon?: string }[];
  image?: string;
  imageAlt?: string;
  imageSide?: 'left' | 'right';
}
const { tagline, heading, body, items = [], image, imageAlt = '', imageSide = 'right' } = Astro.props;
const hasOverlay = Astro.slots.has('overlay');
---

<FeatureShowcase
  tagline={tagline}
  heading={heading}
  body={body}
  items={items}
  imageSide={imageSide}
  wide={true}
  mediaBleed={true}
>
  <div class="ps-media" slot="media">
    {image && <img src={image} alt={imageAlt} />}
    {hasOverlay && <div class="ps-scrim"></div>}
    {hasOverlay && <div class="ps-overlay"><slot name="overlay" /></div>}
  </div>
</FeatureShowcase>

<style>
  .ps-media { position: relative; width: 100%; height: 100%; }
  .ps-media > img { width: 100%; height: 100%; object-fit: cover; display: block; }
  /* Veil that makes the photo fade into the page background on the left: fully solid
     background at the left edge (so there's no visible image edge — it blends into the
     section), then ramps out to clear on the right where the photo's subject sits. */
  .ps-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      var(--background) 0%,
      var(--background) 7%,
      color-mix(in srgb, var(--background) 86%, transparent) 34%,
      color-mix(in srgb, var(--background) 42%, transparent) 62%,
      transparent 84%
    );
  }
  /* Light UI card layered on the photo, anchored to the left edge of the media.
     pointer-events stay on the card. */
  .ps-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-block: var(--space-32);
    padding-inline: var(--space-48);
    pointer-events: none;
  }
  .ps-overlay > :global(*) { width: 100%; max-width: 460px; pointer-events: auto; }

  /* On small mobile the overlay card otherwise fills the whole photo — shrink the
     real layout box with zoom (same approach as the homepage FeatureTabs/FeatureSplit
     overlays) so it sits comfortably within the image. */
  @media (max-width: 599px) {
    .ps-overlay { padding-inline: var(--space-24); }
    .ps-overlay > :global(*) { zoom: 0.72; }
  }
</style>
