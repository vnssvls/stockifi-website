---
// Customer story item header (Figma 100:2669): full-bleed background photo + dark
// scrim, centered logo + title, then avatar + featured quote + name + designation.
// Pulled up behind the floating nav so the photo runs full height to the very top.
interface Props {
  title: string;
  image?: string;
  /** CSS background-position for the header photo (default 'center'). */
  imagePosition?: string;
  logo?: string;
  avatar?: string;
  quote?: string;
  name: string;
  designation?: string;
}
const { title, image, imagePosition, logo, avatar, quote, name, designation } = Astro.props;
---

<header class="cs-header" style={image ? `--cs-bg: url('${image}'); --cs-pos: ${imagePosition ?? 'center'}` : undefined}>
  <div class="container cs-inner">
    <div class="cs-title">
      {logo && <img class="cs-logo" src={logo} alt="" width="56" height="56" loading="eager" />}
      <h1 class="cs-h1">{title}</h1>
    </div>
    <div class="cs-author">
      {avatar && <img class="cs-avatar" src={avatar} alt={name} width="56" height="56" loading="eager" />}
      {quote && <p class="cs-quote">{quote}</p>}
      <div class="cs-meta">
        {name && <p class="cs-name">{name}</p>}
        {designation && <p class="cs-sub">{designation}</p>}
      </div>
    </div>
  </div>
</header>

<style>
  /* Pulled up by the nav height so the photo backdrop reaches the very top (behind the
     transparent floating nav); the extra top padding keeps the content below the nav. */
  .cs-header {
    --cs-bg: none;
    margin-top: calc(-1 * var(--nav-h));
    /* nav-h clears the floating nav; the small extra is the only real top padding, so
       the header stays compact and the body peeks above the fold. */
    padding-top: calc(var(--nav-h) + var(--space-32));
    padding-bottom: var(--space-48);
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--background) 74%, transparent),
        color-mix(in srgb, var(--background) 88%, transparent)
      ),
      var(--cs-bg);
    background-size: cover;
    background-position: var(--cs-pos, center);
  }
  /* Wider column so the title fits ~2 lines on desktop. */
  .cs-inner { display: flex; flex-direction: column; align-items: center; gap: var(--space-32); max-width: 60rem; text-align: center; }

  .cs-title { display: flex; flex-direction: column; align-items: center; gap: var(--space-16); width: 100%; }
  .cs-logo { height: 56px; width: auto; object-fit: contain; }
  /* text-wrap:pretty overrides the base heading 'balance', which compressed the title
     into short, narrow lines instead of filling the width. */
  .cs-h1 { font-size: var(--text-h2); line-height: var(--lh-h2); text-wrap: pretty; }

  .cs-author { display: flex; flex-direction: column; align-items: center; gap: var(--space-16); }
  .cs-avatar { width: 56px; height: 56px; border-radius: var(--radius-full); object-fit: cover; }
  .cs-quote { max-width: 520px; font-size: var(--text-body); color: color-mix(in srgb, var(--foreground) 90%, transparent); }
  .cs-meta { display: flex; flex-direction: column; gap: var(--space-4); }
  .cs-name { font-weight: var(--fw-semibold); }
  .cs-sub { font-size: var(--text-body-sm); color: var(--muted-foreground); }
</style>
