---
// Hero (home) — split layout: copy + CTAs left, image slides right.
// Supports multiple images (auto-cycling crossfade) or a single image.
// On desktop, left edge of the image fades into the page background.
import Button from './Button.astro';

interface Props {
  tagline?: string;
  heading: string;
  subhead?: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
  image?: { src: string; alt: string };
  images?: { src: string; alt: string }[];
  wide?: boolean;
}
const { tagline, heading, subhead, primary, secondary, image, images: imagesProp, wide = false } = Astro.props;
const slides = imagesProp ?? (image ? [image] : []);
---

<section class="hero">
  <div class:list={[wide ? 'container-wide' : 'container', 'hero-grid']}>
    <div class="hero-copy">
      {tagline && <p class="tagline">{tagline}</p>}
      <h1 class="hero-title">{heading}</h1>
      {subhead && <p class="hero-subhead">{subhead}</p>}
      {(primary || secondary) && (
        <div class="hero-actions">
          {primary && <Button variant="primary" href={primary.href}>{primary.label}</Button>}
          {secondary && <Button variant="secondary" href={secondary.href}>{secondary.label}</Button>}
        </div>
      )}
    </div>

    <div class="hero-media">
      {slides.length > 0 ? (
        <div class="hero-slides" data-hero-slides>
          {slides.map((img, i) => (
            <img
              src={img.src}
              alt={img.alt}
              class:list={['hero-slide', { 'is-active': i === 0 }]}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
      ) : (
        <div class="hero-placeholder" role="img" aria-label="Hero visual placeholder">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" />
            <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" />
            <path d="m21 15-5-5L5 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      )}
      <slot name="overlays" />
      <!-- Extra dark layer for slides that need stronger contrast (e.g. light kitchen bg) -->
      <div class="hero-veil-extra" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-48);
    padding-bottom: var(--space-64);
    position: relative;
    background-image:
      radial-gradient(50% 65% at 88% 48%, rgba(158, 180, 250, 0.09), transparent 62%),
      radial-gradient(45% 55% at 96% 28%, rgba(186, 140, 238, 0.08), transparent 64%),
      radial-gradient(48% 52% at 84% 72%, rgba(248, 176, 214, 0.07), transparent 62%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-48);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: var(--text-display);
    line-height: var(--lh-display);
  }
  .tagline + .hero-title { margin-top: var(--space-16); }
  .hero-subhead {
    margin-top: var(--space-24);
    max-width: 48ch;
    font-size: var(--text-body-lg);
    color: var(--muted-foreground);
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-16); margin-top: var(--space-32); }

  /* Media wrapper — clips images, hosts the gradient overlay */
  .hero-media {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    /* Mobile: bleed to screen edge */
    margin-inline: calc(-1 * var(--gutter-wide));
  }

  /* Dark veil — all screen sizes. Boosts contrast for transparent overlay text.
     Uses color-mix with --background so the veil color tracks the active palette. */
  .hero-media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--background) 90%, transparent) 0%,
      color-mix(in srgb, var(--background) 72%, transparent) 28%,
      color-mix(in srgb, var(--background) 35%, transparent) 52%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Slides container: aspect-ratio drives the height, images stack absolutely inside */
  .hero-slides {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }
  .hero-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.6s ease;
  }
  .hero-slide.is-active { opacity: 1; }

  /* Per-slide extra veil — fades in only on slides with a lighter bg (data-slide="1" = chef) */
  .hero-veil-extra {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--background) 42%, transparent) 0%,
      color-mix(in srgb, var(--background) 28%, transparent) 35%,
      color-mix(in srgb, var(--background) 8%, transparent) 58%,
      transparent 72%
    );
    opacity: 0;
    pointer-events: none;
    z-index: 2;
    transition: opacity 1.4s ease;
  }
  .hero-media[data-slide="1"] .hero-veil-extra { opacity: 1; }

  .hero-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--muted);
    color: var(--muted-foreground);
  }

  /* Overlay: transparent element sitting in the faded-left zone of the image.
     :global() needed because overlays are slotted in from index.astro. */
  :global(.hero-overlay) {
    position: absolute;
    left: 5%;
    top: 50%;
    transform: translateY(-50%);
    width: 46%;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  :global(.hero-overlay.is-active) { opacity: 1; }

  /* Desktop: 2-column split + left-edge image fade via mask */
  @media (min-width: 1024px) {
    .hero-media {
      border-radius: var(--radius-xl);
      margin-inline: 0;
    }
    .hero-grid {
      grid-template-columns: 1fr 1.3fr;
      gap: var(--space-24);
    }
    .container-wide.hero-grid {
      padding-inline: 100px;
    }
    /* Mask fades the actual image pixels — left 30% goes transparent to fully opaque */
    .hero-slides {
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 30%);
      mask-image: linear-gradient(to right, transparent 0%, black 30%);
    }
    :global(.hero-overlay) {
      width: 32%;
    }
  }
</style>

<script>
  const containers = document.querySelectorAll<HTMLElement>('[data-hero-slides]');
  containers.forEach(container => {
    const slides   = container.querySelectorAll<HTMLElement>('.hero-slide');
    const media    = container.closest<HTMLElement>('.hero-media');
    const overlays = media?.querySelectorAll<HTMLElement>('.hero-overlay');
    if (slides.length < 2) return;
    let current = 0;

    // Show first overlay immediately
    overlays?.[0]?.classList.add('is-active');
    media?.setAttribute('data-slide', '0');

    setInterval(() => {
      slides[current].classList.remove('is-active');
      overlays?.[current]?.classList.remove('is-active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('is-active');
      overlays?.[current]?.classList.add('is-active');
      media?.setAttribute('data-slide', String(current));
    }, 5000);
  });
</script>
