---
// Hero (home) — split layout from wireframe node 45:3649: copy + CTAs left, visual
// right; stacks on mobile. Variant-driven via props so copy/visual are swappable.
// Real hero visual (product/dashboard or moody photo) is pending — placeholder for now.
import Button from './Button.astro';

interface Props {
  tagline?: string;
  heading: string;
  subhead?: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
  image?: { src: string; alt: string };
  /** Use the near-full-width container (reduced 20px gutter) instead of the capped one. */
  wide?: boolean;
}
const { tagline, heading, subhead, primary, secondary, image, wide = false } = Astro.props;
---

<section class="hero">
  <div class:list={[wide ? 'container-wide' : 'container', 'hero-grid']}>
    <div class="hero-copy">
      {tagline && <p class="tagline">{tagline}</p>}
      <h1 class="hero-title">{heading}</h1>
      {subhead && <p class="hero-subhead">{subhead}</p>}
      {(primary || secondary) && (
        <div class="hero-actions">
          {primary && <Button variant="primary" href={primary.href}>{primary.label}</Button>}
          {secondary && <Button variant="secondary" href={secondary.href}>{secondary.label}</Button>}
        </div>
      )}
    </div>

    <div class="hero-media">
      {image ? (
        <img src={image.src} alt={image.alt} />
      ) : (
        <div class="hero-placeholder" role="img" aria-label="Hero visual placeholder">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" />
            <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" />
            <path d="m21 15-5-5L5 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Tight top so the hero sits just under the nav (beehiv-style); modest bottom so the
     logo banner clears the fold. Soft aurora wash applied to the full-bleed SECTION (not
     the capped inner container) so it spans the viewport width and fades out at the edges
     — background-image isn't lint-guarded, so the rgba stops are fine here. */
  .hero {
    padding-top: var(--space-48);
    padding-bottom: var(--space-64);
    background-image:
      radial-gradient(58% 66% at 62% 50%, rgba(158, 180, 250, 0.08), transparent 62%),
      radial-gradient(54% 62% at 40% 50%, rgba(186, 140, 238, 0.08), transparent 64%),
      radial-gradient(58% 56% at 30% 62%, rgba(248, 176, 214, 0.07), transparent 62%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-48);
    align-items: start;
  }

  .hero-title {
    font-size: var(--text-display);
    line-height: var(--lh-display);
  }
  .tagline + .hero-title { margin-top: var(--space-16); }
  .hero-subhead {
    margin-top: var(--space-24);
    max-width: 48ch;
    font-size: var(--text-body-lg);
    color: var(--muted-foreground);
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-16); margin-top: var(--space-32); }

  .hero-media img,
  .hero-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-xl);
    object-fit: cover;
  }
  .hero-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--muted);
    color: var(--muted-foreground);
  }

  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr 1fr; gap: var(--space-64); }
    /* Wide hero: the 20px wide-gutter is too wide here — add 60px of breathing room
       (keeps the .container-wide token intact for other uses). */
    .container-wide.hero-grid { padding-inline: calc(var(--gutter-wide) + 60px); }
    .hero-media img,
    .hero-placeholder { aspect-ratio: 16 / 10; }
  }
</style>
