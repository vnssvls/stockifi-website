---
// Savings calculator (pricing section 2b). Live, ungated estimate, Fin-style:
// inputs in a narrower left panel, a year-by-year savings breakdown table on the
// wider right (Before / Year 1-3 / Total). Logic mirrors the old Webflow build:
// annual savings = revenue/location × locations × (current% − target%).
// No price/ROI row (Stockifi pricing isn't published). The CTA carries the inputs
// onward (HubSpot wiring provisional). Localized across all 6 locales.

const locale = Astro.currentLocale ?? 'en';
const lp = (p: string) => (locale === 'en' ? p : `/${locale}${p}`);

const STRINGS = {
  en: { eyebrow: 'Savings calculator', heading: 'See the impact Stockifi could have on your profit', subhead: 'Share your numbers below to calculate your potential savings.', revenue: 'Annual revenue per location', locations: 'Number of locations', current: 'Current food & drink cost %', target: 'Target food & drink cost %', saveHeadline: 'Stockifi could save you', inYear: 'in a year', withWord: 'with', unitLoc: 'location', unitLocs: 'locations', perYear: 'per year', perLoc: 'Savings per location', colBefore: 'Before Stockifi', colY1: 'Year 1', colY2: 'Year 2', colY3: 'Year 3', colTotal: 'Total', rowCost: 'Food & drink cost', rowSavings: 'Your savings', cta: 'Get my savings plan', emailPrompt: 'Where should we send your savings plan?', emailPh: 'you@restaurant.com', send: 'Send', sending: 'Sending…', errEmail: 'Please enter a valid email.', errSend: 'Something went wrong. Please try again.' },
  no: { eyebrow: 'Besparingskalkulator', heading: 'Se hvilken effekt Stockifi kan ha på fortjenesten din', subhead: 'Del tallene dine nedenfor for å beregne din potensielle besparelse.', revenue: 'Årlig omsetning per lokasjon', locations: 'Antall lokasjoner', current: 'Nåværende varekost %', target: 'Mål for varekost %', saveHeadline: 'Stockifi kan spare deg', inYear: 'i året', withWord: 'med', unitLoc: 'lokasjon', unitLocs: 'lokasjoner', perYear: 'per år', perLoc: 'Besparelse per lokasjon', colBefore: 'Før Stockifi', colY1: 'År 1', colY2: 'År 2', colY3: 'År 3', colTotal: 'Totalt', rowCost: 'Varekost', rowSavings: 'Din besparelse', cta: 'Få spareplanen min', emailPrompt: 'Hvor skal vi sende spareplanen din?', emailPh: 'deg@restaurant.no', send: 'Send', sending: 'Sender…', errEmail: 'Skriv inn en gyldig e-postadresse.', errSend: 'Noe gikk galt. Prøv igjen.' },
  da: { eyebrow: 'Besparelsesberegner', heading: 'Se, hvilken effekt Stockifi kan have på din fortjeneste', subhead: 'Del dine tal nedenfor for at beregne din potentielle besparelse.', revenue: 'Årlig omsætning per lokation', locations: 'Antal lokationer', current: 'Nuværende vareforbrug %', target: 'Mål for vareforbrug %', saveHeadline: 'Stockifi kan spare dig', inYear: 'om året', withWord: 'med', unitLoc: 'lokation', unitLocs: 'lokationer', perYear: 'om året', perLoc: 'Besparelse per lokation', colBefore: 'Før Stockifi', colY1: 'År 1', colY2: 'År 2', colY3: 'År 3', colTotal: 'I alt', rowCost: 'Vareforbrug', rowSavings: 'Din besparelse', cta: 'Få min besparelsesplan', emailPrompt: 'Hvor skal vi sende din besparelsesplan?', emailPh: 'dig@restaurant.dk', send: 'Send', sending: 'Sender…', errEmail: 'Indtast en gyldig e-mailadresse.', errSend: 'Noget gik galt. Prøv igen.' },
  sv: { eyebrow: 'Besparingskalkylator', heading: 'Se vilken effekt Stockifi kan ha på din vinst', subhead: 'Dela dina siffror nedan för att beräkna din potentiella besparing.', revenue: 'Årlig omsättning per restaurang', locations: 'Antal restauranger', current: 'Nuvarande råvarukostnad %', target: 'Mål för råvarukostnad %', saveHeadline: 'Stockifi kan spara dig', inYear: 'per år', withWord: 'med', unitLoc: 'restaurang', unitLocs: 'restauranger', perYear: 'per år', perLoc: 'Besparing per restaurang', colBefore: 'Före Stockifi', colY1: 'År 1', colY2: 'År 2', colY3: 'År 3', colTotal: 'Totalt', rowCost: 'Råvarukostnad', rowSavings: 'Din besparing', cta: 'Få min besparingsplan', emailPrompt: 'Vart ska vi skicka din besparingsplan?', emailPh: 'du@restaurang.se', send: 'Skicka', sending: 'Skickar…', errEmail: 'Ange en giltig e-postadress.', errSend: 'Något gick fel. Försök igen.' },
  nl: { eyebrow: 'Besparingscalculator', heading: 'Zie welke impact Stockifi op je winst kan hebben', subhead: 'Deel hieronder je cijfers om je mogelijke besparing te berekenen.', revenue: 'Jaaromzet per locatie', locations: 'Aantal locaties', current: 'Huidige foodcost %', target: 'Doel-foodcost %', saveHeadline: 'Stockifi kan je besparen', inYear: 'per jaar', withWord: 'met', unitLoc: 'locatie', unitLocs: 'locaties', perYear: 'per jaar', perLoc: 'Besparing per locatie', colBefore: 'Vóór Stockifi', colY1: 'Jaar 1', colY2: 'Jaar 2', colY3: 'Jaar 3', colTotal: 'Totaal', rowCost: 'Foodcost', rowSavings: 'Jouw besparing', cta: 'Ontvang mijn besparingsplan', emailPrompt: 'Waar mogen we je besparingsplan naartoe sturen?', emailPh: 'jij@restaurant.nl', send: 'Versturen', sending: 'Versturen…', errEmail: 'Voer een geldig e-mailadres in.', errSend: 'Er ging iets mis. Probeer het opnieuw.' },
  de: { eyebrow: 'Einsparungsrechner', heading: 'Sehen Sie, welchen Einfluss Stockifi auf Ihren Gewinn haben kann', subhead: 'Geben Sie unten Ihre Zahlen ein, um Ihre möglichen Einsparungen zu berechnen.', revenue: 'Jahresumsatz pro Standort', locations: 'Anzahl der Standorte', current: 'Aktueller Wareneinsatz %', target: 'Ziel-Wareneinsatz %', saveHeadline: 'Stockifi kann Ihnen sparen', inYear: 'pro Jahr', withWord: 'mit', unitLoc: 'Standort', unitLocs: 'Standorte', perYear: 'pro Jahr', perLoc: 'Einsparungen pro Standort', colBefore: 'Vor Stockifi', colY1: 'Jahr 1', colY2: 'Jahr 2', colY3: 'Jahr 3', colTotal: 'Gesamt', rowCost: 'Wareneinsatz', rowSavings: 'Ihre Einsparung', cta: 'Meinen Einsparungsplan erhalten', emailPrompt: 'Wohin sollen wir Ihren Einsparungsplan senden?', emailPh: 'sie@restaurant.de', send: 'Senden', sending: 'Senden…', errEmail: 'Bitte geben Sie eine gültige E-Mail-Adresse ein.', errSend: 'Etwas ist schiefgelaufen. Bitte versuchen Sie es erneut.' },
};
const s = STRINGS[locale as keyof typeof STRINGS] ?? STRINGS.en;

const CUR: Record<string, { tag: string; cur: string; sym: string }> = {
  en: { tag: 'en-IE', cur: 'EUR', sym: '€' },
  de: { tag: 'de-DE', cur: 'EUR', sym: '€' },
  nl: { tag: 'nl-NL', cur: 'EUR', sym: '€' },
  no: { tag: 'nb-NO', cur: 'NOK', sym: 'kr' },
  sv: { tag: 'sv-SE', cur: 'SEK', sym: 'kr' },
  da: { tag: 'da-DK', cur: 'DKK', sym: 'kr' },
};
const c = CUR[locale] ?? CUR.en;

const LOC_OPTS = Array.from({ length: 30 }, (_, i) => String(i + 1)).concat('30+');
const D = { revenue: 1300000, locDefault: '5', current: 30, target: 27, min: 5, max: 60 };
// Region-typical default annual revenue per location, in the local currency (a round
// market figure, not a literal conversion of the EUR default).
const REV_DEFAULTS: Record<string, number> = { en: 1300000, de: 1300000, nl: 1300000, no: 12000000, sv: 12000000, da: 8000000 };
const defRev = REV_DEFAULTS[locale] ?? D.revenue;
const bookHref = lp('/book-a-demo');
---

<section class="sc section" data-sc data-tag={c.tag} data-cur={c.cur} data-book={bookHref}
  data-inyear={s.inYear} data-with={s.withWord} data-uloc={s.unitLoc} data-ulocs={s.unitLocs}>
  <div class="container sc-inner">
    <header class="sc-head">
      <p class="sc-eyebrow">{s.eyebrow}</p>
      <h2 class="sc-heading">{s.heading}</h2>
      <p class="sc-sub text-muted">{s.subhead}</p>
    </header>

    <div class="sc-grid">
      <!-- Inputs panel (left, narrower) -->
      <div class="sc-inputs">
        <div class="sc-field">
          <label class="sc-label" for="sc-rev">{s.revenue}</label>
          <div class="sc-money">
            <span class="sc-sym" aria-hidden="true">{c.sym}</span>
            <input class="sc-input sc-input--money" id="sc-rev" type="text" inputmode="numeric"
              autocomplete="off" data-def-rev={defRev} placeholder={defRev.toLocaleString(c.tag)} value={defRev.toLocaleString(c.tag)} />
          </div>
        </div>
        <div class="sc-field">
          <label class="sc-label" for="sc-loc">{s.locations}</label>
          <div class="sc-sel-wrap">
            <select class="sc-input sc-select" id="sc-loc">
              {LOC_OPTS.map((v) => (<option value={v} selected={v === D.locDefault}>{v}</option>))}
            </select>
            <svg class="sc-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
        <div class="sc-field">
          <div class="sc-slabel"><span class="sc-label">{s.current}</span><span class="sc-pct" id="sc-cur-val">{D.current}%</span></div>
          <input class="sc-range" id="sc-cur" type="range" min={D.min} max={D.max} step="1" value={D.current} />
        </div>
        <div class="sc-field">
          <div class="sc-slabel"><span class="sc-label">{s.target}</span><span class="sc-pct" id="sc-tgt-val">{D.target}%</span></div>
          <input class="sc-range" id="sc-tgt" type="range" min={D.min} max={D.max} step="1" value={D.target} />
        </div>
      </div>

      <!-- Results panel (right, wider) — headline + year-by-year breakdown -->
      <div class="sc-card">
        <div class="sc-rtop">
          <div class="sc-stat sc-stat--primary">
            <p class="sc-stat-l text-muted">{s.saveHeadline}</p>
            <strong class="sc-result-n" id="sc-total">—</strong>
            <p class="sc-result-sub text-muted" id="sc-ctx">{s.inYear}</p>
          </div>
          <div class="sc-stat">
            <p class="sc-stat-l text-muted">{s.perLoc}</p>
            <strong class="sc-stat-n" id="sc-perloc">—</strong>
            <p class="sc-result-sub text-muted">{s.perYear}</p>
          </div>
        </div>

        <div class="sc-table-wrap">
          <table class="sc-table">
            <thead>
              <tr>
                <th scope="col"></th>
                <th scope="col">{s.colBefore}</th>
                <th scope="col">{s.colY1}</th>
                <th scope="col">{s.colY2}</th>
                <th scope="col">{s.colY3}</th>
                <th scope="col">{s.colTotal}</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">{s.rowCost}</th>
                <td id="sc-cost-b">—</td>
                <td id="sc-cost-1">—</td>
                <td id="sc-cost-2">—</td>
                <td id="sc-cost-3">—</td>
                <td id="sc-cost-t">—</td>
              </tr>
              <tr class="sc-tr-save">
                <th scope="row">{s.rowSavings}</th>
                <td>–</td>
                <td id="sc-sav-1">—</td>
                <td id="sc-sav-2">—</td>
                <td id="sc-sav-3">—</td>
                <td id="sc-sav-t">—</td>
              </tr>
            </tbody>
          </table>
        </div>

        <button class="sc-cta" id="sc-cta" type="button">
          <span>{s.cta}</span>
          <svg class="sc-cta-arrow" width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <!-- Email capture: revealed on CTA click. Results above stay visible (ungated).
             Submits to the HubSpot Savings Calculator form, then continues to book-a-demo. -->
        <form class="sc-capture sc-hidden" id="sc-capture" novalidate
          data-erremail={s.errEmail} data-errsend={s.errSend} data-sending={s.sending}>
          <label class="sc-cap-label" for="sc-email">{s.emailPrompt}</label>
          <div class="sc-cap-row">
            <input class="sc-input sc-cap-input" id="sc-email" type="email" inputmode="email"
              autocomplete="email" placeholder={s.emailPh} required />
            <button class="sc-cta sc-cap-btn" id="sc-send" type="submit">
              <span>{s.send}</span>
              <svg class="sc-cta-arrow" width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          <p class="sc-cap-err" id="sc-cap-err" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  /* Full LIGHT section on the dark page — reads as a built-in band, not an embed. */
  .sc {
    position: relative; isolation: isolate; overflow: clip;
    background: radial-gradient(100% 85% at 50% -8%, color-mix(in srgb, var(--primary) 22%, #f4f4f5), #f4f4f5 62%);
    color: #1a1620;
  }

  /* Wider than the page's 1280 container so the results + breakdown table get
     Fin-like room (this is a featured light band, intentionally wider). */
  .sc-inner { max-width: 1600px; display: flex; flex-direction: column; gap: var(--space-48); }
  .sc-head { max-width: 50rem; margin-inline: auto; text-align: center; }
  .sc-eyebrow {
    font-size: var(--text-body-sm); font-weight: var(--fw-semibold);
    letter-spacing: 0.08em; text-transform: uppercase; color: #6d46aa;
    margin-bottom: var(--space-12);
  }
  .sc-heading { font-size: var(--text-h2); line-height: var(--lh-h2); margin-bottom: var(--space-16); color: #1a1620; }
  .sc-sub { font-size: var(--text-body-lg); line-height: var(--lh-body); }

  .sc-grid {
    display: grid; grid-template-columns: minmax(0, 1fr); align-items: stretch;
    border: 1px solid #ececec; border-radius: var(--radius-xl);
    background: #fff; color: #1a1620;
    box-shadow: 0 10px 40px -12px rgba(60, 40, 100, 0.18);
    overflow: hidden;
  }
  .sc-inputs { display: flex; flex-direction: column; gap: var(--space-32); padding: var(--space-32); }
  .sc .sc-label { color: #1a1620; }
  .sc .sc-pct { color: #6d46aa; }
  .sc .text-muted { color: #6b6675; }
  .sc-field { display: flex; flex-direction: column; gap: var(--space-16); }

  .sc-label { font-size: var(--text-body-sm); font-weight: var(--fw-medium); }
  .sc-slabel { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-12); }
  .sc-pct { font-size: var(--text-body); font-weight: var(--fw-semibold); font-variant-numeric: tabular-nums; }

  .sc-input {
    width: 100%; height: 56px; padding: 0 var(--space-16);
    background: #fff; border: 1.5px solid #e2e2e2;
    border-radius: var(--radius-md); color: #1a1620;
    font-size: var(--text-body); font-family: var(--font-body); font-weight: var(--fw-medium);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    -webkit-appearance: none; appearance: none;
  }
  .sc-input::placeholder { color: #8a8594; font-weight: 400; }
  .sc-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(149, 101, 219, 0.28); }

  .sc-money { position: relative; }
  .sc-money .sc-sym { position: absolute; left: var(--space-16); top: 50%; transform: translateY(-50%); color: #6b6675; font-size: var(--text-body); pointer-events: none; }
  .sc-input--money { padding-left: 2.25rem; }

  .sc-sel-wrap { position: relative; }
  .sc-select { padding-right: 42px; cursor: pointer; }
  .sc-select option { background: #fff; color: #1a1620; }
  .sc-chev { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: #6b6675; pointer-events: none; }

  .sc-range {
    -webkit-appearance: none; appearance: none; width: 100%; height: 6px;
    border-radius: 999px; cursor: pointer; margin: 10px 0;
    background: linear-gradient(to right, var(--primary) var(--fill, 50%), #dcdcdc var(--fill, 50%));
  }
  .sc-range::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 22px; height: 22px; border-radius: 50%; background: #fff; border: 1px solid rgba(0, 0, 0, 0.12); box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4); cursor: pointer; }
  .sc-range::-moz-range-thumb { width: 22px; height: 22px; border-radius: 50%; background: #fff; border: 1px solid rgba(0, 0, 0, 0.12); box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4); cursor: pointer; }
  .sc-range:focus-visible { outline: 2px solid var(--primary); outline-offset: 4px; }

  /* Results panel */
  .sc-card { display: flex; flex-direction: column; gap: var(--space-32); padding: var(--space-32); }

  /* Two stats aligned at the top (primary + per-location) read as a clear pair.
     column-gap spaces them side-by-side on desktop; row-gap keeps them tight when
     they wrap to a stack on mobile (was a single 100px gap → huge vertical hole). */
  .sc-rtop { display: flex; align-items: flex-start; justify-content: flex-start; column-gap: 100px; row-gap: var(--space-24); flex-wrap: wrap; }
  .sc-stat { text-align: left; }
  .sc-stat-l { font-size: var(--text-body-sm); }
  .sc-result-n { display: block; font-family: var(--font-body); font-size: var(--text-h3); line-height: 1.05; font-weight: var(--fw-medium); color: #1a1620; font-variant-numeric: tabular-nums; margin-top: var(--space-4); }
  .sc-stat-n { display: block; font-family: var(--font-body); font-size: var(--text-h3); line-height: 1.05; font-weight: var(--fw-medium); color: #1a1620; font-variant-numeric: tabular-nums; margin-top: var(--space-4); }
  .sc-result-sub { font-size: var(--text-body-sm); margin-top: var(--space-8); }

  /* Breakdown table */
  .sc-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .sc-table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  .sc-table th, .sc-table td { padding: var(--space-12) var(--space-12); text-align: right; font-size: var(--text-body-sm); white-space: nowrap; }
  .sc-table thead th { color: #6b6675; font-weight: var(--fw-medium); border-bottom: 1px solid #e5e5e5; }
  .sc-table tbody th { text-align: left; font-weight: var(--fw-medium); color: #1a1620; }
  .sc-table tbody td { color: #4a4655; }
  .sc-table th:first-child, .sc-table td:first-child { padding-left: 0; }
  .sc-table th:last-child, .sc-table td:last-child { padding-right: 0; }
  .sc-tr-save th, .sc-tr-save td { color: #1a1620; font-weight: var(--fw-semibold); border-top: 1px solid #e5e5e5; }
  .sc-tr-save td:last-child { color: var(--primary-dark); }

  .sc-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-8);
    align-self: flex-end; width: auto; height: 54px; padding: 0 var(--space-48); margin-top: auto;
    background: var(--primary); color: #fff; border: none;
    border-radius: var(--radius-full); font-size: var(--text-body);
    font-weight: var(--fw-semibold); font-family: var(--font-body); cursor: pointer;
    transition: background 0.18s ease;
  }
  .sc-cta:hover { background: var(--primary-dark); }
  .sc-cta-arrow { transition: transform 0.18s ease; }
  .sc-cta:hover .sc-cta-arrow { transform: translateX(3px); }
  .sc-cta:disabled { opacity: 0.65; cursor: default; }

  /* Email capture (revealed on CTA click) */
  .sc-hidden { display: none !important; }
  .sc-capture { margin-top: auto; display: flex; flex-direction: column; gap: var(--space-12); }
  .sc-cap-label { font-size: var(--text-body-sm); font-weight: var(--fw-medium); color: #1a1620; }
  .sc-cap-row { display: flex; gap: var(--space-12); flex-wrap: wrap; }
  .sc-cap-input { flex: 1 1 240px; }
  .sc-cap-btn { align-self: auto; margin-top: 0; height: 56px; flex: 0 0 auto; white-space: nowrap; }
  .sc-cap-err { font-size: var(--text-body-sm); color: #c0392b; min-height: 1.1em; }

  @media (min-width: 1024px) {
    /* Inputs narrower, results + table wider (Fin layout). */
    .sc-grid { grid-template-columns: 400px minmax(0, 1fr); }
    .sc-inputs { padding: var(--space-64); gap: var(--space-48); }
    .sc-card { padding: var(--space-64); border-left: 1px solid #e5e5e5; }
  }

  @media (max-width: 1023px) {
    .sc-inner { gap: var(--space-32); }
    /* Freeze the label column; the year columns scroll horizontally under it. */
    .sc-table th:first-child, .sc-table td:first-child {
      position: sticky; left: 0; z-index: 2; background: #fff;
      box-shadow: 8px 0 10px -8px rgba(0, 0, 0, 0.14);
    }
  }

  /* Phones: tighten the stacked layout so the inputs and both result values sit
     close enough to read together while the user drags the sliders. */
  @media (max-width: 640px) {
    .sc-inner { gap: var(--space-24); }
    .sc-inputs { padding: var(--space-24); gap: var(--space-24); }
    .sc-card { padding: var(--space-24); gap: var(--space-24); }
    .sc-rtop { row-gap: var(--space-16); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-sc]').forEach((root) => {
    const tag = root.dataset.tag || 'en-IE';
    const cur = root.dataset.cur || 'EUR';
    const bookHref = root.dataset.book || '/book-a-demo';
    const inYear = root.dataset.inyear || '';
    const withW = root.dataset.with || '';
    const uloc = root.dataset.uloc || '';
    const ulocs = root.dataset.ulocs || '';

    const $ = (id: string) => root.querySelector<HTMLElement>('#' + id)!;
    const rev = $('sc-rev') as HTMLInputElement;
    const loc = $('sc-loc') as HTMLSelectElement;
    const curS = $('sc-cur') as HTMLInputElement;
    const tgtS = $('sc-tgt') as HTMLInputElement;
    const cta = $('sc-cta') as HTMLButtonElement;

    const money = new Intl.NumberFormat(tag, { style: 'currency', currency: cur, maximumFractionDigits: 0 });
    const groups = new Intl.NumberFormat(tag);
    const digits = (v: string) => parseInt(v.replace(/\D/g, ''), 10) || 0;
    const DEF_REV = Number(rev.dataset.defRev) || 1300000;
    const venueBucket = (n: number) => n <= 1 ? '1' : n <= 4 ? '2 - 4' : n <= 10 ? '5 - 10' : n <= 20 ? '11 - 20' : '20+';

    function fillTrack(el: HTMLInputElement) {
      const min = Number(el.min), max = Number(el.max);
      el.style.setProperty('--fill', ((Number(el.value) - min) / (max - min)) * 100 + '%');
    }

    function calc() {
      const revenue = digits(rev.value) || DEF_REV;
      const locations = loc.value === '30+' ? 30 : (parseInt(loc.value, 10) || 5);
      const current = Number(curS.value);
      const target = Number(tgtS.value);
      const costDiff = Math.max(0, (current - target) / 100);

      const baseline = revenue * locations * (current / 100);
      const annual = revenue * locations * costDiff;
      const reduced = baseline - annual;
      const total3 = annual * 3;
      const perLoc = annual / locations;

      $('sc-total').textContent = money.format(annual);
      $('sc-ctx').textContent = inYear + ' ' + withW + ' ' + locations + ' ' + (locations === 1 ? uloc : ulocs);
      $('sc-perloc').textContent = money.format(perLoc);
      $('sc-cost-b').textContent = money.format(baseline);
      $('sc-cost-1').textContent = $('sc-cost-2').textContent = $('sc-cost-3').textContent = money.format(reduced);
      $('sc-cost-t').textContent = money.format(reduced * 3);
      $('sc-sav-1').textContent = $('sc-sav-2').textContent = $('sc-sav-3').textContent = money.format(annual);
      $('sc-sav-t').textContent = money.format(total3);
      $('sc-cur-val').textContent = current + '%';
      $('sc-tgt-val').textContent = target + '%';
      fillTrack(curS); fillTrack(tgtS);

      return { revenue, locations, number_of_venues: venueBucket(locations), current, target, annualSavings: annual, threeYearSavings: total3 };
    }

    rev.addEventListener('input', () => {
      const n = digits(rev.value);
      rev.value = n ? groups.format(n) : '';
      rev.setSelectionRange(rev.value.length, rev.value.length);
      calc();
    });
    loc.addEventListener('change', calc);
    [curS, tgtS].forEach((el) => el.addEventListener('input', calc));

    // HubSpot "Savings Calculator" form (portal 48915892). annualrevenue +
    // number_of_venues map to the Company object (0-2), email + message to Contact (0-1),
    // mirroring the book-a-demo form's object mapping.
    const PORTAL_ID = '48915892';
    const FORM_GUID = '815a7d5c-eb14-4078-a5a7-f16cdeb4b36a';
    const capture = $('sc-capture') as HTMLFormElement;
    const emailEl = $('sc-email') as HTMLInputElement;
    const sendBtn = $('sc-send') as HTMLButtonElement;
    const sendLabel = sendBtn.querySelector('span')!;
    const capErr = $('sc-cap-err');
    const sendDefault = sendLabel.textContent || '';
    const T = {
      email: capture.dataset.erremail || 'Please enter a valid email.',
      send: capture.dataset.errsend || 'Something went wrong. Please try again.',
      sending: capture.dataset.sending || 'Sending…',
    };

    // Team-facing notification line, packed into the HubSpot Message field. English on
    // purpose (internal alert), but currency follows what the visitor saw on screen.
    function buildMessage(d: ReturnType<typeof calc>) {
      const venues = d.locations === 1 ? 'venue' : 'venues';
      return `They're at ${d.current}% food cost and want to bring it down to ${d.target}%, `
        + `across ${d.locations} ${venues} at around ${money.format(d.revenue)} revenue each. `
        + `That's about ${money.format(d.annualSavings)} in savings a year, or `
        + `${money.format(d.threeYearSavings)} over three years. `
        + `Sent from the savings calculator on the pricing page.`;
    }

    const validEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    cta.addEventListener('click', () => {
      const d = calc();
      // Anonymous usage signal — every click, no email needed. Picked up by whichever
      // analytics tool ends up installed (dataLayer push + a generic CustomEvent).
      try {
        (window as any).dataLayer = (window as any).dataLayer || [];
        (window as any).dataLayer.push({
          event: 'savings_plan_clicked',
          annual_savings: d.annualSavings, three_year_savings: d.threeYearSavings,
          locations: d.locations, current_food_cost: d.current, target_food_cost: d.target,
          revenue: d.revenue, currency: cur,
        });
        document.dispatchEvent(new CustomEvent('savings_plan_clicked', { detail: d }));
      } catch (_) {}
      cta.classList.add('sc-hidden');
      capture.classList.remove('sc-hidden');
      emailEl.focus();
    });

    capture.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailEl.value.trim();
      if (!validEmail(email)) { capErr.textContent = T.email; emailEl.focus(); return; }
      capErr.textContent = '';

      const d = calc();
      sendBtn.disabled = true;
      sendLabel.textContent = T.sending;

      const fields = [
        { objectTypeId: '0-1', name: 'email', value: email },
        { objectTypeId: '0-2', name: 'annualrevenue', value: String(d.revenue) },
        { objectTypeId: '0-2', name: 'number_of_venues', value: d.number_of_venues },
        { objectTypeId: '0-1', name: 'message', value: buildMessage(d) },
      ];
      const hutk = document.cookie.split(';').map((x) => x.trim()).find((x) => x.startsWith('hubspotutk='))?.split('=')[1];

      try {
        const res = await fetch(
          `https://api.hsforms.com/submissions/v3/integration/submit/${PORTAL_ID}/${FORM_GUID}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              fields,
              context: { pageUri: window.location.href, pageName: document.title, ...(hutk && { hutk }) },
            }),
          }
        );
        if (!res.ok) throw new Error('hs');
        // Carry the inputs onward so the demo form can pre-fill from them later.
        try { sessionStorage.setItem('stockifi_savings', JSON.stringify(d)); } catch (_) {}
        window.location.href = bookHref;
      } catch (_) {
        sendBtn.disabled = false;
        sendLabel.textContent = sendDefault;
        capErr.textContent = T.send;
      }
    });

    calc();
  });
</script>
