---
// Savings calculator (pricing section 2b). Live, ungated estimate that mirrors the
// old Webflow logic: annualSavings = revenue/location × locations × (current% − target%).
// The inputs ARE the lead data; the "Unlock savings" CTA carries them onward.
// Locations is a dropdown using the SAME ranges as the book-a-demo `number_of_venues`
// field, so the carry-over maps 1:1. HubSpot wiring is provisional (see the script)
// until V picks the approach. Localized across all 6 locales.

const locale = Astro.currentLocale ?? 'en';
const lp = (p: string) => (locale === 'en' ? p : `/${locale}${p}`);

const STRINGS = {
  en: { eyebrow: 'Savings calculator', heading: 'See the impact Stockifi could have on your profit', subhead: 'Share your numbers below to calculate your potential savings.', revenue: 'Annual revenue per location', locations: 'Number of locations', current: 'Current food & drink cost %', target: 'Target food & drink cost %', resultH: 'Annual savings', resultSub: 'In year one with Stockifi', per1: 'Every 1% improvement', perLoc: 'Savings per location', cta: 'Unlock savings', locs: ['1 location', '2 - 4 locations', '5 - 10 locations', '11 - 20 locations', '20+ locations'] },
  no: { eyebrow: 'Besparingskalkulator', heading: 'Se hvilken effekt Stockifi kan ha på fortjenesten din', subhead: 'Del tallene dine nedenfor for å beregne din potensielle besparelse.', revenue: 'Årlig omsetning per lokasjon', locations: 'Antall lokasjoner', current: 'Nåværende varekost %', target: 'Mål for varekost %', resultH: 'Årlig besparelse', resultSub: 'Det første året med Stockifi', per1: 'Hver forbedring på 1 %', perLoc: 'Besparelse per lokasjon', cta: 'Lås opp besparelsen', locs: ['1 lokasjon', '2 - 4 lokasjoner', '5 - 10 lokasjoner', '11 - 20 lokasjoner', '20+ lokasjoner'] },
  da: { eyebrow: 'Besparelsesberegner', heading: 'Se, hvilken effekt Stockifi kan have på din fortjeneste', subhead: 'Del dine tal nedenfor for at beregne din potentielle besparelse.', revenue: 'Årlig omsætning per lokation', locations: 'Antal lokationer', current: 'Nuværende vareforbrug %', target: 'Mål for vareforbrug %', resultH: 'Årlig besparelse', resultSub: 'Det første år med Stockifi', per1: 'Hver forbedring på 1 %', perLoc: 'Besparelse per lokation', cta: 'Lås op for besparelsen', locs: ['1 lokation', '2 - 4 lokationer', '5 - 10 lokationer', '11 - 20 lokationer', '20+ lokationer'] },
  sv: { eyebrow: 'Besparingskalkylator', heading: 'Se vilken effekt Stockifi kan ha på din vinst', subhead: 'Dela dina siffror nedan för att beräkna din potentiella besparing.', revenue: 'Årlig omsättning per restaurang', locations: 'Antal restauranger', current: 'Nuvarande råvarukostnad %', target: 'Mål för råvarukostnad %', resultH: 'Årlig besparing', resultSub: 'Det första året med Stockifi', per1: 'Varje förbättring på 1 %', perLoc: 'Besparing per restaurang', cta: 'Lås upp besparingen', locs: ['1 restaurang', '2 - 4 restauranger', '5 - 10 restauranger', '11 - 20 restauranger', '20+ restauranger'] },
  nl: { eyebrow: 'Besparingscalculator', heading: 'Zie welke impact Stockifi op je winst kan hebben', subhead: 'Deel hieronder je cijfers om je mogelijke besparing te berekenen.', revenue: 'Jaaromzet per locatie', locations: 'Aantal locaties', current: 'Huidige foodcost %', target: 'Doel-foodcost %', resultH: 'Jaarlijkse besparing', resultSub: 'In het eerste jaar met Stockifi', per1: 'Elke verbetering van 1%', perLoc: 'Besparing per locatie', cta: 'Ontgrendel je besparing', locs: ['1 locatie', '2 - 4 locaties', '5 - 10 locaties', '11 - 20 locaties', '20+ locaties'] },
  de: { eyebrow: 'Einsparungsrechner', heading: 'Sehen Sie, welchen Einfluss Stockifi auf Ihren Gewinn haben kann', subhead: 'Geben Sie unten Ihre Zahlen ein, um Ihre möglichen Einsparungen zu berechnen.', revenue: 'Jahresumsatz pro Standort', locations: 'Anzahl der Standorte', current: 'Aktueller Wareneinsatz %', target: 'Ziel-Wareneinsatz %', resultH: 'Jährliche Einsparungen', resultSub: 'Im ersten Jahr mit Stockifi', per1: 'Jede Verbesserung um 1 %', perLoc: 'Einsparungen pro Standort', cta: 'Einsparungen freischalten', locs: ['1 Standort', '2 - 4 Standorte', '5 - 10 Standorte', '11 - 20 Standorte', '20+ Standorte'] },
};
const s = STRINGS[locale as keyof typeof STRINGS] ?? STRINGS.en;

const CUR: Record<string, { tag: string; cur: string; sym: string }> = {
  en: { tag: 'en-IE', cur: 'EUR', sym: '€' },
  de: { tag: 'de-DE', cur: 'EUR', sym: '€' },
  nl: { tag: 'nl-NL', cur: 'EUR', sym: '€' },
  no: { tag: 'nb-NO', cur: 'NOK', sym: 'kr' },
  sv: { tag: 'sv-SE', cur: 'SEK', sym: 'kr' },
  da: { tag: 'da-DK', cur: 'DKK', sym: 'kr' },
};
const c = CUR[locale] ?? CUR.en;

// Location ranges match book-a-demo's number_of_venues values 1:1 for clean carry-over.
const LOC_VALUES = ['1', '2 - 4', '5 - 10', '11 - 20', '20+'];
const D = { revenue: 1300000, locDefault: '5 - 10', current: 30, target: 27, min: 5, max: 60 };
const bookHref = lp('/book-a-demo');
---

<section class="sc section" data-sc data-tag={c.tag} data-cur={c.cur} data-book={bookHref}>
  <div class="container sc-inner">
    <header class="sc-head">
      <p class="sc-eyebrow">{s.eyebrow}</p>
      <h2 class="sc-heading">{s.heading}</h2>
      <p class="sc-sub text-muted">{s.subhead}</p>
    </header>

    <div class="sc-grid">
      <!-- Inputs -->
      <div class="sc-inputs">
        <div class="sc-row2">
          <div class="sc-field">
            <label class="sc-label" for="sc-rev">{s.revenue}</label>
            <div class="sc-money">
              <span class="sc-sym" aria-hidden="true">{c.sym}</span>
              <input class="sc-input sc-input--money" id="sc-rev" type="text" inputmode="numeric"
                autocomplete="off" placeholder={D.revenue.toLocaleString(c.tag)} value={D.revenue.toLocaleString(c.tag)} />
            </div>
          </div>
          <div class="sc-field">
            <label class="sc-label" for="sc-loc">{s.locations}</label>
            <div class="sc-sel-wrap">
              <select class="sc-input sc-select" id="sc-loc">
                {LOC_VALUES.map((v, i) => (
                  <option value={v} selected={v === D.locDefault}>{s.locs[i]}</option>
                ))}
              </select>
              <svg class="sc-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <div class="sc-row2">
          <div class="sc-field">
            <div class="sc-slabel"><span class="sc-label">{s.current}</span><span class="sc-pct" id="sc-cur-val">{D.current}%</span></div>
            <input class="sc-range" id="sc-cur" type="range" min={D.min} max={D.max} step="1" value={D.current} />
          </div>
          <div class="sc-field">
            <div class="sc-slabel"><span class="sc-label">{s.target}</span><span class="sc-pct" id="sc-tgt-val">{D.target}%</span></div>
            <input class="sc-range" id="sc-tgt" type="range" min={D.min} max={D.max} step="1" value={D.target} />
          </div>
        </div>
      </div>

      <!-- Result card -->
      <div class="sc-card">
        <div class="sc-result">
          <div class="sc-result-top">
            <div>
              <p class="sc-result-h">{s.resultH}</p>
              <p class="sc-result-sub text-muted">{s.resultSub}</p>
            </div>
            <strong class="sc-result-n" id="sc-annual">—</strong>
          </div>

          <div class="sc-rows">
            <div class="sc-srow"><span class="text-muted">{s.per1}</span><span id="sc-per1">—</span></div>
            <div class="sc-srow"><span class="text-muted">{s.perLoc}</span><span id="sc-perloc">—</span></div>
          </div>

          <button class="sc-cta" id="sc-cta" type="button">{s.cta}</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sc-inner { display: flex; flex-direction: column; gap: var(--space-48); }
  .sc-head { max-width: 40ch; }
  .sc-eyebrow {
    font-size: var(--text-body-sm); font-weight: var(--fw-semibold);
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--primary-light);
    margin-bottom: var(--space-12);
  }
  .sc-heading { font-size: var(--text-h2); line-height: var(--lh-h2); margin-bottom: var(--space-16); }
  .sc-sub { font-size: var(--text-body-lg); line-height: var(--lh-body); }

  .sc-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-48); align-items: start; }

  .sc-inputs { display: flex; flex-direction: column; gap: var(--space-32); }
  .sc-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-24); }
  .sc-field { display: flex; flex-direction: column; gap: var(--space-12); }

  .sc-label { font-size: var(--text-body-sm); font-weight: var(--fw-medium); color: var(--foreground); }
  .sc-slabel { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-12); }
  .sc-pct { font-size: var(--text-body); font-weight: var(--fw-semibold); color: var(--primary-light); font-variant-numeric: tabular-nums; }

  .sc-input {
    width: 100%; height: 50px; padding: 0 var(--space-16);
    background: var(--background); border: 1.5px solid var(--border);
    border-radius: var(--radius-md); color: var(--foreground);
    font-size: var(--text-body); font-family: var(--font-body);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    -webkit-appearance: none; appearance: none;
  }
  .sc-input::placeholder { color: var(--muted-foreground); }
  .sc-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(149, 101, 219, 0.18); }

  .sc-money { position: relative; }
  .sc-money .sc-sym {
    position: absolute; left: var(--space-16); top: 50%; transform: translateY(-50%);
    color: var(--muted-foreground); font-size: var(--text-body); pointer-events: none;
  }
  .sc-input--money { padding-left: 2.25rem; }

  .sc-sel-wrap { position: relative; }
  .sc-select { padding-right: 42px; cursor: pointer; }
  .sc-select option { background: var(--popover); color: var(--foreground); }
  .sc-chev { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: var(--muted-foreground); pointer-events: none; }

  /* Range slider — track filled to the thumb with the brand purple. */
  .sc-range {
    -webkit-appearance: none; appearance: none; width: 100%; height: 6px;
    border-radius: 999px; cursor: pointer; margin: 8px 0;
    background: linear-gradient(to right, var(--primary) var(--fill, 50%), color-mix(in srgb, var(--foreground) 12%, transparent) var(--fill, 50%));
  }
  .sc-range::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; width: 22px; height: 22px;
    border-radius: 50%; background: #fff; border: none;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4); cursor: pointer;
  }
  .sc-range::-moz-range-thumb {
    width: 22px; height: 22px; border-radius: 50%; background: #fff; border: none;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4); cursor: pointer;
  }
  .sc-range:focus-visible { outline: 2px solid var(--primary); outline-offset: 4px; }

  /* Result card */
  .sc-card {
    border: 1px solid #2e283e7d; border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--muted) 35%, transparent);
    box-shadow: 0 8px 32px -4px rgba(0, 0, 0, 0.25);
    padding: var(--space-32);
  }
  .sc-result { display: flex; flex-direction: column; gap: var(--space-24); }
  .sc-result-top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-16); }
  .sc-result-h { font-family: var(--font-heading); font-size: var(--text-h4); font-weight: var(--fw-bold); color: var(--foreground); }
  .sc-result-sub { font-size: var(--text-body-sm); margin-top: var(--space-4); }
  .sc-result-n {
    font-family: var(--font-heading); font-size: var(--text-h3); font-weight: var(--fw-bold);
    color: var(--foreground); text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap;
  }
  .sc-rows { display: flex; flex-direction: column; gap: var(--space-16); padding-top: var(--space-24); border-top: 1px solid var(--border); }
  .sc-srow { display: flex; align-items: center; justify-content: space-between; gap: var(--space-16); font-size: var(--text-body); }
  .sc-srow span:last-child { font-weight: var(--fw-semibold); color: var(--foreground); font-variant-numeric: tabular-nums; }

  .sc-cta {
    display: inline-flex; align-items: center; justify-content: center;
    width: 100%; height: 50px; padding: 0 var(--space-32); margin-top: var(--space-8);
    background: var(--primary); color: var(--primary-foreground); border: none;
    border-radius: var(--radius-full); font-size: var(--text-body);
    font-weight: var(--fw-semibold); font-family: var(--font-body); cursor: pointer;
    transition: background 0.18s ease;
  }
  .sc-cta:hover { background: var(--primary-dark); }

  @media (min-width: 1024px) {
    .sc-grid { grid-template-columns: 1.05fr 0.95fr; gap: var(--space-96); }
    .sc-head { max-width: none; }
  }

  /* Mobile: compact fields + pin the result to the bottom so it stays visible while
     the user edits the inputs above. Big number stacks under its label. */
  @media (max-width: 1023px) {
    .sc-inner { gap: var(--space-32); }
    .sc-grid { gap: var(--space-24); }
    .sc-inputs { gap: var(--space-24); }
    .sc-input { height: 46px; }

    .sc-card { padding: var(--space-24); }
    .sc-result { gap: var(--space-16); }
    .sc-result-top { flex-direction: column; gap: var(--space-4); }
    .sc-result-n { text-align: left; font-size: var(--text-h2); }
    .sc-rows { padding-top: var(--space-16); gap: var(--space-12); }
  }
  @media (max-width: 600px) {
    .sc-row2 { grid-template-columns: 1fr; }
  }
</style>

<script>
  const COUNT: Record<string, number> = { '1': 1, '2 - 4': 2, '5 - 10': 5, '11 - 20': 11, '20+': 20 };

  document.querySelectorAll<HTMLElement>('[data-sc]').forEach((root) => {
    const tag = root.dataset.tag || 'en-IE';
    const cur = root.dataset.cur || 'EUR';
    const bookHref = root.dataset.book || '/book-a-demo';

    const rev = root.querySelector<HTMLInputElement>('#sc-rev')!;
    const loc = root.querySelector<HTMLSelectElement>('#sc-loc')!;
    const curS = root.querySelector<HTMLInputElement>('#sc-cur')!;
    const tgtS = root.querySelector<HTMLInputElement>('#sc-tgt')!;
    const curV = root.querySelector<HTMLElement>('#sc-cur-val')!;
    const tgtV = root.querySelector<HTMLElement>('#sc-tgt-val')!;
    const outAnnual = root.querySelector<HTMLElement>('#sc-annual')!;
    const outPer1 = root.querySelector<HTMLElement>('#sc-per1')!;
    const outPerLoc = root.querySelector<HTMLElement>('#sc-perloc')!;
    const cta = root.querySelector<HTMLButtonElement>('#sc-cta')!;

    const money = new Intl.NumberFormat(tag, { style: 'currency', currency: cur, maximumFractionDigits: 0 });
    const groups = new Intl.NumberFormat(tag);
    const digits = (v: string) => parseInt(v.replace(/\D/g, ''), 10) || 0;
    const DEF_REV = 1300000;

    function fillTrack(el: HTMLInputElement) {
      const min = Number(el.min), max = Number(el.max);
      el.style.setProperty('--fill', ((Number(el.value) - min) / (max - min)) * 100 + '%');
    }

    function calc() {
      const revenue = digits(rev.value) || DEF_REV;
      const range = loc.value;
      const locations = COUNT[range] ?? 5;
      const current = Number(curS.value);
      const target = Number(tgtS.value);
      const costDiff = Math.max(0, (current - target) / 100);

      const annual = revenue * locations * costDiff;
      const per1 = revenue * 0.01 * locations;
      const perLoc = annual / locations;

      outAnnual.textContent = money.format(annual);
      outPer1.textContent = money.format(per1);
      outPerLoc.textContent = money.format(perLoc);
      curV.textContent = current + '%';
      tgtV.textContent = target + '%';
      fillTrack(curS); fillTrack(tgtS);

      return { revenue, locationsRange: range, locations, current, target, annual };
    }

    rev.addEventListener('input', () => {
      const n = digits(rev.value);
      rev.value = n ? groups.format(n) : '';
      rev.setSelectionRange(rev.value.length, rev.value.length);
      calc();
    });
    loc.addEventListener('change', calc);
    [curS, tgtS].forEach((el) => el.addEventListener('input', calc));

    cta.addEventListener('click', () => {
      const data = calc();
      // PROVISIONAL: stash inputs + result and route to book-a-demo. The HubSpot
      // carry-over is wired once V picks the approach. locationsRange already
      // matches the book-a-demo number_of_venues values 1:1.
      try { sessionStorage.setItem('stockifi_savings', JSON.stringify(data)); } catch (_) {}
      window.location.href = bookHref;
    });

    calc();
  });
</script>
