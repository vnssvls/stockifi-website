---
// Savings calculator (pricing section 2b). Live, ungated estimate that mirrors the
// old Webflow logic: annualSavings = revenue/location × locations × (current% − target%).
// Locations is an exact-increment dropdown (1–30, then 30+) because the count drives
// the calculation. The CTA carries the inputs onward; HubSpot wiring is provisional
// until V picks the approach (the stash already includes a number_of_venues bucket).
// Localized across all 6 locales.

const locale = Astro.currentLocale ?? 'en';
const lp = (p: string) => (locale === 'en' ? p : `/${locale}${p}`);

const STRINGS = {
  en: { eyebrow: 'Savings calculator', heading: 'See the impact Stockifi could have on your profit', subhead: 'Share your numbers below to calculate your potential savings.', revenue: 'Annual revenue per location', locations: 'Number of locations', current: 'Current food & drink cost %', target: 'Target food & drink cost %', resultH: 'Annual savings', resultSub: 'In year one with Stockifi', per1: 'Every 1% improvement', perLoc: 'Savings per location', cta: 'Get my savings plan' },
  no: { eyebrow: 'Besparingskalkulator', heading: 'Se hvilken effekt Stockifi kan ha på fortjenesten din', subhead: 'Del tallene dine nedenfor for å beregne din potensielle besparelse.', revenue: 'Årlig omsetning per lokasjon', locations: 'Antall lokasjoner', current: 'Nåværende varekost %', target: 'Mål for varekost %', resultH: 'Årlig besparelse', resultSub: 'Det første året med Stockifi', per1: 'Hver forbedring på 1 %', perLoc: 'Besparelse per lokasjon', cta: 'Få spareplanen min' },
  da: { eyebrow: 'Besparelsesberegner', heading: 'Se, hvilken effekt Stockifi kan have på din fortjeneste', subhead: 'Del dine tal nedenfor for at beregne din potentielle besparelse.', revenue: 'Årlig omsætning per lokation', locations: 'Antal lokationer', current: 'Nuværende vareforbrug %', target: 'Mål for vareforbrug %', resultH: 'Årlig besparelse', resultSub: 'Det første år med Stockifi', per1: 'Hver forbedring på 1 %', perLoc: 'Besparelse per lokation', cta: 'Få min besparelsesplan' },
  sv: { eyebrow: 'Besparingskalkylator', heading: 'Se vilken effekt Stockifi kan ha på din vinst', subhead: 'Dela dina siffror nedan för att beräkna din potentiella besparing.', revenue: 'Årlig omsättning per restaurang', locations: 'Antal restauranger', current: 'Nuvarande råvarukostnad %', target: 'Mål för råvarukostnad %', resultH: 'Årlig besparing', resultSub: 'Det första året med Stockifi', per1: 'Varje förbättring på 1 %', perLoc: 'Besparing per restaurang', cta: 'Få min besparingsplan' },
  nl: { eyebrow: 'Besparingscalculator', heading: 'Zie welke impact Stockifi op je winst kan hebben', subhead: 'Deel hieronder je cijfers om je mogelijke besparing te berekenen.', revenue: 'Jaaromzet per locatie', locations: 'Aantal locaties', current: 'Huidige foodcost %', target: 'Doel-foodcost %', resultH: 'Jaarlijkse besparing', resultSub: 'In het eerste jaar met Stockifi', per1: 'Elke verbetering van 1%', perLoc: 'Besparing per locatie', cta: 'Ontvang mijn besparingsplan' },
  de: { eyebrow: 'Einsparungsrechner', heading: 'Sehen Sie, welchen Einfluss Stockifi auf Ihren Gewinn haben kann', subhead: 'Geben Sie unten Ihre Zahlen ein, um Ihre möglichen Einsparungen zu berechnen.', revenue: 'Jahresumsatz pro Standort', locations: 'Anzahl der Standorte', current: 'Aktueller Wareneinsatz %', target: 'Ziel-Wareneinsatz %', resultH: 'Jährliche Einsparungen', resultSub: 'Im ersten Jahr mit Stockifi', per1: 'Jede Verbesserung um 1 %', perLoc: 'Einsparungen pro Standort', cta: 'Meinen Einsparungsplan erhalten' },
};
const s = STRINGS[locale as keyof typeof STRINGS] ?? STRINGS.en;

const CUR: Record<string, { tag: string; cur: string; sym: string }> = {
  en: { tag: 'en-IE', cur: 'EUR', sym: '€' },
  de: { tag: 'de-DE', cur: 'EUR', sym: '€' },
  nl: { tag: 'nl-NL', cur: 'EUR', sym: '€' },
  no: { tag: 'nb-NO', cur: 'NOK', sym: 'kr' },
  sv: { tag: 'sv-SE', cur: 'SEK', sym: 'kr' },
  da: { tag: 'da-DK', cur: 'DKK', sym: 'kr' },
};
const c = CUR[locale] ?? CUR.en;

// Exact increments (the count drives the calc). 1–30, then 30+.
const LOC_OPTS = Array.from({ length: 30 }, (_, i) => String(i + 1)).concat('30+');
const D = { revenue: 1300000, locDefault: '5', current: 30, target: 27, min: 5, max: 60 };
const bookHref = lp('/book-a-demo');
---

<section class="sc section" data-sc data-tag={c.tag} data-cur={c.cur} data-book={bookHref}>
  <div class="container sc-inner">
    <header class="sc-head">
      <p class="sc-eyebrow">{s.eyebrow}</p>
      <h2 class="sc-heading">{s.heading}</h2>
      <p class="sc-sub text-muted">{s.subhead}</p>
    </header>

    <div class="sc-grid">
      <!-- Inputs panel (single column, mirrors the results card) -->
      <div class="sc-inputs">
        <div class="sc-field">
          <label class="sc-label" for="sc-rev">{s.revenue}</label>
          <div class="sc-money">
            <span class="sc-sym" aria-hidden="true">{c.sym}</span>
            <input class="sc-input sc-input--money" id="sc-rev" type="text" inputmode="numeric"
              autocomplete="off" placeholder={D.revenue.toLocaleString(c.tag)} value={D.revenue.toLocaleString(c.tag)} />
          </div>
        </div>
        <div class="sc-field">
          <label class="sc-label" for="sc-loc">{s.locations}</label>
          <div class="sc-sel-wrap">
            <select class="sc-input sc-select" id="sc-loc">
              {LOC_OPTS.map((v) => (<option value={v} selected={v === D.locDefault}>{v}</option>))}
            </select>
            <svg class="sc-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
        <div class="sc-field">
          <div class="sc-slabel"><span class="sc-label">{s.current}</span><span class="sc-pct" id="sc-cur-val">{D.current}%</span></div>
          <input class="sc-range" id="sc-cur" type="range" min={D.min} max={D.max} step="1" value={D.current} />
        </div>
        <div class="sc-field">
          <div class="sc-slabel"><span class="sc-label">{s.target}</span><span class="sc-pct" id="sc-tgt-val">{D.target}%</span></div>
          <input class="sc-range" id="sc-tgt" type="range" min={D.min} max={D.max} step="1" value={D.target} />
        </div>
      </div>

      <!-- Result card -->
      <div class="sc-card">
        <div class="sc-result">
          <div class="sc-primary">
            <p class="sc-result-h">{s.resultH}</p>
            <strong class="sc-result-n" id="sc-annual">—</strong>
            <p class="sc-result-sub text-muted">{s.resultSub}</p>
          </div>

          <div class="sc-rows">
            <div class="sc-srow"><span class="text-muted">{s.per1}</span><span id="sc-per1">—</span></div>
            <div class="sc-srow"><span class="text-muted">{s.perLoc}</span><span id="sc-perloc">—</span></div>
          </div>

          <button class="sc-cta" id="sc-cta" type="button">
            <span>{s.cta}</span>
            <svg class="sc-cta-arrow" width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Full LIGHT section on the dark page — reads as a built-in band, not an embed.
     Subtle brand-tinted gradient backdrop baked into the section. */
  .sc {
    position: relative; isolation: isolate; overflow: clip;
    background: radial-gradient(100% 85% at 50% -8%, color-mix(in srgb, var(--primary) 22%, #f4f4f5), #f4f4f5 62%);
    color: #1a1620;
  }
  /* Crossfade the dark page into the light band (and back) across the section's
     padding only — content stays on the solid light middle. Fade height tracks the
     section padding so the content never sits on a low-contrast zone. */
  .sc::before, .sc::after {
    content: ''; position: absolute; left: 0; right: 0; height: var(--section-y);
    pointer-events: none; z-index: 0;
  }
  .sc::before { top: 0; background: linear-gradient(to bottom, var(--background), transparent); }
  .sc::after { bottom: 0; background: linear-gradient(to top, var(--background), transparent); }

  .sc-inner { position: relative; z-index: 1; display: flex; flex-direction: column; gap: var(--space-48); }
  .sc-head { max-width: 50rem; margin-inline: auto; text-align: center; }
  .sc-eyebrow {
    font-size: var(--text-body-sm); font-weight: var(--fw-semibold);
    letter-spacing: 0.08em; text-transform: uppercase; color: #6d46aa;
    margin-bottom: var(--space-12);
  }
  .sc-heading { font-size: var(--text-h2); line-height: var(--lh-h2); margin-bottom: var(--space-16); color: #1a1620; }
  .sc-sub { font-size: var(--text-body-lg); line-height: var(--lh-body); }

  /* One unified card: inputs + results are two columns inside a single container
     (divider between them), so they read as one component. */
  .sc-grid {
    display: grid; grid-template-columns: 1fr; align-items: stretch;
    border: 1px solid #ececec; border-radius: var(--radius-xl);
    background: #fff; color: #1a1620;
    box-shadow: 0 10px 40px -12px rgba(60, 40, 100, 0.18);
    overflow: hidden;
  }
  .sc-inputs { display: flex; flex-direction: column; gap: var(--space-32); padding: var(--space-32); }
  .sc .sc-label { color: #1a1620; }
  .sc .sc-pct { color: #6d46aa; }
  .sc .text-muted { color: #6b6675; }
  .sc-field { display: flex; flex-direction: column; gap: var(--space-16); }

  .sc-label { font-size: var(--text-body-sm); font-weight: var(--fw-medium); color: var(--foreground); }
  .sc-slabel { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-12); }
  .sc-pct { font-size: var(--text-body); font-weight: var(--fw-semibold); color: var(--primary-light); font-variant-numeric: tabular-nums; }

  /* White fill so it reads clearly as an editable field on the dark page. */
  .sc-input {
    width: 100%; height: 56px; padding: 0 var(--space-16);
    background: #fff; border: 1.5px solid #e2e2e2;
    border-radius: var(--radius-md); color: #1a1620;
    font-size: var(--text-body); font-family: var(--font-body); font-weight: var(--fw-medium);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    -webkit-appearance: none; appearance: none;
  }
  .sc-input::placeholder { color: #8a8594; font-weight: 400; }
  .sc-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(149, 101, 219, 0.28); }

  .sc-money { position: relative; }
  .sc-money .sc-sym {
    position: absolute; left: var(--space-16); top: 50%; transform: translateY(-50%);
    color: #6b6675; font-size: var(--text-body); pointer-events: none;
  }
  .sc-input--money { padding-left: 2.25rem; }

  .sc-sel-wrap { position: relative; }
  .sc-select { padding-right: 42px; cursor: pointer; }
  .sc-select option { background: #fff; color: #1a1620; }
  .sc-chev { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: #6b6675; pointer-events: none; }

  /* Range slider — track filled to the thumb with the brand purple. */
  .sc-range {
    -webkit-appearance: none; appearance: none; width: 100%; height: 6px;
    border-radius: 999px; cursor: pointer; margin: 10px 0;
    background: linear-gradient(to right, var(--primary) var(--fill, 50%), #dcdcdc var(--fill, 50%));
  }
  .sc-range::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; width: 22px; height: 22px;
    border-radius: 50%; background: #fff; border: 1px solid rgba(0, 0, 0, 0.12);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4); cursor: pointer;
  }
  .sc-range::-moz-range-thumb {
    width: 22px; height: 22px; border-radius: 50%; background: #fff; border: 1px solid rgba(0, 0, 0, 0.12);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4); cursor: pointer;
  }
  .sc-range:focus-visible { outline: 2px solid var(--primary); outline-offset: 4px; }

  /* Results column (inside the unified card) — divider separates it from inputs. */
  .sc-card { padding: var(--space-32); border-top: 1px solid #e5e5e5; }
  .sc-result { display: flex; flex-direction: column; gap: var(--space-32); height: 100%; justify-content: space-between; }

  /* Primary result — centered hero */
  .sc-primary { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-8); }
  .sc-result-h { font-family: var(--font-heading); font-size: var(--text-h5); font-weight: var(--fw-bold); color: #1a1620; }
  .sc-result-n {
    font-family: var(--font-body); font-size: var(--text-h3); line-height: 1.1; font-weight: var(--fw-bold);
    color: #1a1620; font-variant-numeric: tabular-nums;
  }
  .sc-result-sub { font-size: var(--text-body-sm); }

  /* Secondary results — unchanged row layout */
  .sc-rows { display: flex; flex-direction: column; gap: var(--space-16); padding-top: var(--space-32); border-top: 1px solid #e5e5e5; }
  .sc-srow { display: flex; align-items: center; justify-content: space-between; gap: var(--space-16); font-size: var(--text-body); }
  .sc-srow span:last-child { font-weight: var(--fw-semibold); color: #1a1620; font-variant-numeric: tabular-nums; }

  /* CTA — purple fill (pops on the light card) with arrow */
  .sc-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-8);
    width: 100%; height: 54px; padding: 0 var(--space-32); margin-top: var(--space-8);
    background: var(--primary); color: #fff; border: none;
    border-radius: var(--radius-full); font-size: var(--text-body);
    font-weight: var(--fw-semibold); font-family: var(--font-body); cursor: pointer;
    transition: background 0.18s ease;
  }
  .sc-cta:hover { background: var(--primary-dark); }
  .sc-cta-arrow { transition: transform 0.18s ease; }
  .sc-cta:hover .sc-cta-arrow { transform: translateX(3px); }

  @media (min-width: 1024px) {
    .sc-grid { grid-template-columns: 1fr 1fr; }
    .sc-inputs { padding: var(--space-64); gap: var(--space-48); }
    .sc-card { padding: var(--space-64); border-top: none; border-left: 1px solid #e5e5e5; }
  }

  @media (max-width: 1023px) {
    .sc-inner { gap: var(--space-32); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-sc]').forEach((root) => {
    const tag = root.dataset.tag || 'en-IE';
    const cur = root.dataset.cur || 'EUR';
    const bookHref = root.dataset.book || '/book-a-demo';

    const rev = root.querySelector<HTMLInputElement>('#sc-rev')!;
    const loc = root.querySelector<HTMLSelectElement>('#sc-loc')!;
    const curS = root.querySelector<HTMLInputElement>('#sc-cur')!;
    const tgtS = root.querySelector<HTMLInputElement>('#sc-tgt')!;
    const curV = root.querySelector<HTMLElement>('#sc-cur-val')!;
    const tgtV = root.querySelector<HTMLElement>('#sc-tgt-val')!;
    const outAnnual = root.querySelector<HTMLElement>('#sc-annual')!;
    const outPer1 = root.querySelector<HTMLElement>('#sc-per1')!;
    const outPerLoc = root.querySelector<HTMLElement>('#sc-perloc')!;
    const cta = root.querySelector<HTMLButtonElement>('#sc-cta')!;

    const money = new Intl.NumberFormat(tag, { style: 'currency', currency: cur, maximumFractionDigits: 0 });
    const groups = new Intl.NumberFormat(tag);
    const digits = (v: string) => parseInt(v.replace(/\D/g, ''), 10) || 0;
    const DEF_REV = 1300000;

    // Map an exact count to the book-a-demo number_of_venues bucket for carry-over.
    const venueBucket = (n: number) => n <= 1 ? '1' : n <= 4 ? '2 - 4' : n <= 10 ? '5 - 10' : n <= 20 ? '11 - 20' : '20+';

    function fillTrack(el: HTMLInputElement) {
      const min = Number(el.min), max = Number(el.max);
      el.style.setProperty('--fill', ((Number(el.value) - min) / (max - min)) * 100 + '%');
    }

    function calc() {
      const revenue = digits(rev.value) || DEF_REV;
      const locations = loc.value === '30+' ? 30 : (parseInt(loc.value, 10) || 5);
      const current = Number(curS.value);
      const target = Number(tgtS.value);
      const costDiff = Math.max(0, (current - target) / 100);

      const annual = revenue * locations * costDiff;
      const per1 = revenue * 0.01 * locations;
      const perLoc = annual / locations;

      outAnnual.textContent = money.format(annual);
      outPer1.textContent = money.format(per1);
      outPerLoc.textContent = money.format(perLoc);
      curV.textContent = current + '%';
      tgtV.textContent = target + '%';
      fillTrack(curS); fillTrack(tgtS);

      return { revenue, locations, number_of_venues: venueBucket(locations), current, target, annual };
    }

    rev.addEventListener('input', () => {
      const n = digits(rev.value);
      rev.value = n ? groups.format(n) : '';
      rev.setSelectionRange(rev.value.length, rev.value.length);
      calc();
    });
    loc.addEventListener('change', calc);
    [curS, tgtS].forEach((el) => el.addEventListener('input', calc));

    cta.addEventListener('click', () => {
      const data = calc();
      // PROVISIONAL: stash inputs + result and route to book-a-demo. HubSpot carry-over
      // wired once V picks the approach; number_of_venues bucket is already included.
      try { sessionStorage.setItem('stockifi_savings', JSON.stringify(data)); } catch (_) {}
      window.location.href = bookHref;
    });

    calc();
  });
</script>
