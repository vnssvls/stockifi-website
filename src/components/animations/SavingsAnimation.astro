---
// SavingsAnimation — quarterly savings trend (Q1–Q4) with count-up total
// and stagger-slide breakdown rows. Seamless loop, no fade.
---

<div class="sv-stage">
  <div class="sv-widget">
    <div class="sv-hd">
      <span class="sv-eyebrow">Savings this month</span>
    </div>
    <div class="sv-hero">
      <span class="sv-kpi" id="sv-kpi">€0</span>
      <span class="sv-icon" id="sv-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <polyline points="2 14 7 8 11 11 16 4" stroke="#34d399" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <polyline points="11 4 16 4 16 9" stroke="#34d399" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
    <div class="sv-chartwrap">
      <svg id="sv-chart" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <clipPath id="sv-clip"><rect id="sv-cliprect" x="0" y="0" width="0" height="0"></rect></clipPath>
          <linearGradient id="sv-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#34d399" stop-opacity="0.22"></stop>
            <stop offset="1" stop-color="#34d399" stop-opacity="0"></stop>
          </linearGradient>
          <linearGradient id="sv-hmask-grad" x1="0" y1="0" x2="760" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="white" stop-opacity="0.04"></stop>
            <stop offset="0.35" stop-color="white" stop-opacity="0.30"></stop>
            <stop offset="0.55" stop-color="white" stop-opacity="1"></stop>
            <stop offset="1" stop-color="white" stop-opacity="1"></stop>
          </linearGradient>
          <mask id="sv-hmask">
            <rect x="0" y="0" width="760" height="160" fill="url(#sv-hmask-grad)"></rect>
          </mask>
        </defs>
        <line id="sv-gridline" class="sv-grid"></line>
        <g clip-path="url(#sv-clip)" mask="url(#sv-hmask)">
          <path id="sv-area" fill="url(#sv-grad)"></path>
          <path id="sv-line" class="sv-line"></path>
        </g>
        <circle id="sv-dot" class="sv-dot" r="4" style="opacity:0"></circle>
      </svg>
      <div class="sv-xaxis" id="sv-xaxis"></div>
    </div>
    <div class="sv-rows">
      <div class="sv-row" id="sv-row-0">
        <span class="sv-check" aria-hidden="true">
          <svg viewBox="0 0 12 12" fill="none"><path d="M2 6.2 4.8 9 10 3.2" stroke="#34d399" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="sv-row-name">Invoice anomalies</span>
        <span class="sv-row-val">€1,280</span>
      </div>
      <div class="sv-row" id="sv-row-1">
        <span class="sv-check" aria-hidden="true">
          <svg viewBox="0 0 12 12" fill="none"><path d="M2 6.2 4.8 9 10 3.2" stroke="#34d399" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="sv-row-name">Recipe deviation</span>
        <span class="sv-row-val">€1,490</span>
      </div>
      <div class="sv-row" id="sv-row-2">
        <span class="sv-check" aria-hidden="true">
          <svg viewBox="0 0 12 12" fill="none"><path d="M2 6.2 4.8 9 10 3.2" stroke="#34d399" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="sv-row-name">Stock variance</span>
        <span class="sv-row-val">€880</span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .sv-stage {
    width: 100%;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 24px;
    padding-inline: 16px;
  }
  .sv-widget {
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
  }
  .sv-hd {
    display: flex;
    align-items: center;
  }
  .sv-eyebrow {
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
  }
  .sv-hero {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
  }
  .sv-kpi {
    font-size: 28px;
    font-weight: 300;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1;
  }
  .sv-icon {
    display: flex;
    align-items: center;
    opacity: 1;
  }
  .sv-chartwrap { margin-top: 14px; }
  .sv-chartwrap svg { display: block; width: 100%; height: auto; }
  .sv-xaxis {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-size: 11px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.3);
    font-variant-numeric: tabular-nums;
  }
  .sv-line {
    fill: none;
    stroke: #34d399;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 0 6px rgba(52, 211, 153, 0.45));
  }
  .sv-dot {
    fill: #212121;
    stroke: #34d399;
    stroke-width: 2;
    filter: drop-shadow(0 0 4px rgba(52, 211, 153, 0.6));
  }
  .sv-grid {
    stroke: rgba(255, 255, 255, 0.07);
    stroke-width: 1;
  }
  .sv-rows {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
  }
  .sv-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 0;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.42s ease, transform 0.42s ease;
  }
  .sv-row + .sv-row {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .sv-check {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: grid;
    place-items: center;
  }
  .sv-check svg { width: 12px; height: 12px; display: block; }
  .sv-row-name {
    flex: 1;
    font-size: 12px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.55);
    white-space: nowrap;
  }
  .sv-row-val {
    font-size: 12px;
    font-weight: 300;
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.85);
    white-space: nowrap;
  }
</style>

<script>
  var SV = {
    kpiStart: 2100,
    kpiEnd: 3650,
    quarters: ['Q1', 'Q2', 'Q3', 'Q4'],
    // 3 points: Q1, Q2, current (stops between Q2 and Q3)
    savings: [2100, 2800, 3650],
    // x positions as fractions of chart width (Q1=0%, Q2=33%, current=55%)
    xFracs: [0, 0.33, 0.55],
    revealMs: 2500,
    rowDelays: [750, 1200, 1650],
    holdMs: 3200,
  };

  var CYCLE_MS = SV.revealMs + SV.holdMs;

  function svFmt(v) {
    var n = Math.round(v);
    if (n >= 1000) {
      return '€' + Math.floor(n / 1000) + ',' + String(n % 1000).padStart(3, '0');
    }
    return '€' + n;
  }

  function svEaseOut(x) { return 1 - Math.pow(1 - x, 3); }
  function svClamp(x) { return Math.max(0, Math.min(1, x)); }

  function svSmoothPath(pts) {
    var d = 'M' + pts[0].x.toFixed(1) + ' ' + pts[0].y.toFixed(1);
    for (var i = 0; i < pts.length - 1; i++) {
      var p0 = pts[i - 1] || pts[i], p1 = pts[i], p2 = pts[i + 1], p3 = pts[i + 2] || p2;
      var c1x = p1.x + (p2.x - p0.x) / 6, c1y = p1.y + (p2.y - p0.y) / 6;
      var c2x = p2.x - (p3.x - p1.x) / 6, c2y = p2.y - (p3.y - p1.y) / 6;
      d += ' C' + c1x.toFixed(1) + ' ' + c1y.toFixed(1) + ' ' + c2x.toFixed(1) + ' ' + c2y.toFixed(1) + ' ' + p2.x.toFixed(1) + ' ' + p2.y.toFixed(1);
    }
    return d;
  }

  (function() {
    var W = 760, H = 160, padX = 8, padT = 14, padB = 6;

    document.getElementById('sv-xaxis').innerHTML = SV.quarters.map(function(q) {
      return '<span>' + q + '</span>';
    }).join('');

    var vals = SV.savings;
    var min = Math.min.apply(null, vals), max = Math.max.apply(null, vals), range = max - min || 1;
    // Generous padding below min so Q1 starts mid-chart, not at the bottom
    var yMin = min - range * 0.9, yRange = range * 2.2;
    var pts = vals.map(function(v, i) {
      return {
        x: padX + SV.xFracs[i] * (W - 2 * padX),
        y: padT + (1 - (v - yMin) / yRange) * (H - padT - padB),
      };
    });
    var lineD = svSmoothPath(pts);
    var areaD = lineD
      + ' L' + pts[pts.length - 1].x.toFixed(1) + ' ' + (H - padB)
      + ' L' + pts[0].x.toFixed(1) + ' ' + (H - padB) + ' Z';

    var chart = document.getElementById('sv-chart');
    chart.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
    document.getElementById('sv-line').setAttribute('d', lineD);
    document.getElementById('sv-area').setAttribute('d', areaD);
    document.getElementById('sv-cliprect').setAttribute('height', H);
    var gl = document.getElementById('sv-gridline');
    gl.setAttribute('x1', 0); gl.setAttribute('x2', W);
    gl.setAttribute('y1', H - padB); gl.setAttribute('y2', H - padB);

    var lineEl  = document.getElementById('sv-line');
    var clipEl  = document.getElementById('sv-cliprect');
    var dotEl   = document.getElementById('sv-dot');
    var kpiEl   = document.getElementById('sv-kpi');
    var iconEl  = document.getElementById('sv-icon');
    var rowEls  = [0, 1, 2].map(function(i) { return document.getElementById('sv-row-' + i); });

    var L = lineEl.getTotalLength();
    var rowShown = [false, false, false];
    var lastCycle = -1;
    var start = null;

    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function resetRows(instant) {
      rowEls.forEach(function(el) {
        el.style.transition = 'none';
        el.style.opacity = '0';
        el.style.transform = 'translateY(14px)';
      });
      if (!instant) {
        rowEls[0] && rowEls[0].getBoundingClientRect();
        rowEls.forEach(function(el) {
          el.style.transition = 'opacity 0.42s ease, transform 0.42s ease';
        });
      }
      rowShown = [false, false, false];
    }

    function paint(clock) {
      var reveal = svClamp(clock / SV.revealMs);
      var eased  = svEaseOut(reveal);

      kpiEl.textContent = svFmt(SV.kpiStart + (SV.kpiEnd - SV.kpiStart) * eased);

      var pt = lineEl.getPointAtLength(L * reveal);
      clipEl.setAttribute('width', pt.x.toFixed(1));
      dotEl.setAttribute('cx', pt.x.toFixed(1));
      dotEl.setAttribute('cy', pt.y.toFixed(1));
      dotEl.style.opacity = reveal > 0.02 ? '1' : '0';

      SV.rowDelays.forEach(function(delay, i) {
        if (!rowShown[i] && clock > delay) {
          rowShown[i] = true;
          rowEls[i].style.opacity = '1';
          rowEls[i].style.transform = 'translateY(0)';
        }
      });

    }

    if (reduced) {
      resetRows(true);
      rowEls.forEach(function(el) { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; });
      paint(SV.revealMs);
      return;
    }

    resetRows(true);
    rowEls.forEach(function(el) {
      el.style.transition = 'opacity 0.42s ease, transform 0.42s ease';
    });

    function loop(ts) {
      if (start === null) start = ts;
      var elapsed = ts - start;
      var cycle = Math.floor(elapsed / CYCLE_MS);
      var clock = elapsed % CYCLE_MS;

      if (cycle !== lastCycle) {
        lastCycle = cycle;
        resetRows(false);
      }

      paint(clock);
      requestAnimationFrame(loop);
    }

    requestAnimationFrame(loop);
  })();
</script>
