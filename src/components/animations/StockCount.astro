---
// Stock counting — a count in progress across storage areas. All areas start counting
// at once, then complete one at a time in random order; the "Stock Count Value" total
// accumulates as each finishes. Area values localise via currency.ts (total = sum of
// area values, self-consistent); area names + label via STRINGS. Light card on the veil.
import { convertAmount, formatAmount, currencyMeta } from '../../data/currency';

const locale = Astro.currentLocale ?? 'en';
const T: Record<string, { title: string; counting: string; areas: string[] }> = {
  en: { title: 'Stock Count Value', counting: 'counting…', areas: ['Dry storage', 'Walk in fridge', 'Prep station', 'Bar fridge', 'Bar shelf'] },
  de: { title: 'Inventurwert', counting: 'zählt…', areas: ['Trockenlager', 'Kühlschrank', 'Vorbereitung', 'Bar-Kühlschrank', 'Bar-Regal'] },
  nl: { title: 'Voorraadwaarde', counting: 'telt…', areas: ['Droogopslag', 'Koelkast', 'Voorbereiding', 'Bar-koelkast', 'Bar-plank'] },
  no: { title: 'Varelagerverdi', counting: 'teller…', areas: ['Tørrlager', 'Kjøleskap', 'Forberedelse', 'Bar-kjøleskap', 'Bar-hylle'] },
  sv: { title: 'Lagervärde', counting: 'räknar…', areas: ['Torrförråd', 'Kylskåp', 'Förberedelse', 'Barkylskåp', 'Barhylla'] },
  da: { title: 'Lagerværdi', counting: 'tæller…', areas: ['Tørvarelager', 'Køleskab', 'Forberedelse', 'Bar-køleskab', 'Bar-hylde'] },
};
const t = T[locale] ?? T.en;
const meta = currencyMeta(locale);

const BASES = [4200, 5800, 2400, 6500, 9200];
const areas = BASES.map((b, idx) => {
  const v = convertAmount(b, locale, { whole: true });
  return { name: t.areas[idx] ?? '', val: formatAmount(v, locale, { whole: true }), valnum: v };
});
const totalFmt = formatAmount(areas.reduce((s, a) => s + a.valnum, 0), locale, { whole: true });
---

<div class="sc-wrap">
  <div class="sc-card" data-tag={meta.tag} data-cur={meta.cur}>
    <span class="sc-doc">{t.title}</span>
    <span class="sc-hero-v">{totalFmt}</span>
    <div class="sc-areas">
      {areas.map((a) => (
        <div class="sc-area" data-valnum={a.valnum}>
          <span class="sc-ic">
            <svg class="ic-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-6.22-8.56" /></svg>
            <svg class="ic-done" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
          </span>
          <span class="sc-name">{a.name}</span>
          <span class="sc-counting">{t.counting}</span>
          <span class="sc-val">{a.val}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .sc-wrap { width: 100%; padding-block: 24px; display: flex; justify-content: flex-start; }
  .sc-card {
    width: 100%;
    max-width: 330px;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-lg, 12px);
    padding: 16px 18px;
    font-family: var(--font-body, 'Inter', sans-serif);
  }
  .sc-doc { display: block; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255, 255, 255, 0.6); }
  .sc-hero-v { display: block; margin-top: 5px; font-size: 27px; font-weight: 500; color: rgba(255, 255, 255, 0.96); font-variant-numeric: tabular-nums; }
  .sc-areas { margin-top: 14px; padding-top: 4px; border-top: 1px solid rgba(255, 255, 255, 0.14); }

  .sc-area { display: flex; align-items: center; gap: 10px; padding: 7px 0; }
  .sc-ic { display: inline-flex; width: 15px; height: 15px; flex: 0 0 auto; }
  .sc-ic svg { width: 15px; height: 15px; }
  .sc-name { flex: 1 1 auto; font-size: 13.5px; font-weight: 300; color: rgba(255, 255, 255, 0.82); white-space: nowrap; }
  .sc-counting { font-size: 12px; color: rgba(255, 255, 255, 0.5); }
  .sc-val { font-size: 13.5px; font-weight: 400; color: rgba(255, 255, 255, 0.92); font-variant-numeric: tabular-nums; }

  .ic-spin { color: #bb86fc; animation: sc-spin 0.9s linear infinite; }
  .ic-done { color: #34d399; }

  /* default (no JS / reduced motion) = all counted */
  .ic-spin, .sc-counting { display: none; }
  .ic-done, .sc-val { display: inline; }

  /* animating: all start counting, then resolve one at a time */
  .sc-card.sc-anim .ic-done, .sc-card.sc-anim .sc-val { display: none; }
  .sc-card.sc-anim .ic-spin, .sc-card.sc-anim .sc-counting { display: inline; }
  .sc-card.sc-anim .sc-area.done .ic-spin, .sc-card.sc-anim .sc-area.done .sc-counting { display: none; }
  .sc-card.sc-anim .sc-area.done .ic-done, .sc-card.sc-anim .sc-area.done .sc-val { display: inline; }

  @keyframes sc-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .ic-spin { animation: none; } }
</style>

<script>
  const INITIAL = 800; // all areas counting before the first completes (ms)
  const STEP = 640;    // gap between completions (ms)
  const HOLD = 2200;   // hold once all done, before the loop restarts (ms)
  const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
  const shuffle = <T,>(a: T[]): T[] => {
    for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; }
    return a;
  };

  document.querySelectorAll<HTMLElement>('.sc-card').forEach((card) => {
    const hero = card.querySelector<HTMLElement>('.sc-hero-v');
    const areas = Array.from(card.querySelectorAll<HTMLElement>('.sc-area'));
    if (!hero || !areas.length) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const fmt = new Intl.NumberFormat(card.dataset.tag, { style: 'currency', currency: card.dataset.cur, minimumFractionDigits: 0, maximumFractionDigits: 0 });
    card.classList.add('sc-anim');

    async function loop() {
      while (card.isConnected) {
        areas.forEach((a) => a.classList.remove('done'));
        hero!.textContent = fmt.format(0);
        await sleep(INITIAL);

        let sum = 0;
        for (const idx of shuffle([...areas.keys()])) {
          areas[idx].classList.add('done');
          sum += Number(areas[idx].dataset.valnum) || 0;
          hero!.textContent = fmt.format(sum);
          await sleep(STEP);
        }
        await sleep(HOLD);
      }
    }
    loop();
  });
</script>
