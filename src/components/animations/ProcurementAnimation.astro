---
// Procurement animation — scrolling supplier price-change ticker.
// 3 rows visible, middle row is the spotlight. Advances every 2.2s with a count-up badge.
// Footer shows dynamic recipe count for the current spotlight ingredient.
// compact prop: scaled-down variant for hero overlays.
// Styles are global because the JS builds rows dynamically (no Astro scope hash on dynamic els).
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---

<div class:list={['inv-wrap', compact && 'inv-wrap--compact']}>
  <div class="inv-inner">
    <p class="inv-head">Latest price changes</p>
    <div class="inv-clip">
      <div class="inv-track"></div>
    </div>
    <div class="inv-footer">
      <svg class="inv-sync" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
        <path d="M3 21v-5h5"/><path d="M21 3v5h-5"/>
      </svg>
      <span class="inv-footer-count"></span>
      <span class="inv-footer-label"> recipes updated</span>
    </div>
  </div>
</div>

<style is:global>
  .inv-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 24px;
  }
  .inv-inner {
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
  }
  .inv-head {
    font-size: 15px;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 18px;
  }
  .inv-clip {
    overflow: hidden;
  }
  .inv-track {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }
  .inv-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.035);
    padding: 17px 0;
    flex-shrink: 0;
  }
  .inv-row-right {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .inv-row-name,
  .inv-row-price {
    font-size: 17px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.3s ease;
  }
  .inv-row-name {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding-right: 8px;
  }
  .inv-row.spotlight .inv-row-name,
  .inv-row.spotlight .inv-row-price {
    color: rgba(255, 255, 255, 0.88);
  }
  .inv-badge {
    max-width: 0;
    padding: 0;
    margin-left: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 300;
    transition: max-width 0.32s ease, padding 0.32s ease, margin-left 0.32s ease, opacity 0.2s ease;
  }
  .inv-badge.visible {
    max-width: 80px;
    padding: 3px 8px;
    margin-left: 10px;
    opacity: 1;
  }
  .inv-badge.up   { color: #f59e0b; background: rgba(245, 158, 11, 0.22); }
  .inv-badge.down { color: #34d399; background: rgba(52, 211, 153, 0.20); }

  .inv-footer {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.4);
  }
  .inv-footer-count {
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.75);
  }
  .inv-sync {
    flex-shrink: 0;
    width: 13px;
    height: 13px;
    color: #34d399;
    animation: inv-spin 2s linear infinite;
  }
  @keyframes inv-spin {
    to { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .inv-sync { animation: none; }
  }

  /* Compact variant — hero overlay */
  .inv-wrap--compact .inv-inner { max-width: 300px; }
  .inv-wrap--compact .inv-head { font-size: 12px; margin-bottom: 12px; }
  .inv-wrap--compact .inv-row { padding: 10px 0; }
  .inv-wrap--compact .inv-row-name,
  .inv-wrap--compact .inv-row-price { font-size: 13px; }
  .inv-wrap--compact .inv-badge { font-size: 11px; }
  .inv-wrap--compact .inv-footer { font-size: 11px; margin-top: 10px; }
  .inv-wrap--compact .inv-sync { width: 11px; height: 11px; }
</style>

<script>
  const ITEMS = [
    { name: 'Cherry tomatoes',      price: '€4.80',  change: +4,  recipes: 6  },
    { name: 'Chicken breast',       price: '€24.50', change: +8,  recipes: 4  },
    { name: 'Olive oil 5 L',        price: '€18.20', change: +5,  recipes: 14 },
    { name: 'Grana Padano 1 kg',    price: '€9.40',  change: +12, recipes: 3  },
    { name: 'Beef tenderloin 1 kg', price: '€32.00', change: +6,  recipes: 2  },
    { name: 'Halibut fillet 1 kg',  price: '€21.50', change: +9,  recipes: 3  },
    { name: 'Potato 10 kg',         price: '€9.20',  change: +5,  recipes: 8  },
    { name: 'Parmesan 1 kg',        price: '€22.00', change: +7,  recipes: 5  },
  ];

  const VISIBLE   = 3;
  const SPOTLIGHT = 1;
  const INTERVAL_MS = 2200;

  function initTicker(track) {
    let head = 0;
    const inner        = track.closest('.inv-inner');
    const footerEl     = inner.querySelector('.inv-footer');
    const footerCountEl = inner.querySelector('.inv-footer-count');

    function updateFooter(item) {
      const target = item.recipes;
      const dur = 380;
      const t0 = performance.now();
      (function step(now) {
        const p = Math.min((now - t0) / dur, 1);
        footerCountEl.textContent = Math.round(p * target);
        if (p < 1) requestAnimationFrame(step);
      })(performance.now());
    }

    function makeRow(item, isSpot) {
      const row = document.createElement('div');
      row.className = 'inv-row' + (isSpot ? ' spotlight' : '');
      row.innerHTML =
        `<span class="inv-row-name">${item.name}</span>` +
        `<span class="inv-row-right">` +
          `<span class="inv-row-price">${item.price}</span>` +
          `<span class="inv-badge ${item.change > 0 ? 'up' : 'down'}"></span>` +
        `</span>`;
      return row;
    }

    function countUp(el, target) {
      const sign = target > 0 ? '↑' : '↓';
      const abs  = Math.abs(target);
      const dur  = 550;
      const t0   = performance.now();
      (function step(now) {
        const p = Math.min((now - t0) / dur, 1);
        el.textContent = sign + Math.round(p * abs) + '%';
        if (p < 1) requestAnimationFrame(step);
      })(performance.now());
    }

    // Build initial rows
    for (let i = 0; i < VISIBLE; i++) {
      track.appendChild(makeRow(ITEMS[(head + i) % ITEMS.length], i === SPOTLIGHT));
    }

    // Set initial footer + trigger badge
    const initItem  = ITEMS[(head + SPOTLIGHT) % ITEMS.length];
    const initBadge = track.children[SPOTLIGHT].querySelector('.inv-badge');
    footerCountEl.textContent = '0';
    setTimeout(() => {
      initBadge.classList.add('visible');
      countUp(initBadge, initItem.change);
      updateFooter(initItem);
    }, 400);

    function tick() {
      const rows = track.children;
      const rowH = rows[0].offsetHeight;

      rows[SPOTLIGHT].classList.remove('spotlight');

      track.style.transition = `transform ${Math.round(INTERVAL_MS * 0.25)}ms cubic-bezier(0.4,0,0.2,1)`;
      track.style.transform  = `translateY(-${rowH}px)`;

      setTimeout(() => {
        track.style.transition = 'none';
        track.style.transform  = '';

        track.removeChild(rows[0]);
        head = (head + 1) % ITEMS.length;
        track.appendChild(makeRow(ITEMS[(head + VISIBLE - 1) % ITEMS.length], false));

        track.children[SPOTLIGHT].classList.add('spotlight');
        const newItem = ITEMS[(head + SPOTLIGHT) % ITEMS.length];
        const badge   = track.children[SPOTLIGHT].querySelector('.inv-badge');

        setTimeout(() => {
          badge.classList.add('visible');
          countUp(badge, newItem.change);
          updateFooter(newItem);
        }, 80);
      }, Math.round(INTERVAL_MS * 0.3));
    }

    setInterval(tick, INTERVAL_MS);
  }

  document.querySelectorAll('.inv-track').forEach(initTicker);
</script>
