---
// Invoice automation — a supplier invoice read line by line. Every row starts as a
// pending skeleton (name + price), pulsing like it's syncing. A purple beam sweeps
// down; as it crosses a row the skeletons resolve into the real ingredient + price,
// then a check appears and the tally ticks up. Loops. Light card, reads on the dark
// left veil. Static DOM + a small script that toggles classes, so styles stay scoped.
const ROWS = [
  { name: 'Cherry tomatoes', price: '€4.80' },
  { name: 'Olive oil 5 L',   price: '€18.20' },
  { name: 'Chicken breast',  price: '€24.50' },
  { name: 'Grana Padano',    price: '€9.40' },
  { name: 'Sea salt 1 kg',   price: '€3.20' },
];
---

<div class="iv-wrap">
  <div class="iv-card">
    <div class="iv-top">
      <span class="iv-doc">Invoice</span>
      <span class="iv-tally"><b class="iv-n">0</b> items captured</span>
    </div>
    <div class="iv-rows">
      {ROWS.map((r) => (
        <div class="iv-row">
          <span class="iv-name">
            <span class="iv-real">{r.name}</span>
            <i class="iv-sk" aria-hidden="true"></i>
          </span>
          <span class="iv-right">
            <span class="iv-pricewrap">
              <span class="iv-price">{r.price}</span>
              <i class="iv-sk" aria-hidden="true"></i>
            </span>
            <svg class="iv-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
          </span>
        </div>
      ))}
      <div class="iv-beam" aria-hidden="true"></div>
    </div>
  </div>
</div>

<style>
  .iv-wrap { width: 100%; padding-block: 24px; display: flex; justify-content: flex-start; }
  .iv-card {
    position: relative;
    width: 100%;
    max-width: 330px;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-lg, 12px);
    padding: 15px 18px 17px;
    overflow: hidden;
    font-family: var(--font-body, 'Inter', sans-serif);
  }
  .iv-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .iv-doc { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255, 255, 255, 0.6); }
  .iv-tally { font-size: 12px; color: rgba(255, 255, 255, 0.5); }
  .iv-tally b { color: rgba(255, 255, 255, 0.9); font-weight: 500; font-variant-numeric: tabular-nums; }

  .iv-rows { position: relative; }
  .iv-row { display: flex; align-items: center; gap: 12px; padding: 9px 0; border-top: 1px solid rgba(255, 255, 255, 0.07); }
  .iv-row:first-child { border-top: none; }

  /* name + price: real value sits in flow (sets the cell width) but stays invisible
     until scanned; the skeleton bar overlays it, pulsing, until then. */
  .iv-name { position: relative; flex: 0 1 auto; min-width: 64px; }
  .iv-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
  .iv-pricewrap { position: relative; min-width: 46px; text-align: right; }

  .iv-real, .iv-price { font-size: 14px; font-weight: 300; color: rgba(255, 255, 255, 0.92); white-space: nowrap; opacity: 0; transition: opacity 0.3s ease; }
  .iv-price { font-variant-numeric: tabular-nums; }

  .iv-sk {
    position: absolute;
    left: 0; right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 8px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.18);
    animation: iv-pulse 1.4s ease-in-out infinite;
  }
  @keyframes iv-pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 0.85; } }

  .iv-check { width: 15px; height: 15px; flex: 0 0 auto; color: #bb86fc; opacity: 0; transform: scale(0.6); transition: opacity 0.3s ease, transform 0.3s ease; }

  /* scanned */
  .iv-row.done .iv-sk { animation: none; opacity: 0; transition: opacity 0.25s ease; }
  .iv-row.done .iv-real,
  .iv-row.done .iv-price { opacity: 1; }
  .iv-row.done .iv-check { opacity: 1; transform: scale(1); transition-delay: 0.12s; }

  /* scan beam — spans into the card padding to reach both edges */
  .iv-beam {
    position: absolute;
    left: -18px; right: -18px;
    top: 0;
    height: 2px;
    background: #bb86fc;
    box-shadow: 0 0 12px 2px rgba(187, 134, 252, 0.7);
    opacity: 0;
  }
  .iv-beam.on { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .iv-beam { display: none; }
    .iv-sk { animation: none; }
  }
</style>

<script>
  const SWEEP = 2600; // beam top -> bottom (ms)
  const HOLD = 1100;  // pause before the loop restarts (ms)

  document.querySelectorAll<HTMLElement>('.iv-card').forEach((card) => {
    const beam = card.querySelector<HTMLElement>('.iv-beam');
    const rows = Array.from(card.querySelectorAll<HTMLElement>('.iv-row'));
    const nEl = card.querySelector<HTMLElement>('.iv-n');
    if (!beam || !rows.length) return;

    let timers: number[] = [];
    const clearAll = () => { timers.forEach((t) => clearTimeout(t)); timers = []; };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      rows.forEach((r) => r.classList.add('done'));
      if (nEl) nEl.textContent = String(rows.length);
      return;
    }

    function run() {
      clearAll();
      beam!.style.transition = 'none';
      beam!.style.top = '0%';
      beam!.classList.remove('on');
      rows.forEach((r) => r.classList.remove('done'));
      if (nEl) nEl.textContent = '0';

      // start the sweep next frame so the reset paints first
      requestAnimationFrame(() => requestAnimationFrame(() => {
        beam!.style.transition = `top ${SWEEP}ms linear`;
        beam!.classList.add('on');
        beam!.style.top = '100%';
      }));

      // resolve each row as the beam crosses its midpoint
      rows.forEach((r, i) => {
        const at = SWEEP * ((i + 0.5) / rows.length);
        timers.push(window.setTimeout(() => {
          r.classList.add('done');
          if (nEl) nEl.textContent = String(i + 1);
        }, at));
      });

      timers.push(window.setTimeout(run, SWEEP + HOLD));
    }

    run();
  });
</script>
