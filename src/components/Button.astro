---
// Button / CTA. variant: primary (filled) | secondary (outline) | ghost (borderless text link).
// Renders <a> when href is set, else <button>. Primary hover flips to
// foreground/background per the design-system dark-mode treatment.
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit';
  block?: boolean;
  class?: string;
  [key: string]: unknown;
}
const {
  variant = 'primary',
  href,
  type = 'button',
  block = false,
  class: className,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const tagProps = href ? { href } : { type };
---

<Tag class:list={['btn', `btn-${variant}`, block && 'btn-block', className]} {...tagProps} {...rest}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    padding: var(--space-12) var(--space-24);
    border: 1px solid transparent;
    /* Finite radius that still clamps to a pill on a ~40px-tall button, so the
       hover morph to --radius-md animates through the visible range (a true pill
       at 9999px would just snap at the very end). */
    border-radius: var(--radius-xl);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--fw-semibold);
    line-height: 1;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.18s ease, color 0.18s ease, border-color 0.18s ease, border-radius 0.3s ease;
  }
  /* Hover tightens the pill into a soft rounded-rect */
  .btn:hover { text-decoration: none; border-radius: var(--radius-md); }
  .btn-block { width: 100%; }

  .btn-primary {
    background: var(--primary);
    color: var(--primary-foreground);
  }
  .btn-primary:hover {
    background: var(--foreground);
    color: var(--background);
  }

  .btn-secondary {
    background: transparent;
    color: var(--foreground);
    border-color: var(--border);
  }
  .btn-secondary:hover {
    border-color: var(--foreground);
  }

  /* Ghost: no border, no fill — a text link block (e.g. "View all integrations →"). */
  .btn-ghost {
    background: transparent;
    color: var(--foreground);
    border-color: transparent;
    padding-inline: 0;
  }
  .btn-ghost:hover { color: var(--primary); gap: var(--space-12); }
</style>
