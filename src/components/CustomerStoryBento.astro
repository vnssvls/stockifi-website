---
// Customer-story bento (Figma 103:800 / 103:846) for the home page customer-story slot:
// centered header + a 4-slot bento of image-backed story cards — big left, two top-right,
// wide bottom-right. Wide 80px gutter. Card title = company name; body = oneLiner (falls
// back to featuredQuote); CTA is a "Read story" text link only (no button). Pass `slugs`
// (ordered, up to 4) to choose which stories feature here.
import { getCollection } from 'astro:content';
import Button from './Button.astro';

interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  cta?: { label: string; href: string };
  slugs: string[];
}
const { eyebrow, heading, subhead, cta, slugs } = Astro.props;

const all = await getCollection('customerStories');
const byId = new Map(all.map((s) => [s.id, s]));
const cards = slugs
  .map((sl) => byId.get(sl))
  .filter((s): s is NonNullable<typeof s> => Boolean(s))
  .slice(0, 4)
  .map((s) => ({
    company: s.data.companyName,
    blurb: s.data.cardSummary || s.data.oneLiner || s.data.featuredQuote || '',
    image: s.data.thumbnail || s.data.singleImage || '',
    href: `/customer-stories/${s.id}`,
  }));
---

<section class="section csb">
  <span class="csb-glow" aria-hidden="true"></span>
  <div class="csb-wide">
    <header class="csb-head">
      {eyebrow && <p class="tagline">{eyebrow}</p>}
      <h2 class="csb-heading">{heading}</h2>
      {subhead && <p class="csb-sub text-muted">{subhead}</p>}
      {cta && (
        <div class="csb-head-cta">
          <Button variant="secondary" href={cta.href}>
            {cta.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </Button>
        </div>
      )}
    </header>

    <div class="csb-grid">
      {cards.map((c) => (
        <a class="csb-card" href={c.href}>
          <div class="csb-media">
            {c.image
              ? <img src={c.image} alt={c.company} loading="lazy" decoding="async" />
              : <span class="csb-media-ph" aria-hidden="true"></span>}
          </div>
          <div class="csb-content">
            <h3 class="csb-title">{c.company}</h3>
            {c.blurb && <p class="csb-blurb">{c.blurb}</p>}
            <span class="csb-cta">
              Read story
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* isolation:isolate keeps the z-index:-1 glow visible (in this section's stacking
     context, above its transparent bg). The glow still overflows the box softly into the
     neighbouring sections; without isolation the negative-z layer hides behind the page bg. */
  .csb { position: relative; isolation: isolate; }
  .csb-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: -1;
    width: min(1400px, 96vw);
    height: 1100px;
    background-image: url('/media/gradient-duo.png');
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    opacity: 0.4;
    pointer-events: none;
  }

  .csb-wide { width: 100%; max-width: none; margin-inline: auto; padding-inline: var(--gutter-wide); }

  .csb-head { max-width: 56ch; margin: 0 auto var(--space-64); text-align: center; display: flex; flex-direction: column; align-items: center; }
  .csb-heading { font-size: var(--text-h2); }
  .tagline + .csb-heading { margin-top: var(--space-12); }
  .csb-sub { margin-top: var(--space-16); font-size: var(--text-body-lg); }
  .csb-head-cta { margin-top: var(--space-32); }

  .csb-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-24); }

  /* Image-backed card; copy sits at the bottom over a dark scrim. Whole card is a link.
     isolation keeps the media/scrim/content z-stack contained; subtle shadow lifts the
     card off the gradient backdrop. */
  .csb-card {
    --csb-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.4);
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 320px;
    padding: var(--space-32);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: var(--foreground);
    box-shadow: var(--csb-shadow);
  }
  .csb-card:hover { text-decoration: none; }

  .csb-media { position: absolute; inset: 0; z-index: 0; background: var(--muted); }
  .csb-media img,
  .csb-media-ph { display: block; width: 100%; height: 100%; object-fit: cover; }
  .csb-media-ph { background: var(--muted); }
  /* Colour by default — mobile + tablet keep full-colour photos. The B&W-at-rest →
     colour-on-hover treatment is desktop-only (added in the min-width:1024 block), since
     touch devices have no hover to reveal the colour. */
  .csb-media img { transition: filter 0.5s ease, transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1); }

  /* Dark scrim toward the bottom so the copy reads over the photo. */
  .csb-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(
      to top,
      color-mix(in srgb, var(--background) 92%, transparent),
      color-mix(in srgb, var(--background) 55%, transparent) 45%,
      color-mix(in srgb, var(--background) 8%, transparent)
    );
  }

  .csb-content { position: relative; z-index: 2; display: flex; flex-direction: column; gap: var(--space-8); }
  .csb-title { font-family: var(--font-body); font-size: var(--text-h6); text-wrap: pretty; }
  .csb-blurb {
    font-size: var(--text-body-sm);
    line-height: var(--lh-body-sm);
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .csb-cta { display: inline-flex; align-items: center; gap: var(--space-8); margin-top: var(--space-8); font-size: var(--text-body-sm); font-weight: var(--fw-regular); color: var(--muted-foreground); transition: color 0.18s ease, gap 0.18s ease; }
  .csb-card:hover .csb-cta { gap: var(--space-12); color: var(--foreground); }

  @media (min-width: 1024px) {
    .csb-wide { padding-inline: 80px; }
    /* Desktop only: monochrome at rest, colour + zoom on hover. */
    .csb-media img { filter: grayscale(1); }
    .csb-card:hover .csb-media img { filter: grayscale(0); transform: scale(1.05); }
    /* 4 columns x 2 rows: big left (1-2 / 1-2), two top-right (col 3, col 4), wide
       bottom-right (cols 3-4). */
    .csb-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, minmax(260px, 1fr));
    }
    .csb-card { min-height: 0; }
    .csb-card:nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; }
    .csb-card:nth-child(2) { grid-column: 3 / 4; grid-row: 1 / 2; }
    .csb-card:nth-child(3) { grid-column: 4 / 5; grid-row: 1 / 2; }
    .csb-card:nth-child(4) { grid-column: 3 / 5; grid-row: 2 / 3; }
    /* Bigger cards carry a larger company name + a little more blurb room. */
    .csb-card:nth-child(1) .csb-title { font-size: var(--text-h4); }
    .csb-card:nth-child(4) .csb-title { font-size: var(--text-h5); }
    .csb-card:nth-child(1) .csb-blurb { -webkit-line-clamp: 3; line-clamp: 3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .csb-media img,
    .csb-card:hover .csb-media img { transform: none; }
  }
</style>
